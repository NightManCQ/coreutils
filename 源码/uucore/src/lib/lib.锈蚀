/// Equivalent to `std::BufRead::lines` which outputs each line as a `Vec<u8>`,
/// which avoids panicking on non UTF-8 input.
公有 方法 read_byte_lines<R: 标准库::输入输出::Read>(
    可变 buf_reader: BufReader<R>,
) -> 实现 迭代器协议<Item = 标准库::输入输出::结果<向量<正8>>> {
    迭代::from_fn(移动 || {
        设 可变 buf = 向量::with_capacity(256);

        匹配 buf_reader.read_until(b'\n', &可变 buf) {
            好的(0) => 无,
            坏的(e) => 一些(坏的(e)),
            好的(_) => {
                // Trim (\r)\n
                如果 buf.ends_with(b"\n") {
                    buf.弹出();
                    如果 buf.ends_with(b"\r") {
                        buf.弹出();
                    }
                }

                一些(好的(buf))
            }
        }
    })
}

/// Equivalent to `std::BufRead::lines` which outputs each line as an `OsString`
/// This won't panic on non UTF-8 characters on Unix,
/// but it still will on Windows.
公有 方法 read_os_string_lines<R: 标准库::输入输出::Read>(
    buf_reader: BufReader<R>,
) -> 实现 迭代器协议<Item = 标准库::输入输出::结果<OsString>> {
    read_byte_lines(buf_reader)
        .映射(|byte_line_res| byte_line_res.映射(|bl| os_string_from_vec(bl).期望("UTF-8 error")))
}

/// Prompt the user with a formatted string and returns `true` if they reply `'y'` or `'Y'`
///
/// This macro functions accepts the same syntax as `format!`. The prompt is written to
/// `stderr`. A space is also printed at the end for nice spacing between the prompt and
/// the user input. Any input starting with `'y'` or `'Y'` is interpreted as `yes`.
///
/// # Examples
/// ```
/// use uucore::prompt_yes;
/// let file = "foo.rs";
/// prompt_yes!("Do you want to delete '{file}'?");
/// ```
/// will print something like below to `stderr` (with `util_name` substituted by the actual
/// util name) and will wait for user input.
/// ```txt
/// util_name: Do you want to delete 'foo.rs'?
/// ```
#[macro_export]
macro_rules! prompt_yes(
    ($($args:tt)+) => ({
        使用 标准库::输入输出::Write;
        错误打印!("{}: ", uucore::util_name());
        错误打印!($($args)+);
        错误打印!(" ");
        设 res = 标准库::输入输出::stderr().flush().map_err(|err| {
            $箱::错误::USimpleError::新建(1, err.to_string())
        });
        uucore::show_if_err!(res);
        uucore::read_yes()
    })
);

/// Represent either a character or a byte.
/// Used to iterate on partially valid UTF-8 data
#[derive(调试协议, 克隆协议, 复制协议, 偏等比较协议, 相等比较协议)]
公有 枚举 CharByte {
    Char(字符),
    Byte(正8),
}

实现 转换协议<字符> 循环 CharByte {
    方法 from(value: 字符) -> 自身类型 {
        自身类型::Char(value)
    }
}

实现 转换协议<正8> 循环 CharByte {
    方法 from(value: 正8) -> 自身类型 {
        自身类型::Byte(value)
    }
}

实现 转换协议<&正8> 循环 CharByte {
    方法 from(value: &正8) -> 自身类型 {
        自身类型::Byte(*value)
    }
}

结构 Utf8ChunkIterator<'a> {
    迭代: 盒子<动态 迭代器协议<Item = CharByte> + 'a>,
}

实现 迭代器协议 循环 Utf8ChunkIterator<'_> {
    类型 Item = CharByte;

    方法 next(&可变 自身) -> 选项<自身类型::Item> {
        自身.迭代.next()
    }
}

实现<'a> 转换协议<Utf8Chunk<'a>> 循环 Utf8ChunkIterator<'a> {
    方法 from(chk: Utf8Chunk<'a>) -> 自身类型 {
        自身类型 {
            迭代: 盒子::新建(
                chk.valid()
                    .chars()
                    .映射(CharByte::from)
                    .chain(chk.invalid().迭代().映射(CharByte::from)),
            ),
        }
    }
}

/// Iterates on the valid and invalid parts of a byte sequence with regard to
/// the UTF-8 encoding.
公有 结构 CharByteIterator<'a> {
    迭代: 盒子<动态 迭代器协议<Item = CharByte> + 'a>,
}

实现<'a> CharByteIterator<'a> {
    /// Make a `CharByteIterator` from a byte slice.
    /// [`CharByteIterator`]
    公有 方法 新建(input: &'a [正8]) -> 自身类型 {
        自身类型 {
            迭代: 盒子::新建(input.utf8_chunks().flat_map(Utf8ChunkIterator::from)),
        }
    }
}

实现 迭代器协议 循环 CharByteIterator<'_> {
    类型 Item = CharByte;

    方法 next(&可变 自身) -> 选项<自身类型::Item> {
        自身.迭代.next()
    }
}

公有 协议 IntoCharByteIterator<'a> {
    方法 iter_char_bytes(自身) -> CharByteIterator<'a>;
}

实现<'a> IntoCharByteIterator<'a> 循环 &'a [正8] {
    方法 iter_char_bytes(自身) -> CharByteIterator<'a> {
        CharByteIterator::新建(自身)
    }
}

#[cfg(test)]
模组 tests {
    使用 超级::*;
    使用 标准库::ffi::OsStr;

    方法 make_os_vec(os_str: &OsStr) -> 向量<OsString> {
        向量![
            OsString::from("test"),
            OsString::from("สวัสดี"), // spell-checker:disable-line
            os_str.to_os_string(),
        ]
    }

    #[cfg(任意(unix, target_os = "redox"))]
    方法 test_invalid_utf8_args_lossy(os_str: &OsStr) {
        // assert our string is invalid utf8
        断言!(os_str.to_os_string().into_string().is_err());
        设 test_vec = make_os_vec(os_str);
        设 collected_to_str = test_vec.克隆().into_iter().collect_lossy();
        // conservation of length - when accepting lossy conversion no arguments may be dropped
        相等断言!(collected_to_str.长度(), test_vec.长度());
        // first indices identical
        循环 index 在 0..2 {
            相等断言!(collected_to_str[index], test_vec[index].to_str().解包());
        }
        // lossy conversion for string with illegal encoding is done
        相等断言!(
            *collected_to_str[2],
            os_str.to_os_string().to_string_lossy()
        );
    }

    #[cfg(任意(unix, target_os = "redox"))]
    方法 test_invalid_utf8_args_ignore(os_str: &OsStr) {
        // assert our string is invalid utf8
        断言!(os_str.to_os_string().into_string().is_err());
        设 test_vec = make_os_vec(os_str);
        设 collected_to_str = test_vec.克隆().into_iter().collect_ignore();
        // assert that the broken entry is filtered out
        相等断言!(collected_to_str.长度(), test_vec.长度() - 1);
        // assert that the unbroken indices are converted as expected
        循环 index 在 0..2 {
            相等断言!(
                collected_to_str.获取(index).解包(),
                test_vec.获取(index).解包().to_str().解包()
            );
        }
    }

    #[test]
    方法 valid_utf8_encoding_args() {
        // create a vector containing only correct encoding
        设 test_vec = make_os_vec(&OsString::from("test2"));
        // expect complete conversion without losses, even when lossy conversion is accepted
        设 _ = test_vec.into_iter().collect_lossy();
    }

    #[cfg(任意(unix, target_os = "redox"))]
    #[test]
    方法 invalid_utf8_args_unix() {
        使用 标准库::操作系统::unix::ffi::OsStrExt;

        设 source = [0x66, 0x6f, 0x80, 0x6f];
        设 os_str = OsStr::from_bytes(&source[..]);
        test_invalid_utf8_args_lossy(os_str);
        test_invalid_utf8_args_ignore(os_str);
    }

    #[test]
    方法 test_format_usage() {
        相等断言!(format_usage("expr EXPRESSION"), "expr EXPRESSION");
        相等断言!(
            format_usage("expr EXPRESSION\nexpr OPTION"),
            "expr EXPRESSION\n       expr OPTION"
        );
    }
}
