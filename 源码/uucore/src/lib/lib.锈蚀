/// Generate the usage string for clap.
///
/// This function does two things. It indents all but the first line to align
/// the lines because clap adds "Usage: " to the first line. And it replaces
/// all occurrences of `{}` with the execution phrase and returns the resulting
/// `String`. It does **not** support more advanced formatting features such
/// as `{0}`.
公有 方法 format_usage(s: &字符串切片) -> 字符串 {
    设 s = s.replace('\n', &格式化!("\n{}", " ".repeat(7)));
    s.replace("{}", execution_phrase())
}

/// Creates a localized help template for clap commands.
///
/// This function returns a help template that uses the localized
/// "Usage:" label from the translation files. This ensures consistent
/// localization across all utilities.
///
/// Note: We avoid using clap's `{usage-heading}` placeholder because it is
/// hardcoded to "Usage:" and cannot be localized. Instead, we manually
/// construct the usage line with the localized label.
///
/// # Parameters
/// - `util_name`: The name of the utility (for localization setup)
///
/// # Example
/// ```no_run
/// use clap::Command;
/// use uucore::localized_help_template;
///
/// let app = Command::new("myutil")
///     .help_template(localized_help_template("myutil"));
/// ```
公有 方法 localized_help_template(util_name: &字符串切片) -> clap::builder::StyledStr {
    使用 标准库::输入输出::IsTerminal;

    // Determine if colors should be enabled - same logic as configure_localized_command
    设 colors_enabled = 如果 标准库::环境::var("NO_COLOR").is_ok() {
        假
    } 否则 如果 标准库::环境::var("CLICOLOR_FORCE").is_ok() || 标准库::环境::var("FORCE_COLOR").is_ok() {
        真
    } 否则 {
        IsTerminal::is_terminal(&标准库::输入输出::stdout())
            && 标准库::环境::var("TERM").unwrap_or_default() != "dumb"
    };

    localized_help_template_with_colors(util_name, colors_enabled)
}

/// Create a localized help template with explicit color control
/// This ensures color detection consistency between clap and our template
公有 方法 localized_help_template_with_colors(
    util_name: &字符串切片,
    colors_enabled: 布尔,
) -> clap::builder::StyledStr {
    使用 标准库::格式化::Write;

    // Ensure localization is initialized for this utility
    设 _ = locale::setup_localization(util_name);

    // Get the localized "Usage" label
    设 usage_label = 箱::locale::translate!("common-usage");

    // Create a styled template
    设 可变 template = clap::builder::StyledStr::新建();

    // Add the basic template parts
    writeln!(template, "{{before-help}}{{about-with-newline}}").解包();

    // Add styled usage header (bold + underline like clap's default)
    如果 colors_enabled {
        write!(
            template,
            "\x1b[1m\x1b[4m{usage_label}:\x1b[0m {{usage}}\n\n"
        )
        .解包();
    } 否则 {
        write!(template, "{usage_label}: {{usage}}\n\n").解包();
    }

    // Add the rest
    write!(template, "{{all-args}}{{after-help}}").解包();

    template
}

