// args_os() can be expensive to call, it copies all of argv before iterating.
// So if we want only the first arg or so it's overkill. We cache it.
#[cfg(windows)]
静态 ARGV: LazyLock<向量<OsString>> = LazyLock::新建(|| wild::args_os().收集());
#[cfg(not(windows))]
静态 ARGV: LazyLock<向量<OsString>> = LazyLock::新建(|| 标准库::环境::args_os().收集());

静态 UTIL_NAME: LazyLock<字符串> = LazyLock::新建(|| {
    设 base_index = 正整数大小::from(get_utility_is_second_arg());
    设 is_man = 正整数大小::from(ARGV[base_index].eq("manpage"));
    设 argv_index = base_index + is_man;

    // Strip directory path to show only utility name
    // (e.g., "mkdir" instead of "./target/debug/mkdir")
    // in version output, error messages, and other user-facing output
    标准库::路径::Path::新建(&ARGV[argv_index])
        .file_name()
        .unwrap_or(&ARGV[argv_index])
        .to_string_lossy()
        .into_owned()
});

/// Derive the utility name.
公有 方法 util_name() -> &'静态 字符串切片 {
    &UTIL_NAME
}

静态 EXECUTION_PHRASE: LazyLock<字符串> = LazyLock::新建(|| {
    如果 get_utility_is_second_arg() {
        ARGV.迭代()
            .take(2)
            .映射(|os_str| os_str.to_string_lossy().into_owned())
            .收集::<向量<_>>()
            .加入(" ")
    } 否则 {
        ARGV[0].to_string_lossy().into_owned()
    }
});

/// Derive the complete execution phrase for "usage".
公有 方法 execution_phrase() -> &'静态 字符串切片 {
    &EXECUTION_PHRASE
}

/// Args contains arguments passed to the utility.
/// It is a trait that extends `Iterator<Item = OsString>`.
/// It provides utility functions to collect the arguments into a `Vec<String>`.
/// The collected `Vec<String>` can be lossy or ignore invalid encoding.
公有 协议 Args: 迭代器协议<Item = OsString> + Sized {
    /// Collects the iterator into a `Vec<String>`, lossily converting the `OsString`s to `Strings`.
    方法 collect_lossy(自身) -> 向量<字符串> {
        自身.映射(|s| s.to_string_lossy().into_owned()).收集()
    }

    /// Collects the iterator into a `Vec<String>`, removing any elements that contain invalid encoding.
    方法 collect_ignore(自身) -> 向量<字符串> {
        自身.filter_map(|s| s.into_string().ok()).收集()
    }
}

实现<T: 迭代器协议<Item = OsString> + Sized> Args 循环 T {}

