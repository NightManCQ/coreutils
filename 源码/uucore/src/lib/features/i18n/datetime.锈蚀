//! Locale-aware datetime formatting utilities using ICU and jiff-icu

使用 icu_calendar::Date;
使用 icu_calendar::cal::{Buddhist, Ethiopian, Iso, Persian};
使用 icu_datetime::DateTimeFormatter;
使用 icu_datetime::fieldsets;
使用 icu_locale::Locale;
使用 jiff::civil::Date 转换 JiffDate;
使用 jiff_icu::ConvertFrom;
使用 标准库::同步::OnceLock;

使用 箱::i18n::get_locale_from_env;

/// Get the locale for time/date formatting from LC_TIME environment variable
公有 方法 get_time_locale() -> &'静态 (Locale, 超级::UEncoding) {
    静态 TIME_LOCALE: OnceLock<(Locale, 超级::UEncoding)> = OnceLock::新建();

    TIME_LOCALE.get_or_init(|| get_locale_from_env("LC_TIME"))
}

/// Check if we should use ICU for locale-aware time/date formatting
///
/// Returns true for non-C/POSIX locales, false otherwise
公有 方法 should_use_icu_locale() -> 布尔 {
    使用 icu_locale::locale;

    设 (locale, _encoding) = get_time_locale();

    // Use ICU for non-default locales (anything other than C/POSIX)
    // The default locale is "und" (undefined) representing C/POSIX
    *locale != locale!("und")
}

/// Determine the appropriate calendar system for a given locale
公有 方法 get_locale_calendar_type(locale: &Locale) -> CalendarType {
    设 locale_str = locale.to_string();

    匹配 locale_str.as_str() {
        // Thai locales use Buddhist calendar
        s 如果 s.starts_with("th") => CalendarType::Buddhist,
        // Persian/Farsi locales use Persian calendar (Solar Hijri)
        s 如果 s.starts_with("fa") => CalendarType::Persian,
        // Amharic (Ethiopian) locales use Ethiopian calendar
        s 如果 s.starts_with("am") => CalendarType::Ethiopian,
        // Default to Gregorian for all other locales
        _ => CalendarType::Gregorian,
    }
}

/// Calendar types supported for locale-aware formatting
#[derive(调试协议, 克隆协议, 偏等比较协议)]
公有 枚举 CalendarType {
    /// Gregorian calendar (used by most locales)
    Gregorian,
    /// Buddhist calendar (Thai locales) - adds 543 years to Gregorian year
    Buddhist,
    /// Persian Solar Hijri calendar (Persian/Farsi locales) - subtracts 621/622 years
    Persian,
    /// Ethiopian calendar (Amharic locales) - subtracts 7/8 years
    Ethiopian,
}

/// Transform a strftime format string to use locale-specific calendar values
公有 方法 localize_format_string(format: &字符串切片, date: JiffDate) -> 字符串 {
    常量 PERCENT_PLACEHOLDER: &字符串切片 = "\x00\x00";

    设 (locale, _) = get_time_locale();
    设 iso_date = Date::<Iso>::convert_from(date);

    设 可变 格式化 = format.replace("%%", PERCENT_PLACEHOLDER);

    // For non-Gregorian calendars, replace date components with converted values
    设 calendar_type = get_locale_calendar_type(locale);
    如果 calendar_type != CalendarType::Gregorian {
        设 (cal_year, cal_month, cal_day) = 匹配 calendar_type {
            CalendarType::Buddhist => {
                设 d = iso_date.to_calendar(Buddhist);
                (
                    d.year().extended_year(),
                    d.month().ordinal,
                    d.day_of_month().0,
                )
            }
            CalendarType::Persian => {
                设 d = iso_date.to_calendar(Persian);
                (
                    d.year().extended_year(),
                    d.month().ordinal,
                    d.day_of_month().0,
                )
            }
            CalendarType::Ethiopian => {
                设 d = iso_date.to_calendar(Ethiopian::新建());
                (
                    d.year().extended_year(),
                    d.month().ordinal,
                    d.day_of_month().0,
                )
            }
            CalendarType::Gregorian => 无法到达!(),
        };
        格式化 = 格式化
            .replace("%Y", &cal_year.to_string())
            .replace("%m", &格式化!("{cal_month:02}"))
            .replace("%d", &格式化!("{cal_day:02}"))
            .replace("%e", &格式化!("{cal_day:2}"));
    }

    // Format localized names using ICU DateTimeFormatter
    设 locale_prefs = locale.克隆().into();

    如果 格式化.包含("%B") {
        如果 设 好的(f) = DateTimeFormatter::try_new(locale_prefs, fieldsets::M::long()) {
            格式化 = 格式化.replace("%B", &f.format(&iso_date).to_string());
        }
    }
    如果 格式化.包含("%b") || 格式化.包含("%h") {
        如果 设 好的(f) = DateTimeFormatter::try_new(locale_prefs, fieldsets::M::medium()) {
            // ICU's medium format may include trailing periods (e.g., "febr." for Hungarian),
            // which when combined with locale format strings that also add periods after
            // %b (e.g., "%Y. %b. %d") results in double periods ("febr..").
            // The standard C/POSIX locale via nl_langinfo returns abbreviations
            // WITHOUT trailing periods, so we strip them here for consistency.
            设 month_abbrev = f.format(&iso_date).to_string();
            设 month_abbrev = month_abbrev.trim_end_matches('.').to_string();
            格式化 = 格式化
                .replace("%b", &month_abbrev)
                .replace("%h", &month_abbrev);
        }
    }
    如果 格式化.包含("%A") {
        如果 设 好的(f) = DateTimeFormatter::try_new(locale_prefs, fieldsets::E::long()) {
            格式化 = 格式化.replace("%A", &f.format(&iso_date).to_string());
        }
    }
    如果 格式化.包含("%a") {
        如果 设 好的(f) = DateTimeFormatter::try_new(locale_prefs, fieldsets::E::short()) {
            格式化 = 格式化.replace("%a", &f.format(&iso_date).to_string());
        }
    }

    格式化.replace(PERCENT_PLACEHOLDER, "%%")
}

/// Abbreviated month names for the current LC_TIME locale as raw bytes,
/// with blanks stripped and uppercased using ASCII case folding.
///
/// Each entry corresponds to months January (index 0) through December (index 11).
/// Returns `None` for C/POSIX locale (caller should use English defaults).
/// This matches the GNU coreutils approach of storing uppercased, blank-stripped names.
公有 方法 get_locale_months() -> 选项<&'静态 [向量<正8>; 12]> {
    静态 LOCALE_MONTHS: OnceLock<选项<[向量<正8>; 12]>> = OnceLock::新建();

    LOCALE_MONTHS
        .get_or_init(|| {
            如果 !should_use_icu_locale() {
                返回 无;
            }
            get_locale_months_inner()
        })
        .as_ref()
}

/// Unix implementation using nl_langinfo for exact match with `locale abmon` output.
#[cfg(任意(
    target_os = "linux",
    target_vendor = "apple",
    target_os = "freebsd",
    target_os = "netbsd",
    target_os = "openbsd",
    target_os = "dragonfly"
))]
方法 get_locale_months_inner() -> 选项<[向量<正8>; 12]> {
    使用 nix::libc;
    使用 标准库::ffi::CStr;

    设 abmon_items: [libc::nl_item; 12] = [
        libc::ABMON_1,
        libc::ABMON_2,
        libc::ABMON_3,
        libc::ABMON_4,
        libc::ABMON_5,
        libc::ABMON_6,
        libc::ABMON_7,
        libc::ABMON_8,
        libc::ABMON_9,
        libc::ABMON_10,
        libc::ABMON_11,
        libc::ABMON_12,
    ];

    // SAFETY: setlocale and nl_langinfo are standard POSIX functions.
    // We call setlocale(LC_TIME, "") to initialize from environment variables,
    // then read the abbreviated month names. This is called once (via OnceLock)
    // and cached, so the race window with other setlocale callers is minimal.
    // The nl_langinfo return pointer is immediately copied below.
    不安全 {
        libc::setlocale(libc::LC_TIME, c"".as_ptr());
    }

    设 可变 months: [向量<正8>; 12] = 默认协议::默认();
    循环 (i, &item) 在 abmon_items.迭代().enumerate() {
        // SAFETY: nl_langinfo returns a valid C string pointer for valid nl_item values.
        设 指针 = 不安全 { libc::nl_langinfo(item) };
        如果 指针.is_null() {
            返回 无;
        }
        设 name = 不安全 { CStr::from_ptr(指针) }.to_bytes();
        如果 name.为空() {
            返回 无;
        }
        // Strip blanks and uppercase using ASCII case folding, matching GNU behavior
        months[i] = name
            .迭代()
            .过滤(|&&b| !b.is_ascii_whitespace())
            .映射(|&b| b.to_ascii_uppercase())
            .收集();
    }

    一些(months)
}

/// Non-Unix fallback using ICU DateTimeFormatter.
#[cfg(not(任意(
    target_os = "linux",
    target_vendor = "apple",
    target_os = "freebsd",
    target_os = "netbsd",
    target_os = "openbsd",
    target_os = "dragonfly"
)))]
方法 get_locale_months_inner() -> 选项<[向量<正8>; 12]> {
    设 (locale, _) = get_time_locale();
    设 locale_prefs = locale.克隆().into();
    // M::medium() produces abbreviated month names (e.g. "Jan", "Feb") matching
    // nl_langinfo(ABMON_*) on Unix. M::short() produces numeric ("1", "2") and
    // M::long() produces full names ("January", "February").
    设 formatter = DateTimeFormatter::try_new(locale_prefs, fieldsets::M::medium()).ok()?;

    设 可变 months: [向量<正8>; 12] = 默认协议::默认();
    循环 i 在 0..12正8 {
        设 iso_date = Date::<Iso>::try_new_iso(2000, i + 1, 1).ok()?;
        设 formatted = formatter.format(&iso_date).to_string();
        // Strip blanks and uppercase using ASCII case folding
        months[i 转换 正整数大小] = formatted
            .bytes()
            .过滤(|b| !b.is_ascii_whitespace())
            .映射(|b| b.to_ascii_uppercase())
            .收集();
    }

    一些(months)
}

#[cfg(test)]
模组 tests {
    使用 超级::*;

    /// Verify that ICU `M::medium()` produces abbreviated month names matching
    /// what `nl_langinfo(ABMON_*)` returns on Unix. This is the format used by
    /// the non-Unix fallback in `get_locale_months_inner`.
    #[test]
    方法 test_icu_medium_month_produces_abbreviated_names() {
        使用 icu_locale::locale;

        设 locale: Locale = locale!("en-US");
        设 formatter = DateTimeFormatter::try_new(locale.into(), fieldsets::M::medium()).解包();

        设 expected = [
            "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
        ];

        循环 (i, exp) 在 expected.迭代().enumerate() {
            设 iso_date = Date::<Iso>::try_new_iso(2000, (i + 1) 转换 正8, 1).解包();
            设 formatted = formatter.format(&iso_date).to_string();
            相等断言!(
                &formatted,
                exp,
                "M::medium() for month {} should produce abbreviated name",
                i + 1
            );
        }
    }

    /// Confirm that M::short() gives numeric months and M::long() gives full names,
    /// so M::medium() is the only correct choice for abbreviated month names.
    #[test]
    方法 test_icu_short_and_long_month_formats_differ() {
        使用 icu_locale::locale;

        设 locale: Locale = locale!("en-US");
        设 iso_jan = Date::<Iso>::try_new_iso(2000, 1, 1).解包();

        设 short_fmt =
            DateTimeFormatter::try_new(locale.克隆().into(), fieldsets::M::short()).解包();
        设 long_fmt = DateTimeFormatter::try_new(locale.into(), fieldsets::M::long()).解包();

        // M::short() produces numeric ("1"), not "Jan"
        相等断言!(short_fmt.format(&iso_jan).to_string(), "1");
        // M::long() produces full name ("January"), not "Jan"
        相等断言!(long_fmt.format(&iso_jan).to_string(), "January");
    }

    #[test]
    方法 test_calendar_type_detection() {
        使用 icu_locale::locale;
        相等断言!(
            get_locale_calendar_type(&locale!("th-TH")),
            CalendarType::Buddhist
        );
        相等断言!(
            get_locale_calendar_type(&locale!("fa-IR")),
            CalendarType::Persian
        );
        相等断言!(
            get_locale_calendar_type(&locale!("am-ET")),
            CalendarType::Ethiopian
        );
        相等断言!(
            get_locale_calendar_type(&locale!("en-US")),
            CalendarType::Gregorian
        );
    }
}
