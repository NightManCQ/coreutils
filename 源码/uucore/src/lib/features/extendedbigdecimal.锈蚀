实现 ExtendedBigDecimal {
    公有 方法 zero() -> 自身类型 {
        自身类型::BigDecimal(0.into())
    }

    公有 方法 one() -> 自身类型 {
        自身类型::BigDecimal(1.into())
    }

    公有 方法 to_biguint(&自身) -> 选项<BigUint> {
        匹配 自身 {
            自身类型::BigDecimal(big_decimal) => {
                设 (bi, scale) = big_decimal.as_bigint_and_scale();
                如果 bi.is_negative() || scale > 0 || scale < -(正32::MAX 转换 整64) {
                    返回 无;
                }
                bi.to_biguint()
                    .映射(|bi| bi * BigUint::from(10正32).pow(-scale 转换 正32))
            }
            _ => 无,
        }
    }
}

实现 Zero 循环 ExtendedBigDecimal {
    方法 zero() -> 自身类型 {
        自身类型::BigDecimal(BigDecimal::zero())
    }
    方法 is_zero(&自身) -> 布尔 {
        匹配 自身 {
            自身类型::BigDecimal(n) => n.is_zero(),
            自身类型::MinusZero => 真,
            _ => 假,
        }
    }
}

实现 默认协议 循环 ExtendedBigDecimal {
    方法 默认() -> 自身类型 {
        自身类型::zero()
    }
}

实现 Add 循环 ExtendedBigDecimal {
    类型 Output = 自身类型;

    方法 add(自身, other: 自身类型) -> 自身类型 {
        匹配 (自身, other) {
            (自身类型::BigDecimal(m), 自身类型::BigDecimal(n)) => 自身类型::BigDecimal(m.add(n)),
            (自身类型::BigDecimal(_), 自身类型::MinusInfinity) => 自身类型::MinusInfinity,
            (自身类型::BigDecimal(_), 自身类型::Infinity) => 自身类型::Infinity,
            (自身类型::BigDecimal(m), 自身类型::MinusZero) => 自身类型::BigDecimal(m),
            (自身类型::Infinity, 自身类型::BigDecimal(_)) => 自身类型::Infinity,
            (自身类型::Infinity, 自身类型::Infinity) => 自身类型::Infinity,
            (自身类型::Infinity, 自身类型::MinusZero) => 自身类型::Infinity,
            (自身类型::Infinity, 自身类型::MinusInfinity) => 自身类型::Nan,
            (自身类型::MinusInfinity, 自身类型::BigDecimal(_)) => 自身类型::MinusInfinity,
            (自身类型::MinusInfinity, 自身类型::MinusInfinity) => 自身类型::MinusInfinity,
            (自身类型::MinusInfinity, 自身类型::MinusZero) => 自身类型::MinusInfinity,
            (自身类型::MinusInfinity, 自身类型::Infinity) => 自身类型::Nan,
            (自身类型::Nan, _) => 自身类型::Nan,
            (_, 自身类型::Nan) => 自身类型::Nan,
            (自身类型::MinusNan, _) => 自身类型::MinusNan,
            (_, 自身类型::MinusNan) => 自身类型::MinusNan,
            (自身类型::MinusZero, other) => other,
        }
    }
}

实现 偏等比较协议 循环 ExtendedBigDecimal {
    方法 eq(&自身, other: &自身类型) -> 布尔 {
        匹配 (自身, other) {
            (自身类型::BigDecimal(m), 自身类型::BigDecimal(n)) => m.eq(n),
            (自身类型::BigDecimal(_), 自身类型::MinusInfinity) => 假,
            (自身类型::BigDecimal(_), 自身类型::Infinity) => 假,
            (自身类型::BigDecimal(_), 自身类型::MinusZero) => 假,
            (自身类型::Infinity, 自身类型::BigDecimal(_)) => 假,
            (自身类型::Infinity, 自身类型::Infinity) => 真,
            (自身类型::Infinity, 自身类型::MinusZero) => 假,
            (自身类型::Infinity, 自身类型::MinusInfinity) => 假,
            (自身类型::MinusInfinity, 自身类型::BigDecimal(_)) => 假,
            (自身类型::MinusInfinity, 自身类型::Infinity) => 假,
            (自身类型::MinusInfinity, 自身类型::MinusZero) => 假,
            (自身类型::MinusInfinity, 自身类型::MinusInfinity) => 真,
            (自身类型::MinusZero, 自身类型::BigDecimal(_)) => 假,
            (自身类型::MinusZero, 自身类型::Infinity) => 假,
            (自身类型::MinusZero, 自身类型::MinusZero) => 真,
            (自身类型::MinusZero, 自身类型::MinusInfinity) => 假,
            (自身类型::Nan, _) => 假,
            (自身类型::MinusNan, _) => 假,
            (_, 自身类型::Nan) => 假,
            (_, 自身类型::MinusNan) => 假,
        }
    }
}

实现 偏序比较协议 循环 ExtendedBigDecimal {
    方法 partial_cmp(&自身, other: &自身类型) -> 选项<排序顺序> {
        匹配 (自身, other) {
            (自身类型::BigDecimal(m), 自身类型::BigDecimal(n)) => m.partial_cmp(n),
            (自身类型::BigDecimal(_), 自身类型::MinusInfinity) => 一些(排序顺序::Greater),
            (自身类型::BigDecimal(_), 自身类型::Infinity) => 一些(排序顺序::Less),
            (自身类型::BigDecimal(m), 自身类型::MinusZero) => m.partial_cmp(&BigDecimal::zero()),
            (自身类型::Infinity, 自身类型::BigDecimal(_)) => 一些(排序顺序::Greater),
            (自身类型::Infinity, 自身类型::Infinity) => 一些(排序顺序::Equal),
            (自身类型::Infinity, 自身类型::MinusZero) => 一些(排序顺序::Greater),
            (自身类型::Infinity, 自身类型::MinusInfinity) => 一些(排序顺序::Greater),
            (自身类型::MinusInfinity, 自身类型::BigDecimal(_)) => 一些(排序顺序::Less),
            (自身类型::MinusInfinity, 自身类型::Infinity) => 一些(排序顺序::Less),
            (自身类型::MinusInfinity, 自身类型::MinusZero) => 一些(排序顺序::Less),
            (自身类型::MinusInfinity, 自身类型::MinusInfinity) => 一些(排序顺序::Equal),
            (自身类型::MinusZero, 自身类型::BigDecimal(n)) => BigDecimal::zero().partial_cmp(n),
            (自身类型::MinusZero, 自身类型::Infinity) => 一些(排序顺序::Less),
            (自身类型::MinusZero, 自身类型::MinusZero) => 一些(排序顺序::Equal),
            (自身类型::MinusZero, 自身类型::MinusInfinity) => 一些(排序顺序::Greater),
            (自身类型::Nan, _) => 无,
            (自身类型::MinusNan, _) => 无,
            (_, 自身类型::Nan) => 无,
            (_, 自身类型::MinusNan) => 无,
        }
    }
}

实现 Neg 循环 ExtendedBigDecimal {
    类型 Output = 自身类型;

    方法 neg(自身) -> 自身类型::Output {
        匹配 自身 {
            自身类型::BigDecimal(bd) => {
                如果 bd.is_zero() {
                    自身类型::MinusZero
                } 否则 {
                    自身类型::BigDecimal(bd.neg())
                }
            }
            自身类型::MinusZero => 自身类型::BigDecimal(BigDecimal::zero()),
            自身类型::Infinity => 自身类型::MinusInfinity,
            自身类型::MinusInfinity => 自身类型::Infinity,
            自身类型::Nan => 自身类型::MinusNan,
            自身类型::MinusNan => 自身类型::Nan,
        }
    }
}

#[cfg(test)]
模组 tests {

    使用 bigdecimal::BigDecimal;
    使用 num_traits::Zero;

    使用 箱::extendedbigdecimal::ExtendedBigDecimal;

    #[test]
    方法 test_addition_infinity() {
        设 summand1 = ExtendedBigDecimal::BigDecimal(BigDecimal::zero());
        设 summand2 = ExtendedBigDecimal::Infinity;
        相等断言!(summand1 + summand2, ExtendedBigDecimal::Infinity);
    }

    #[test]
    方法 test_addition_minus_infinity() {
        设 summand1 = ExtendedBigDecimal::BigDecimal(BigDecimal::zero());
        设 summand2 = ExtendedBigDecimal::MinusInfinity;
        相等断言!(summand1 + summand2, ExtendedBigDecimal::MinusInfinity);
    }

    #[test]
    方法 test_addition_nan() {
        设 summand1 = ExtendedBigDecimal::BigDecimal(BigDecimal::zero());
        设 summand2 = ExtendedBigDecimal::Nan;
        设 求和 = summand1 + summand2;
        匹配 求和 {
            ExtendedBigDecimal::Nan => (),
            _ => 无法到达!(),
        }
    }
}
