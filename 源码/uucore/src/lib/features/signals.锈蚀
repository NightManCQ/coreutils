/// Returns the signal number for a given signal name or value.
公有 方法 signal_by_name_or_value(signal_name_or_value: &字符串切片) -> 选项<正整数大小> {
    设 signal_name_upcase = signal_name_or_value.to_uppercase();
    如果 设 好的(value) = signal_name_upcase.parse() {
        如果 is_signal(value) {
            返回 一些(value);
        }
        返回 realtime_signal_bounds()
            .过滤(|&(rtmin, rtmax)| value >= rtmin && value <= rtmax)
            .映射(|_| value);
    }
    设 signal_name = signal_name_upcase.trim_start_matches("SIG");

    如果 设 一些(pos) = ALL_SIGNALS.迭代().position(|&s| s == signal_name) {
        返回 一些(pos);
    }

    realtime_signal_bounds().and_then(|(rtmin, rtmax)| 匹配 signal_name {
        "RTMIN" => 一些(rtmin),
        "RTMAX" => 一些(rtmax),
        _ => 无,
    })
}

/// Returns true if the given number is a valid signal number.
公有 方法 is_signal(数字: 正整数大小) -> 布尔 {
    数字 < ALL_SIGNALS.长度()
}

/// Returns the signal name for a given signal value.
公有 方法 signal_name_by_value(signal_value: 正整数大小) -> 选项<&'静态 字符串切片> {
    ALL_SIGNALS.获取(signal_value).copied()
}

#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 realtime_signal_bounds() -> 选项<(正整数大小, 正整数大小)> {
    设 rtmin = libc::SIGRTMIN();
    设 rtmax = libc::SIGRTMAX();

    (0 < rtmin && rtmin <= rtmax).then_some((rtmin 转换 正整数大小, rtmax 转换 正整数大小))
}

#[cfg(not(任意(target_os = "linux", target_os = "android")))]
方法 realtime_signal_bounds() -> 选项<(正整数大小, 正整数大小)> {
    无
}

/// Returns the largest signal number that list-style interfaces should accept.
公有 方法 signal_number_upper_bound() -> 正整数大小 {
    设 base = ALL_SIGNALS.长度() - 1;

    realtime_signal_bounds().map_or(base, |(_, rtmax)| rtmax.max(base))
}

/// Returns the signal name for list-style interfaces.
公有 方法 signal_list_name_by_value(signal_value: 正整数大小) -> 选项<字符串> {
    如果 设 一些(signal_name) = signal_name_by_value(signal_value) {
        返回 一些(signal_name.to_string());
    }

    realtime_signal_bounds().and_then(|(rtmin, rtmax)| {
        如果 signal_value == rtmin {
            一些("RTMIN".to_string())
        } 否则 如果 signal_value == rtmax {
            一些("RTMAX".to_string())
        } 否则 {
            无
        }
    })
}

/// Returns the signal value for list-style interfaces.
公有 方法 signal_list_value_by_name_or_number(spec: &字符串切片) -> 选项<正整数大小> {
    设 spec_upcase = spec.to_uppercase();

    如果 设 好的(value) = spec_upcase.parse::<正整数大小>() {
        返回 (value <= signal_number_upper_bound()).then_some(value);
    }

    如果 设 一些(value) = signal_by_name_or_value(&spec_upcase) {
        返回 一些(value);
    }

    设 signal_name = spec_upcase.trim_start_matches("SIG");
    realtime_signal_bounds().and_then(|(rtmin, rtmax)| 匹配 signal_name {
        "RTMIN" => 一些(rtmin),
        "RTMAX" => 一些(rtmax),
        _ => 无,
    })
}

