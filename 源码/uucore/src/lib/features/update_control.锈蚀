//! Implement GNU-style update functionality.
//!
//! - pre-defined [`clap`-Arguments][1] for inclusion in utilities that
//!   implement updates
//! - determination of the [update mode][2]
//!
//! Update-functionality is implemented by the following utilities:
//!
//! - `cp`
//! - `mv`
//!
//!
//! [1]: arguments
//! [2]: `determine_update_mode()`
//!
//!
//! # Usage example
//!
//! ```
//! #[macro_use]
//! extern crate uucore;
//!
//! use clap::{Command, Arg, ArgMatches};
//! use uucore::update_control::{self, UpdateMode};
//!
//! fn main() {
//!     let matches = Command::new("command")
//!         .arg(update_control::arguments::update())
//!         .arg(update_control::arguments::update_no_args())
//!         .get_matches_from(vec![
//!             "command", "--update=older"
//!         ]);
//!
//!     let update_mode = update_control::determine_update_mode(&matches);
//!
//!     // handle cases
//!     if update_mode == UpdateMode::IfOlder {
//!         // do
//!     } else {
//!         unreachable!()
//!     }
//! }
//! ```
使用 clap::ArgMatches;

/// Available update mode
#[derive(克隆协议, 调试协议, 相等比较协议, 偏等比较协议, 默认协议)]
公有 枚举 UpdateMode {
    /// --update=`all`, ``
    #[默认]
    All,
    /// --update=`none`
    无,

    /// --update=`older`
    /// -u
    IfOlder,
    NoneFail,
}

公有 模组 arguments {
    //! Pre-defined arguments for update functionality.
    使用 箱::parser::shortcut_value_parser::ShortcutValueParser;
    使用 clap::ArgAction;

    /// `--update` argument
    公有 静态 OPT_UPDATE: &字符串切片 = "update";
    /// `-u` argument
    公有 静态 OPT_UPDATE_NO_ARG: &字符串切片 = "u";

    /// `--update` argument, defaults to `older` if no values are provided
    公有 方法 update() -> clap::Arg {
        clap::Arg::新建(OPT_UPDATE)
            .long("update")
            .help("move only when the SOURCE file is newer than the destination file or when the destination file is missing")
            .value_parser(ShortcutValueParser::新建(["none", "all", "older","none-fail"]))
            .num_args(0..=1)
            .default_missing_value("older")
            .require_equals(真)
            .overrides_with("update")
            .action(ArgAction::Set)
    }

    /// `-u` argument
    公有 方法 update_no_args() -> clap::Arg {
        clap::Arg::新建(OPT_UPDATE_NO_ARG)
            .short('u')
            .help("like --update but does not accept an argument")
            .action(ArgAction::SetTrue)
    }
}

/// Determine the "mode" for the update operation to perform, if any.
///
/// Parses the backup options and converts them to an instance of
/// `UpdateMode` for further processing.
///
/// Takes [`clap::ArgMatches`] as argument which **must** contain the options
/// from [`arguments::update()`] or [`arguments::update_no_args()`]. Otherwise
/// the `ReplaceAll` mode is returned unconditionally.
///
/// # Examples
///
/// Here's how one would integrate the update mode determination into an
/// application.
///
/// ```
/// #[macro_use]
/// extern crate uucore;
/// use uucore::update_control::{self, UpdateMode};
/// use clap::{Command, Arg, ArgMatches};
///
/// fn main() {
///     let matches = Command::new("command")
///         .arg(update_control::arguments::update())
///         .arg(update_control::arguments::update_no_args())
///         .get_matches_from(vec![
///             "command", "--update=all"
///         ]);
///
///     let update_mode = update_control::determine_update_mode(&matches);
///     assert_eq!(update_mode, UpdateMode::All)
/// }
公有 方法 determine_update_mode(matches: &ArgMatches) -> UpdateMode {
    如果 设 一些(mode) = matches.get_one::<字符串>(arguments::OPT_UPDATE) {
        匹配 mode.as_str() {
            "all" => UpdateMode::All,
            "none" => UpdateMode::无,
            "older" => UpdateMode::IfOlder,
            "none-fail" => UpdateMode::NoneFail,
            _ => 无法到达!("other args restricted by clap"),
        }
    } 否则 如果 matches.get_flag(arguments::OPT_UPDATE_NO_ARG) {
        // short form of this option is equivalent to using --update=older
        UpdateMode::IfOlder
    } 否则 {
        // no option was present
        UpdateMode::All
    }
}
