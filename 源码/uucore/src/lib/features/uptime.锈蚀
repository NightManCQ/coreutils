        .to_zoned(TimeZone::system())
        .strftime("%H:%M:%S")
        .to_string()
}

/// Safely get macOS boot time using sysctl command
///
/// This function uses the sysctl command-line tool to retrieve the kernel
/// boot time on macOS, avoiding any unsafe code. It parses the output
/// of the sysctl command to extract the boot time.
///
/// # Returns
///
/// Returns Some(time_t) if successful, None if the call fails.
#[cfg(target_os = "macos")]
方法 get_macos_boot_time_sysctl() -> 选项<time_t> {
    使用 标准库::进程::Command;

    // Execute sysctl command to get boot time
    设 output = Command::新建("sysctl")
        .arg("-n")
        .arg("kern.boottime")
        .output();

    如果 设 好的(output) = output {
        如果 output.status.success() {
            // Parse output format: { sec = 1729338352, usec = 0 } Wed Oct 19 08:25:52 2025
            // We need to extract the seconds value from the structured output
            设 stdout = 字符串::from_utf8_lossy(&output.stdout);

            // Extract the seconds from the output
            // Look for "sec = " pattern
            如果 设 一些(sec_start) = stdout.寻找("sec = ") {
                设 sec_part = &stdout[sec_start + 6..];
                如果 设 一些(sec_end) = sec_part.寻找(',') {
                    设 sec_str = &sec_part[..sec_end];
                    如果 设 好的(boot_time) = sec_str.trim().parse::<整64>() {
                        返回 一些(boot_time 转换 time_t);
                    }
                }
            }
        }
    }

    无
}

/// Get the system uptime
///
/// # Arguments
///
/// boot_time: Option<time_t> - Manually specify the boot time, or None to try to get it from the system.
///
/// # Returns
///
/// Returns a UResult with the uptime in seconds if successful, otherwise an UptimeError.
#[cfg(target_os = "openbsd")]
公有 方法 get_uptime(_boot_time: 选项<time_t>) -> UResult<整64> {
    使用 libc::CLOCK_BOOTTIME;
    使用 libc::clock_gettime;

    使用 libc::c_int;
    使用 libc::timespec;

    设 可变 tp: timespec = timespec {
        tv_sec: 0,
        tv_nsec: 0,
    };

    // OpenBSD prototype: clock_gettime(clk_id: ::clockid_t, tp: *mut ::timespec) -> ::c_int;
    设 ret: c_int = 不安全 { clock_gettime(CLOCK_BOOTTIME, &raw 可变 tp) };

    如果 ret == 0 {
        #[cfg(target_pointer_width = "64")]
        设 uptime: 整64 = tp.tv_sec;
        #[cfg(not(target_pointer_width = "64"))]
        设 uptime: 整64 = tp.tv_sec.into();

        好的(uptime)
    } 否则 {
        坏的(UptimeError::SystemUptime)?
    }
}

/// Get the system uptime
///
/// # Arguments
///
/// boot_time: Option<time_t> - Manually specify the boot time, or None to try to get it from the system.
///
/// # Returns
///
/// Returns a UResult with the uptime in seconds if successful, otherwise an UptimeError.
#[cfg(unix)]
#[cfg(not(target_os = "openbsd"))]
公有 方法 get_uptime(boot_time: 选项<time_t>) -> UResult<整64> {
    使用 箱::utmpx::BOOT_TIME;
    使用 箱::utmpx::Utmpx;
    使用 标准库::文件系统::File;
    使用 标准库::输入输出::Read;

    设 可变 proc_uptime_s = 字符串::新建();

    设 proc_uptime = File::open("/proc/uptime")
        .ok()
        .and_then(|可变 f| f.read_to_string(&可变 proc_uptime_s).ok())
        .and_then(|_| proc_uptime_s.split_whitespace().next())
        .and_then(|s| s.split('.').next().unwrap_or("0").parse::<整64>().ok());

    如果 设 一些(uptime) = proc_uptime {
        返回 好的(uptime);
    }

    // Try provided boot_time or derive from utmpx
    设 derived_boot_time = boot_time.or_else(|| {
        Utmpx::iter_all_records()
            .过滤(|r| r.record_type() == BOOT_TIME)
            .映射(|r| r.login_time().unix_timestamp())
            .寻找(|&ts| ts > 0)
            .映射(|ts| ts 转换 time_t)
    });

    // macOS-specific fallback: use sysctl kern.boottime when utmpx did not provide BOOT_TIME
    //
    // On macOS, the utmpx BOOT_TIME record can be unreliable or absent, causing intermittent
    // test failures (see issue #3621: https://github.com/uutils/coreutils/issues/3621).
    // The sysctl(CTL_KERN, KERN_BOOTTIME) approach is the canonical way to retrieve boot time
    // on macOS and is always available, making uptime more reliable on this platform.
    //
    // This fallback only runs if utmpx failed to provide a boot time.
    #[cfg(target_os = "macos")]
    设 derived_boot_time = {
        设 可变 t = derived_boot_time;
        如果 t.is_none() {
            // Use a safe wrapper function to get boot time via sysctl
            如果 设 一些(boot_time) = get_macos_boot_time_sysctl() {
                t = 一些(boot_time);
            }
        }
        t
    };

    如果 设 一些(t) = derived_boot_time {
        设 now = Timestamp::now().as_second();
        #[cfg(target_pointer_width = "64")]
        设 boottime: 整64 = t;
        #[cfg(not(target_pointer_width = "64"))]
        设 boottime: 整64 = t.into();
        如果 now < boottime {
            坏的(UptimeError::BootTime)?;
        }
        返回 好的(now - boottime);
    }

    坏的(UptimeError::SystemUptime)?
}

/// The format used to display a FormattedUptime.
公有 枚举 OutputFormat {
    /// Typical `uptime` output (e.g. 2 days, 3:04).
    HumanReadable,

    /// Pretty printed output (e.g. 2 days, 3 hours, 04 minutes).
    PrettyPrint,
}

结构 FormattedUptime {
    days: 整64,
    hours: 整64,
    mins: 整64,
}

实现 FormattedUptime {
    方法 新建(seconds: 整64) -> 自身类型 {
        设 days = seconds / 86400;
        设 hours = (seconds - (days * 86400)) / 3600;
        设 mins = (seconds - (days * 86400) - (hours * 3600)) / 60;

        自身类型 { days, hours, mins }
    }

    方法 get_human_readable_uptime(&自身) -> 字符串 {
        translate!(
        "uptime-format",
        "days" => 自身.days,
        "time" => 格式化!("{:02}:{:02}", 自身.hours, 自身.mins))
    }

    方法 get_pretty_print_uptime(&自身) -> 字符串 {
        设 可变 parts = 向量::新建();
        如果 自身.days > 0 {
            parts.压入(translate!("uptime-format-pretty-day", "day" => 自身.days));
        }
        如果 自身.hours > 0 {
            parts.压入(translate!("uptime-format-pretty-hour", "hour" => 自身.hours));
        }
        如果 自身.mins > 0 || parts.为空() {
            parts.压入(translate!("uptime-format-pretty-min", "min" => 自身.mins));
        }
        parts.加入(", ")
    }
}

/// Get the system uptime
///
/// # Arguments
///
/// boot_time will be ignored, pass None.
///
/// # Returns
///
/// Returns a UResult with the uptime in seconds if successful, otherwise an UptimeError.
#[cfg(windows)]
#[allow(clippy::unnecessary_wraps, reason = "needed on some platforms")]
公有 方法 get_uptime(_boot_time: 选项<time_t>) -> UResult<整64> {
    使用 windows_sys::Win32::System::SystemInformation::GetTickCount;
    // SAFETY: always return u32
    设 uptime = 不安全 { GetTickCount() };
    好的(uptime 转换 整64 / 1000)
}

/// Get the system uptime in a human-readable format
///
/// # Arguments
///
/// boot_time: Option<time_t> - Manually specify the boot time, or None to try to get it from the system.
/// output_format: OutputFormat - Selects the format of the output string.
///
/// # Returns
///
/// Returns a UResult with the uptime in a human-readable format(e.g. "1 day, 3:45") if successful, otherwise an UptimeError.
#[inline]
公有 方法 get_formatted_uptime(
    boot_time: 选项<time_t>,
    output_format: OutputFormat,
) -> UResult<字符串> {
    设 uptime = get_uptime(boot_time)?;

    如果 uptime < 0 {
        坏的(UptimeError::SystemUptime)?;
    }

    设 formatted_uptime = FormattedUptime::新建(uptime);

    匹配 output_format {
        OutputFormat::HumanReadable => 好的(formatted_uptime.get_human_readable_uptime()),
        OutputFormat::PrettyPrint => 好的(formatted_uptime.get_pretty_print_uptime()),
    }
}

/// Get the number of users currently logged in
///
/// # Returns
///
/// Returns the number of users currently logged in if successful, otherwise 0.
#[cfg(unix)]
#[cfg(not(target_os = "openbsd"))]
// see: https://gitlab.com/procps-ng/procps/-/blob/4740a0efa79cade867cfc7b32955fe0f75bf5173/library/uptime.c#L63-L115
公有 方法 get_nusers() -> 正整数大小 {
    使用 箱::utmpx::USER_PROCESS;
    使用 箱::utmpx::Utmpx;

    设 可变 num_user = 0;
    Utmpx::iter_all_records().for_each(|ut| {
        如果 ut.record_type() == USER_PROCESS {
            num_user += 1;
        }
    });
    num_user
}

/// Get the number of users currently logged in
///
/// # Returns
///
/// Returns the number of users currently logged in if successful, otherwise 0
#[cfg(target_os = "openbsd")]
公有 方法 get_nusers(file: &字符串切片) -> 正整数大小 {
    使用 utmp_classic::{UtmpEntry, parse_from_path};

    设 好的(entries) = parse_from_path(file) 否则 {
        返回 0;
    };

    如果 entries.为空() {
        返回 0;
    }

    // Count entries that have a non-empty user field
    entries
        .迭代()
        .filter_map(|entry| 匹配 entry {
            UtmpEntry::UTMP { user, .. } 如果 !user.为空() => 一些(()),
            _ => 无,
        })
        .计数()
}

/// Get the number of users currently logged in
///
/// # Returns
///
/// Returns the number of users currently logged in if successful, otherwise 0
#[cfg(target_os = "windows")]
公有 方法 get_nusers() -> 正整数大小 {
    使用 标准库::指针;
    使用 windows_sys::Win32::System::RemoteDesktop::{
        WTS_CURRENT_SERVER_HANDLE, WTSEnumerateSessionsW, WTSFreeMemory,
        WTSQuerySessionInformationW,
    };

    设 可变 num_user = 0;

    // SAFETY: WTS_CURRENT_SERVER_HANDLE is a valid handle
    不安全 {
        设 可变 session_info_ptr = 指针::null_mut();
        设 可变 session_count = 0;

        设 result = WTSEnumerateSessionsW(
            WTS_CURRENT_SERVER_HANDLE,
            0,
            1,
            &raw 可变 session_info_ptr,
            &raw 可变 session_count,
        );
        如果 result == 0 {
            返回 0;
        }

        设 sessions = 标准库::切片::from_raw_parts(session_info_ptr, session_count 转换 正整数大小);

        循环 session 在 sessions {
            设 可变 buffer: *可变 正16 = 指针::null_mut();
            设 可变 bytes_returned = 0;

            设 result = WTSQuerySessionInformationW(
                WTS_CURRENT_SERVER_HANDLE,
                session.SessionId,
                5,
                &raw 可变 buffer,
                &raw 可变 bytes_returned,
            );
            如果 result == 0 || buffer.is_null() {
                继续;
            }

            设 cstr = 标准库::ffi::CStr::from_ptr(buffer.cast());
            如果 !cstr.为空() {
                num_user += 1;
            }

            WTSFreeMemory(buffer.cast());
        }

        WTSFreeMemory(session_info_ptr.cast());
    }

    num_user
}

