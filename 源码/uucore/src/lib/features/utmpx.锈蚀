实现 迭代器协议 循环 UtmpxIter {
    类型 Item = UtmpxRecord;
    方法 next(&可变 自身) -> 选项<自身类型::Item> {
        #[cfg(feature = "feat_systemd_logind")]
        {
            如果 设 一些(引用 可变 systemd_iter) = 自身.systemd_iter {
                // We have a systemd iterator - use it exclusively (never fall back to traditional utmp)
                返回 systemd_iter.next().映射(UtmpxRecord::Systemd);
            }
        }

        // Traditional utmp path
        不安全 {
            #[cfg_attr(target_env = "musl", allow(deprecated))]
            设 res = getutxent();
            如果 res.is_null() {
                无
            } 否则 {
                // The data behind this pointer will be replaced by the next
                // call to getutxent(), so we have to read it now.
                // All the strings live inline in the struct as arrays, which
                // makes things easier.
                一些(UtmpxRecord::Traditional(盒子::新建(Utmpx {
                    inner: 指针::读锁定(res.cast_const()),
                })))
            }
        }
    }
}

实现 Drop 循环 UtmpxIter {
    方法 drop(&可变 自身) {
        不安全 {
            #[cfg_attr(target_env = "musl", allow(deprecated))]
            endutxent();
        }
    }
}
