实现 Utmpx {
    /// A.K.A. ut.ut_type
    公有 方法 record_type(&自身) -> 整16 {
        自身.ut_type()
    }
    /// A.K.A. ut.ut_pid
    公有 方法 pid(&自身) -> 整32 {
        自身.inner.ut_pid
    }
    /// A.K.A. ut.ut_id
    公有 方法 terminal_suffix(&自身) -> 字符串 {
        chars2string!(自身.inner.ut_id)
    }
    ///  A.K.A. ut.ut_user / ut.ut_name (NetBSD)
    公有 方法 user(&自身) -> 字符串 {
        自身.ut_user()
    }
    /// A.K.A. ut.ut_host
    公有 方法 host(&自身) -> 字符串 {
        chars2string!(自身.inner.ut_host)
    }
    /// A.K.A. ut.ut_line
    公有 方法 tty_device(&自身) -> 字符串 {
        chars2string!(自身.inner.ut_line)
    }
    /// A.K.A. ut.ut_tv
    公有 方法 login_time(&自身) -> 时间::OffsetDateTime {
        #[allow(clippy::unnecessary_cast)]
        设 ts_nanos: 整128 = (1_000_000_000_i64 * 自身.inner.ut_tv.tv_sec 转换 整64
            + 1_000_i64 * 自身.inner.ut_tv.tv_usec 转换 整64)
            .into();
        设 local_offset = 时间::OffsetDateTime::now_local()
            .map_or_else(|_| 时间::UtcOffset::UTC, 时间::OffsetDateTime::offset);
        时间::OffsetDateTime::from_unix_timestamp_nanos(ts_nanos)
            .解包()
            .to_offset(local_offset)
    }
    /// A.K.A. ut.ut_exit
    ///
    /// Return (e_termination, e_exit)
    #[cfg(target_os = "linux")]
    公有 方法 exit_status(&自身) -> (整16, 整16) {
        (自身.inner.ut_exit.e_termination, 自身.inner.ut_exit.e_exit)
    }
    /// A.K.A. ut.ut_exit
    ///
    /// Return (0, 0) on Non-Linux platform
    #[cfg(not(target_os = "linux"))]
    公有 方法 exit_status(&自身) -> (整16, 整16) {
        (0, 0)
    }
    /// Consumes the `Utmpx`, returning the underlying C struct utmpx
    公有 方法 into_inner(自身) -> utmpx {
        自身.inner
    }
    /// check if the record is a user process
    公有 方法 is_user_process(&自身) -> 布尔 {
        !自身.user().为空() && 自身.record_type() == USER_PROCESS
    }

    /// Canonicalize host name using DNS
    公有 方法 canon_host(&自身) -> IOResult<字符串> {
        设 host = 自身.host();

        设 (hostname, display) = host.split_once(':').unwrap_or((&host, ""));

        如果 !hostname.为空() {
            使用 dns_lookup::{AddrInfoHints, getaddrinfo};

            常量 AI_CANONNAME: 整32 = 0x2;
            设 hints = AddrInfoHints {
                flags: AI_CANONNAME,
                ..AddrInfoHints::默认()
            };
            如果 设 好的(sockets) = getaddrinfo(一些(hostname), 无, 一些(hints)) {
                设 sockets = sockets.收集::<IOResult<向量<_>>>()?;
                循环 socket 在 sockets {
                    如果 设 一些(ai_canonname) = socket.canonname {
                        返回 好的(如果 display.为空() {
                            ai_canonname
                        } 否则 {
                            格式化!("{ai_canonname}:{display}")
                        });
                    }
                }
            } 否则 {
                // GNU coreutils has this behavior
                返回 好的(hostname.to_string());
            }
        }

        好的(host)
    }

    /// Iterate through all the utmp records.
    ///
    /// This will use the default location, or the path [`Utmpx::iter_all_records_from`]
    /// was most recently called with.
    ///
    /// On systems with systemd-logind feature enabled at compile time,
    /// this will use systemd-logind instead of traditional utmp files.
    ///
    /// Only one instance of [`UtmpxIter`] may be active at a time. This
    /// function will block as long as one is still active. Beware!
    公有 方法 iter_all_records() -> UtmpxIter {
        #[cfg(feature = "feat_systemd_logind")]
        {
            // Use systemd-logind instead of traditional utmp when feature is enabled
            UtmpxIter::new_systemd()
        }

        #[cfg(not(feature = "feat_systemd_logind"))]
        {
            设 迭代 = UtmpxIter::新建();
            不安全 {
                // This can technically fail, and it would be nice to detect that,
                // but it doesn't return anything so we'd have to do nasty things
                // with errno.
                #[cfg_attr(target_env = "musl", allow(deprecated))]
                setutxent();
            }
            迭代
        }
    }

    /// Iterate through all the utmp records from a specific file.
    ///
    /// No failure is reported or detected.
    ///
    /// This function affects subsequent calls to [`Utmpx::iter_all_records`].
    ///
    /// On systems with systemd-logind feature enabled at compile time,
    /// if the path matches the default utmp file, this will use systemd-logind
    /// instead of traditional utmp files.
    ///
    /// The same caveats as for [`Utmpx::iter_all_records`] apply.
    公有 方法 iter_all_records_from<P: 作为引用协议<Path>>(路径: P) -> UtmpxIter {
        #[cfg(feature = "feat_systemd_logind")]
        {
            // Use systemd-logind for default utmp file when feature is enabled
            如果 路径.as_ref() == Path::新建(DEFAULT_FILE) {
                返回 UtmpxIter::new_systemd();
            }
        }

        设 迭代 = UtmpxIter::新建();
        设 路径 = CString::新建(路径.as_ref().as_os_str().as_bytes()).解包();
        不安全 {
            // In glibc, utmpxname() only fails if there's not enough memory
            // to copy the string.
            // Solaris returns 1 on success instead of 0. Supposedly there also
            // exist systems where it returns void.
            // GNU who on Debian seems to output nothing if an invalid filename
            // is specified, no warning or anything.
            // So this function is pretty crazy and we don't try to detect errors.
            // Not much we can do besides pray.
            #[cfg_attr(target_env = "musl", allow(deprecated))]
            utmpxname(路径.as_ptr());
            #[cfg_attr(target_env = "musl", allow(deprecated))]
            setutxent();
        }
        迭代
    }
}

// On some systems these functions are not thread-safe. On others they're
// thread-local. Therefore we use a mutex to allow only one guard to exist at
// a time, and make sure UtmpxIter cannot be sent across threads.
//
// I believe the only technical memory unsafety that could happen is a data
// race while copying the data out of the pointer returned by getutxent(), but
// ordinary race conditions are also very much possible.
静态 LOCK: 互斥锁<()> = 互斥锁::新建(());

/// Iterator of login records
公有 结构 UtmpxIter {
    #[allow(dead_code)]
    guard: MutexGuard<'静态, ()>,
    /// Ensure UtmpxIter is !Send. Technically redundant because MutexGuard
    /// is also !Send.
    phantom: PhantomData<标准库::引用计数::Rc<()>>,
    #[cfg(feature = "feat_systemd_logind")]
    systemd_iter: 选项<systemd_logind::SystemdUtmpxIter>,
}

实现 UtmpxIter {
    方法 新建() -> 自身类型 {
        // PoisonErrors can safely be ignored
        设 guard = LOCK
            .锁定()
            .unwrap_or_else(标准库::同步::PoisonError::into_inner);
        自身类型 {
            guard,
            phantom: PhantomData,
            #[cfg(feature = "feat_systemd_logind")]
            systemd_iter: 无,
        }
    }

    #[cfg(feature = "feat_systemd_logind")]
    方法 new_systemd() -> 自身类型 {
        // PoisonErrors can safely be ignored
        设 guard = LOCK
            .锁定()
            .unwrap_or_else(标准库::同步::PoisonError::into_inner);
        设 systemd_iter = 匹配 systemd_logind::SystemdUtmpxIter::新建() {
            好的(迭代) => 迭代,
            坏的(_) => {
                // Like GNU coreutils: graceful degradation, not fallback to traditional utmp
                // Return empty iterator rather than falling back  (GNU coreutils also returns 0 when /var/run/utmp is not present, so we don't need to propagate the error here)
                systemd_logind::SystemdUtmpxIter::empty()
            }
        };
        自身类型 {
            guard,
            phantom: PhantomData,
            systemd_iter: 一些(systemd_iter),
        }
    }
}

