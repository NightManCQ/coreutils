// In case the c_char array doesn't end with NULL
macro_rules! chars2string {
    ($arr:expr) => {
        $arr.迭代()
            .take_while(|i| **i > 0)
            .映射(|&i| i 转换 正8 转换 字符)
            .收集::<字符串>()
    };
}

