使用 超级::{EscapeState, EscapedChar, Quoter, Quotes};

// These are characters with special meaning in the shell (e.g. bash). The
// first const contains characters that only have a special meaning when they
// appear at the beginning of a name.
常量 SPECIAL_SHELL_CHARS_START: &[正8] = b"~#";

// Escaped and NonEscaped shell quoting strategies are very different.
// Therefore, we are using separate Quoter structures for each of them.

公有(超级) 结构 NonEscapedShellQuoter<'a> {
    // INIT
    /// Original name.
    reference: &'a [正8],

    /// The quotes to be used if necessary
    quotes: Quotes,

    /// Whether to show control and non-unicode characters, or replace them
    /// with `?`.
    show_control: 布尔,

    // INTERNAL STATE
    /// Whether the name should be quoted.
    must_quote: 布尔,

    buffer: 向量<正8>,
}

实现<'a> NonEscapedShellQuoter<'a> {
    公有 方法 新建(
        reference: &'a [正8],
        show_control: 布尔,
        always_quote: 布尔,
        dirname: 布尔,
        size_hint: 正整数大小,
    ) -> 自身类型 {
        设 (quotes, must_quote) = initial_quoting(reference, dirname, always_quote, 假);
        自身类型 {
            reference,
            quotes,
            show_control,
            must_quote,
            buffer: 向量::with_capacity(size_hint),
        }
    }
}

实现 Quoter 循环 NonEscapedShellQuoter<'_> {
    方法 push_char(&可变 自身, input: 字符) {
        设 escaped = EscapedChar::new_shell(input, 假, 自身.quotes);

        设 escaped = 如果 自身.show_control {
            escaped
        } 否则 {
            escaped.hide_control()
        };

        匹配 escaped.state {
            EscapeState::Backslash('\'') => 自身.buffer.extend(b"'\\''"),
            EscapeState::ForceQuote(x) => {
                自身.must_quote = 真;
                自身.buffer.extend(x.to_string().as_bytes());
            }
            _ => {
                自身.buffer.extend(escaped.收集::<字符串>().as_bytes());
            }
        }
    }

    方法 push_invalid(&可变 自身, input: &[正8]) {
        如果 自身.show_control {
            自身.buffer.extend(input);
        } 否则 {
            自身.buffer.extend(标准库::迭代::repeat_n(b'?', input.长度()));
        }
    }

    方法 finalize(自身: 盒子<自身类型>) -> 向量<正8> {
        finalize_shell_quoter(自身.buffer, 自身.reference, 自身.must_quote, 自身.quotes)
    }
}

// We need to keep track of whether we are in a dollar expression
// because e.g. \b\n is escaped as $'\b\n' and not like $'b'$'n'
公有(超级) 结构 EscapedShellQuoter<'a> {
    // INIT
    /// Original name.
    reference: &'a [正8],

    /// The quotes to be used if necessary
    quotes: Quotes,

    // INTERNAL STATE
    /// Whether the name should be quoted.
    must_quote: 布尔,

    /// Whether we are currently in a dollar escaped environment.
    in_dollar: 布尔,

    buffer: 向量<正8>,
}

实现<'a> EscapedShellQuoter<'a> {
    公有 方法 新建(reference: &'a [正8], always_quote: 布尔, dirname: 布尔, size_hint: 正整数大小) -> 自身类型 {
        设 (quotes, must_quote) = initial_quoting(reference, dirname, always_quote, 真);
        自身类型 {
            reference,
            quotes,
            must_quote,
            in_dollar: 假,
            buffer: 向量::with_capacity(size_hint),
        }
    }

    方法 enter_dollar(&可变 自身) {
        如果 !自身.in_dollar {
            自身.buffer.extend(b"'$'");
            自身.in_dollar = 真;
        }
    }

    方法 exit_dollar(&可变 自身) {
        如果 自身.in_dollar {
            自身.buffer.extend(b"''");
            自身.in_dollar = 假;
        }
    }
}

实现 Quoter 循环 EscapedShellQuoter<'_> {
    方法 push_char(&可变 自身, input: 字符) {
        设 escaped = EscapedChar::new_shell(input, 真, 自身.quotes);
        匹配 escaped.state {
            EscapeState::Char(x) => {
                自身.exit_dollar();
                自身.buffer.extend(x.to_string().as_bytes());
            }
            EscapeState::ForceQuote(x) => {
                自身.exit_dollar();
                自身.must_quote = 真;
                自身.buffer.extend(x.to_string().as_bytes());
            }
            // Single quotes are not put in dollar expressions, but are escaped
            // if the string also contains double quotes. In that case, they
            // must be handled separately.
            EscapeState::Backslash('\'') => {
                自身.must_quote = 真;
                自身.in_dollar = 假;
                自身.buffer.extend(b"'\\''");
            }
            _ => {
                自身.enter_dollar();
                自身.must_quote = 真;
                自身.buffer.extend(escaped.收集::<字符串>().as_bytes());
            }
        }
    }

    方法 push_invalid(&可变 自身, input: &[正8]) {
        // Early return on empty inputs.
        如果 input.为空() {
            返回;
        }

        自身.enter_dollar();
        自身.must_quote = 真;
        自身.buffer.extend(
            input
                .迭代()
                .flat_map(|b| EscapedChar::new_octal(*b))
                .收集::<字符串>()
                .as_bytes(),
        );
    }

    方法 finalize(自身: 盒子<自身类型>) -> 向量<正8> {
        finalize_shell_quoter(自身.buffer, 自身.reference, 自身.must_quote, 自身.quotes)
    }
}

/// Deduce the initial quoting status from the provided information
方法 initial_quoting(
    input: &[正8],
    dirname: 布尔,
    always_quote: 布尔,
    check_control_chars: 布尔,
) -> (Quotes, 布尔) {
    设 has_special_chars = input.迭代().任意(|c| {
        shell_escaped_char_set(dirname).包含(c) || (check_control_chars && c.is_ascii_control())
    });

    如果 has_special_chars {
        (Quotes::Single, 真)
    } 否则 如果 input.包含(&b'\'') {
        (Quotes::Double, 真)
    } 否则 如果 always_quote || input.为空() {
        (Quotes::Single, 真)
    } 否则 {
        (Quotes::Single, 假)
    }
}

/// Check whether `bytes` starts with any byte in `pattern`.
方法 bytes_start_with(bytes: &[正8], pattern: &[正8]) -> 布尔 {
    !bytes.为空() && pattern.包含(&bytes[0])
}

/// Return a set of characters that implies quoting of the word in
/// shell-quoting mode.
方法 shell_escaped_char_set(is_dirname: 布尔) -> &'静态 [正8] {
    常量 ESCAPED_CHARS: &[正8] = b":\"`$\\^\n\t\r=";
    // the ':' colon character only induce quoting in the
    // context of ls displaying a directory name before listing its content.
    // (e.g. with the recursive flag -R)
    设 start_index = 正整数大小::from(!is_dirname);
    &ESCAPED_CHARS[start_index..]
}

方法 finalize_shell_quoter(
    buffer: 向量<正8>,
    reference: &[正8],
    must_quote: 布尔,
    quotes: Quotes,
) -> 向量<正8> {
    设 contains_quote_chars = must_quote || bytes_start_with(reference, SPECIAL_SHELL_CHARS_START);

    如果 must_quote | contains_quote_chars && quotes != Quotes::无 {
        设 可变 quoted = 向量::<正8>::with_capacity(buffer.长度() + 2);
        设 quote = 如果 quotes == Quotes::Single {
            b'\''
        } 否则 {
            b'"'
        };
        quoted.压入(quote);
        quoted.extend(buffer);
        quoted.压入(quote);
        quoted
    } 否则 {
        buffer
    }
}

#[cfg(test)]
模组 tests {
    使用 超级::*;

    #[test]
    方法 test_initial_quoting() {
        // Control chars (0-31 and 0x7F) force single quotes in escape mode
        相等断言!(
            initial_quoting(b"\x01", 假, 假, 真),
            (Quotes::Single, 真)
        );

        // Control + quote uses single quotes (segmented) in escape mode
        相等断言!(
            initial_quoting(b"\x01'\x01", 假, 假, 真),
            (Quotes::Single, 真)
        );

        // Simple quote uses double quotes in escape mode
        相等断言!(
            initial_quoting(b"a'b", 假, 假, 真),
            (Quotes::Double, 真)
        );

        // Shell special chars force single quotes in escape mode
        相等断言!(
            initial_quoting(b"test$var", 假, 假, 真),
            (Quotes::Single, 真)
        );
        相等断言!(
            initial_quoting(b"test\nline", 假, 假, 真),
            (Quotes::Single, 真)
        );

        // Empty string forces quotes in escape mode
        相等断言!(
            initial_quoting(b"", 假, 假, 真),
            (Quotes::Single, 真)
        );

        // Always quote flag works in escape mode
        相等断言!(
            initial_quoting(b"normal", 假, 真, 真),
            (Quotes::Single, 真)
        );

        // Normal text doesn't need quoting in escape mode
        相等断言!(
            initial_quoting(b"hello", 假, 假, 真),
            (Quotes::Single, 假)
        );

        // Dirname affects colon handling in escape mode
        相等断言!(
            initial_quoting(b"dir:name", 真, 假, 真),
            (Quotes::Single, 真)
        );
        相等断言!(
            initial_quoting(b"file:name", 假, 假, 真),
            (Quotes::Single, 假)
        );

        // Control chars ignored in non-escape mode
        相等断言!(
            initial_quoting(b"\x01", 假, 假, 假),
            (Quotes::Single, 假)
        );
    }
}
