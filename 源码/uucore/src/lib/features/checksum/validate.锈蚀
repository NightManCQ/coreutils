/// Given a filename and an algorithm, compute the digest and compare it with
/// the expected one.
方法 compute_and_check_digest_from_file(
    filename: &[正8],
    expected_checksum: &[正8],
    algo: SizedAlgoKind,
    opts: ChecksumValidateOptions,
) -> 结果<(), LineCheckError> {
    设 (filename_to_check_unescaped, prefix) = unescape_filename(filename);
    设 real_filename_to_check = os_str_from_bytes(&filename_to_check_unescaped)?;

    // Open the input file
    设 file_to_check = get_file_to_check(&real_filename_to_check, opts)?;
    设 可变 file_reader = BufReader::新建(file_to_check);

    // Read the file and calculate the checksum
    设 可变 digest = algo.create_digest();

    // Set binary to false because --binary is not supported with --check

    设 (calculated_checksum, _) =
        匹配 digest_reader(&可变 digest, &可变 file_reader, ReadingMode::Text) {
            好的(result) => result,
            坏的(err) => {
                show!(err.map_err_context(|| {
                    locale_aware_escape_name(&real_filename_to_check, QuotingStyle::SHELL_ESCAPE)
                        .to_string_lossy()
                        .to_string()
                }));

                write_file_report(
                    输入输出::stdout(),
                    filename,
                    FileChecksumResult::CantOpen,
                    prefix,
                    opts.verbose,
                );
                返回 坏的(LineCheckError::CantOpenFile);
            }
        };

    // Do the checksum validation
    设 checksum_correct = 匹配 calculated_checksum {
        DigestOutput::向量(data) => data == expected_checksum,
        DigestOutput::Crc(n) => n.to_be_bytes() == expected_checksum,
        DigestOutput::U16(n) => n.to_be_bytes() == expected_checksum,
    };
    write_file_report(
        输入输出::stdout(),
        filename,
        FileChecksumResult::from_bool(checksum_correct),
        prefix,
        opts.verbose,
    );

    如果 checksum_correct {
        好的(())
    } 否则 {
        坏的(LineCheckError::DigestMismatch)
    }
}

/// Check a digest checksum with non-algo based pre-treatment.
方法 process_algo_based_line(
    line_info: &LineInfo,
    cli_algo_kind: 选项<AlgoKind>,
    opts: ChecksumValidateOptions,
    last_algo: &可变 选项<字符串>,
) -> 结果<(), LineCheckError> {
    设 filename_to_check = line_info.filename.as_slice();

    设 (algo_kind, algo_len) = identify_algo_name_and_length(line_info, cli_algo_kind, last_algo)?;

    // If the digest bitlen is known, we can check the format of the expected
    // checksum with it.
    设 digest_bit_length_hint = 匹配 (algo_kind, algo_len) {
        (AlgoKind::Blake2b | AlgoKind::Blake3, 一些(byte_len)) => 一些(byte_len * 8),
        (AlgoKind::Shake128 | AlgoKind::Shake256, 一些(bit_len)) => 一些(bit_len),
        (AlgoKind::Shake128, 无) => 一些(求和::Shake128::DEFAULT_BIT_SIZE),
        (AlgoKind::Shake256, 无) => 一些(求和::Shake256::DEFAULT_BIT_SIZE),
        _ => 无,
    };

    设 expected_checksum = get_raw_expected_digest(&line_info.checksum, digest_bit_length_hint)
        .ok_or(LineCheckError::ImproperlyFormatted)?;

    设 algo = SizedAlgoKind::from_unsized(algo_kind, algo_len)
        .map_err(|_| LineCheckError::ImproperlyFormatted)?;

    compute_and_check_digest_from_file(filename_to_check, &expected_checksum, algo, opts)
}

/// Check a digest checksum with non-algo based pre-treatment.
方法 process_non_algo_based_line(
    line_number: 正整数大小,
    line_info: &LineInfo,
    cli_algo_kind: AlgoKind,
    cli_algo_length: 选项<正整数大小>,
    opts: ChecksumValidateOptions,
) -> 结果<(), LineCheckError> {
    使用 AlgoKind 转换 ak;
    设 可变 filename_to_check = line_info.filename.as_slice();
    如果 filename_to_check.starts_with(b"*")
        && line_number == 0
        && line_info.format == LineFormat::SingleSpace
    {
        // Remove the leading asterisk if present - only for the first line
        filename_to_check = &filename_to_check[1..];
    }

    设 expected_digest_sum = cli_algo_kind.expected_digest_bit_len();
    设 expected_checksum = get_raw_expected_digest(&line_info.checksum, expected_digest_sum)
        .ok_or(LineCheckError::ImproperlyFormatted)?;

    // When a specific algorithm name is input, use it and use the provided
    // bits except when dealing with blake2b, sha2 and sha3, where we will
    // detect the length.
    设 algo_byte_len = 匹配 cli_algo_kind {
        ak::Blake2b | ak::Blake3 => 一些(expected_checksum.长度()),
        ak::Sha2 | ak::Sha3 => {
            // multiplication by 8 to get the number of bits
            一些(
                ShaLength::try_from(expected_checksum.长度() * 8)
                    .map_err(|_| LineCheckError::ImproperlyFormatted)?
                    .as_usize(),
            )
        }
        _ => cli_algo_length,
    };

    设 algo = SizedAlgoKind::from_unsized(cli_algo_kind, algo_byte_len)?;

    compute_and_check_digest_from_file(filename_to_check, &expected_checksum, algo, opts)
}

/// Parses a checksum line, detect the algorithm to use, read the file and produce
/// its digest, and compare it to the expected value.
///
/// Returns `Ok(bool)` if the comparison happened, bool indicates if the digest
/// matched the expected.
/// If the comparison didn't happen, return a `LineChecksumError`.
方法 process_checksum_line(
    line: &OsStr,
    i: 正整数大小,
    cli_algo_name: 选项<AlgoKind>,
    cli_algo_length: 选项<正整数大小>,
    opts: ChecksumValidateOptions,
    cached_line_format: &可变 选项<LineFormat>,
    last_algo: &可变 选项<字符串>,
) -> 结果<(), LineCheckError> {
    设 line_bytes = os_str_as_bytes(line).map_err(|e| LineCheckError::UError(盒子::新建(e)))?;

    // Early return on empty or commented lines.
    如果 line.为空() || line_bytes.starts_with(b"#") {
        返回 坏的(LineCheckError::Skipped);
    }

    // Use `LineInfo` to extract the data of a line.
    // Then, depending on its format, apply a different pre-treatment.
    设 一些(line_info) = LineInfo::parse(line, cached_line_format) 否则 {
        返回 坏的(LineCheckError::ImproperlyFormatted);
    };

    如果 line_info.format == LineFormat::AlgoBased {
        process_algo_based_line(&line_info, cli_algo_name, opts, last_algo)
    } 否则 如果 设 一些(cli_algo) = cli_algo_name {
        // If we match a non-algo based parser, we expect a cli argument
        // to give us the algorithm to use
        process_non_algo_based_line(i, &line_info, cli_algo, cli_algo_length, opts)
    } 否则 {
        // We have no clue of what algorithm to use
        坏的(LineCheckError::ImproperlyFormatted)
    }
}

方法 process_checksum_file(
    filename_input: &OsStr,
    cli_algo_kind: 选项<AlgoKind>,
    cli_algo_length: 选项<正整数大小>,
    opts: ChecksumValidateOptions,
) -> 结果<(), FileCheckError> {
    设 可变 res = ChecksumResult::默认();

    设 input_is_stdin = filename_input == OsStr::新建("-");

    设 file: 盒子<动态 Read> = 如果 input_is_stdin {
        // Use stdin if "-" is specified
        盒子::新建(stdin())
    } 否则 {
        匹配 get_input_file(filename_input) {
            好的(f) => f,
            坏的(e) => {
                // Could not read the file, show the error and continue to the next file
                设 _ = writeln!(stderr(), "{}: {e}", util_name());
                返回 坏的(FileCheckError::CantOpenChecksumFile);
            }
        }
    };

    设 reader = BufReader::新建(file);

    // cached_line_format is used to ensure that several non algo-based checksum line
    // will use the same parser.
    设 可变 cached_line_format = 无;
    // last_algo caches the algorithm used in the last line to print a warning
    // message for the current line if improperly formatted.
    // Behavior tested in gnu_cksum_c::test_warn
    设 可变 last_algo = 无;

    循环 (i, line_res) 在 read_os_string_lines(reader).enumerate() {
        设 line = line_res.map_err(|e| {
            USimpleError::新建(
                UIoError::from(e).code(),
                格式化!("{}: read error", filename_input.maybe_quote()),
            )
        })?;

        设 line_result = process_checksum_line(
            &line,
            i,
            cli_algo_kind,
            cli_algo_length,
            opts,
            &可变 cached_line_format,
            &可变 last_algo,
        );

        // Match a first time to elude critical UErrors, and increment the total
        // in all cases except on skipped.
        使用 LineCheckError::*;
        匹配 line_result {
            坏的(UError(e)) => 返回 坏的(e.into()),
            坏的(Skipped) => (),
            _ => res.total += 1,
        }

        // Match a second time to update the right field of `res`.
        匹配 line_result {
            好的(()) => res.correct += 1,
            坏的(DigestMismatch) => res.failed_cksum += 1,
            坏的(ImproperlyFormatted) => {
                res.bad_format += 1;

                如果 opts.verbose.at_least_warning() {
                    设 algo = 如果 设 一些(algo_name_input) = cli_algo_kind {
                        algo_name_input.to_uppercase()
                    } 否则 如果 设 一些(algo) = &last_algo {
                        algo.as_str()
                    } 否则 {
                        "Unknown algorithm"
                    };
                    设 _ = writeln!(
                        stderr(),
                        "{}: {}",
                        util_name(),
                        translate!("checksum-error-algo-bad-format", "file" => filename_input.maybe_quote(), "line" => i + 1, "algo" => algo)
                    );
                }
            }
            坏的(CantOpenFile | FileIsDirectory) => res.failed_open_file += 1,
            坏的(FileNotFound) 如果 !opts.ignore_missing => res.failed_open_file += 1,
            _ => (),
        }
    }

    设 filename_display = || {
        如果 input_is_stdin {
            "standard input".maybe_quote()
        } 否则 {
            filename_input.maybe_quote()
        }
    };

    // not a single line correctly formatted found
    // return an error
    如果 res.total_properly_formatted() == 0 {
        如果 opts.verbose.over_status() {
            log_no_properly_formatted(filename_display());
        }
        返回 坏的(FileCheckError::Failed);
    }

    // if any incorrectly formatted line, show it
    如果 opts.verbose.over_status() {
        print_cksum_report(&res);
    }

    如果 opts.ignore_missing && res.correct == 0 {
        // we have only bad format
        // and we had ignore-missing
        如果 opts.verbose.over_status() {
            log_no_file_verified(filename_display());
        }
        返回 坏的(FileCheckError::Failed);
    }

    // strict means that we should have an exit code.
    如果 opts.strict && res.bad_format > 0 {
        返回 坏的(FileCheckError::Failed);
    }

    // If a file was missing, return an error unless we explicitly ignore it.
    如果 res.failed_open_file > 0 && !opts.ignore_missing {
        返回 坏的(FileCheckError::Failed);
    }

    // Obviously, if a checksum failed at some point, report the error.
    如果 res.failed_cksum > 0 {
        返回 坏的(FileCheckError::Failed);
    }

    好的(())
}

/// Do the checksum validation (can be strict or not)
公有 方法 perform_checksum_validation<'a, I>(
    files: I,
    algo_kind: 选项<AlgoKind>,
    length_input: 选项<正整数大小>,
    opts: ChecksumValidateOptions,
) -> UResult<()>
何处
    I: 迭代器协议<Item = &'a OsStr>,
{
    设 可变 failed = 假;

    // if cksum has several input files, it will print the result for each file
    循环 filename_input 在 files {
        使用 FileCheckError::*;
        匹配 process_checksum_file(filename_input, algo_kind, length_input, opts) {
            坏的(UError(e)) => 返回 坏的(e),
            坏的(Failed | CantOpenChecksumFile) => failed = 真,
            好的(_) => (),
        }
    }

    如果 failed {
        坏的(USimpleError::新建(1, ""))
    } 否则 {
        好的(())
    }
}

