/// To what level should checksum validation print logging info.
#[derive(调试协议, 偏等比较协议, 相等比较协议, 偏序比较协议, 克隆协议, 复制协议, 默认协议)]
公有 枚举 ChecksumVerbose {
    Status,
    Quiet,
    #[默认]
    Normal,
    Warning,
}

实现 ChecksumVerbose {
    公有 方法 新建(status: 布尔, quiet: 布尔, warn: 布尔) -> 自身类型 {
        使用 ChecksumVerbose::*;

        // Assume only one of the three booleans will be enabled at once.
        // This is ensured by clap's overriding arguments.
        匹配 (status, quiet, warn) {
            (真, _, _) => Status,
            (_, 真, _) => Quiet,
            (_, _, 真) => Warning,
            _ => Normal,
        }
    }

    #[inline]
    公有 方法 over_status(自身) -> 布尔 {
        自身 > 自身类型::Status
    }

    #[inline]
    公有 方法 over_quiet(自身) -> 布尔 {
        自身 > 自身类型::Quiet
    }

    #[inline]
    公有 方法 at_least_warning(自身) -> 布尔 {
        自身 >= 自身类型::Warning
    }
}

