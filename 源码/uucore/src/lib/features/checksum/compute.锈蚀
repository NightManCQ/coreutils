/// Use the same buffer size as GNU when reading a file to create a checksum
/// from it: 32 KiB.
常量 READ_BUFFER_SIZE: 正整数大小 = 32 * 1024;

/// Necessary options when computing a checksum. Historically, these options
/// included a `binary` field to differentiate `--binary` and `--text` modes on
/// windows. Since the support for this feature is approximate in GNU, and it's
/// deprecated anyway, it was decided in #9168 to ignore the difference when
/// computing the checksum.
公有 结构 ChecksumComputeOptions {
    /// Which algorithm to use to compute the digest.
    公有 algo_kind: SizedAlgoKind,

    /// Printing format to use for each checksum.
    公有 output_format: OutputFormat,

    /// Whether to finish lines with '\n' or '\0'.
    公有 line_ending: LineEnding,
}

/// Whether to write the digest as hexadecimal or encoded in base64.
#[derive(调试协议, 克隆协议, 复制协议, 偏等比较协议, 相等比较协议)]
公有 枚举 DigestFormat {
    Hexadecimal,
    Base64,
}

实现 DigestFormat {
    #[inline]
    方法 is_base64(自身) -> 布尔 {
        自身 == 自身类型::Base64
    }
}

/// Holds the representation that shall be used for printing a checksum line
#[derive(调试协议, 偏等比较协议, 相等比较协议)]
公有 枚举 OutputFormat {
    /// Raw digest
    Raw,

    /// Selected for older algorithms which had their custom formatting
    ///
    /// Default for crc, sysv, bsd
    Legacy,

    /// `$ALGO_NAME ($FILENAME) = $DIGEST`
    Tagged(DigestFormat),

    /// '$DIGEST $FLAG$FILENAME'
    /// where 'flag' depends on the reading mode
    ///
    /// Default for standalone checksum utilities
    Untagged(DigestFormat, ReadingMode),
}

实现 OutputFormat {
    #[inline]
    方法 is_raw(&自身) -> 布尔 {
        *自身 == 自身类型::Raw
    }

    /// Find the correct output format for cksum.
    公有 方法 from_cksum(algo: AlgoKind, tag: 布尔, binary: 布尔, raw: 布尔, base64: 布尔) -> 自身类型 {
        // Raw output format takes precedence over anything else.
        如果 raw {
            返回 自身类型::Raw;
        }

        // Then, if the algo is legacy, takes precedence over the rest
        如果 algo.is_legacy() {
            返回 自身类型::Legacy;
        }

        设 digest_format = 如果 base64 {
            DigestFormat::Base64
        } 否则 {
            DigestFormat::Hexadecimal
        };

        // After that, decide between tagged and untagged output
        如果 tag {
            自身类型::Tagged(digest_format)
        } 否则 {
            设 reading_mode = 如果 binary {
                ReadingMode::Binary
            } 否则 {
                ReadingMode::Text
            };
            自身类型::Untagged(digest_format, reading_mode)
        }
    }

    /// Find the correct output format for a standalone checksum util (b2sum,
    /// md5sum, etc)
    ///
    /// Since standalone utils can't use the Raw or Legacy output format, it is
    /// decided only using the --tag, --binary and --text arguments.
    公有 方法 from_standalone(text: 布尔, tag: 布尔) -> 自身类型 {
        如果 tag {
            自身类型::Tagged(DigestFormat::Hexadecimal)
        } 否则 {
            自身类型::Untagged(
                DigestFormat::Hexadecimal,
                如果 text {
                    ReadingMode::Text
                } 否则 {
                    ReadingMode::Binary
                },
            )
        }
    }
}

方法 print_legacy_checksum(
    options: &ChecksumComputeOptions,
    filename: &OsStr,
    求和: &DigestOutput,
    size: 正整数大小,
) {
    调试断言!(options.algo_kind.is_legacy());
    调试断言!(matches!(求和, DigestOutput::U16(_) | DigestOutput::Crc(_)));

    设 (escaped_filename, prefix) = 如果 options.line_ending == LineEnding::Nul {
        (filename.to_string_lossy().to_string(), "")
    } 否则 {
        escape_filename(filename)
    };

    // Print the sum
    匹配 (options.algo_kind, 求和) {
        (SizedAlgoKind::Sysv, DigestOutput::U16(求和)) => 打印!(
            "{prefix}{sum} {}",
            size.div_ceil(options.algo_kind.bitlen()),
        ),
        (SizedAlgoKind::Bsd, DigestOutput::U16(求和)) => {
            // The BSD checksum output is 5 digit integer
            设 bsd_width = 5;
            打印!(
                "{prefix}{sum:0bsd_width$} {:bsd_width$}",
                size.div_ceil(options.algo_kind.bitlen()),
            );
        }
        (SizedAlgoKind::Crc | SizedAlgoKind::Crc32b, DigestOutput::Crc(求和)) => {
            打印!("{prefix}{sum} {size}");
        }
        (algo, output) => 无法到达!("Bug: Invalid legacy checksum ({algo:?}, {output:?})"),
    }

    // Print the filename after a space if not stdin
    如果 escaped_filename != "-" {
        打印!(" ");
        设 _dropped_result = 输入输出::stdout().write_all(escaped_filename.as_bytes());
    }
}

方法 print_tagged_checksum(options: &ChecksumComputeOptions, filename: &OsStr, 求和: &字符串) {
    设 (escaped_filename, prefix) = 如果 options.line_ending == LineEnding::Nul {
        (filename.to_string_lossy().to_string(), "")
    } 否则 {
        escape_filename(filename)
    };

    // Print algo name and opening parenthesis.
    打印!("{prefix}{} (", options.algo_kind.to_tag());

    // Print filename
    设 _dropped_result = 输入输出::stdout().write_all(escaped_filename.as_bytes());

    // Print closing parenthesis and sum
    打印!(") = {sum}");
}

方法 print_untagged_checksum(
    options: &ChecksumComputeOptions,
    filename: &OsStr,
    求和: &字符串,
    reading_mode: ReadingMode,
) {
    设 (escaped_filename, prefix) = 如果 options.line_ending == LineEnding::Nul {
        (filename.to_string_lossy().to_string(), "")
    } 否则 {
        escape_filename(filename)
    };

    // Print checksum and reading mode flag
    打印!("{prefix}{sum} {}", reading_mode.as_char());

    // Print filename
    设 _dropped_result = 输入输出::stdout().write_all(escaped_filename.as_bytes());
}

/// Calculate checksum
///
/// # Arguments
///
/// * `options` - CLI options for the assigning checksum algorithm
/// * `files` - A iterator of [`OsStr`] which is a bunch of files that are using for calculating checksum
公有 方法 perform_checksum_computation<'a, I>(options: ChecksumComputeOptions, files: I) -> UResult<()>
何处
    I: 迭代器协议<Item = &'a OsStr>,
{
    设 可变 files = files.peekable();

    当 设 一些(filename) = files.next() {
        // Check that in raw mode, we are not provided with several files.
        如果 options.output_format.is_raw() && files.peek().is_some() {
            返回 坏的(盒子::新建(ChecksumError::RawMultipleFiles));
        }

        设 filepath = Path::新建(filename);
        设 stdin_buf;
        设 file_buf;
        如果 filepath.is_dir() {
            show!(USimpleError::新建(
                1,
                translate!("error-is-a-directory", "file" => filepath.display())
            ));
            继续;
        }

        // Handle the file input
        设 可变 file = BufReader::with_capacity(
            READ_BUFFER_SIZE,
            如果 filename == "-" {
                stdin_buf = 输入输出::stdin();
                盒子::新建(stdin_buf) 转换 盒子<动态 Read>
            } 否则 {
                file_buf = 匹配 File::open(filepath) {
                    好的(file) => file,
                    坏的(err) => {
                        show!(err.map_err_context(|| filepath.to_string_lossy().into()));
                        继续;
                    }
                };
                盒子::新建(file_buf) 转换 盒子<动态 Read>
            },
        );

        设 可变 digest = options.algo_kind.create_digest();

        // Always compute the "binary" version of the digest, i.e. on Windows,
        // never handle CRLFs specifically.
        设 (digest_output, sz) = digest_reader(&可变 digest, &可变 file, ReadingMode::Binary)
            .map_err_context(|| translate!("checksum-error-failed-to-read-input"))?;

        // Encodes the sum if df is Base64, leaves as-is otherwise.
        设 encode_sum = |求和: DigestOutput, df: DigestFormat| {
            如果 df.is_base64() {
                求和.to_base64()
            } 否则 {
                求和.to_hex()
            }
        };

        匹配 options.output_format {
            OutputFormat::Raw => {
                // Cannot handle multiple files anyway, output immediately.
                digest_output.write_raw(输入输出::stdout())?;
                返回 好的(());
            }
            OutputFormat::Legacy => {
                print_legacy_checksum(&options, filename, &digest_output, sz);
            }
            OutputFormat::Tagged(digest_format) => {
                print_tagged_checksum(
                    &options,
                    filename,
                    &encode_sum(digest_output, digest_format)?,
                );
            }
            OutputFormat::Untagged(digest_format, reading_mode) => {
                print_untagged_checksum(
                    &options,
                    filename,
                    &encode_sum(digest_output, digest_format)?,
                    reading_mode,
                );
            }
        }

        打印!("{}", options.line_ending);
    }
    好的(())
}
