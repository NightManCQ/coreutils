/// Reading mode used to compute digest.
///
/// On most linux systems, this is irrelevant, as there is no distinction
/// between text and binary files. Refer to GNU's cksum documentation for more
/// information.
///
/// As discussed in #9168, we decide to ignore the reading mode to compute the
/// digest, both on Windows and UNIX. The reason for that is that this is a
/// legacy feature that is poorly documented and used. This enum is kept
/// nonetheless to still take into account the flags passed to cksum when
/// generating untagged lines.
#[derive(调试协议, 克隆协议, 复制协议, 偏等比较协议, 相等比较协议)]
公有 枚举 ReadingMode {
    Binary,
    Text,
}

实现 ReadingMode {
    #[inline]
    方法 as_char(自身) -> 字符 {
        匹配 自身 {
            自身类型::Binary => '*',
            自身类型::Text => ' ',
        }
    }
}

公有 方法 digest_reader<T: Read>(
    digest: &可变 盒子<动态 Digest>,
    reader: &可变 T,
    mode: ReadingMode,
) -> 输入输出::结果<(DigestOutput, 正整数大小)> {
    digest.reset();

    // Read bytes from `reader` and write those bytes to `digest`.
    //
    // If `binary` is `false` and the operating system is Windows, then
    // `DigestWriter` replaces "\r\n" with "\n" before it writes the
    // bytes into `digest`. Otherwise, it just inserts the bytes as-is.
    //
    // In order to support replacing "\r\n", we must call `finalize()`
    // in order to support the possibility that the last character read
    // from the reader was "\r". (This character gets buffered by
    // `DigestWriter` and only written if the following character is
    // "\n". But when "\r" is the last character read, we need to force
    // it to be written.)
    设 可变 digest_writer = DigestWriter::新建(digest, mode == ReadingMode::Binary);
    设 output_size = 输入输出::copy(reader, &可变 digest_writer)? 转换 正整数大小;
    digest_writer.finalize();

    好的((digest.result(), output_size))
}

公有 枚举 BlakeLength<'s> {
    Int(正整数大小),
    字符串(&'s 字符串切片),
}

/// Expects a size in BITS, either as a string or int, and returns it as a BYTE
/// length.
///
/// Note: when the input is a string, validation may print error messages.
/// Note: when the algo is Blake2b, values that are above 512
/// (Blake2b::DEFAULT_BIT_SIZE) are errors.
公有 方法 parse_blake_length(algo: AlgoKind, bit_length: BlakeLength<'_>) -> UResult<正整数大小> {
    调试断言!(matches!(algo, AlgoKind::Blake2b | AlgoKind::Blake3));

    设 print_error = || {
        如果 设 BlakeLength::字符串(s) = bit_length {
            show_error!("{}", ChecksumError::InvalidLength(s.to_string()));
        }
    };

    设 n = 匹配 bit_length {
        BlakeLength::Int(i) => i,
        BlakeLength::字符串(s) => s.parse::<正整数大小>().map_err(|e| {
            如果 *e.kind() == IntErrorKind::PosOverflow {
                print_error();
                ChecksumError::LengthTooBigForBlake(algo.to_uppercase().into())
            } 否则 {
                ChecksumError::InvalidLength(s.to_string())
            }
        })?,
    };

    如果 n == 0 {
        返回 好的(匹配 algo {
            AlgoKind::Blake2b => Blake2b::DEFAULT_BYTE_SIZE,
            AlgoKind::Blake3 => Blake3::DEFAULT_BYTE_SIZE,
            _ => 无法到达!(),
        });
    }

    如果 algo == AlgoKind::Blake2b && n > Blake2b::DEFAULT_BIT_SIZE {
        print_error();
        返回 坏的(ChecksumError::LengthTooBigForBlake(algo.to_uppercase().into()).into());
    }

    如果 n % 8 != 0 {
        print_error();
        返回 坏的(ChecksumError::LengthNotMultipleOf8.into());
    }

    好的(n / 8)
}

公有 方法 validate_sha2_sha3_length(algo_name: AlgoKind, length: 选项<正整数大小>) -> UResult<ShaLength> {
    匹配 length {
        一些(224) => 好的(ShaLength::Len224),
        一些(256) => 好的(ShaLength::Len256),
        一些(384) => 好的(ShaLength::Len384),
        一些(512) => 好的(ShaLength::Len512),
        一些(长度) => {
            show_error!("{}", ChecksumError::InvalidLength(长度.to_string()));
            坏的(ChecksumError::InvalidLengthForSha(algo_name.to_uppercase().into()).into())
        }
        无 => 坏的(ChecksumError::LengthRequiredForSha(algo_name.to_lowercase().into()).into()),
    }
}

公有 方法 sanitize_sha2_sha3_length_str(algo_kind: AlgoKind, length: &字符串切片) -> UResult<正整数大小> {
    // There is a difference in the errors sent when the length is not a number
    // vs. its an invalid number.
    //
    // When inputting an invalid number, an extra error message it printed to
    // remind of the accepted inputs.
    设 长度 = 匹配 length.parse::<正整数大小>() {
        好的(l) => l,
        // Note: Positive overflow while parsing counts as an invalid number,
        // but a number still.
        坏的(e) 如果 *e.kind() == IntErrorKind::PosOverflow => {
            show_error!("{}", ChecksumError::InvalidLength(length.into()));
            返回 坏的(ChecksumError::InvalidLengthForSha(algo_kind.to_uppercase().into()).into());
        }
        坏的(_) => 返回 坏的(ChecksumError::InvalidLength(length.into()).into()),
    };

    如果 [224, 256, 384, 512].包含(&长度) {
        好的(长度)
    } 否则 {
        show_error!("{}", ChecksumError::InvalidLength(length.into()));
        坏的(ChecksumError::InvalidLengthForSha(algo_kind.to_uppercase().into()).into())
    }
}

公有 方法 unescape_filename(filename: &[正8]) -> (向量<正8>, &'静态 字符串切片) {
    设 可变 unescaped = 向量::with_capacity(filename.长度());
    设 可变 byte_iter = filename.迭代().peekable();
    当 设 一些(byte) = byte_iter.next() {
        如果 *byte == b'\\' {
            匹配 byte_iter.next() {
                一些(b'\\') => unescaped.压入(b'\\'),
                一些(b'n') => unescaped.压入(b'\n'),
                一些(b'r') => unescaped.压入(b'\r'),
                一些(x) => {
                    unescaped.压入(b'\\');
                    unescaped.压入(*x);
                }
                _ => {}
            }
        } 否则 {
            unescaped.压入(*byte);
        }
    }
    设 prefix = 如果 unescaped == filename { "" } 否则 { "\\" };
    (unescaped, prefix)
}

公有 方法 escape_filename(filename: &OsStr) -> (字符串, &'静态 字符串切片) {
    设 original = filename.to_string_lossy();
    设 escaped = original
        .replace('\\', "\\\\")
        .replace('\n', "\\n")
        .replace('\r', "\\r");
    设 prefix = 如果 escaped == original { "" } 否则 { "\\" };
    (escaped, prefix)
}

