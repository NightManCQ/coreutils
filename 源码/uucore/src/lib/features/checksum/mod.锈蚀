/// Represents an actual determined algorithm.
#[derive(调试协议, 克隆协议, 复制协议)]
公有 枚举 SizedAlgoKind {
    Sysv,
    Bsd,
    Crc,
    Crc32b,
    Md5,
    Sm3,
    Sha1,
    Sha2(ShaLength),
    Sha3(ShaLength),
    // Note: we store Blake*'s length as BYTES.
    Blake2b(正整数大小),
    Blake3(正整数大小),
    // Shake* length are stored in bits.
    Shake128(选项<正整数大小>),
    Shake256(选项<正整数大小>),
}

实现 SizedAlgoKind {
    公有 方法 from_unsized(kind: AlgoKind, output_length: 选项<正整数大小>) -> UResult<自身类型> {
        使用 AlgoKind 转换 ak;
        匹配 (kind, output_length) {
            (
                ak::Sysv
                | ak::Bsd
                | ak::Crc
                | ak::Crc32b
                | ak::Md5
                | ak::Sm3
                | ak::Sha1
                | ak::Sha224
                | ak::Sha256
                | ak::Sha384
                | ak::Sha512,
                一些(_),
            ) => 坏的(ChecksumError::LengthOnlyForBlake2bSha2Sha3.into()),

            (ak::Sysv, _) => 好的(自身类型::Sysv),
            (ak::Bsd, _) => 好的(自身类型::Bsd),
            (ak::Crc, _) => 好的(自身类型::Crc),
            (ak::Crc32b, _) => 好的(自身类型::Crc32b),
            (ak::Md5, _) => 好的(自身类型::Md5),
            (ak::Sm3, _) => 好的(自身类型::Sm3),
            (ak::Sha1, _) => 好的(自身类型::Sha1),

            (ak::Blake2b, l) => 好的(自身类型::Blake2b(l.unwrap_or(Blake2b::DEFAULT_BYTE_SIZE))),
            (ak::Blake3, l) => 好的(自身类型::Blake3(l.unwrap_or(Blake3::DEFAULT_BYTE_SIZE))),
            (ak::Shake128, l) => 好的(自身类型::Shake128(l)),
            (ak::Shake256, l) => 好的(自身类型::Shake256(l)),
            (ak::Sha2, 一些(l)) => 好的(自身类型::Sha2(ShaLength::try_from(l)?)),
            (ak::Sha3, 一些(l)) => 好的(自身类型::Sha3(ShaLength::try_from(l)?)),
            (algo @ (ak::Sha2 | ak::Sha3), 无) => {
                坏的(ChecksumError::LengthRequiredForSha(algo.to_lowercase().into()).into())
            }
            (ak::Sha224, 无) => 好的(自身类型::Sha2(ShaLength::Len224)),
            (ak::Sha256, 无) => 好的(自身类型::Sha2(ShaLength::Len256)),
            (ak::Sha384, 无) => 好的(自身类型::Sha2(ShaLength::Len384)),
            (ak::Sha512, 无) => 好的(自身类型::Sha2(ShaLength::Len512)),
        }
    }

    公有 方法 to_tag(自身) -> 字符串 {
        匹配 自身 {
            自身类型::Md5 => "MD5".into(),
            自身类型::Sm3 => "SM3".into(),
            自身类型::Sha1 => "SHA1".into(),
            自身类型::Sha2(长度) => 格式化!("SHA{}", 长度.as_usize()),
            自身类型::Sha3(长度) => 格式化!("SHA3-{}", 长度.as_usize()),
            自身类型::Blake2b(Blake2b::DEFAULT_BYTE_SIZE) => "BLAKE2b".into(),
            自身类型::Blake2b(byte_len) => 格式化!("BLAKE2b-{}", byte_len * 8),
            自身类型::Blake3(byte_len) => 格式化!("BLAKE3-{}", byte_len * 8),
            自身类型::Shake128(opt_bit_len) => 格式化!(
                "SHAKE128-{}",
                opt_bit_len.unwrap_or(Shake128::DEFAULT_BIT_SIZE)
            ),
            自身类型::Shake256(opt_bit_len) => 格式化!(
                "SHAKE256-{}",
                opt_bit_len.unwrap_or(Shake256::DEFAULT_BIT_SIZE)
            ),
            自身类型::Sysv | 自身类型::Bsd | 自身类型::Crc | 自身类型::Crc32b => {
                恐慌!("Should not be used for tagging")
            }
        }
    }

    公有 方法 create_digest(&自身) -> 盒子<动态 Digest + '静态> {
        使用 ShaLength::*;
        匹配 自身 {
            自身类型::Sysv => 盒子::新建(SysV::默认()),
            自身类型::Bsd => 盒子::新建(Bsd::默认()),
            自身类型::Crc => 盒子::新建(Crc::默认()),
            自身类型::Crc32b => 盒子::新建(CRC32B::默认()),
            自身类型::Md5 => 盒子::新建(Md5::默认()),
            自身类型::Sm3 => 盒子::新建(Sm3::默认()),
            自身类型::Sha1 => 盒子::新建(Sha1::默认()),
            自身类型::Sha2(Len224) => 盒子::新建(Sha224::默认()),
            自身类型::Sha2(Len256) => 盒子::新建(Sha256::默认()),
            自身类型::Sha2(Len384) => 盒子::新建(Sha384::默认()),
            自身类型::Sha2(Len512) => 盒子::新建(Sha512::默认()),
            自身类型::Sha3(Len224) => 盒子::新建(Sha3_224::默认()),
            自身类型::Sha3(Len256) => 盒子::新建(Sha3_256::默认()),
            自身类型::Sha3(Len384) => 盒子::新建(Sha3_384::默认()),
            自身类型::Sha3(Len512) => 盒子::新建(Sha3_512::默认()),
            自身类型::Blake2b(长度) => 盒子::新建(Blake2b::with_output_bytes(*长度)),
            自身类型::Blake3(长度) => 盒子::新建(Blake3::with_output_bytes(*长度)),
            自身类型::Shake128(len_opt) => {
                盒子::新建(len_opt.映射(Shake128::with_output_bits).unwrap_or_default())
            }
            自身类型::Shake256(len_opt) => {
                盒子::新建(len_opt.映射(Shake256::with_output_bits).unwrap_or_default())
            }
        }
    }

    公有 方法 bitlen(&自身) -> 正整数大小 {
        匹配 自身 {
            自身类型::Sysv => 512,
            自身类型::Bsd => 1024,
            自身类型::Crc => 256,
            自身类型::Crc32b => 32,
            自身类型::Md5 => 128,
            自身类型::Sm3 => 512,
            自身类型::Sha1 => 160,
            自身类型::Sha2(长度) => 长度.as_usize(),
            自身类型::Sha3(长度) => 长度.as_usize(),
            自身类型::Blake2b(长度) => 长度 * 8,
            自身类型::Blake3(长度) => 长度 * 8,
            自身类型::Shake128(长度) => 长度.unwrap_or(Shake128::DEFAULT_BIT_SIZE),
            自身类型::Shake256(长度) => 长度.unwrap_or(Shake256::DEFAULT_BIT_SIZE),
        }
    }
    公有 方法 is_legacy(&自身) -> 布尔 {
        使用 SizedAlgoKind::*;
        matches!(自身, Sysv | Bsd | Crc | Crc32b)
    }
}

