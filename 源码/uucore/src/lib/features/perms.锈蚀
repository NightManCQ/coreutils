/// Determines symbolic link traversal and recursion settings based on flags.
/// Returns the updated `dereference` and `traverse_symlinks` values.
公有 方法 configure_symlink_and_recursion(
    matches: &ArgMatches,
    default_traverse_symlinks: TraverseSymlinks,
) -> 结果<(布尔, 布尔, TraverseSymlinks), 盒子<动态 箱::错误::UError>> {
    设 可变 dereference = 如果 matches.get_flag(options::dereference::DEREFERENCE) {
        一些(真) // Follow symlinks
    } 否则 如果 matches.get_flag(options::dereference::NO_DEREFERENCE) {
        一些(假) // Do not follow symlinks
    } 否则 {
        无 // Default behavior
    };

    设 可变 traverse_symlinks = 如果 matches.get_flag("L") {
        TraverseSymlinks::All
    } 否则 如果 matches.get_flag("H") {
        TraverseSymlinks::First
    } 否则 如果 matches.get_flag("P") {
        TraverseSymlinks::无
    } 否则 {
        default_traverse_symlinks
    };

    设 recursive = matches.get_flag(options::RECURSIVE);
    如果 recursive {
        如果 traverse_symlinks == TraverseSymlinks::无 {
            如果 dereference == 一些(真) {
                返回 坏的(USimpleError::新建(1, "-R --dereference requires -H or -L"));
            }
            dereference = 一些(假);
        }
    } 否则 {
        traverse_symlinks = TraverseSymlinks::无;
    }

    好的((recursive, dereference.unwrap_or(真), traverse_symlinks))
}

/// Base implementation for `chgrp` and `chown`.
///
/// An argument called `add_arg_if_not_reference` will be added to `command` if
/// `args` does not contain the `--reference` option.
/// `parse_gid_uid_and_filter` will be called to obtain the target gid and uid, and the filter,
/// from `ArgMatches`.
/// `groups_only` determines whether verbose output will only mention the group.
#[allow(clippy::cognitive_complexity)]
公有 方法 chown_base(
    可变 command: Command,
    args: 实现 箱::Args,
    add_arg_if_not_reference: &'静态 字符串切片,
    parse_gid_uid_and_filter: GidUidFilterOwnerParser,
    groups_only: 布尔,
) -> UResult<()> {
    设 args: 向量<_> = args.收集();
    设 可变 reference = 假;
    设 可变 help = 假;
    // stop processing options on --
    循环 arg 在 args.迭代().take_while(|s| *s != "--") {
        如果 arg.to_string_lossy().starts_with("--reference=") || arg == "--reference" {
            reference = 真;
        } 否则 如果 arg == "--help" {
            // we stop processing once we see --help,
            // as it doesn't matter if we've seen reference or not
            help = 真;
            中断;
        }
    }

    如果 help || !reference {
        // add both positional arguments
        // arg_group is only required if
        command = command.arg(
            Arg::新建(add_arg_if_not_reference)
                .value_name(add_arg_if_not_reference)
                .required(真),
        );
    }
    command = command.arg(
        Arg::新建(options::ARG_FILES)
            .value_name(options::ARG_FILES)
            .value_hint(clap::ValueHint::FilePath)
            .action(clap::ArgAction::Append)
            .required(真)
            .num_args(1..)
            .value_parser(clap::value_parser!(OsString)),
    );
    设 matches = 箱::clap_localization::handle_clap_result(command, args)?;

    设 files: 向量<OsString> = matches
        .get_many::<OsString>(options::ARG_FILES)
        .映射(|v| v.cloned().收集())
        .unwrap_or_default();

    设 preserve_root = matches.get_flag(options::preserve_root::PRESERVE);
    设 (recursive, dereference, traverse_symlinks) =
        configure_symlink_and_recursion(&matches, TraverseSymlinks::无)?;

    设 verbosity_level = 如果 matches.get_flag(options::verbosity::CHANGES) {
        VerbosityLevel::Changes
    } 否则 如果 matches.get_flag(options::verbosity::SILENT)
        || matches.get_flag(options::verbosity::QUIET)
    {
        VerbosityLevel::Silent
    } 否则 如果 matches.get_flag(options::verbosity::VERBOSE) {
        VerbosityLevel::Verbose
    } 否则 {
        VerbosityLevel::Normal
    };
    设 GidUidOwnerFilter {
        dest_gid,
        dest_uid,
        raw_owner,
        过滤,
    } = parse_gid_uid_and_filter(&matches)?;

    设 executor = ChownExecutor {
        traverse_symlinks,
        dest_gid,
        dest_uid,
        raw_owner,
        verbosity: Verbosity {
            groups_only,
            level: verbosity_level,
        },
        recursive,
        dereference,
        preserve_root,
        files,
        过滤,
    };
    executor.exec()
}

