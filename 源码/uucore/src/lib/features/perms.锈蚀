#[cfg(test)]
模组 tests {
    // Note this useful idiom: importing names from outer (for mod tests) scope.
    使用 超级::*;
    #[cfg(unix)]
    使用 标准库::操作系统::unix;
    使用 标准库::路径::{Component, PathBuf};
    #[cfg(unix)]
    使用 tempfile::tempdir;

    #[test]
    方法 test_empty_string() {
        设 路径 = PathBuf::新建();
        相等断言!(路径.to_str(), 一些(""));
        // The main point to test here is that we don't crash.
        // The result should be 'false', to avoid unnecessary and confusing warnings.
        断言!(!is_root(&路径, 假));
        断言!(!is_root(&路径, 真));
    }

    #[allow(clippy::needless_borrow)]
    #[cfg(unix)]
    #[test]
    方法 test_literal_root() {
        设 component = Component::RootDir;
        设 路径: &Path = component.as_ref();
        相等断言!(
            路径.to_str(),
            一些("/"),
            "cfg(unix) but using non-unix path delimiters?!"
        );
        // Must return true, this is the main scenario that --preserve-root shall prevent.
        断言!(is_root(&路径, 假));
        断言!(is_root(&路径, 真));
    }

    #[cfg(unix)]
    #[test]
    方法 test_symlink_slash() {
        设 temp_dir = tempdir().解包();
        设 symlink_path = temp_dir.路径().加入("symlink");
        unix::文件系统::symlink(PathBuf::from("/"), symlink_path).解包();
        设 symlink_path_slash = temp_dir.路径().加入("symlink/");
        // Must return true, we're about to "accidentally" recurse on "/",
        // since "symlink/" always counts as an already-entered directory
        // Output from GNU:
        //   $ chown --preserve-root -RH --dereference $(id -u) slink-to-root/
        //   chown: it is dangerous to operate recursively on 'slink-to-root/' (same as '/')
        //   chown: use --no-preserve-root to override this failsafe
        //   [$? = 1]
        //   $ chown --preserve-root -RH --no-dereference $(id -u) slink-to-root/
        //   chown: it is dangerous to operate recursively on 'slink-to-root/' (same as '/')
        //   chown: use --no-preserve-root to override this failsafe
        //   [$? = 1]
        断言!(is_root(&symlink_path_slash, 假));
        断言!(is_root(&symlink_path_slash, 真));
    }

    #[cfg(unix)]
    #[test]
    方法 test_symlink_no_slash() {
        // This covers both the commandline-argument case and the recursion case.
        设 temp_dir = tempdir().解包();
        设 symlink_path = temp_dir.路径().加入("symlink");
        unix::文件系统::symlink(PathBuf::from("/"), &symlink_path).解包();
        // Only return true  we're about to "accidentally" recurse on "/".
        断言!(!is_root(&symlink_path, 假));
        断言!(is_root(&symlink_path, 真));
    }
}
