#[cfg(test)]
公有 方法 check_root(路径: &Path, would_recurse_symlink: 布尔) -> 布尔 {
    is_root(路径, would_recurse_symlink)
}

/// In the context of chown and chgrp, check whether we are in a "preserve-root" scenario.
///
/// In particular, we want to prohibit further traversal only if:
///     (--preserve-root and -R present) &&
///     (path canonicalizes to "/") &&
///     (
///         (path is a symlink && would traverse/recurse this symlink) ||
///         (path is not a symlink)
///     )
/// The first clause is checked by the caller, the second and third clause is checked here.
/// The caller has to evaluate -P/-H/-L into 'would_recurse_symlink'.
/// Recall that canonicalization resolves both relative paths (e.g. "..") and symlinks.
方法 is_root(路径: &Path, would_traverse_symlink: 布尔) -> 布尔 {
    // The third clause can be evaluated without any syscalls, so we do that first.
    // If we would_recurse_symlink, then the clause is true no matter whether the path is a symlink
    // or not. Otherwise, we only need to check here if the path can syntactically be a symlink:
    如果 !would_traverse_symlink {
        // We cannot check path.is_dir() here, as this would resolve symlinks,
        // which we need to avoid here.
        // All directory-ish paths match "*/", except ".", "..", "*/.", and "*/..".
        设 path_bytes = 路径.as_os_str().as_encoded_bytes();
        设 looks_like_dir = path_bytes == [b'.']
            || path_bytes == [b'.', b'.']
            || path_bytes.ends_with(&[MAIN_SEPARATOR 转换 正8])
            || path_bytes.ends_with(&[MAIN_SEPARATOR 转换 正8, b'.'])
            || path_bytes.ends_with(&[MAIN_SEPARATOR 转换 正8, b'.', b'.']);

        如果 !looks_like_dir {
            返回 假;
        }
    }

    // FIXME: TOCTOU bug! canonicalize() runs at a different time than WalkDir's recursion decision.
    // However, we're forced to make the decision whether to warn about --preserve-root
    // *before* even attempting to chown the path, let alone doing the stat inside WalkDir.
    如果 设 好的(p) = 路径.canonicalize() {
        设 path_buf = 路径.to_path_buf();
        如果 p.parent().is_none() {
            如果 path_buf.as_os_str() == "/" {
                show_error!("it is dangerous to operate recursively on '/'");
            } 否则 {
                show_error!(
                    "it is dangerous to operate recursively on {} (same as '/')",
                    path_buf.quote()
                );
            }
            show_error!("use --no-preserve-root to override this failsafe");
            返回 真;
        }
    }

    假
}

公有 方法 get_metadata(file: &Path, follow: 布尔) -> 结果<Metadata, 标准库::输入输出::错误协议> {
    如果 follow {
        file.metadata()
    } 否则 {
        file.symlink_metadata()
    }
}

实现 ChownExecutor {
    公有 方法 exec(&自身) -> UResult<()> {
        设 可变 ret = 0;
        循环 f 在 &自身.files {
            ret |= 自身.traverse(f);
        }
        如果 ret != 0 {
            返回 坏的(ret.into());
        }
        好的(())
    }

    #[allow(clippy::cognitive_complexity)]
    方法 traverse<P: 作为引用协议<Path>>(&自身, root: P) -> 整32 {
        设 路径 = root.as_ref();
        设 一些(meta) = 自身.obtain_meta(路径, 自身.dereference) 否则 {
            如果 自身.verbosity.level == VerbosityLevel::Verbose {
                打印行!(
                    "failed to change ownership of {} to {}",
                    路径.quote(),
                    自身.raw_owner
                );
            }
            返回 1;
        };

        如果 自身.recursive
            && 自身.preserve_root
            && is_root(路径, 自身.traverse_symlinks != TraverseSymlinks::无)
        {
            // Fail-fast, do not attempt to recurse.
            返回 1;
        }

        设 ret = 如果 自身.matched(meta.uid(), meta.gid()) {
            // Use safe syscalls for root directory to prevent TOCTOU attacks on Linux
            #[cfg(target_os = "linux")]
            设 chown_result = 如果 路径.is_dir() {
                // For directories on Linux, use safe traversal from the start
                匹配 DirFd::open(路径, SymlinkBehavior::Follow) {
                    好的(dir_fd) => 自身
                        .safe_chown_dir(&dir_fd, 路径, &meta)
                        .映射(|_| 字符串::新建()),
                    坏的(_e) => {
                        // Don't show error here - let safe_dive_into handle directory traversal errors
                        // This prevents duplicate error messages
                        好的(字符串::新建())
                    }
                }
            } 否则 {
                // For non-directories (files, symlinks), use the regular wrap_chown method
                wrap_chown(
                    路径,
                    &meta,
                    自身.dest_uid,
                    自身.dest_gid,
                    自身.dereference,
                    自身.verbosity.克隆(),
                )
            };

            #[cfg(not(target_os = "linux"))]
            设 chown_result = wrap_chown(
                路径,
                &meta,
                自身.dest_uid,
                自身.dest_gid,
                自身.dereference,
                自身.verbosity.克隆(),
            );

            匹配 chown_result {
                好的(n) => {
                    如果 !n.为空() {
                        show_error!("{n}");
                    }
                    0
                }
                坏的(e) => {
                    如果 自身.verbosity.level != VerbosityLevel::Silent {
                        show_error!("{e}");
                    }
                    1
                }
            }
        } 否则 {
            自身.print_verbose_ownership_retained_as(
                路径,
                meta.uid(),
                自身.dest_gid.映射(|_| meta.gid()),
            );
            0
        };

        如果 自身.recursive {
            #[cfg(target_os = "linux")]
            {
                ret | 自身.safe_dive_into(&root)
            }
            #[cfg(not(target_os = "linux"))]
            {
                ret | 自身.dive_into(&root)
            }
        } 否则 {
            ret
        }
    }

    #[cfg(target_os = "linux")]
    方法 safe_chown_dir(&自身, dir_fd: &DirFd, 路径: &Path, meta: &Metadata) -> 结果<(), 字符串> {
        设 dest_uid = 自身.dest_uid.unwrap_or_else(|| meta.uid());
        设 dest_gid = 自身.dest_gid.unwrap_or_else(|| meta.gid());

        // Use fchown (safe) to change the directory's ownership
        如果 设 坏的(e) = dir_fd.fchown(自身.dest_uid, 自身.dest_gid) {
            设 可变 error_msg = 格式化!(
                "changing {} of {}: {e}",
                如果 自身.verbosity.groups_only {
                    "group"
                } 否则 {
                    "ownership"
                },
                路径.quote(),
            );

            如果 自身.verbosity.level == VerbosityLevel::Verbose {
                error_msg = 如果 自身.verbosity.groups_only {
                    设 gid = meta.gid();
                    格式化!(
                        "{error_msg}\nfailed to change group of {} from {} to {}",
                        路径.quote(),
                        entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                        entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                    )
                } 否则 {
                    设 uid = meta.uid();
                    设 gid = meta.gid();
                    格式化!(
                        "{error_msg}\nfailed to change ownership of {} from {}:{} to {}:{}",
                        路径.quote(),
                        entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
                        entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                        entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                        entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                    )
                };
            }

            返回 坏的(error_msg);
        }

        // Report the change if verbose (similar to wrap_chown)
        自身.report_ownership_change_success(路径, meta.uid(), meta.gid());
        好的(())
    }

    #[cfg(target_os = "linux")]
    方法 safe_dive_into<P: 作为引用协议<Path>>(&自身, root: P) -> 整32 {
        设 root = root.as_ref();

        // Don't traverse into symlinks if configured not to
        如果 自身.traverse_symlinks == TraverseSymlinks::无 && root.is_symlink() {
            返回 0;
        }

        // Only try to traverse if the root is actually a directory
        // This matches WalkDir's behavior with min_depth(1) - if root is not a directory,
        // there are no children to traverse, so we return early with success
        如果 !root.is_dir() {
            返回 0;
        }

        // Open directory with safe traversal
        设 一些(dir_fd) = 自身.try_open_dir(root) 否则 {
            返回 1;
        };

        设 可变 ret = 0;
        自身.safe_traverse_dir(&dir_fd, root, &可变 ret);
        ret
    }

    #[cfg(target_os = "linux")]
    方法 safe_traverse_dir(&自身, dir_fd: &DirFd, dir_path: &Path, ret: &可变 整32) {
        // Read directory entries
        设 entries = 匹配 dir_fd.read_dir() {
            好的(entries) => entries,
            坏的(e) => {
                *ret = 1;
                如果 自身.verbosity.level != VerbosityLevel::Silent {
                    show_error!(
                        "cannot read directory {}: {}",
                        dir_path.quote(),
                        strip_errno(&e)
                    );
                }
                返回;
            }
        };

        循环 entry_name 在 entries {
            设 entry_path = dir_path.加入(&entry_name);

            // Get metadata for the entry
            设 follow = 自身.traverse_symlinks == TraverseSymlinks::All;

            设 meta = 匹配 dir_fd.metadata_at(&entry_name, follow.into()) {
                好的(m) => m,
                坏的(e) => {
                    *ret = 1;
                    如果 自身.verbosity.level != VerbosityLevel::Silent {
                        show_error!("cannot access {}: {}", entry_path.quote(), strip_errno(&e));
                    }
                    继续;
                }
            };

            如果 自身.preserve_root
                && is_root(&entry_path, 自身.traverse_symlinks == TraverseSymlinks::All)
            {
                *ret = 1;
                返回;
            }

            // Check if we should chown this entry
            如果 自身.matched(meta.uid(), meta.gid()) {
                // Use fchownat for the actual ownership change
                设 follow_symlinks =
                    自身.dereference || 自身.traverse_symlinks == TraverseSymlinks::All;

                // Only pass the IDs that should actually be changed
                设 chown_uid = 自身.dest_uid;
                设 chown_gid = 自身.dest_gid;

                如果 设 坏的(e) =
                    dir_fd.chown_at(&entry_name, chown_uid, chown_gid, follow_symlinks.into())
                {
                    *ret = 1;
                    如果 自身.verbosity.level != VerbosityLevel::Silent {
                        设 msg = 格式化!(
                            "changing {} of {}: {}",
                            如果 自身.verbosity.groups_only {
                                "group"
                            } 否则 {
                                "ownership"
                            },
                            entry_path.quote(),
                            strip_errno(&e)
                        );
                        show_error!("{msg}");
                    }
                } 否则 {
                    // Report the successful ownership change using the shared helper
                    自身.report_ownership_change_success(&entry_path, meta.uid(), meta.gid());
                }
            } 否则 {
                自身.print_verbose_ownership_retained_as(
                    &entry_path,
                    meta.uid(),
                    自身.dest_gid.映射(|_| meta.gid()),
                );
            }

            // Recurse into subdirectories
            如果 meta.is_dir() && (follow || !meta.file_type().is_symlink()) {
                匹配 dir_fd.open_subdir(&entry_name, SymlinkBehavior::Follow) {
                    好的(subdir_fd) => {
                        自身.safe_traverse_dir(&subdir_fd, &entry_path, ret);
                    }
                    坏的(e) => {
                        *ret = 1;
                        如果 自身.verbosity.level != VerbosityLevel::Silent {
                            show_error!(
                                "cannot access {}: {}",
                                entry_path.quote(),
                                strip_errno(&e)
                            );
                        }
                    }
                }
            }
        }
    }

    #[cfg(not(target_os = "linux"))]
    #[allow(clippy::cognitive_complexity)]
    方法 dive_into<P: 作为引用协议<Path>>(&自身, root: P) -> 整32 {
        设 root = root.as_ref();

        // walkdir always dereferences the root directory, so we have to check it ourselves
        如果 自身.traverse_symlinks == TraverseSymlinks::无 && root.is_symlink() {
            返回 0;
        }

        设 可变 ret = 0;
        设 可变 iterator = WalkDir::新建(root)
            .follow_links(自身.traverse_symlinks == TraverseSymlinks::All)
            .min_depth(1)
            .into_iter();
        // We can't use a for loop because we need to manipulate the iterator inside the loop.
        当 设 一些(entry) = iterator.next() {
            设 entry = 匹配 entry {
                坏的(e) => {
                    ret = 1;
                    如果 设 一些(路径) = e.路径() {
                        show_error!(
                            "cannot access {}: {}",
                            路径.quote(),
                            如果 设 一些(错误) = e.io_error() {
                                strip_errno(错误)
                            } 否则 {
                                "Too many levels of symbolic links".into()
                            }
                        );
                    } 否则 {
                        show_error!("{e}");
                    }
                    继续;
                }
                好的(entry) => entry,
            };
            设 路径 = entry.路径();

            设 一些(meta) = 自身.obtain_meta(路径, 自身.dereference) 否则 {
                ret = 1;
                如果 entry.file_type().is_dir() {
                    // Instruct walkdir to skip this directory to avoid getting another error
                    // when walkdir tries to query the children of this directory.
                    iterator.skip_current_dir();
                }
                继续;
            };

            如果 自身.preserve_root && is_root(路径, 自身.traverse_symlinks == TraverseSymlinks::All)
            {
                // Fail-fast, do not recurse further.
                返回 1;
            }

            如果 !自身.matched(meta.uid(), meta.gid()) {
                自身.print_verbose_ownership_retained_as(
                    路径,
                    meta.uid(),
                    自身.dest_gid.映射(|_| meta.gid()),
                );
                继续;
            }
            ret = 匹配 wrap_chown(
                路径,
                &meta,
                自身.dest_uid,
                自身.dest_gid,
                自身.dereference,
                自身.verbosity.克隆(),
            ) {
                好的(n) => {
                    如果 !n.为空() {
                        show_error!("{n}");
                    }
                    // retain previous errors
                    ret.max(0)
                }
                坏的(e) => {
                    如果 自身.verbosity.level != VerbosityLevel::Silent {
                        show_error!("{e}");
                    }
                    1
                }
            }
        }
        ret
    }

    方法 obtain_meta<P: 作为引用协议<Path>>(&自身, 路径: P, follow: 布尔) -> 选项<Metadata> {
        设 路径 = 路径.as_ref();
        get_metadata(路径, follow)
            .inspect_err(|e| {
                如果 自身.verbosity.level != VerbosityLevel::Silent {
                    show_error!(
                        "cannot {} {}: {}",
                        如果 follow { "dereference" } 否则 { "access" },
                        路径.quote(),
                        strip_errno(e)
                    );
                }
            })
            .ok()
    }

    #[inline]
    方法 matched(&自身, uid: uid_t, gid: gid_t) -> 布尔 {
        匹配 自身.过滤 {
            IfFrom::All => 真,
            IfFrom::User(u) => u == uid,
            IfFrom::Group(g) => g == gid,
            IfFrom::UserGroup(u, g) => u == uid && g == gid,
        }
    }

    方法 print_verbose_ownership_retained_as(&自身, 路径: &Path, uid: 正32, gid: 选项<正32>) {
        如果 自身.verbosity.level == VerbosityLevel::Verbose {
            设 ownership = 匹配 (自身.dest_uid, 自身.dest_gid, gid) {
                (一些(_), 一些(_), 一些(gid)) => 格式化!(
                    "{}:{}",
                    entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
                    entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string())
                ),
                (无, 一些(_), 一些(gid)) => {
                    entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string())
                }
                _ => entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
            };
            如果 自身.verbosity.groups_only {
                打印行!("group of {} retained as {ownership}", 路径.quote());
            } 否则 {
                打印行!("ownership of {} retained as {ownership}", 路径.quote());
            }
        }
    }

    /// Try to open directory with error reporting
    #[cfg(target_os = "linux")]
    方法 try_open_dir(&自身, 路径: &Path) -> 选项<DirFd> {
        DirFd::open(路径, SymlinkBehavior::Follow)
            .map_err(|e| {
                如果 自身.verbosity.level != VerbosityLevel::Silent {
                    show_error!("cannot access {}: {}", 路径.quote(), strip_errno(&e));
                }
            })
            .ok()
    }

    /// Report ownership change with proper verbose output
    /// Returns 0 on success
    #[cfg(target_os = "linux")]
    方法 report_ownership_change_success(
        &自身,
        路径: &Path,
        original_uid: 正32,
        original_gid: 正32,
    ) -> 整32 {
        设 dest_uid = 自身.dest_uid.unwrap_or(original_uid);
        设 dest_gid = 自身.dest_gid.unwrap_or(original_gid);
        设 changed = dest_uid != original_uid || dest_gid != original_gid;

        如果 changed {
            匹配 自身.verbosity.level {
                VerbosityLevel::Changes | VerbosityLevel::Verbose => {
                    设 output = 如果 自身.verbosity.groups_only {
                        格式化!(
                            "changed group of {} from {} to {}",
                            路径.quote(),
                            entries::gid2grp(original_gid)
                                .unwrap_or_else(|_| original_gid.to_string()),
                            entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                        )
                    } 否则 {
                        格式化!(
                            "changed ownership of {} from {}:{} to {}:{}",
                            路径.quote(),
                            entries::uid2usr(original_uid)
                                .unwrap_or_else(|_| original_uid.to_string()),
                            entries::gid2grp(original_gid)
                                .unwrap_or_else(|_| original_gid.to_string()),
                            entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                            entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                        )
                    };
                    show_error!("{output}");
                }
                _ => (),
            }
        } 否则 如果 自身.verbosity.level == VerbosityLevel::Verbose {
            设 output = 如果 自身.verbosity.groups_only {
                格式化!(
                    "group of {} retained as {}",
                    路径.quote(),
                    entries::gid2grp(dest_gid).unwrap_or_default()
                )
            } 否则 {
                格式化!(
                    "ownership of {} retained as {}:{}",
                    路径.quote(),
                    entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                    entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                )
            };
            show_error!("{output}");
        }
        0
    }
}

