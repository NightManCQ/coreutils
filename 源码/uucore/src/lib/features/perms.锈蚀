/// Actually perform the change of owner on a path
方法 chown<P: 作为引用协议<Path>>(路径: P, uid: uid_t, gid: gid_t, follow: 布尔) -> IOResult<()> {
    设 路径 = 路径.as_ref();
    设 s = CString::新建(路径.as_os_str().as_bytes()).解包();
    设 ret = 不安全 {
        如果 follow {
            libc::chown(s.as_ptr(), uid, gid)
        } 否则 {
            libc::lchown(s.as_ptr(), uid, gid)
        }
    };
    如果 ret == 0 {
        好的(())
    } 否则 {
        坏的(IOError::last_os_error())
    }
}

/// Perform the change of owner on a path
/// with the various options
/// and error messages management
公有 方法 wrap_chown<P: 作为引用协议<Path>>(
    路径: P,
    meta: &Metadata,
    dest_uid: 选项<正32>,
    dest_gid: 选项<正32>,
    follow: 布尔,
    verbosity: Verbosity,
) -> 结果<字符串, 字符串> {
    设 dest_uid = dest_uid.unwrap_or_else(|| meta.uid());
    设 dest_gid = dest_gid.unwrap_or_else(|| meta.gid());
    设 路径 = 路径.as_ref();
    设 可变 out: 字符串 = 字符串::新建();

    如果 设 坏的(e) = chown(路径, dest_uid, dest_gid, follow) {
        匹配 verbosity.level {
            VerbosityLevel::Silent => (),
            level => {
                out = 格式化!(
                    "changing {} of {}: {e}",
                    如果 verbosity.groups_only {
                        "group"
                    } 否则 {
                        "ownership"
                    },
                    路径.quote(),
                );
                如果 level == VerbosityLevel::Verbose {
                    out = 如果 verbosity.groups_only {
                        设 gid = meta.gid();
                        格式化!(
                            "{out}\nfailed to change group of {} from {} to {}",
                            路径.quote(),
                            entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                            entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                        )
                    } 否则 {
                        设 uid = meta.uid();
                        设 gid = meta.gid();
                        格式化!(
                            "{out}\nfailed to change ownership of {} from {}:{} to {}:{}",
                            路径.quote(),
                            entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
                            entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                            entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                            entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                        )
                    };
                }
            }
        }
        返回 坏的(out);
    }

    设 changed = dest_uid != meta.uid() || dest_gid != meta.gid();
    如果 changed {
        匹配 verbosity.level {
            VerbosityLevel::Changes | VerbosityLevel::Verbose => {
                设 gid = meta.gid();
                out = 如果 verbosity.groups_only {
                    格式化!(
                        "changed group of {} from {} to {}",
                        路径.quote(),
                        entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                        entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                    )
                } 否则 {
                    设 gid = meta.gid();
                    设 uid = meta.uid();
                    格式化!(
                        "changed ownership of {} from {}:{} to {}:{}",
                        路径.quote(),
                        entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
                        entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string()),
                        entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                        entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
                    )
                };
            }
            _ => (),
        }
    } 否则 如果 verbosity.level == VerbosityLevel::Verbose {
        out = 如果 verbosity.groups_only {
            格式化!(
                "group of {} retained as {}",
                路径.quote(),
                entries::gid2grp(dest_gid).unwrap_or_default()
            )
        } 否则 {
            格式化!(
                "ownership of {} retained as {}:{}",
                路径.quote(),
                entries::uid2usr(dest_uid).unwrap_or_else(|_| dest_uid.to_string()),
                entries::gid2grp(dest_gid).unwrap_or_else(|_| dest_gid.to_string())
            )
        };
    }

    好的(out)
}

