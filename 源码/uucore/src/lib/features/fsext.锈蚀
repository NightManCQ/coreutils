#[cfg(unix)]
公有 方法 statfs(路径: &OsStr) -> 结果<StatFs, 字符串> {
    #[cfg(unix)]
    设 p = 路径.as_bytes();
    #[cfg(not(unix))]
    设 p = 路径.into_string().解包();

    匹配 CString::新建(p) {
        好的(p) => {
            设 可变 buffer: StatFs = 不安全 { 内存::zeroed() };
            不安全 {
                如果 statfs_fn(p.as_ptr(), &raw 可变 buffer) == 0 {
                    好的(buffer)
                } 否则 {
                    设 errno = IOError::last_os_error().raw_os_error().unwrap_or(0);
                    坏的(CStr::from_ptr(strerror(errno))
                        .to_str()
                        .map_err(|_| "Error message contains invalid UTF-8".to_owned())?
                        .to_owned())
                }
            }
        }
        坏的(e) => 坏的(e.to_string()),
    }
}

