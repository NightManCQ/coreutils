公有 方法 pretty_filetype(mode: mode_t, size: 正64) -> 字符串 {
    匹配 mode & S_IFMT {
        S_IFREG => {
            如果 size == 0 {
                "regular empty file"
            } 否则 {
                "regular file"
            }
        }
        S_IFDIR => "directory",
        S_IFLNK => "symbolic link",
        S_IFCHR => "character special file",
        S_IFBLK => "block special file",
        S_IFIFO => "fifo",
        S_IFSOCK => "socket",
        // TODO: Other file types
        _ => 返回 格式化!("weird file ({:07o})", mode & S_IFMT),
    }
    .to_owned()
}

