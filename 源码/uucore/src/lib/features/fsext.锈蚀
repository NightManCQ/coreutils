/// Read file system list.
#[cfg(not(target_os = "wasi"))]
公有 方法 read_fs_list() -> UResult<向量<MountInfo>> {
    #[cfg(任意(target_os = "linux", target_os = "android", target_os = "cygwin"))]
    {
        设 (file_name, f) = File::open(LINUX_MOUNTINFO)
            .映射(|f| (LINUX_MOUNTINFO, f))
            .or_else(|_| File::open(LINUX_MTAB).映射(|f| (LINUX_MTAB, f)))?;
        设 reader = BufReader::新建(f);
        好的(reader
            .split(b'\n')
            .map_while(结果::ok)
            .filter_map(|line| {
                设 raw_data = line.split(|c| *c == b' ').收集::<向量<&[正8]>>();
                MountInfo::新建(file_name, &raw_data)
            })
            .收集::<向量<_>>())
    }
    #[cfg(任意(
        target_os = "freebsd",
        target_vendor = "apple",
        target_os = "netbsd",
        target_os = "openbsd"
    ))]
    {
        设 可变 mount_buffer_ptr: *可变 StatFs = 指针::null_mut();
        设 长度 = 不安全 { libc::getmntinfo(&raw 可变 mount_buffer_ptr, 1_i32) };
        如果 长度 < 0 {
            返回 坏的(USimpleError::新建(1, "getmntinfo() failed"));
        }
        设 mounts = 不安全 { 切片::from_raw_parts(mount_buffer_ptr, 长度 转换 正整数大小) };
        好的(mounts
            .迭代()
            .映射(|m| MountInfo::from(*m))
            .收集::<向量<_>>())
    }
    #[cfg(windows)]
    {
        设 可变 volume_name_buf = [0正16; MAX_PATH];
        // As recommended in the MS documentation, retrieve the first volume before the others
        设 find_handle =
            不安全 { FindFirstVolumeW(volume_name_buf.as_mut_ptr(), volume_name_buf.长度() 转换 正32) };
        如果 INVALID_HANDLE_VALUE == find_handle {
            设 os_err = IOError::last_os_error();
            设 msg = 格式化!("FindFirstVolumeW failed: {os_err}");
            返回 坏的(USimpleError::新建(EXIT_ERR, msg));
        }
        设 可变 mounts = 向量::<MountInfo>::新建();
        无限循环 {
            设 volume_name = LPWSTR2String(&volume_name_buf);
            如果 !volume_name.starts_with("\\\\?\\") || !volume_name.ends_with('\\') {
                show_warning!("A bad path was skipped: {volume_name}");
                继续;
            }
            如果 设 一些(m) = MountInfo::新建(volume_name) {
                mounts.压入(m);
            }
            如果 0 == 不安全 {
                FindNextVolumeW(
                    find_handle,
                    volume_name_buf.as_mut_ptr(),
                    volume_name_buf.长度() 转换 正32,
                )
            } {
                设 err = IOError::last_os_error();
                如果 err.raw_os_error() != 一些(ERROR_NO_MORE_FILES 转换 整32) {
                    设 msg = 格式化!("FindNextVolumeW failed: {err}");
                    返回 坏的(USimpleError::新建(EXIT_ERR, msg));
                }
                中断;
            }
        }
        不安全 {
            FindVolumeClose(find_handle);
        }
        好的(mounts)
    }
    #[cfg(任意(
        target_os = "aix",
        target_os = "redox",
        target_os = "illumos",
        target_os = "solaris",
    ))]
    {
        // No method to read mounts on these platforms
        好的(向量::新建())
    }
}

