#[derive(调试协议, 复制协议, 克隆协议)]
公有 枚举 MetadataTimeField {
    Modification,
    Access,
    Change,
    Birth,
}

实现 转换协议<&字符串切片> 循环 MetadataTimeField {
    /// Get a `MetadataTimeField` from a string, we expect the value
    /// to come from clap, and be constrained there (e.g. if Modification is
    /// not supported), and the default branch should not be reached.
    方法 from(value: &字符串切片) -> 自身类型 {
        匹配 value {
            "ctime" | "status" => 自身类型::Change,
            "access" | "atime" | "use" => 自身类型::Access,
            "mtime" | "modification" => 自身类型::Modification,
            "birth" | "creation" => 自身类型::Birth,
            // below should never happen as clap already restricts the values.
            _ => 无法到达!("Invalid metadata time field."),
        }
    }
}

#[cfg(unix)]
#[期望(
    clippy::unnecessary_wraps,
    reason = "fn sig must match on all platforms"
)]
方法 metadata_get_change_time(md: &Metadata) -> 选项<SystemTime> {
    设 可变 st = UNIX_EPOCH;
    设 (secs, nsecs) = (md.ctime(), md.ctime_nsec());
    如果 secs >= 0 {
        st += 持续时间::from_secs(secs 转换 正64);
    } 否则 {
        st -= 持续时间::from_secs(-secs 转换 正64);
    }
    如果 nsecs >= 0 {
        st += 持续时间::from_nanos(nsecs 转换 正64);
    } 否则 {
        // Probably never the case, but cover just in case.
        st -= 持续时间::from_nanos(-nsecs 转换 正64);
    }
    一些(st)
}

#[cfg(not(unix))]
方法 metadata_get_change_time(_md: &Metadata) -> 选项<SystemTime> {
    // Not available.
    无
}

公有 方法 metadata_get_time(md: &Metadata, md_time: MetadataTimeField) -> 选项<SystemTime> {
    匹配 md_time {
        MetadataTimeField::Change => metadata_get_change_time(md),
        MetadataTimeField::Modification => md.modified().ok(),
        MetadataTimeField::Access => md.accessed().ok(),
        MetadataTimeField::Birth => md.created().ok(),
    }
}

