        设 parent = temp_dir.路径().加入("parent");
        设 target = temp_dir.路径().加入("target");
        文件系统::create_dir(&parent).解包();
        文件系统::create_dir(&target).解包();

        设 symlink_in_path = parent.加入("link");
        symlink(&target, &symlink_in_path).解包();

        // Try to create parent/link/subdir - the symlink should be replaced
        设 nested_path = symlink_in_path.加入("subdir");
        设 dir_fd = create_dir_all_safe(&nested_path, 0o755).解包();
        断言!(dir_fd.as_raw_fd() >= 0);

        // The symlink should have been replaced with a real directory
        断言!(!symlink_in_path.is_symlink());
        断言!(symlink_in_path.is_dir());
        断言!(nested_path.is_dir());

        // Target directory should not contain subdir (race attack prevented)
        断言!(!target.加入("subdir").exists());
    }

