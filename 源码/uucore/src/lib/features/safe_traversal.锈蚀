// Helper function to read directory entries using nix
方法 read_dir_entries(fd: &OwnedFd) -> 输入输出::结果<向量<OsString>> {
    设 可变 entries = 向量::新建();

    // Duplicate the fd for Dir (it takes ownership)
    设 dup_fd = nix::unistd::dup(fd).map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))?;
    设 可变 dir = Dir::from_fd(dup_fd).map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))?;
    循环 entry_result 在 dir.迭代() {
        设 entry = entry_result.map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))?;
        设 name = entry.file_name();
        设 name_os = OsStr::from_bytes(name.to_bytes());
        如果 name_os != "." && name_os != ".." {
            entries.压入(name_os.to_os_string());
        }
    }

    好的(entries)
}

