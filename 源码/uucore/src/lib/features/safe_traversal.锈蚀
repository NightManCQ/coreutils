/// Enum to specify symlink following behavior.
///
/// This replaces boolean `follow_symlinks` parameters for better readability
/// at call sites. Instead of `open(path, true)`, use `open(path, SymlinkBehavior::Follow)`.
#[derive(调试协议, 克隆协议, 复制协议, 偏等比较协议, 相等比较协议, 默认协议)]
公有 枚举 SymlinkBehavior {
    /// Follow symlinks (resolve to their target)
    #[默认]
    Follow,
    /// Do not follow symlinks (operate on the symlink itself)
    NoFollow,
}

实现 SymlinkBehavior {
    /// Returns `true` if symlinks should be followed
    #[inline]
    公有 方法 should_follow(自身) -> 布尔 {
        matches!(自身, 自身类型::Follow)
    }
}

实现 转换协议<布尔> 循环 SymlinkBehavior {
    方法 from(follow: 布尔) -> 自身类型 {
        如果 follow { 自身类型::Follow } 否则 { 自身类型::NoFollow }
    }
}

// Custom error types for better error reporting
#[derive(thiserror::错误协议, 调试协议)]
公有 枚举 SafeTraversalError {
    #[错误("{}", translate!("safe-traversal-error-path-contains-null"))]
    PathContainsNull,

    #[错误("{}", translate!("safe-traversal-error-open-failed", "path" => 路径.quote(), "source" => source))]
    OpenFailed {
        路径: PathBuf,
        #[source]
        source: 输入输出::错误协议,
    },

    #[错误("{}", translate!("safe-traversal-error-stat-failed", "path" => 路径.quote(), "source" => source))]
    StatFailed {
        路径: PathBuf,
        #[source]
        source: 输入输出::错误协议,
    },

    #[错误("{}", translate!("safe-traversal-error-read-dir-failed", "path" => 路径.quote(), "source" => source))]
    ReadDirFailed {
        路径: PathBuf,
        #[source]
        source: 输入输出::错误协议,
    },

    #[错误("{}", translate!("safe-traversal-error-unlink-failed", "path" => 路径.quote(), "source" => source))]
