        symlink(&target, &link).解包();

        // With follow_symlinks=true, should succeed
        设 result_follow = DirFd::open(&link, SymlinkBehavior::Follow);
        断言!(result_follow.is_ok());

        // With follow_symlinks=false, should fail
        设 result_nofollow = DirFd::open(&link, SymlinkBehavior::NoFollow);
        断言!(result_nofollow.is_err());
    }
