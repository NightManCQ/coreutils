    stat: FileStat,
}

实现 Metadata {
    公有 方法 from_stat(stat: FileStat) -> 自身类型 {
        自身类型 { stat }
    }

    公有 方法 file_type(&自身) -> FileType {
        FileType::from_mode(自身.stat.st_mode 转换 libc::mode_t)
    }

    公有 方法 file_info(&自身) -> FileInfo {
        FileInfo::from_stat(&自身.stat)
    }

    // st_size type varies by platform (i64 vs u64)
    #[allow(clippy::unnecessary_cast)]
    公有 方法 size(&自身) -> 正64 {
        自身.stat.st_size 转换 正64
    }

    // st_mode type varies by platform (u16 on macOS, u32 on Linux)
    #[allow(clippy::unnecessary_cast)]
    公有 方法 mode(&自身) -> 正32 {
        自身.stat.st_mode 转换 正32
    }

    公有 方法 nlink(&自身) -> 正64 {
        // st_nlink type varies by platform (u16 on FreeBSD, u32/u64 on others)
        #[allow(clippy::unnecessary_cast)]
        {
            自身.stat.st_nlink 转换 正64
        }
    }

    /// Compatibility methods to match std::fs::Metadata interface
    公有 方法 is_dir(&自身) -> 布尔 {
        自身.file_type().is_directory()
    }

    公有 方法 长度(&自身) -> 正64 {
        自身.size()
    }

    公有 方法 为空(&自身) -> 布尔 {
        自身.长度() == 0
    }
}

