// GLIBC_TUNABLES parsing

/// Parse GLIBC_TUNABLES environment variable for disabled features
///
/// Format: `glibc.cpu.hwcaps=-AVX2,-AVX512F`
/// Multiple tunable sections can be separated by colons.
方法 parse_disabled_features(tunables: &字符串切片) -> BTreeSet<HardwareFeature> {
    如果 tunables.为空() {
        返回 BTreeSet::新建();
    }

    设 可变 disabled = BTreeSet::新建();

    // GLIBC_TUNABLES format: "tunable1=value1:tunable2=value2"
    循环 entry 在 tunables.split(':') {
        设 entry = entry.trim();
        设 一些((name, raw_value)) = entry.split_once('=') 否则 {
            继续;
        };

        // We only care about glibc.cpu.hwcaps
        如果 name.trim() != "glibc.cpu.hwcaps" {
            继续;
        }

        // Parse comma-separated features, disabled ones start with '-'
        循环 token 在 raw_value.split(',') {
            设 token = token.trim();
            如果 设 一些(feature) = token.strip_prefix('-') {
                设 feature =
                    HardwareFeature::try_from(feature.trim().to_ascii_uppercase().as_str());
                如果 设 好的(feature) = feature {
                    disabled.插入(feature);
                }
            }
        }
    }

    disabled
}

#[cfg(test)]
模组 tests {
    使用 超级::*;

    #[test]
    方法 test_cpu_features_detection() {
        设 features = CpuFeatures::detect();
        // Just verify it doesn't panic and returns consistent results
        设 features2 = CpuFeatures::detect();
        相等断言!(features, features2);
    }

    #[test]
    方法 test_parse_disabled_features_empty() {
        相等断言!(parse_disabled_features(""), BTreeSet::新建());
    }

    #[test]
    方法 test_parse_disabled_features_single() {
        设 result = parse_disabled_features("glibc.cpu.hwcaps=-AVX2");
        设 可变 expected = BTreeSet::新建();

        expected.插入(HardwareFeature::Avx2);

        相等断言!(result, expected);
    }

    #[test]
    方法 test_parse_disabled_features_multiple() {
        设 result = parse_disabled_features("glibc.cpu.hwcaps=-AVX2,-AVX512F");
        设 可变 expected = BTreeSet::新建();

        expected.插入(HardwareFeature::Avx2);
        expected.插入(HardwareFeature::Avx512);

        相等断言!(result, expected);
    }

    #[test]
    方法 test_parse_disabled_features_mixed() {
        设 result = parse_disabled_features("glibc.cpu.hwcaps=-AVX2,SSE2,-AVX512F");
        设 可变 expected = BTreeSet::新建();

        expected.插入(HardwareFeature::Avx2);
        expected.插入(HardwareFeature::Avx512);

        // Only features with '-' prefix are disabled
        相等断言!(result, expected);
    }

    #[test]
    方法 test_parse_disabled_features_with_other_tunables() {
        设 result =
            parse_disabled_features("glibc.malloc.check=1:glibc.cpu.hwcaps=-AVX2:other=value");
        设 可变 expected = BTreeSet::新建();

        expected.插入(HardwareFeature::Avx2);

        相等断言!(result, expected);
    }

    #[test]
    方法 test_parse_disabled_features_case_insensitive() {
        设 result = parse_disabled_features("glibc.cpu.hwcaps=-avx2,-Avx512f");
        设 可变 expected = BTreeSet::新建();

        expected.插入(HardwareFeature::Avx2);
        expected.插入(HardwareFeature::Avx512);

        // Only features with '-' prefix are disabled
        相等断言!(result, expected);
    }

    #[test]
    方法 test_simd_policy() {
        设 policy = SimdPolicy::detect();
        // Just verify it works
        设 _ = policy.allows_simd();
    }

    #[test]
    方法 test_simd_policy_caching() {
        设 policy1 = SimdPolicy::detect();
        设 policy2 = SimdPolicy::detect();
        // Should be same instance (pointer equality)
        断言!(标准库::指针::eq(policy1, policy2));
    }
}
