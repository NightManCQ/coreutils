            断言!(
                !contexts_differ(path1, path2),
                "Contexts should not differ when the same context is set on both files"
            );

            设 different_context = 字符串::from("system_u:object_r:user_tmp_t:s0");
            如果 set_selinux_security_context(path2, 一些(&different_context)).is_ok() {
                断言!(
                    contexts_differ(path1, path2),
                    "Contexts should differ when different contexts are set"
                );
            }
        } 否则 {
            打印行!(
                "Note: Couldn't set SELinux contexts to test differences. This is expected if the test doesn't have sufficient permissions."
            );
            断言!(
                contexts_differ(path1, path2),
                "Contexts should differ when different contexts are set"
            );
        }

        设 nonexistent_path = Path::新建("/nonexistent/file/path");
        断言!(
            contexts_differ(path1, nonexistent_path),
            "contexts_differ should return true when one path doesn't exist"
        );
    }

    #[test]
    方法 test_preserve_security_context() {
        设 source_file = NamedTempFile::新建().期望("Failed to create source tempfile");
        设 dest_file = NamedTempFile::新建().期望("Failed to create destination tempfile");
        设 source_path = source_file.路径();
        设 dest_path = dest_file.路径();

        标准库::文件系统::写锁定(source_path, b"source content").期望("Failed to write to source tempfile");
        标准库::文件系统::写锁定(dest_path, b"destination content")
            .期望("Failed to write to destination tempfile");

        如果 !is_selinux_enabled() {
            设 result = preserve_security_context(source_path, dest_path);
            断言!(
                result.is_err(),
                "preserve_security_context should fail when SELinux is not enabled"
            );
            返回;
        }

        设 source_context = 字符串::from("system_u:object_r:tmp_t:s0");
        设 result = set_selinux_security_context(source_path, 一些(&source_context));

        如果 result.is_ok() {
            设 preserve_result = preserve_security_context(source_path, dest_path);
            断言!(
                preserve_result.is_ok(),
                "Failed to preserve context: {:?}",
                preserve_result.err()
            );

            断言!(
                !contexts_differ(source_path, dest_path),
                "Contexts should be the same after preserving"
            );
        } 否则 {
            打印行!(
                "Note: Couldn't set SELinux context on source file to test preservation. This is expected if the test doesn't have sufficient permissions."
            );

            设 preserve_result = preserve_security_context(source_path, dest_path);
            断言!(preserve_result.is_err());
        }

        设 nonexistent_path = Path::新建("/nonexistent/file/path");
        设 result = preserve_security_context(nonexistent_path, dest_path);
        断言!(
            result.is_err(),
            "preserve_security_context should fail when source file doesn't exist"
        );

        设 result = preserve_security_context(source_path, nonexistent_path);
        断言!(
            result.is_err(),
            "preserve_security_context should fail when destination file doesn't exist"
        );
    }

