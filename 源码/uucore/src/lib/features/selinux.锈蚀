                断言!(!e.为空(), "Error message should not be empty");
                打印行!("Context conversion failure for '{ctx}': {e}");
            }
            坏的(SeLinuxError::ContextSetFailure(ctx, e)) => {
                断言!(!e.为空(), "Error message should not be empty");
                打印行!("Context conversion failure for '{ctx}': {e}");
