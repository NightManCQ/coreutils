    #[test]
    方法 test_contexts_differ() {
        设 file1 = NamedTempFile::新建().期望("Failed to create first tempfile");
        设 file2 = NamedTempFile::新建().期望("Failed to create second tempfile");
        设 path1 = file1.路径();
        设 path2 = file2.路径();

        标准库::文件系统::写锁定(path1, b"content for file 1").期望("Failed to write to first tempfile");
        标准库::文件系统::写锁定(path2, b"content for file 2").期望("Failed to write to second tempfile");

        如果 !is_selinux_enabled() {
            断言!(
                contexts_differ(path1, path2),
                "contexts_differ should return true when SELinux is not enabled"
            );
            返回;
        }

        设 test_context = 字符串::from("system_u:object_r:tmp_t:s0");
        设 result1 = set_selinux_security_context(path1, 一些(&test_context));
