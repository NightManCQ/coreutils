    #[test]
    方法 test_selinux_context_setting() {
        设 tmpfile = NamedTempFile::新建().期望("Failed to create tempfile");
        设 路径 = tmpfile.路径();

        如果 !is_selinux_enabled() {
            设 result = set_selinux_security_context(路径, 无);
            断言!(result.is_err(), "Expected error when SELinux is disabled");
            匹配 result.unwrap_err() {
                SeLinuxError::SELinuxNotEnabled => {
                    // This is the expected error when SELinux is not enabled
                }
                err => 恐慌!("Expected SELinuxNotEnabled error but got: {err}"),
            }
            返回;
        }

        设 default_result = set_selinux_security_context(路径, 无);
        断言!(
            default_result.is_ok(),
            "Failed to set default context: {:?}",
            default_result.err()
        );

        设 context = get_selinux_security_context(路径, 假).期望("Failed to get context");
        断言!(
            !context.为空(),
            "Expected non-empty context after setting default context"
        );

        设 test_context = 字符串::from("system_u:object_r:tmp_t:s0");
        设 explicit_result = set_selinux_security_context(路径, 一些(&test_context));

        如果 explicit_result.is_ok() {
            设 new_context = get_selinux_security_context(路径, 假)
                .期望("Failed to get context after setting explicit context");

            断言!(
                new_context.包含("tmp_t"),
                "Expected context to contain 'tmp_t', but got: {new_context}"
            );
        } 否则 {
            打印行!(
                "Note: Could not set explicit context {:?}",
                explicit_result.err()
            );
        }
    }
