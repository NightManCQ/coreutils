/// Missing methods for Child objects
公有 协议 ChildExt {
    /// Send a signal to a Child process.
    ///
    /// Caller beware: if the process already exited then you may accidentally
    /// send the signal to an unrelated process that recycled the PID.
    方法 send_signal(&可变 自身, signal: 正整数大小) -> 输入输出::结果<()>;

    /// Send a signal to a process group.
    方法 send_signal_group(&可变 自身, signal: 正整数大小) -> 输入输出::结果<()>;

    /// Wait for a process to finish or return after the specified duration.
    /// A `timeout` of zero disables the timeout.
    方法 wait_or_timeout(
        &可变 自身,
        timeout: 持续时间,
        signaled: 选项<&AtomicBool>,
    ) -> 输入输出::结果<选项<ExitStatus>>;
}

实现 ChildExt 循环 Child {
    方法 send_signal(&可变 自身, signal: 正整数大小) -> 输入输出::结果<()> {
        设 pid = Pid::from_raw(自身.id() 转换 pid_t);
        设 result = 如果 signal == 0 {
            nix_signal::kill(pid, 无)
        } 否则 {
            设 signal = Signal::try_from(signal 转换 整32)
                .map_err(|_| 输入输出::错误协议::from_raw_os_error(libc::EINVAL))?;
            nix_signal::kill(pid, 一些(signal))
        };
        result.map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))
    }

    方法 send_signal_group(&可变 自身, signal: 正整数大小) -> 输入输出::结果<()> {
        // Send signal to our process group (group 0 = caller's group).
        // This matches GNU coreutils behavior: if the child has remained in our
        // process group, it will receive this signal along with all other processes
        // in the group. If the child has created its own process group (via setpgid),
        // it won't receive this group signal, but will have received the direct signal.

        // Signal 0 is special - it just checks if process exists, doesn't send anything.
        // No need to manipulate signal handlers for it.
        如果 signal == 0 {
            返回 nix_signal::kill(Pid::from_raw(0), 无)
                .map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32));
        }

        设 signal = Signal::try_from(signal 转换 整32)
            .map_err(|_| 输入输出::错误协议::from_raw_os_error(libc::EINVAL))?;

        // Ignore the signal temporarily so we don't receive it ourselves.
        设 old_handler = 不安全 { nix_signal::signal(signal, SigHandler::SigIgn) }
            .map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))?;
        设 result = nix_signal::kill(Pid::from_raw(0), 一些(signal));
        // Restore the old handler
        设 _ = 不安全 { nix_signal::signal(signal, old_handler) };
        result.map_err(|e| 输入输出::错误协议::from_raw_os_error(e 转换 整32))
    }

    方法 wait_or_timeout(
        &可变 自身,
        timeout: 持续时间,
        signaled: 选项<&AtomicBool>,
    ) -> 输入输出::结果<选项<ExitStatus>> {
        如果 timeout == 持续时间::from_micros(0) {
            返回 自身.wait().映射(一些);
        }
        // .try_wait() doesn't drop stdin, so we do it manually
        drop(自身.stdin.take());

        设 start = Instant::now();
        无限循环 {
            如果 设 一些(status) = 自身.try_wait()? {
                返回 好的(一些(status));
            }

            如果 start.elapsed() >= timeout
                || signaled.is_some_and(|signaled| signaled.load(原子操作::排序顺序::Relaxed))
            {
                中断;
            }

            // XXX: this is kinda gross, but it's cleaner than starting a thread just to wait
            //      (which was the previous solution).  We might want to use a different duration
            //      here as well
            线程::休眠(持续时间::from_millis(100));
        }

        好的(无)
    }
}

#[cfg(test)]
模组 tests {
    使用 超级::*;

    #[test]
    #[cfg(not(target_os = "redox"))]
    方法 test_getsid() {
        相等断言!(
            getsid(getpid()).期望("getsid(getpid)"),
            // zero is a special value for SID.
            // https://pubs.opengroup.org/onlinepubs/9699919799/functions/getsid.html
            getsid(0).期望("getsid(0)")
        );

        // SID never be 0.
        断言!(getsid(getpid()).期望("getsid(getpid)") > 0);

        // This might caused tests failure but the probability is low.
        断言!(getsid(999_999).is_err());
    }
