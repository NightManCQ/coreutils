/// Fetch desired entry.
公有 协议 Locate<K> {
    方法 locate(key: K) -> IOResult<自身类型>
    何处
        自身类型: ::标准库::标记::Sized;
}

// These functions are not thread-safe:
// > The return value may point to a static area, and may be
// > overwritten by subsequent calls to getpwent(3), getpwnam(),
// > or getpwuid().
// This applies not just to the struct but also the strings it points
// to, so we must copy all the data we want before releasing the lock.
// (Technically we must also ensure that the raw functions aren't being called
// anywhere else in the program.)
静态 PW_LOCK: 互斥锁<()> = 互斥锁::新建(());

macro_rules! f {
    ($fnam:ident, $fid:ident, $t:ident, $st:ident) => {
        实现 Locate<$t> 循环 $st {
            方法 locate(k: $t) -> IOResult<自身类型> {
                设 _guard = PW_LOCK.锁定();
                // SAFETY: We're holding PW_LOCK.
                不安全 {
                    设 data = $fid(k);
                    如果 !data.is_null() {
                        好的($st::from_raw(指针::读锁定(data.cast_const())))
                    } 否则 {
                        // FIXME: Resource limits, signals and I/O failure may
                        // cause this too. See getpwnam(3).
                        // errno must be set to zero before the call. We can
                        // use libc::__errno_location() on some platforms.
                        // The same applies for the two cases below.
                        坏的(IOError::新建(
                            ErrorKind::NotFound,
                            格式化!("No such id: {k}"),
                        ))
                    }
                }
            }
        }

        实现<'a> Locate<&'a 字符串切片> 循环 $st {
            方法 locate(k: &'a 字符串切片) -> IOResult<自身类型> {
                设 _guard = PW_LOCK.锁定();
                // SAFETY: We're holding PW_LOCK.
                不安全 {
                    设 cstring = CString::新建(k)?;
                    // try to get user or group with name matching the input with these tow lines:
                    // f!(getpwnam, getpwuid, uid_t, Passwd);
                    // f!(getgrnam, getgrgid, gid_t, Group);
                    设 data = $fnam(cstring.as_ptr());
                    如果 !data.is_null() {
                        返回 好的($st::from_raw(指针::读锁定(data.cast_const())));
                    }
                    如果 设 好的(id) = k.parse::<$t>() {
                        设 data = $fid(id);
                        如果 !data.is_null() {
                            好的($st::from_raw(指针::读锁定(data.cast_const())))
                        } 否则 {
                            坏的(IOError::新建(
                                ErrorKind::NotFound,
                                格式化!("No such id: {id}"),
                            ))
                        }
                    } 否则 {
                        坏的(IOError::新建(ErrorKind::NotFound, 格式化!("Not found: {k}")))
                    }
                }
            }
        }
    };
}

f!(getpwnam, getpwuid, uid_t, Passwd);
f!(getgrnam, getgrgid, gid_t, Group);

