//! Utilities for formatting numbers in various formats

使用 bigdecimal::BigDecimal;
使用 bigdecimal::num_bigint::ToBigInt;
使用 num_traits::Signed;
使用 num_traits::Zero;
使用 标准库::比较::min;
使用 标准库::输入输出::Write;

使用 超级::{
    ExtendedBigDecimal, FormatError,
    spec::{CanAsterisk, Spec},
};

公有 协议 Formatter<T> {
    方法 格式化(&自身, writer: 实现 Write, x: T) -> 标准库::输入输出::结果<()>;
    方法 try_from_spec(s: Spec) -> 结果<自身类型, FormatError>
    何处
        自身类型: Sized;
}

