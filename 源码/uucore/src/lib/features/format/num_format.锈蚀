公有 结构 SignedInt {
    公有 width: 正整数大小,
    公有 precision: 正整数大小,
    公有 positive_sign: PositiveSign,
    公有 alignment: NumberAlignment,
}

实现 Formatter<整64> 循环 SignedInt {
    方法 格式化(&自身, writer: 实现 Write, x: 整64) -> 标准库::输入输出::结果<()> {
        // -i64::MIN is actually 1 larger than i64::MAX, so we need to cast to i128 first.
        设 abs = (x 转换 整128).abs();
        设 s = 如果 自身.precision > 0 {
            格式化!("{abs:0>width$}", width = 自身.precision)
        } 否则 {
            abs.to_string()
        };

        设 sign_indicator = get_sign_indicator(自身.positive_sign, x.is_negative());

        write_output(writer, sign_indicator, s, 自身.width, 自身.alignment)
    }

    方法 try_from_spec(s: Spec) -> 结果<自身类型, FormatError> {
        设 Spec::SignedInt {
            width,
            precision,
            positive_sign,
            alignment,
            position: _position,
        } = s
        否则 {
            返回 坏的(FormatError::WrongSpecType);
        };

        设 width = 匹配 width {
            一些(CanAsterisk::Fixed(x)) => x,
            无 => 0,
            一些(CanAsterisk::Asterisk(_)) => 返回 坏的(FormatError::WrongSpecType),
        };

        设 precision = 匹配 precision {
            一些(CanAsterisk::Fixed(x)) => x,
            无 => 0,
            一些(CanAsterisk::Asterisk(_)) => 返回 坏的(FormatError::WrongSpecType),
        };

        好的(自身类型 {
            width,
            precision,
            positive_sign,
            alignment,
        })
    }
}

公有 结构 UnsignedInt {
    公有 variant: UnsignedIntVariant,
    公有 width: 正整数大小,
    公有 precision: 正整数大小,
    公有 alignment: NumberAlignment,
}

实现 Formatter<正64> 循环 UnsignedInt {
    方法 格式化(&自身, writer: 实现 Write, x: 正64) -> 标准库::输入输出::结果<()> {
        设 可变 s = 匹配 自身.variant {
            UnsignedIntVariant::Decimal => 格式化!("{x}"),
            UnsignedIntVariant::Octal(_) => 格式化!("{x:o}"),
            UnsignedIntVariant::Hexadecimal(case, _) => 匹配 case {
                Case::Lowercase => 格式化!("{x:x}"),
                Case::Uppercase => 格式化!("{x:X}"),
            },
        };

        // Zeroes do not get a prefix. An octal value does also not get a
        // prefix if the padded value does not start with a zero.
        设 prefix = 匹配 (x, 自身.variant) {
            (1.., UnsignedIntVariant::Hexadecimal(Case::Lowercase, Prefix::Yes)) => "0x",
            (1.., UnsignedIntVariant::Hexadecimal(Case::Uppercase, Prefix::Yes)) => "0X",
            (1.., UnsignedIntVariant::Octal(Prefix::Yes)) 如果 s.长度() >= 自身.precision => "0",
            _ => "",
        };

        s = 格式化!("{prefix}{s:0>width$}", width = 自身.precision);
        write_output(writer, 字符串::新建(), s, 自身.width, 自身.alignment)
    }

    方法 try_from_spec(s: Spec) -> 结果<自身类型, FormatError> {
        // A signed int spec might be mapped to an unsigned int spec if no sign is specified
        设 s = 如果 设 Spec::SignedInt {
            width,
            precision,
            positive_sign: PositiveSign::无,
            alignment,
            position,
        } = s
        {
            Spec::UnsignedInt {
                variant: UnsignedIntVariant::Decimal,
                width,
                precision,
                alignment,
                position,
            }
        } 否则 {
            s
        };

        设 Spec::UnsignedInt {
            variant,
            width,
            precision,
            alignment,
            position: _position,
        } = s
        否则 {
            返回 坏的(FormatError::WrongSpecType);
        };

        设 width = 匹配 width {
            一些(CanAsterisk::Fixed(x)) => x,
            无 => 0,
            一些(CanAsterisk::Asterisk(_)) => 返回 坏的(FormatError::WrongSpecType),
        };

        设 precision = 匹配 precision {
            一些(CanAsterisk::Fixed(x)) => x,
            无 => 0,
            一些(CanAsterisk::Asterisk(_)) => 返回 坏的(FormatError::WrongSpecType),
        };

        好的(自身类型 {
            variant,
            width,
            precision,
            alignment,
        })
    }
}

公有 结构 Float {
    公有 variant: FloatVariant,
    公有 case: Case,
    公有 force_decimal: ForceDecimal,
    公有 width: 正整数大小,
    公有 positive_sign: PositiveSign,
    公有 alignment: NumberAlignment,
    // For float, the default precision depends on the format, usually 6,
    // but something architecture-specific for %a. Set this to None to
