    公有 precision: 选项<正整数大小>,
}

实现 默认协议 循环 Float {
    方法 默认() -> 自身类型 {
        自身类型 {
            variant: FloatVariant::Decimal,
            case: Case::Lowercase,
            force_decimal: ForceDecimal::No,
            width: 0,
            positive_sign: PositiveSign::无,
            alignment: NumberAlignment::Left,
            precision: 无,
        }
