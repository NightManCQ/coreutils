        相等断言!(格式化(&format, &(-123.0).into()), " -123.000000");
        相等断言!(格式化(&format, &123.15e-8.into()), "    0.000001");
        相等断言!(格式化(&format, &(-123.15e8).into()), "-12315000000.000000");
