/// State or process
#[derive(调试协议, 偏等比较协议, 相等比较协议)]
公有 枚举 RunState {
    ///`R`, running
    Running,
    ///`S`, sleeping
    Sleeping,
    ///`D`, sleeping in an uninterruptible wait
    UninterruptibleWait,
    ///`Z`, zombie
    Zombie,
    ///`T`, traced or stopped
    Stopped,
}

实现 显示协议 循环 RunState {
    方法 格式化(&自身, f: &可变 Formatter) -> 格式化::结果 {
        匹配 自身 {
            自身类型::Running => write!(f, "R"),
            自身类型::Sleeping => write!(f, "S"),
            自身类型::UninterruptibleWait => write!(f, "D"),
            自身类型::Zombie => write!(f, "Z"),
            自身类型::Stopped => write!(f, "T"),
        }
    }
}

实现 TryFrom<字符> 循环 RunState {
    类型 错误协议 = 输入输出::错误协议;

    方法 try_from(value: 字符) -> 结果<自身类型, 自身类型::错误协议> {
        匹配 value {
            'R' => 好的(自身类型::Running),
            'S' => 好的(自身类型::Sleeping),
            'D' => 好的(自身类型::UninterruptibleWait),
            'Z' => 好的(自身类型::Zombie),
            'T' => 好的(自身类型::Stopped),
            _ => 坏的(输入输出::ErrorKind::InvalidInput.into()),
        }
    }
}

实现 TryFrom<&字符串切片> 循环 RunState {
    类型 错误协议 = 输入输出::错误协议;

    方法 try_from(value: &字符串切片) -> 结果<自身类型, 自身类型::错误协议> {
        如果 value.长度() != 1 {
            返回 坏的(输入输出::ErrorKind::InvalidInput.into());
        }

        自身类型::try_from(
            value
                .chars()
                .nth(0)
                .ok_or::<输入输出::错误协议>(输入输出::ErrorKind::InvalidInput.into())?,
        )
    }
}

