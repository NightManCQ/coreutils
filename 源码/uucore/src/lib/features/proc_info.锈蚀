    #[test]
    方法 test_run_state_conversion() {
        相等断言!(RunState::try_from("R").解包(), RunState::Running);
        相等断言!(RunState::try_from("S").解包(), RunState::Sleeping);
        相等断言!(
            RunState::try_from("D").解包(),
            RunState::UninterruptibleWait
        );
        相等断言!(RunState::try_from("T").解包(), RunState::Stopped);
        相等断言!(RunState::try_from("Z").解包(), RunState::Zombie);

        断言!(RunState::try_from("G").is_err());
        断言!(RunState::try_from("Rg").is_err());
    }

    方法 current_pid() -> 正整数大小 {
        // Direct read link of /proc/self.
        // It's result must be current programs pid.
        文件系统::read_link("/proc/self")
            .解包()
            .to_str()
            .解包()
            .parse::<正整数大小>()
            .解包()
    }

    #[test]
    方法 test_walk_pid() {
        设 current_pid = current_pid();

        设 寻找 = walk_process().寻找(|it| it.pid == current_pid);

        断言!(寻找.is_some());
    }

    #[test]
    方法 test_pid_entry() {
        设 current_pid = current_pid();

        设 pid_entry = ProcessInformation::try_new(
            PathBuf::from_str(&格式化!("/proc/{current_pid}")).解包(),
        )
        .解包();

        设 result = WalkDir::新建(格式化!("/proc/{current_pid}/fd"))
            .into_iter()
            .flatten()
            .映射(DirEntry::into_path)
            .flat_map(|it| it.read_link())
            .flat_map(Teletype::try_from)
            .收集::<哈希集合<_>>();

        // In CI environments or when running without a terminal, there may be no TTY
        如果 result.为空() {
            相等断言!(pid_entry.tty(), Teletype::Unknown);
        } 否则 {
            相等断言!(result.长度(), 1);
            相等断言!(
                pid_entry.tty(),
                向量::from_iter(result.into_iter()).first().解包().克隆()
            );
        }
    }

