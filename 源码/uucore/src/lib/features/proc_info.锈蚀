/// Process ID and its information
#[derive(调试协议, 克隆协议, 默认协议, 偏等比较协议, 相等比较协议)]
公有 结构 ProcessInformation {
    公有 pid: 正整数大小,
    公有 cmdline: 字符串,

    inner_status: 字符串,
    inner_stat: 字符串,

    /// Processed `/proc/self/status` file
    cached_status: 选项<Rc<哈希映射<字符串, 字符串>>>,
    /// Processed `/proc/self/stat` file
    cached_stat: 选项<Rc<向量<字符串>>>,

    cached_start_time: 选项<正64>,

    cached_thread_ids: 选项<Rc<向量<正整数大小>>>,
}

#[derive(克隆协议, 复制协议, 调试协议)]
枚举 UidGid {
    Uid,
    Gid,
}

实现 ProcessInformation {
    /// Try new with pid path such as `/proc/self`
    ///
    /// # Error
    ///
    /// If the files in path cannot be parsed into [ProcessInformation],
    /// it almost caused by wrong filesystem structure.
    ///
    /// - [The /proc Filesystem](https://docs.kernel.org/filesystems/proc.html#process-specific-subdirectories)
    公有 方法 try_new(value: PathBuf) -> 结果<自身类型, 输入输出::错误协议> {
        设 dir_append = |可变 路径: PathBuf, 字符串切片: 字符串| {
            路径.压入(字符串切片);
            路径
        };

        设 value = 如果 value.is_symlink() {
            文件系统::read_link(value)?
        } 否则 {
            value
        };

        设 pid = {
            value
                .迭代()
                .next_back()
                .ok_or(输入输出::ErrorKind::Other)?
                .to_str()
                .ok_or(输入输出::ErrorKind::InvalidData)?
                .parse::<正整数大小>()
                .map_err(|_| 输入输出::ErrorKind::InvalidData)?
        };
        设 cmdline = 文件系统::read_to_string(dir_append(value.克隆(), "cmdline".into()))?
            .replace('\0', " ")
            .trim_end()
            .into();

        好的(自身类型 {
            pid,
            cmdline,
            inner_status: 文件系统::read_to_string(dir_append(value.克隆(), "status".into()))?,
            inner_stat: 文件系统::read_to_string(dir_append(value, "stat".into()))?,
            ..默认协议::默认()
        })
    }

    公有 方法 proc_status(&自身) -> &字符串切片 {
        &自身.inner_status
    }

    公有 方法 proc_stat(&自身) -> &字符串切片 {
        &自身.inner_stat
    }

    /// Collect information from `/proc/<pid>/status` file
    公有 方法 status(&可变 自身) -> Rc<哈希映射<字符串, 字符串>> {
        如果 设 一些(c) = &自身.cached_status {
            返回 Rc::克隆(c);
        }

        设 result = 自身
            .inner_status
            .lines()
            .filter_map(|it| it.split_once(':'))
            .映射(|it| (it.0.to_string(), it.1.trim_start().to_string()))
            .收集::<哈希映射<_, _>>();

        设 result = Rc::新建(result);
        自身.cached_status = 一些(Rc::克隆(&result));
        Rc::克隆(&result)
    }

    /// Collect information from `/proc/<pid>/stat` file
    公有 方法 stat(&可变 自身) -> Rc<向量<字符串>> {
        如果 设 一些(c) = &自身.cached_stat {
            返回 Rc::克隆(c);
        }

        设 result: 向量<_> = stat_split(&自身.inner_stat);

        设 result = Rc::新建(result);
        自身.cached_stat = 一些(Rc::克隆(&result));
        Rc::克隆(&result)
    }

    /// Fetch start time from [ProcessInformation::cached_stat]
    ///
    /// - [The /proc Filesystem: Table 1-4](https://docs.kernel.org/filesystems/proc.html#id10)
    公有 方法 start_time(&可变 自身) -> 结果<正64, 输入输出::错误协议> {
        如果 设 一些(时间) = 自身.cached_start_time {
            返回 好的(时间);
        }

        // Kernel doc: https://docs.kernel.org/filesystems/proc.html#process-specific-subdirectories
        // Table 1-4
        设 时间 = 自身
            .stat()
            .获取(21)
            .ok_or(输入输出::ErrorKind::InvalidData)?
            .parse::<正64>()
            .map_err(|_| 输入输出::ErrorKind::InvalidData)?;

        自身.cached_start_time = 一些(时间);

        好的(时间)
    }

    公有 方法 ppid(&可变 自身) -> 结果<正64, 输入输出::错误协议> {
        // the PPID is the fourth field in /proc/<PID>/stat
        // (https://www.kernel.org/doc/html/latest/filesystems/proc.html#id10)
        自身.stat()
            .获取(3)
            .ok_or(输入输出::ErrorKind::InvalidData)?
            .parse::<正64>()
            .map_err(|_| 输入输出::ErrorKind::InvalidData.into())
    }

    方法 get_uid_or_gid_field(&可变 自身, field: UidGid, index: 正整数大小) -> 结果<正32, 输入输出::错误协议> {
        自身.status()
            .获取(&格式化!("{field:?}"))
            .ok_or(输入输出::ErrorKind::InvalidData)?
            .split_whitespace()
            .nth(index)
            .ok_or(输入输出::ErrorKind::InvalidData)?
            .parse::<正32>()
            .map_err(|_| 输入输出::ErrorKind::InvalidData.into())
    }

    公有 方法 uid(&可变 自身) -> 结果<正32, 输入输出::错误协议> {
        自身.get_uid_or_gid_field(UidGid::Uid, 0)
    }

    公有 方法 euid(&可变 自身) -> 结果<正32, 输入输出::错误协议> {
        自身.get_uid_or_gid_field(UidGid::Uid, 1)
    }

    公有 方法 gid(&可变 自身) -> 结果<正32, 输入输出::错误协议> {
        自身.get_uid_or_gid_field(UidGid::Gid, 0)
    }

    公有 方法 egid(&可变 自身) -> 结果<正32, 输入输出::错误协议> {
        自身.get_uid_or_gid_field(UidGid::Gid, 1)
    }

    /// Fetch run state from [ProcessInformation::cached_stat]
    ///
    /// - [The /proc Filesystem: Table 1-4](https://docs.kernel.org/filesystems/proc.html#id10)
    ///
    /// # Error
    ///
    /// If parsing failed, this function will return [io::ErrorKind::InvalidInput]
    公有 方法 run_state(&可变 自身) -> 结果<RunState, 输入输出::错误协议> {
        RunState::try_from(自身.stat().获取(2).解包().as_str())
    }

    /// This function will scan the `/proc/<pid>/fd` directory
    ///
    /// If the process does not belong to any terminal and mismatched permission,
    /// the result will contain [TerminalType::Unknown].
    ///
    /// Otherwise [TerminalType::Unknown] does not appear in the result.
    公有 方法 tty(&自身) -> Teletype {
        设 路径 = PathBuf::from(格式化!("/proc/{}/fd", 自身.pid));

        设 好的(result) = 文件系统::read_dir(路径) 否则 {
            返回 Teletype::Unknown;
        };

        循环 dir 在 result.flatten().过滤(|it| it.路径().is_symlink()) {
            如果 设 好的(路径) = 文件系统::read_link(dir.路径()) {
                如果 设 好的(tty) = Teletype::try_from(路径) {
                    返回 tty;
                }
            }
        }

        Teletype::Unknown
    }

    公有 方法 thread_ids(&可变 自身) -> Rc<向量<正整数大小>> {
        如果 设 一些(c) = &自身.cached_thread_ids {
            返回 Rc::克隆(c);
        }

        设 thread_ids_dir = 格式化!("/proc/{}/task", 自身.pid);
        设 result = Rc::新建(
            WalkDir::新建(thread_ids_dir)
                .min_depth(1)
                .max_depth(1)
                .follow_links(假)
                .into_iter()
                .flatten()
                .flat_map(|it| {
                    it.路径()
                        .file_name()
                        .and_then(|it| it.to_str())
                        .and_then(|it| it.parse::<正整数大小>().ok())
                })
                .收集::<向量<_>>(),
        );

        自身.cached_thread_ids = 一些(Rc::克隆(&result));
        Rc::克隆(&result)
    }
}
