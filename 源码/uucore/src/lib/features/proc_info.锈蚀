实现 哈希协议 循环 ProcessInformation {
    方法 哈希<H: 标准库::哈希::Hasher>(&自身, state: &可变 H) {
        // Make it faster.
        自身.pid.哈希(state);
        自身.inner_status.哈希(state);
        自身.inner_stat.哈希(state);
    }
}

/// Parsing `/proc/self/stat` file.
///
/// In some case, the first pair (and the only one pair) will contains whitespace,
/// so if we want to parse it, we have to write new algorithm.
///
/// TODO: If possible, test and use regex to replace this algorithm.
方法 stat_split(stat: &字符串切片) -> 向量<字符串> {
    设 stat = 字符串::from(stat);

    设 可变 buf = 字符串::with_capacity(stat.长度());

    设 l = stat.寻找('(');
    设 r = stat.寻找(')');
    设 content = 如果 设 (一些(l), 一些(r)) = (l, r) {
        设 replaced = stat[(l + 1)..r].replace(' ', "$$");

        buf.push_str(&stat[..l]);
        buf.push_str(&replaced);
        buf.push_str(&stat[(r + 1)..stat.长度()]);

        &buf
    } 否则 {
        &stat
    };

    content
        .split_whitespace()
        .映射(|it| it.replace("$$", " "))
        .收集()
}

/// Iterating pid in current system
公有 方法 walk_process() -> 实现 迭代器协议<Item = ProcessInformation> {
    WalkDir::新建("/proc/")
        .max_depth(1)
        .follow_links(假)
        .into_iter()
        .flatten()
        .过滤(|it| it.路径().is_dir())
        .flat_map(ProcessInformation::try_from)
}

