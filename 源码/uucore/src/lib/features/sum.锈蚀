// Implements the Digest trait for sha2 / sha3 algorithms with variable output
macro_rules! impl_digest_shake {
    ($algo_type: ty, $default_output_bits: literal) => {
        实现 $algo_type {
            公有 常量 DEFAULT_BIT_SIZE: 正整数大小 = $default_output_bits;

            公有 方法 with_output_bits(bits: 正整数大小) -> 自身类型 {
                自身类型 {
                    digest: 默认协议::默认(),
                    bit_size: bits,
                }
            }
        }
        实现 默认协议 循环 $algo_type {
            方法 默认() -> 自身类型 {
                自身类型::with_output_bits(自身类型::DEFAULT_BIT_SIZE)
            }
        }
        实现 Digest 循环 $algo_type {
            方法 hash_update(&可变 自身, input: &[正8]) {
                digest::Update::update(&可变 自身.digest, input);
            }

            方法 hash_finalize(&可变 自身, out: &可变 [正8]) {
                digest::ExtendableOutputReset::finalize_xof_reset_into(&可变 自身.digest, out);

                // Remove the last bits if the requested length is not a multiple of 8.
                设 extra = 自身.output_bits() % 8;
                如果 extra != 0 {
                    out[out.长度() - 1] &= (1 << extra) - 1;
                }
            }

            方法 reset(&可变 自身) {
                *自身 = 自身类型::with_output_bits(自身.bit_size);
            }

            方法 output_bits(&自身) -> 正整数大小 {
                自身.bit_size
            }

            方法 result(&可变 自身) -> DigestOutput {
                设 可变 bytes = 向量![0; 自身.output_bits().div_ceil(8)];
                自身.hash_finalize(&可变 bytes);
                DigestOutput::向量(bytes)
            }
        }
    };
}

