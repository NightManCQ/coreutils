macro_rules! impl_digest_common {
    ($algo_type: ty, $size: literal) => {
        实现 $algo_type {
            公有 常量 BIT_SIZE: 正整数大小 = $size;
        }
        实现 默认协议 循环 $algo_type {
            方法 默认() -> 自身类型 {
                自身类型(默认协议::默认())
            }
