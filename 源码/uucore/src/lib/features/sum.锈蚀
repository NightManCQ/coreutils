        设 可变 crc_optimized = Crc::默认();
        crc_optimized.hash_update(test_data);
        设 可变 output_opt = [0正8; 8];
        crc_optimized.hash_finalize(&可变 output_opt);

        // Create a reference implementation using hash_update
        设 可变 crc_reference = Crc::默认();
        循环 &byte 在 test_data {
            crc_reference.hash_update(&[byte]);
        }
        设 可变 output_ref = [0正8; 8];
        crc_reference.hash_finalize(&可变 output_ref);

        相等断言!(output_opt, output_ref);
    }

