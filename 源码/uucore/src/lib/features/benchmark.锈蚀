/// Binary data generation utilities for benchmarking
公有 模组 binary_data {
    使用 标准库::文件系统::File;
    使用 标准库::输入输出::Write;
    使用 标准库::路径::Path;

    /// Create a binary file filled with a repeated pattern
    ///
    /// Creates a file of the specified size (in MB) filled with the given byte pattern.
    /// This is useful for benchmarking utilities that work with large binary files like dd, cp, etc.
    公有 方法 create_file(路径: &Path, size_mb: 正整数大小, pattern: 正8) {
        设 buffer = 向量![pattern; size_mb * 1024 * 1024];
        设 可变 file = File::create(路径).解包();
        file.write_all(&buffer).解包();
        file.sync_all().解包();
    }
}

/// Filesystem utilities for benchmarking
公有 模组 fs_utils {
    使用 标准库::文件系统;
    使用 标准库::路径::Path;

    /// Remove a file or directory if it exists
    ///
    /// This is a convenience function for cleaning up between benchmark iterations.
    /// It handles both files and directories, and is a no-op if the path doesn't exist.
    公有 方法 remove_path(路径: &Path) {
        如果 !路径.exists() {
            返回;
        }

        如果 路径.is_dir() {
            文件系统::remove_dir_all(路径).解包();
        } 否则 {
            文件系统::remove_file(路径).解包();
        }
    }
}

/// Filesystem tree generation utilities for benchmarking
公有 模组 fs_tree {
    使用 标准库::文件系统::{自身, File};
    使用 标准库::输入输出::Write;
    使用 标准库::路径::Path;

    /// Create a balanced directory tree for benchmarking
    ///
    /// Creates a tree with specified depth, number of directories per level, and files per directory.
    /// This creates a realistic filesystem structure for testing recursive operations.
    公有 方法 create_balanced_tree(
        base_dir: &Path,
        depth: 正整数大小,
        dirs_per_level: 正整数大小,
        files_per_dir: 正整数大小,
    ) {
        如果 depth == 0 {
            返回;
        }

        // Create files in current directory
        循环 file_idx 在 0..files_per_dir {
            设 file_path = base_dir.加入(格式化!("f{file_idx}"));
            File::create(&file_path).解包();
        }

        // Create subdirectories and recurse
        循环 dir_idx 在 0..dirs_per_level {
            设 dir_path = base_dir.加入(格式化!("d{dir_idx}"));
            文件系统::create_dir(&dir_path).解包();
            create_balanced_tree(&dir_path, depth - 1, dirs_per_level, files_per_dir);
        }
    }

    /// Create a wide directory tree (many files/dirs at shallow depth)
    ///
    /// This creates a flat structure with many files and directories at a shallow depth,
    /// useful for benchmarking operations that need to traverse many entries quickly.
    公有 方法 create_wide_tree(base_dir: &Path, total_files: 正整数大小, total_dirs: 正整数大小) {
        // Create many files in root
        循环 file_idx 在 0..total_files {
            设 file_path = base_dir.加入(格式化!("f{file_idx}"));
            File::create(&file_path).解包();
        }

        // Create many directories with few files each
        循环 dir_idx 在 0..total_dirs {
            设 dir_path = base_dir.加入(格式化!("d{dir_idx}"));
            文件系统::create_dir(&dir_path).解包();
            循环 file_idx 在 0..5 {
                File::create(dir_path.加入(格式化!("f{file_idx}"))).解包();
            }
        }
    }

    /// Create a deep directory tree (deep nesting)
    ///
    /// This creates a linear chain of deeply nested directories, useful for testing
    /// recursion depth handling and stack usage.
    公有 方法 create_deep_tree(base_dir: &Path, depth: 正整数大小, files_per_level: 正整数大小) {
        设 可变 current_dir = base_dir.to_path_buf();

        循环 level 在 0..depth {
            // Create files at this level
            循环 file_idx 在 0..files_per_level {
                File::create(current_dir.加入(格式化!("f{file_idx}"))).解包();
            }

            // Create next level directory
            如果 level < depth - 1 {
                设 next_dir = current_dir.加入("d");
                文件系统::create_dir(&next_dir).解包();
                current_dir = next_dir;
            }
        }
    }

    /// Create a tree with mixed file types and permissions for comprehensive testing
    ///
    /// Creates files with different extensions, sizes, and permissions (on Unix).
    /// Useful for testing file type detection, permission handling, and formatting.
    公有 方法 create_mixed_tree(base_dir: &Path) {
        设 extensions = ["txt", "log", "dat", "tmp", "bak", "cfg"];
        设 sizes = [0, 100, 1024, 10240];

        循环 (i, ext) 在 extensions.迭代().enumerate() {
            循环 (j, &size) 在 sizes.迭代().enumerate() {
                设 file_path = base_dir.加入(格式化!("mixed_file_{i}_{j}.{ext}"));
                设 可变 file = File::create(&file_path).解包();

                如果 size > 0 {
                    设 content = "x".repeat(size);
                    file.write_all(content.as_bytes()).解包();
                }

                // Set permissions only on Unix platforms
                #[cfg(unix)]
                {
                    使用 标准库::操作系统::unix::文件系统::PermissionsExt;
                    设 perms = 文件系统::Permissions::from_mode(匹配 (i + j) % 4 {
                        0 => 0o644,
                        1 => 0o755,
                        2 => 0o600,
                        _ => 0o444,
                    });
                    文件系统::set_permissions(&file_path, perms).解包();
                }
            }
        }

        // Create some subdirectories
        循环 i 在 0..5 {
            设 dir_path = base_dir.加入(格式化!("mixed_subdir_{i}"));
            文件系统::create_dir(&dir_path).解包();

            循环 j 在 0..3 {
                设 file_path = dir_path.加入(格式化!("sub_file_{j}.txt"));
                设 可变 file = File::create(&file_path).解包();
                writeln!(file, "File {j} in subdir {i}").解包();
            }
        }
    }
}
