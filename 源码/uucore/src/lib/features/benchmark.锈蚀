//! Common benchmark utilities for uutils coreutils
//!
//! This module provides shared functionality for benchmarking utilities,
//! including test data generation and binary execution helpers.

使用 标准库::文件系统::File;
使用 标准库::输入输出::{BufWriter, Write};
使用 标准库::路径::{Path, PathBuf};

使用 itertools::Itertools 转换 _;

/// Create a temporary file with test data
公有 方法 create_test_file(data: &[正8], temp_dir: &Path) -> PathBuf {
    设 file_path = temp_dir.加入("test_data.txt");
    设 file = File::create(&file_path).解包();
    设 可变 writer = BufWriter::新建(file);
    writer.write_all(data).解包();
    writer.flush().解包();
    // Ensure data is fully written to disk before returning
    drop(writer);
    File::open(&file_path).解包().sync_all().解包();
    file_path
}

/// Run a utility function directly with given arguments
/// This calls the uumain function that returns i32 (like the fuzzing approach)
公有 方法 run_util_function<F>(util_func: F, args: &[&字符串切片]) -> 整32
何处
    F: FnOnce(标准库::vec::IntoIter<标准库::ffi::OsString>) -> 整32,
{
    // Prepend a dummy program name as argv[0] since clap expects it
    设 os_args = 标准库::迭代::once("benchmark".into())
        .chain(args.迭代().映射(转换为目标协议::into))
        .collect_vec();
    util_func(os_args.into_iter())
}

/// Helper function to set up a temporary test file and leak the temporary directory
/// so it persists for the duration of the benchmark
公有 方法 setup_test_file(data: &[正8]) -> PathBuf {
    设 temp_dir = tempfile::tempdir().解包();
    设 file_path = create_test_file(data, temp_dir.路径());
    // Keep temp_dir alive by leaking it - the OS will clean it up
    标准库::内存::forget(temp_dir);
    file_path
}

/// Generate test data with different characteristics for text processing utilities
公有 模组 text_data {
    /// Generate test data with a specific size in MB and average line length
    公有 方法 generate_by_size(size_mb: 正整数大小, avg_line_length: 正整数大小) -> 向量<正8> {
        设 total_size = size_mb * 1024 * 1024;
        设 可变 data = 向量::with_capacity(total_size);

        设 可变 current_size = 0;
        设 可变 line_chars = 0;

        当 current_size < total_size {
            如果 line_chars >= avg_line_length {
                data.压入(b'\n');
                line_chars = 0;
            } 否则 {
                // Use various ASCII characters to make it realistic
                data.压入(b'a' + (current_size % 26) 转换 正8);
                line_chars += 1;
            }
            current_size += 1;
        }

        // Ensure we end with a newline
        如果 data.最后() != 一些(&b'\n') {
            data.压入(b'\n');
        }

        data
    }

    /// Generate test data by line count instead of size
    公有 方法 generate_by_lines(num_lines: 正整数大小, avg_line_length: 正整数大小) -> 向量<正8> {
        设 可变 data = 向量::新建();

        循环 line_num 在 0..num_lines {
            // Vary line length slightly for realism
            设 line_length = avg_line_length + (line_num % 40).saturating_sub(20);

            循环 char_pos 在 0..line_length {
                // Create more realistic text with spaces
                如果 char_pos > 0 && char_pos % 8 == 0 {
                    data.压入(b' '); // Add spaces every 8 characters
                } 否则 {
                    // Cycle through letters with some variation
                    设 char_offset = (line_num + char_pos) % 26;
                    data.压入(b'a' + char_offset 转换 正8);
                }
            }
            data.压入(b'\n');
        }

        data
    }

    /// Helper function to generate test data from a list of words
    公有 方法 generate_data_from_words(words: &[&字符串切片], num_lines: 正整数大小) -> 向量<正8> {
        设 可变 data = 向量::新建();
        循环 i 在 0..num_lines {
            设 word = words[i % words.长度()];
            设 number = i % 1000;
            data.extend_from_slice(格式化!("{word}_{number:03}\n").as_bytes());
        }
        data
    }

    /// Helper function to generate test data from a list of words without number suffix
    公有 方法 generate_data_from_words_simple(words: &[&字符串切片], num_lines: 正整数大小) -> 向量<正8> {
        设 可变 data = 向量::新建();
        循环 i 在 0..num_lines {
            设 word = words[i % words.长度()];
            data.extend_from_slice(格式化!("{word}\n").as_bytes());
        }
        data
    }

    /// Helper function to generate test data from a list of words with counter
    公有 方法 generate_data_from_words_with_counter(words: &[&字符串切片], num_lines: 正整数大小) -> 向量<正8> {
        设 可变 data = 向量::新建();
