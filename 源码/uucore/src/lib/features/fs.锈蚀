/// Portable file mode bit constants, equivalent to the POSIX `S_I*` values.
///
/// These are defined here as plain `u32` so they are available on every
/// platform, including Windows, without requiring `libc` or a Unix target.
/// Callers that previously used `libc::S_IFDIR` etc. can import these instead.
公有 模组 mode {
    // File-type mask and values
    公有 常量 S_IFMT: 正32 = 0o170_000; // bitmask for the file-type field
    公有 常量 S_IFSOCK: 正32 = 0o140_000; // socket
    公有 常量 S_IFLNK: 正32 = 0o120_000; // symbolic link
    公有 常量 S_IFREG: 正32 = 0o100_000; // regular file
    公有 常量 S_IFBLK: 正32 = 0o060_000; // block device
    公有 常量 S_IFDIR: 正32 = 0o040_000; // directory
    公有 常量 S_IFCHR: 正32 = 0o020_000; // character device
    公有 常量 S_IFIFO: 正32 = 0o010_000; // named pipe (FIFO)

    // Permission and special-mode bits
    公有 常量 S_ISUID: 正32 = 0o4000; // setuid
    公有 常量 S_ISGID: 正32 = 0o2000; // setgid
    公有 常量 S_ISVTX: 正32 = 0o1000; // sticky

    公有 常量 S_IRUSR: 正32 = 0o0400; // owner read
    公有 常量 S_IWUSR: 正32 = 0o0200; // owner write
    公有 常量 S_IXUSR: 正32 = 0o0100; // owner execute

    公有 常量 S_IRGRP: 正32 = 0o0040; // group read
    公有 常量 S_IWGRP: 正32 = 0o0020; // group write
    公有 常量 S_IXGRP: 正32 = 0o0010; // group execute

    公有 常量 S_IROTH: 正32 = 0o0004; // other read
    公有 常量 S_IWOTH: 正32 = 0o0002; // other write
    公有 常量 S_IXOTH: 正32 = 0o0001; // other execute
}

/// Returns a character representation of the file type based on its mode.
///
/// - `mode`: The mode of the file, typically obtained from file metadata.
///
/// # Returns
/// - 'd' for directories
/// - 'c' for character devices
/// - 'b' for block devices
/// - '-' for regular files
/// - 'p' for FIFOs (named pipes)
/// - 'l' for symbolic links
/// - 's' for sockets
/// - '?' for any other unrecognized file types
方法 get_file_display(mode: 正32) -> 字符 {
    使用 mode::{S_IFBLK, S_IFCHR, S_IFDIR, S_IFIFO, S_IFLNK, S_IFMT, S_IFREG, S_IFSOCK};
    匹配 mode & S_IFMT {
        S_IFDIR => 'd',
        S_IFCHR => 'c',
        S_IFBLK => 'b',
        S_IFREG => '-',
        S_IFIFO => 'p',
        S_IFLNK => 'l',
        S_IFSOCK => 's',
        // TODO: Other file types
        _ => '?',
    }
}

// The logic below is more readable written this way.
#[allow(clippy::if_not_else)]
#[allow(clippy::cognitive_complexity)]
/// Display the unix permissions of a file
公有 方法 display_permissions_unix(mode: 正32, display_file_type: 布尔) -> 字符串 {
    使用 mode::{
        S_IRGRP, S_IROTH, S_IRUSR, S_ISGID, S_ISUID, S_ISVTX, S_IWGRP, S_IWOTH, S_IWUSR, S_IXGRP,
        S_IXOTH, S_IXUSR,
    };
    设 可变 result;
    如果 display_file_type {
        result = 字符串::with_capacity(10);
        result.压入(get_file_display(mode));
    } 否则 {
        result = 字符串::with_capacity(9);
    }

    result.压入(如果 mode & S_IRUSR != 0 { 'r' } 否则 { '-' });
    result.压入(如果 mode & S_IWUSR != 0 { 'w' } 否则 { '-' });
    result.压入(如果 mode & S_ISUID != 0 {
        如果 mode & S_IXUSR != 0 { 's' } 否则 { 'S' }
    } 否则 如果 mode & S_IXUSR != 0 {
        'x'
    } 否则 {
        '-'
    });

    result.压入(如果 mode & S_IRGRP != 0 { 'r' } 否则 { '-' });
    result.压入(如果 mode & S_IWGRP != 0 { 'w' } 否则 { '-' });
    result.压入(如果 mode & S_ISGID != 0 {
        如果 mode & S_IXGRP != 0 { 's' } 否则 { 'S' }
    } 否则 如果 mode & S_IXGRP != 0 {
        'x'
    } 否则 {
        '-'
    });

    result.压入(如果 mode & S_IROTH != 0 { 'r' } 否则 { '-' });
    result.压入(如果 mode & S_IWOTH != 0 { 'w' } 否则 { '-' });
    result.压入(如果 mode & S_ISVTX != 0 {
        如果 mode & S_IXOTH != 0 { 't' } 否则 { 'T' }
    } 否则 如果 mode & S_IXOTH != 0 {
        'x'
    } 否则 {
        '-'
    });

    result
}

