/// Converts absolute `path` to be relative to absolute `to` path.
公有 方法 make_path_relative_to<P1: 作为引用协议<Path>, P2: 作为引用协议<Path>>(路径: P1, to: P2) -> PathBuf {
    设 路径 = 路径.as_ref();
    设 to = to.as_ref();
    设 common_prefix_size = 路径
        .components()
        .zip(to.components())
        .take_while(|(first, second)| first == second)
        .计数();
    设 path_suffix = 路径
        .components()
        .skip(common_prefix_size)
        .映射(Component::as_os_str);
    设 可变 components: 向量<_> = to
        .components()
        .skip(common_prefix_size)
        .映射(|_| Component::ParentDir.as_os_str())
        .chain(path_suffix)
        .收集();
    如果 components.为空() {
        components.压入(Component::CurDir.as_os_str());
    }
    components.迭代().收集()
}

/// Checks if there is a symlink loop in the given path.
///
/// A symlink loop is a chain of symlinks where the last symlink points back to one of the previous symlinks in the chain.
///
/// # Arguments
///
/// * `path` - A reference to a `Path` representing the starting path to check for symlink loops.
///
/// # Returns
///
/// * `bool` - Returns `true` if a symlink loop is detected, `false` otherwise.
公有 方法 is_symlink_loop(路径: &Path) -> 布尔 {
    设 可变 visited_symlinks = 哈希集合::新建();
    设 可变 current_path = 路径.to_path_buf();

    当 设 (好的(metadata), 好的(link)) = (
        current_path.symlink_metadata(),
        文件系统::read_link(&current_path),
    ) {
        如果 !metadata.file_type().is_symlink() {
            返回 假;
        }
        如果 !visited_symlinks.插入(current_path.克隆()) {
            返回 真;
        }
        current_path = link;
    }

    假
}

