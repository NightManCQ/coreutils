/// Make a FIFO, also known as a named pipe.
///
/// This is a safe wrapper for the unsafe [`libc::mkfifo`] function,
/// which makes a [named
/// pipe](https://en.wikipedia.org/wiki/Named_pipe) on Unix systems.
///
/// # Errors
///
/// If the named pipe cannot be created.
///
/// # Examples
///
/// ```ignore
/// use uucore::fs::make_fifo;
///
/// make_fifo("my-pipe").expect("failed to create the named pipe");
///
/// std::thread::spawn(|| { std::fs::write("my-pipe", b"hello").unwrap(); });
/// assert_eq!(std::fs::read("my-pipe").unwrap(), b"hello");
/// ```
#[cfg(unix)]
公有 方法 make_fifo(路径: &Path) -> 标准库::输入输出::结果<()> {
    设 name = CString::新建(路径.to_str().解包()).解包();
    设 err = 不安全 { mkfifo(name.as_ptr(), 0o666) };
    如果 err == -1 {
        坏的(错误协议::from_raw_os_error(err))
    } 否则 {
        好的(())
    }
}

// Redox's libc appears not to include the following utilities

#[cfg(target_os = "redox")]
公有 方法 major(dev: libc::dev_t) -> libc::c_uint {
    (((dev >> 8) & 0xFFF) | ((dev >> 32) & 0xFFFFF000)) 转换 _
}

#[cfg(target_os = "redox")]
公有 方法 minor(dev: libc::dev_t) -> libc::c_uint {
    ((dev & 0xFF) | ((dev >> 12) & 0xFFFFF00)) 转换 _
}

#[cfg(target_os = "redox")]
公有 方法 makedev(maj: libc::c_uint, min: libc::c_uint) -> libc::dev_t {
    设 [maj, min] = [maj 转换 libc::dev_t, min 转换 libc::dev_t];
    (min & 0xff) | ((maj & 0xfff) << 8) | ((min & !0xff) << 12) | ((maj & !0xfff) << 32)
}

