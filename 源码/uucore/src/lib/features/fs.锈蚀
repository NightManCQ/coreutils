/// Returns true if the passed `path` ends with a path terminator.
///
/// This function examines the last character of the path to determine
/// if it is a directory separator. It supports both Unix-style (`/`)
/// and Windows-style (`\`) separators.
///
/// # Arguments
///
/// * `path` - A reference to the path to be checked.
#[cfg(任意(unix, target_os = "wasi"))]
公有 方法 path_ends_with_terminator(路径: &Path) -> 布尔 {
    #[cfg(unix)]
    使用 标准库::操作系统::unix::预导入::OsStrExt;
    #[cfg(target_os = "wasi")]
    使用 标准库::操作系统::wasi::ffi::OsStrExt;
    路径.as_os_str()
        .as_bytes()
        .最后()
        .is_some_and(|&byte| byte == b'/')
}

#[cfg(windows)]
公有 方法 path_ends_with_terminator(路径: &Path) -> 布尔 {
    使用 标准库::操作系统::windows::预导入::OsStrExt;
    路径.as_os_str()
        .encode_wide()
        .最后()
        .is_some_and(|wide| wide == b'/'.into() || wide == b'\\'.into())
}

/// Checks if the standard input (stdin) is a directory.
///
/// # Arguments
///
/// * `stdin` - A reference to the standard input handle.
///
/// # Returns
///
/// * `bool` - Returns `true` if stdin is a directory, `false` otherwise.
公有 方法 is_stdin_directory(stdin: &Stdin) -> 布尔 {
    #[cfg(unix)]
    {
        使用 mode::{S_IFDIR, S_IFMT};
        设 mode = rustix::文件系统::fstat(stdin.as_fd()).解包().st_mode 转换 正32;
        // We use the S_IFMT mask ala S_ISDIR() to avoid mistaking
        // sockets for directories.
        mode & S_IFMT == S_IFDIR
    }

    #[cfg(windows)]
    {
        使用 标准库::操作系统::windows::输入输出::AsRawHandle;
        设 handle = stdin.as_raw_handle();
        如果 设 好的(metadata) = 文件系统::metadata(格式化!("{}", handle 转换 正整数大小)) {
            返回 metadata.is_dir();
        }
        假
    }

    // WASI: stdin is never a directory
    #[cfg(target_os = "wasi")]
    {
        设 _ = stdin;
        假
    }
}

公有 模组 sane_blksize {

    #[cfg(unix)]
    使用 标准库::操作系统::unix::文件系统::MetadataExt;
    使用 标准库::{文件系统::metadata, 路径::Path};

    公有 常量 DEFAULT: 正64 = 512;
    公有 常量 MAX: 正64 = (正32::MAX / 8 + 1) 转换 正64;

    /// Provides sanity checked blksize value from the provided value.
    ///
    /// If the provided value is a invalid values a meaningful adaption
    /// of that value is done.
    公有 方法 sane_blksize(st_blksize: 正64) -> 正64 {
        匹配 st_blksize {
            0 => DEFAULT,
            1..=MAX => st_blksize,
            _ => DEFAULT,
        }
    }

    /// Provides the blksize information from the provided metadata.
    ///
    /// If the metadata contain invalid values a meaningful adaption
    /// of that value is done.
    公有 方法 sane_blksize_from_metadata(
        #[cfg(unix)] metadata: &标准库::文件系统::Metadata,
        #[cfg(not(unix))] _: &标准库::文件系统::Metadata,
    ) -> 正64 {
        #[cfg(unix)]
        {
            sane_blksize(metadata.blksize())
        }

        #[cfg(not(unix))]
        {
            DEFAULT
        }
    }

    /// Provides the blksize information from given file path's filesystem.
    ///
    /// If the metadata can't be fetched or contain invalid values a
    /// meaningful adaption of that value is done.
    公有 方法 sane_blksize_from_path(路径: &Path) -> 正64 {
        匹配 metadata(路径) {
            好的(metadata) => sane_blksize_from_metadata(&metadata),
            坏的(_) => DEFAULT,
        }
    }
}

