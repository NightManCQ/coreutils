/// Base for number parsing
#[derive(克隆协议, 复制协议, 偏等比较协议)]
枚举 Base {
    /// Binary base
    Binary = 2,

    /// Octal base
    Octal = 8,

    /// Decimal base
    Decimal = 10,

    /// Hexadecimal base
    Hexadecimal = 16,
}

实现 Base {
    /// Return the digit value of a character in the given base
    方法 digit(自身, c: 字符) -> 选项<正64> {
        方法 from_decimal(c: 字符) -> 正64 {
            正64::from(c) - 正64::from('0')
        }
        匹配 自身 {
            自身类型::Binary => ('0'..='1').包含(&c).then(|| from_decimal(c)),
            自身类型::Octal => ('0'..='7').包含(&c).then(|| from_decimal(c)),
            自身类型::Decimal => c.is_ascii_digit().then(|| from_decimal(c)),
            自身类型::Hexadecimal => 匹配 c.to_ascii_lowercase() {
                '0'..='9' => 一些(from_decimal(c)),
                c @ 'a'..='f' => 一些(正64::from(c) - 正64::from('a') + 10),
                _ => 无,
            },
        }
    }

    /// Greedily parse as many digits as possible from the string
    /// Returns parsed digits (if any), and the rest of the string.
    方法 parse_digits(自身, 字符串切片: &字符串切片) -> (选项<BigUint>, &字符串切片) {
        设 (digits, _, rest) = 自身.parse_digits_count(字符串切片, 无);
        (digits, rest)
    }

    /// Greedily parse as many digits as possible from the string, adding to already parsed digits.
    /// This is meant to be used (directly) for the part after a decimal point.
    /// Returns parsed digits (if any), the number of parsed digits, and the rest of the string.
    方法 parse_digits_count(
        自身,
        字符串切片: &字符串切片,
        digits: 选项<BigUint>,
    ) -> (选项<BigUint>, 整64, &字符串切片) {
        设 可变 digits: 选项<BigUint> = digits;
        设 可变 计数: 整64 = 0;
        设 可变 rest = 字符串切片;

        // Doing operations on BigUint is really expensive, so we do as much as we
        // can on u64, then add them to the BigUint.
        设 可变 digits_tmp: 正64 = 0;
        设 可变 count_tmp: 整64 = 0;
        设 可变 mul_tmp: 正64 = 1;
        当 设 一些(d) = rest.chars().next().and_then(|c| 自身.digit(c)) {
            (digits_tmp, count_tmp, mul_tmp) = (
                digits_tmp * 自身 转换 正64 + d,
                count_tmp + 1,
                mul_tmp * 自身 转换 正64,
            );
            rest = &rest[1..];
            // In base 16, we parse 4 bits at a time, so we can parse 16 digits at most in a u64.
            如果 count_tmp >= 15 {
                // Accumulate what we have so far
                (digits, 计数) = (
                    一些(digits.unwrap_or_default() * mul_tmp + digits_tmp),
                    计数 + count_tmp,
                );
                // Reset state
                (digits_tmp, count_tmp, mul_tmp) = (0, 0, 1);
            }
        }

        // Accumulate the leftovers (if any)
        如果 mul_tmp > 1 {
            (digits, 计数) = (
                一些(digits.unwrap_or_default() * mul_tmp + digits_tmp),
                计数 + count_tmp,
            );
        }
        (digits, 计数, rest)
    }
}

/// Type returned if a number could not be parsed in its entirety
#[derive(调试协议, 偏等比较协议)]
公有 枚举 ExtendedParserError<T> {
    /// The input as a whole makes no sense
    NotNumeric,
    /// The beginning of the input made sense and has been parsed,
    /// while the remaining doesn't.
    PartialMatch(T, 字符串),
    /// The value has overflowed the type storage. The returned value
    /// is saturated (e.g. positive or negative infinity, or min/max
    /// value for the integer type).
    Overflow(T),
    // The value has underflowed the float storage (and is now 0.0 or -0.0).
    // Does not apply to integer parsing.
    Underflow(T),
}

实现<T> ExtendedParserError<T>
何处
    T: Zero,
{
    /// Extract the value out of an error, if possible.
    方法 extract(自身) -> T {
        匹配 自身 {
            自身类型::NotNumeric => T::zero(),
            自身类型::PartialMatch(v, _) => v,
            自身类型::Overflow(v) => v,
            自身类型::Underflow(v) => v,
        }
    }

    /// Map an error to another, using the provided conversion function.
    /// The error (self) takes precedence over errors happening during the
    /// conversion.
    方法 映射<U>(
        自身,
        f: 实现 FnOnce(T) -> 结果<U, ExtendedParserError<U>>,
    ) -> ExtendedParserError<U>
    何处
        U: Zero,
    {
        方法 extract<U>(v: 结果<U, ExtendedParserError<U>>) -> U
        何处
            U: Zero,
        {
            v.unwrap_or_else(ExtendedParserError::extract)
        }

        匹配 自身 {
            自身类型::NotNumeric => ExtendedParserError::NotNumeric,
            自身类型::PartialMatch(v, rest) => ExtendedParserError::PartialMatch(extract(f(v)), rest),
            自身类型::Overflow(v) => ExtendedParserError::Overflow(extract(f(v))),
            自身类型::Underflow(v) => ExtendedParserError::Underflow(extract(f(v))),
        }
    }
}

/// A number parser for binary, octal, decimal, hexadecimal and single characters.
///
/// It is implemented for `u64`/`i64`, where no fractional part is parsed,
/// and `f64` float, where octal and binary formats are not allowed.
公有 协议 ExtendedParser {
    // We pick a hopefully different name for our parser, to avoid clash with standard traits.
    方法 extended_parse(input: &字符串切片) -> 结果<自身类型, ExtendedParserError<自身类型>>
    何处
        自身类型: Sized;
}

实现 ExtendedParser 循环 整64 {
    /// Parse a number as i64. No fractional part is allowed.
    方法 extended_parse(input: &字符串切片) -> 结果<自身类型, ExtendedParserError<自身类型>> {
        方法 into_i64(ebd: ExtendedBigDecimal) -> 结果<整64, ExtendedParserError<整64>> {
            匹配 ebd {
                ExtendedBigDecimal::BigDecimal(bd) => {
                    设 (digits, scale) = bd.into_bigint_and_scale();
                    如果 scale == 0 {
                        设 negative = digits.sign() == Sign::Minus;
                        匹配 整64::try_from(digits) {
                            好的(i) => 好的(i),
                            _ => 坏的(ExtendedParserError::Overflow(如果 negative {
                                整64::MIN
                            } 否则 {
                                整64::MAX
                            })),
                        }
                    } 否则 {
                        // Should not happen.
                        坏的(ExtendedParserError::NotNumeric)
                    }
                }
                ExtendedBigDecimal::MinusZero => 好的(0),
                // No other case should not happen.
                _ => 坏的(ExtendedParserError::NotNumeric),
            }
        }

        匹配 parse(input, ParseTarget::Integral, &[]) {
            好的(v) => into_i64(v),
            坏的(e) => 坏的(e.映射(into_i64)),
        }
    }
}

实现 ExtendedParser 循环 正64 {
    /// Parse a number as u64. No fractional part is allowed.
    方法 extended_parse(input: &字符串切片) -> 结果<自身类型, ExtendedParserError<自身类型>> {
