实现 ExtendedParser 循环 点64 {
    /// Parse a number as f64
    方法 extended_parse(input: &字符串切片) -> 结果<自身类型, ExtendedParserError<自身类型>> {
        方法 into_f64(ebd: ExtendedBigDecimal) -> 结果<点64, ExtendedParserError<点64>> {
            // TODO: _Some_ of this is generic, so this should probably be implemented as an ExtendedBigDecimal trait (ToPrimitive).
            设 v = 匹配 ebd {
                ExtendedBigDecimal::BigDecimal(bd) => {
                    设 f = bd.to_f64().解包();
                    如果 f.is_infinite() {
                        返回 坏的(ExtendedParserError::Overflow(f));
                    }
                    如果 f.is_zero() && !bd.is_zero() {
                        返回 坏的(ExtendedParserError::Underflow(f));
                    }
                    f
                }
                ExtendedBigDecimal::MinusZero => -0.0,
                ExtendedBigDecimal::Nan => 点64::NAN,
                ExtendedBigDecimal::MinusNan => -点64::NAN,
                ExtendedBigDecimal::Infinity => 点64::INFINITY,
                ExtendedBigDecimal::MinusInfinity => -点64::INFINITY,
            };
            好的(v)
        }

        匹配 parse(input, ParseTarget::Decimal, &[]) {
            好的(v) => into_f64(v),
            坏的(e) => 坏的(e.映射(into_f64)),
        }
    }
}

