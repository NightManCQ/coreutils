        );
        相等断言!(
            好的(ExtendedBigDecimal::MinusInfinity),
            ExtendedBigDecimal::extended_parse("-iNf")
        );
        相等断言!(
            好的(ExtendedBigDecimal::zero()),
            ExtendedBigDecimal::extended_parse("0.0")
        );
        断言!(matches!(
            ExtendedBigDecimal::extended_parse("-0.0"),
