        相等断言!(好的(1024 * 1024), parser.parse("1M"));
        相等断言!(好的(1024 * 1024 * 1024), parser.parse("1G"));

        断言!(parser.parse("1T").is_err());
        断言!(parser.parse("1P").is_err());
        断言!(parser.parse("1E").is_err());

        parser
            .with_allow_list(&[
                "b", "k", "K", "m", "M", "MB", "g", "G", "t", "T", "P", "E", "Z", "Y", "R", "Q",
            ])
            .with_default_unit("K")
            .with_b_byte_count(真);

        相等断言!(好的(1024), parser.parse("1"));
        相等断言!(好的(2 * 1024), parser.parse("2"));
        相等断言!(好的(1000 * 1000), parser.parse("1MB"));
        相等断言!(好的(1024 * 1024), parser.parse("1M"));
        相等断言!(好的(1024 * 1024 * 1024), parser.parse("1G"));
        相等断言!(
            好的(1_237_940_039_285_380_274_899_124_224),
            parser.parse_u128("1R")
        );
        相等断言!(
            好的(1_267_650_600_228_229_401_496_703_205_376),
            parser.parse_u128("1Q")
        );

        相等断言!(好的(1), parser.parse("1b"));
        相等断言!(好的(1024), parser.parse("1024b"));
        相等断言!(好的(1024 * 1024 * 1024), parser.parse("1024Mb"));

        断言!(parser.parse("b").is_err());
        断言!(parser.parse("1B").is_err());
        断言!(parser.parse("B").is_err());
    }

