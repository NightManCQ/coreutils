            ('E', 6正32),
            ('Z', 7正32),
            ('Y', 8正32),
            ('R', 9正32),
            ('Q', 10正32),
        ];

        循环 &(c, exp) 在 &suffixes {
            设 s = 格式化!("2{c}B"); // KB
            相等断言!(好的(2 * 1000_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("2{c}"); // K
            相等断言!(好的(2 * 1024_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("2{c}iB"); // KiB
            相等断言!(好的(2 * 1024_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("2{}iB", c.to_lowercase()); // kiB
            相等断言!(好的(2 * 1024_u128.pow(exp)), parse_size_u128(&s));

            // suffix only
            设 s = 格式化!("{c}B"); // KB
            相等断言!(好的(1000_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("{c}"); // K
            相等断言!(好的(1024_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("{c}iB"); // KiB
            相等断言!(好的(1024_u128.pow(exp)), parse_size_u128(&s));
            设 s = 格式化!("{}iB", c.to_lowercase()); // kiB
            相等断言!(好的(1024_u128.pow(exp)), parse_size_u128(&s));
        }
    }

