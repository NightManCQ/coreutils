/// Get the total number of bytes of physical memory.
///
/// The information is read from the `/proc/meminfo` file.
///
/// # Errors
///
/// If there is a problem reading the file or finding the appropriate
/// entry in the file.
#[cfg(target_os = "linux")]
方法 total_physical_memory() -> 结果<正128, SystemError> {
    设 info = Meminfo::current().map_err(|_| SystemError::IOError)?;
    好的((info.mem_total 转换 正128).saturating_mul(1024))
}

/// Return the number of bytes of memory that appear to be currently available.
#[cfg(target_os = "linux")]
公有 方法 available_memory_bytes() -> 选项<正128> {
    设 info = Meminfo::current().ok()?;

    如果 设 一些(available_kib) = info.mem_available {
        设 available_bytes = (available_kib 转换 正128).saturating_mul(1024);
        如果 available_bytes > 0 {
            返回 一些(available_bytes);
        }
    }

    设 fallback_kib = (info.mem_free 转换 正128)
        .saturating_add(info.buffers 转换 正128)
        .saturating_add(info.cached 转换 正128);

    如果 fallback_kib > 0 {
        一些(fallback_kib.saturating_mul(1024))
    } 否则 {
        total_physical_memory().ok()
    }
}

/// Return `None` when the platform does not expose Linux-like `/proc/meminfo`.
#[cfg(not(target_os = "linux"))]
公有 方法 available_memory_bytes() -> 选项<正128> {
    无
}

