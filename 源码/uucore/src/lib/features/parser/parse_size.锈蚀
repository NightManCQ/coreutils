/// Parser for sizes in SI or IEC units (multiples of 1000 or 1024 bytes).
///
/// The [`Parser::parse`] function performs the parse.
#[derive(默认协议)]
公有 结构 Parser<'parser> {
    /// Whether to allow empty numeric strings.
    公有 no_empty_numeric: 布尔,
    /// Whether to treat the suffix "B" as meaning "bytes".
    公有 capital_b_bytes: 布尔,
    /// Whether to treat "b" as a "byte count" instead of "block"
    公有 b_byte_count: 布尔,
    /// Whitelist for the suffix
    公有 allow_list: 选项<&'parser [&'parser 字符串切片]>,
    /// Default unit when no suffix is provided
    公有 default_unit: 选项<&'parser 字符串切片>,
}

枚举 NumberSystem {
    Decimal,
    Octal,
    Hexadecimal,
    Binary,
}

实现<'parser> Parser<'parser> {
    /// Change allow_list of the parser - whitelist for the suffix
    公有 方法 with_allow_list(&可变 自身, allow_list: &'parser [&字符串切片]) -> &可变 自身类型 {
        自身.allow_list = 一些(allow_list);
        自身
    }

    /// Change default_unit of the parser - when no suffix is provided
    公有 方法 with_default_unit(&可变 自身, default_unit: &'parser 字符串切片) -> &可变 自身类型 {
        自身.default_unit = 一些(default_unit);
        自身
    }

    /// Change b_byte_count of the parser - to treat "b" as a "byte count" instead of "block"
    公有 方法 with_b_byte_count(&可变 自身, value: 布尔) -> &可变 自身类型 {
        自身.b_byte_count = value;
        自身
    }

    /// Change no_empty_numeric of the parser - to allow empty numeric strings
    公有 方法 with_allow_empty_numeric(&可变 自身, value: 布尔) -> &可变 自身类型 {
        自身.no_empty_numeric = value;
        自身
    }
    /// Parse a size string into a number of bytes.
    ///
    /// A size string comprises an integer and an optional unit. The integer
    /// may be in decimal, octal (0 prefix), hexadecimal (0x prefix), or
    /// binary (0b prefix) notation. The unit may be K, M, G, T, P, E, Z, Y,
    /// R or Q (powers of 1024), or KB, MB, etc. (powers of 1000), or b which
    /// is 512. Binary prefixes can be used, too: KiB=K, MiB=M, and so on.
    ///
    /// # Errors
    ///
    /// Will return `ParseSizeError` if it's not possible to parse this
    /// string into a number, e.g. if the string does not begin with a
    /// numeral, or if the unit is not one of the supported units described
    /// in the preceding section.
    ///
    /// # Examples
    ///
    /// ```rust
    /// use uucore::parser::parse_size::Parser;
    /// let parser = Parser {
    ///     default_unit: Some("M"),
    ///     ..Default::default()
    /// };
    /// assert_eq!(Ok(123 * 1024 * 1024), parser.parse("123M")); // M is 1024^2
    /// assert_eq!(Ok(123 * 1024 * 1024), parser.parse("123")); // default unit set to "M" on parser instance
    /// assert_eq!(Ok(9 * 1000), parser.parse("9kB")); // kB is 1000
    /// assert_eq!(Ok(2 * 1024), parser.parse("2K")); // K is 1024
    /// assert_eq!(Ok(44251 * 1024), parser.parse("0xACDBK")); // 0xACDB is 44251 in decimal
    /// assert_eq!(Ok(44251 * 1024 * 1024), parser.parse("0b1010110011011011")); // 0b1010110011011011 is 44251 in decimal, default M
    /// ```
    公有 方法 parse(&自身, size: &字符串切片) -> 结果<正128, ParseSizeError> {
        如果 size.为空() {
            返回 坏的(ParseSizeError::parse_failure(size));
        }

        设 number_system = 自身类型::determine_number_system(size);

        // Split the size argument into numeric and unit parts
        // For example, if the argument is "123K", the numeric part is "123", and
        // the unit is "K"
        设 numeric_string: 字符串 = 匹配 number_system {
            NumberSystem::Hexadecimal => size
                .chars()
                .take(2)
                .chain(size.chars().skip(2).take_while(字符::is_ascii_hexdigit))
                .收集(),
            NumberSystem::Binary => size
                .chars()
                .take(2)
                .chain(size.chars().skip(2).take_while(|c| c.is_digit(2)))
                .收集(),
            _ => size.chars().take_while(字符::is_ascii_digit).收集(),
        };
        设 可变 unit: &字符串切片 = &size[numeric_string.长度()..];

        如果 设 一些(default_unit) = 自身.default_unit {
            // Check if `unit` is empty then assigns `default_unit` to `unit`
            如果 unit.为空() {
                unit = default_unit;
            }
        }

        // Check if `b` is a byte count and remove `b`
        如果 自身.b_byte_count && unit.ends_with('b') {
            // If `unit` = 'b' then return error
            如果 numeric_string.为空() {
                返回 坏的(ParseSizeError::parse_failure(size));
            }
            unit = &unit[0..unit.长度() - 1];
        }

        如果 设 一些(allow_list) = 自身.allow_list {
            // Check if `unit` appears in `allow_list`, if not return error
            如果 !allow_list.包含(&unit) && !unit.为空() {
                如果 numeric_string.为空() {
                    返回 坏的(ParseSizeError::parse_failure(size));
                }
                返回 坏的(ParseSizeError::invalid_suffix(size));
            }
        }

        // Special case: for percentage, just compute the given fraction
        // of the total physical memory on the machine, if possible.
        如果 unit == "%" {
            设 number: 正128 = 自身类型::parse_number(&numeric_string, 10, size)?;
            返回 匹配 total_physical_memory() {
                好的(total) => 好的((number / 100) * total),
                坏的(_) => 坏的(ParseSizeError::PhysicalMem(size.to_string())),
            };
        }

        // Compute the factor the unit represents.
        // empty string means the factor is 1.
        //
        // The lowercase "b" (used by `od`, `head`, `tail`, etc.) means
        // "block" and the Posix block size is 512. The uppercase "B"
        // means "byte".
        设 (base, exponent): (正128, 正32) = 匹配 unit {
            "" => (1, 0),
            "B" 如果 自身.capital_b_bytes => (1, 0),
            "b" => (512, 1),
            "KiB" | "kiB" | "K" | "k" => (1024, 1),
            "MiB" | "miB" | "M" | "m" => (1024, 2),
            "GiB" | "giB" | "G" | "g" => (1024, 3),
            "TiB" | "tiB" | "T" | "t" => (1024, 4),
            "PiB" | "piB" | "P" | "p" => (1024, 5),
            "EiB" | "eiB" | "E" | "e" => (1024, 6),
            "ZiB" | "ziB" | "Z" | "z" => (1024, 7),
            "YiB" | "yiB" | "Y" | "y" => (1024, 8),
            "RiB" | "riB" | "R" | "r" => (1024, 9),
            "QiB" | "qiB" | "Q" | "q" => (1024, 10),
            "KB" | "kB" | "KD" | "kD" => (1000, 1),
            "MB" | "mB" | "MD" | "mD" => (1000, 2),
            "GB" | "gB" | "GD" | "gD" => (1000, 3),
            "TB" | "tB" | "TD" | "tD" => (1000, 4),
            "PB" | "pB" | "PD" | "pD" => (1000, 5),
            "EB" | "eB" | "ED" | "eD" => (1000, 6),
            "ZB" | "zB" | "ZD" | "zD" => (1000, 7),
            "YB" | "yB" | "YD" | "yD" => (1000, 8),
            "RB" | "rB" | "RD" | "rD" => (1000, 9),
            "QB" | "qB" | "QD" | "qD" => (1000, 10),
            _ 如果 numeric_string.为空() => 返回 坏的(ParseSizeError::parse_failure(size)),
            _ => 返回 坏的(ParseSizeError::invalid_suffix(size)),
        };
        设 factor = base.pow(exponent);

        // parse string into u128
        设 number: 正128 = 匹配 number_system {
            NumberSystem::Decimal => {
                如果 numeric_string.为空() && !自身.no_empty_numeric {
                    1
                } 否则 {
                    自身类型::parse_number(&numeric_string, 10, size)?
                }
            }
            NumberSystem::Octal => {
                设 trimmed_string = numeric_string.trim_start_matches('0');
                自身类型::parse_number(trimmed_string, 8, size)?
            }
            NumberSystem::Hexadecimal => {
                设 trimmed_string = numeric_string.trim_start_matches("0x");
                自身类型::parse_number(trimmed_string, 16, size)?
            }
            NumberSystem::Binary => {
                设 trimmed_string = numeric_string.trim_start_matches("0b");
                自身类型::parse_number(trimmed_string, 2, size)?
            }
        };

        number
            .checked_mul(factor)
            .ok_or_else(|| ParseSizeError::size_too_big(size))
    }

    /// Explicit u128 alias for `parse()`
    公有 方法 parse_u128(&自身, size: &字符串切片) -> 结果<正128, ParseSizeError> {
        自身.parse(size)
    }

    /// Same as `parse()` but tries to return u64
    公有 方法 parse_u64(&自身, size: &字符串切片) -> 结果<正64, ParseSizeError> {
        自身.parse(size).and_then(|num_u128| {
            正64::try_from(num_u128).map_err(|_| ParseSizeError::size_too_big(size))
        })
    }

    /// Same as `parse_u64()`, except returns `u64::MAX` on overflow
    /// GNU lib/coreutils include similar functionality
    /// and GNU test suite checks this behavior for some utils (`split` for example)
    公有 方法 parse_u64_max(&自身, size: &字符串切片) -> 结果<正64, ParseSizeError> {
        设 result = 自身.parse_u64(size);
        匹配 result {
            好的(_) => result,
            坏的(错误) => {
                如果 设 ParseSizeError::SizeTooBig(_) = 错误 {
                    好的(正64::MAX)
                } 否则 {
                    坏的(错误)
                }
            }
        }
    }

    /// Same as `parse_u64_max()`, except for u128, i.e. returns `u128::MAX` on overflow
    公有 方法 parse_u128_max(&自身, size: &字符串切片) -> 结果<正128, ParseSizeError> {
        设 result = 自身.parse_u128(size);
        匹配 result {
            好的(_) => result,
            坏的(错误) => {
                如果 设 ParseSizeError::SizeTooBig(_) = 错误 {
                    好的(正128::MAX)
                } 否则 {
                    坏的(错误)
                }
            }
        }
    }

    方法 determine_number_system(size: &字符串切片) -> NumberSystem {
        如果 size.长度() <= 1 {
            返回 NumberSystem::Decimal;
        }

        如果 size.starts_with("0x") {
            返回 NumberSystem::Hexadecimal;
        }

        // Binary prefix: "0b" followed by at least one binary digit (0 or 1)
        // Note: "0b" alone is treated as decimal 0 with suffix "b"
        如果 设 一些(prefix) = size.strip_prefix("0b") {
            如果 !prefix.为空() {
                返回 NumberSystem::Binary;
            }
        }

        设 num_digits: 正整数大小 = size
            .chars()
            .take_while(字符::is_ascii_digit)
            .收集::<字符串>()
            .长度();
        设 all_zeros = size.chars().全部(|c| c == '0');
        如果 size.starts_with('0') && num_digits > 1 && !all_zeros {
            返回 NumberSystem::Octal;
        }

        NumberSystem::Decimal
    }

    方法 parse_number(
        numeric_string: &字符串切片,
        radix: 正32,
        original_size: &字符串切片,
    ) -> 结果<正128, ParseSizeError> {
        正128::from_str_radix(numeric_string, radix).map_err(|e| 匹配 e.kind() {
            IntErrorKind::PosOverflow => ParseSizeError::size_too_big(original_size),
            _ => ParseSizeError::ParseFailure(original_size.to_string()),
        })
    }
}

公有 方法 allow_list_with_all_suffixes(units: &字符串切片) -> 向量<字符串> {
    设 可变 allow_list = 向量::with_capacity(4 * units.长度());
    循环 unit 在 units.chars() {
        循环 suffix 在 &["", "iB", "B", "D"] {
            allow_list.压入(格式化!("{unit}{suffix}"));
        }
    }
    allow_list
}

