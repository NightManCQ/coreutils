//! Systemd-logind support for reading login records
//!
//! This module provides systemd-logind based implementation for reading
//! login records as an alternative to traditional utmp/utmpx files.
//! When the systemd-logind feature is enabled and systemd is available,
//! this will be used instead of traditional utmp files.

使用 标准库::ffi::CStr;
使用 标准库::内存::MaybeUninit;
使用 标准库::时间::{SystemTime, UNIX_EPOCH};

使用 箱::错误::{UResult, USimpleError};

/// FFI bindings for libsystemd login and D-Bus functions
模组 ffi {
    使用 标准库::ffi::c_char;
    使用 标准库::操作系统::raw::{c_int, c_uint};

    #[link(name = "systemd")]
    不安全 外部 "C" {
        公有 方法 sd_get_sessions(sessions: *可变 *可变 *可变 c_char) -> c_int;
        公有 方法 sd_session_get_uid(session: *常量 c_char, uid: *可变 c_uint) -> c_int;
        公有 方法 sd_session_get_start_time(session: *常量 c_char, usec: *可变 正64) -> c_int;
        公有 方法 sd_session_get_tty(session: *常量 c_char, tty: *可变 *可变 c_char) -> c_int;
        公有 方法 sd_session_get_remote_host(
            session: *常量 c_char,
            remote_host: *可变 *可变 c_char,
        ) -> c_int;
        公有 方法 sd_session_get_display(session: *常量 c_char, display: *可变 *可变 c_char) -> c_int;
        公有 方法 sd_session_get_type(session: *常量 c_char, session_type: *可变 *可变 c_char)
        -> c_int;
        公有 方法 sd_session_get_seat(session: *常量 c_char, seat: *可变 *可变 c_char) -> c_int;

    }
}

