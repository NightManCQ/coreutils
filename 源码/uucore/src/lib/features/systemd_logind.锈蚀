        设 mock_records = 向量![
            SystemdLoginRecord {
                session_id: "session1".to_string(),
                user: "user1".to_string(),
                seat_or_tty: "tty1".to_string(),
                raw_device: "tty1".to_string(),
                host: "host1".to_string(),
                login_time: UNIX_EPOCH,
                pid: 1234,
                session_leader_pid: 1234,
                record_type: SystemdRecordType::UserProcess,
            },
            SystemdLoginRecord {
                session_id: "session2".to_string(),
                user: "user2".to_string(),
                seat_or_tty: "pts/0".to_string(),
                raw_device: "pts/0".to_string(),
                host: "host2".to_string(),
                login_time: UNIX_EPOCH,
                pid: 5678,
                session_leader_pid: 5678,
                record_type: SystemdRecordType::UserProcess,
            },
        ];

        设 可变 迭代 = SystemdUtmpxIter {
            records: mock_records,
            current_index: 0,
        };

        相等断言!(迭代.长度(), 2);
        断言!(!迭代.为空());

        // Test iterator behavior
        设 first = 迭代.next();
        断言!(first.is_some());

        设 second = 迭代.next();
        断言!(second.is_some());

        设 third = 迭代.next();
        断言!(third.is_none());

        // Iterator should be exhausted
        断言!(迭代.next().is_none());
    }

