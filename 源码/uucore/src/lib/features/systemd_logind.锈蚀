    /// Get all active sessions
    公有 方法 get_sessions() -> 结果<向量<字符串>, 盒子<动态 标准库::错误::错误协议>> {
        设 可变 sessions_ptr: *可变 *可变 libc::c_char = 指针::null_mut();

        设 result = 不安全 { ffi::sd_get_sessions(&raw 可变 sessions_ptr) };

        如果 result < 0 {
            返回 坏的(格式化!("sd_get_sessions failed: {result}").into());
        }

        设 可变 sessions = 向量::新建();
        如果 !sessions_ptr.is_null() {
            设 可变 i = 0;
            无限循环 {
                设 session_ptr = 不安全 { *sessions_ptr.add(i) };
                如果 session_ptr.is_null() {
                    中断;
                }

                设 session_cstr = 不安全 { CStr::from_ptr(session_ptr) };
                sessions.压入(session_cstr.to_string_lossy().into_owned());

                不安全 { libc::free(session_ptr.cast()) };
                i += 1;
            }

            不安全 { libc::free(sessions_ptr.cast()) };
        }

        好的(sessions)
    }

