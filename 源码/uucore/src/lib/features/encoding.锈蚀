实现 SupportsFastDecodeAndEncode 循环 Base64SimdWrapper {
    方法 alphabet(&自身) -> &'静态 [正8] {
        自身.alphabet
    }

    方法 decode_into_vec(&自身, input: &[正8], output: &可变 向量<正8>) -> UResult<()> {
        设 original_len = output.长度();

        设 decode_result = 如果 自身.use_padding {
            // GNU coreutils keeps decoding even when '=' appears before the true end
            // of the stream (e.g. concatenated padded chunks). Mirror that logic
            // by splitting at each '='-containing quantum, decoding those 4-byte
            // groups with the padded variant, then letting the remainder fall back
            // to whichever alphabet fits.
            设 可变 start = 0正整数大小;
            当 start < input.长度() {
                设 remaining = &input[start..];

                如果 remaining.为空() {
                    中断;
                }

                如果 设 一些(eq_rel_idx) = remaining.迭代().position(|&b| b == b'=') {
                    设 blocks = (eq_rel_idx / 4) + 1;
                    设 segment_len = blocks * 4;

                    如果 segment_len > remaining.长度() {
                        返回 坏的(USimpleError::新建(1, "error: invalid input"));
                    }

                    如果 自身类型::decode_with_standard(&remaining[..segment_len], output).is_err() {
                        返回 坏的(USimpleError::新建(1, "error: invalid input"));
                    }

                    start += segment_len;
                } 否则 {
                    // If there are no more '=' bytes the tail might still be padded
                    // (len % 4 == 0) or purposely unpadded (GNU --ignore-garbage or
                    // concatenated streams), so select the matching alphabet.
                    设 decoder = 如果 remaining.长度().is_multiple_of(4) {
                        自身类型::decode_with_standard
                    } 否则 {
                        自身类型::decode_with_no_pad
                    };

                    如果 decoder(remaining, output).is_err() {
                        返回 坏的(USimpleError::新建(1, "error: invalid input"));
                    }

                    中断;
                }
            }

            好的(())
        } 否则 {
            自身类型::decode_with_no_pad(input, output)
                .map_err(|_| USimpleError::新建(1, "error: invalid input"))
        };

        如果 设 坏的(err) = decode_result {
            output.truncate(original_len);
            坏的(err)
        } 否则 {
            好的(())
        }
    }

    方法 encode_to_vec_deque(&自身, input: &[正8], output: &可变 VecDeque<正8>) -> UResult<()> {
        设 encoded = 如果 自身.use_padding {
            base64_simd::STANDARD.encode_to_string(input)
        } 否则 {
            base64_simd::STANDARD_NO_PAD.encode_to_string(input)
        };

        output.extend(encoded.as_bytes());

        好的(())
    }

    方法 unpadded_multiple(&自身) -> 正整数大小 {
        自身.unpadded_multiple
    }

    方法 valid_decoding_multiple(&自身) -> 正整数大小 {
        自身.valid_decoding_multiple
    }
}

