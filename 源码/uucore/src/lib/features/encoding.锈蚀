        }

        设 string = z85::encode(input);

        output.extend(string.as_bytes());

        好的(())
    }

    方法 unpadded_multiple(&自身) -> 正整数大小 {
        4
    }
}

实现 SupportsFastDecodeAndEncode 循环 EncodingWrapper {
    方法 alphabet(&自身) -> &'静态 [正8] {
        自身.alphabet
    }

    // Adapted from `decode` in the "data-encoding" crate
    方法 decode_into_vec(&自身, input: &[正8], output: &可变 向量<正8>) -> UResult<()> {
        设 decode_len_result = 匹配 自身.encoding.decode_len(input.长度()) {
            好的(us) => us,
            坏的(_de) => {
                返回 坏的(USimpleError::新建(1, "error: invalid input"));
            }
        };

        设 output_len = output.长度();

        output.resize(output_len + decode_len_result, 0);

        匹配 自身.encoding.decode_mut(input, &可变 (output[output_len..])) {
            好的(us) => {
                // See:
                // https://docs.rs/data-encoding/latest/data_encoding/struct.Encoding.html#method.decode_mut
                // "Returns the length of the decoded output. This length may be smaller than the output length if the input contained padding or ignored characters. The output bytes after the returned length are not initialized and should not be read."
                output.truncate(output_len + us);
            }
            坏的(_de) => {
                返回 坏的(USimpleError::新建(1, "error: invalid input"));
            }
        }

        好的(())
    }

    方法 valid_decoding_multiple(&自身) -> 正整数大小 {
        自身.valid_decoding_multiple
    }

    // Adapted from `encode_append` in the "data-encoding" crate
    方法 encode_to_vec_deque(&自身, input: &[正8], output: &可变 VecDeque<正8>) -> UResult<()> {
        设 output_len = output.长度();

        output.resize(output_len + 自身.encoding.encode_len(input.长度()), 0);

        设 make_contiguous_result = output.make_contiguous();

        自身.encoding
            .encode_mut(input, &可变 (make_contiguous_result[output_len..]));

        好的(())
    }

    方法 unpadded_multiple(&自身) -> 正整数大小 {
        自身.unpadded_multiple
    }
}

