公有 协议 SupportsFastDecodeAndEncode {
    /// Returns the list of characters used by this encoding
    方法 alphabet(&自身) -> &'静态 [正8];

    方法 decode_into_vec(&自身, input: &[正8], output: &可变 向量<正8>) -> UResult<()>;

    方法 encode_to_vec_deque(&自身, input: &[正8], output: &可变 VecDeque<正8>) -> UResult<()>;

    /// Inputs with a length that is a multiple of this number do not have padding when encoded. For instance:
    ///
    /// "The quick brown"
    ///
    /// is 15 characters (divisible by 3), so it is encoded in Base64 without padding:
    ///
    /// "VGhlIHF1aWNrIGJyb3du"
    ///
    /// While:
    ///
    /// "The quick brown fox"
    ///
    /// is 19 characters, which is not divisible by 3, so its Base64 representation has padding:
    ///
    /// "VGhlIHF1aWNrIGJyb3duIGZveA=="
    ///
    /// The encoding performed by `fast_encode` depends on this number being correct.
    方法 unpadded_multiple(&自身) -> 正整数大小;

    /// Data to decode must be a length that is multiple of this number
    ///
    /// The decoding performed by `fast_decode` depends on this number being correct.
    方法 valid_decoding_multiple(&自身) -> 正整数大小;

    /// Whether the decoder can flush partial chunks (multiples of `valid_decoding_multiple`)
    /// before seeing the full input. Defaults to `false` for encodings that must consume the
    /// entire input (e.g. base58).
    方法 supports_partial_decode(&自身) -> 布尔 {
        假
    }

    /// Gives encoding-specific logic a chance to pad a trailing, non-empty remainder
    /// before the final decode attempt. The default implementation opts out.
    方法 pad_remainder(&自身, _remainder: &[正8]) -> 选项<PadResult> {
        无
    }
}

实现 SupportsFastDecodeAndEncode 循环 Base58Wrapper {
    方法 alphabet(&自身) -> &'静态 [正8] {
        // Base58 alphabet
        b"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz"
    }

    方法 decode_into_vec(&自身, input: &[正8], output: &可变 向量<正8>) -> UResult<()> {
        如果 input.为空() {
            返回 好的(());
        }

        // Count leading zeros (will become leading 1s in base58)
        设 leading_ones = input.迭代().take_while(|&&b| b == b'1').计数();

        // Skip leading 1s for conversion
        设 input_trimmed = &input[leading_ones..];
        如果 input_trimmed.为空() {
            output.resize(output.长度() + leading_ones, 0);
            返回 好的(());
        }

        // Convert base58 to big integer
        设 可变 数字: 向量<正32> = 向量![0];
        设 alphabet = 自身.alphabet();

        循环 &byte 在 input_trimmed {
            // Find position in alphabet
            设 digit = alphabet
                .迭代()
                .position(|&b| b == byte)
                .ok_or_else(|| USimpleError::新建(1, "error: invalid input"))?;

            // Multiply by 58 and add digit
            设 可变 carry = digit 转换 正32;
            循环 n 在 &可变 数字 {
                设 tmp = (*n 转换 正64) * 58 + carry 转换 正64;
                *n = tmp 转换 正32;
                carry = (tmp >> 32) 转换 正32;
            }
            如果 carry > 0 {
                数字.压入(carry);
            }
        }

        // Convert to bytes (little endian, then reverse)
        设 可变 result = 向量::新建();
        循环 &n 在 &数字 {
            result.extend_from_slice(&n.to_le_bytes());
        }

        // Remove trailing zeros and reverse to get big endian
        当 result.最后() == 一些(&0) && result.长度() > 1 {
            result.弹出();
        }
        result.reverse();

        // Add leading zeros for leading 1s in input
        设 可变 final_result = 向量![0; leading_ones];
        final_result.extend_from_slice(&result);

        output.extend_from_slice(&final_result);
        好的(())
    }

    方法 encode_to_vec_deque(&自身, input: &[正8], output: &可变 VecDeque<正8>) -> UResult<()> {
        如果 input.为空() {
            返回 好的(());
        }

        // Count leading zeros
        设 leading_zeros = input.迭代().take_while(|&&b| b == 0).计数();

        // Skip leading zeros
        设 input_trimmed = &input[leading_zeros..];
        如果 input_trimmed.为空() {
            循环 _ 在 0..leading_zeros {
                output.push_back(b'1');
            }
            返回 好的(());
        }

        // Convert bytes to big integer (Vec<u32> in little-endian format)
        设 可变 数字 = 向量::with_capacity(input_trimmed.长度().div_ceil(4) + 1);
        循环 &byte 在 input_trimmed {
            设 可变 carry = byte 转换 正64;
            循环 n 在 &可变 数字 {
                设 tmp = (*n 转换 正64) * 256 + carry;
                *n = tmp 转换 正32;
                carry = tmp >> 32;
            }
            如果 carry > 0 {
                数字.压入(carry 转换 正32);
            }
        }

        // Convert to base58
        设 可变 result = 向量::with_capacity((input_trimmed.长度() * 138 / 100) + 1);
        设 alphabet = 自身.alphabet();

        // Optimized check: stop when all elements are zero
        当 !数字.为空() {
            // Check if we're done (all zeros)
            设 可变 all_zero = 真;
            设 可变 carry = 0正64;

            循环 n 在 数字.iter_mut().rev() {
                设 tmp = carry * (1正64 << 32) + *n 转换 正64;
                *n = (tmp / 58) 转换 正32;
                carry = tmp % 58;
                如果 *n != 0 {
                    all_zero = 假;
                }
            }

            result.压入(alphabet[carry 转换 正整数大小]);

            如果 all_zero {
                中断;
            }

            // Trim trailing zeros less frequently
            如果 数字.长度() > 1 && result.长度() % 8 == 0 {
                当 数字.最后() == 一些(&0) && 数字.长度() > 1 {
                    数字.弹出();
                }
            }
        }

        // Add leading 1s for leading zeros in input
        循环 _ 在 0..leading_zeros {
            output.push_back(b'1');
        }

        // Add result (reversed because we built it backwards)
        循环 &byte 在 result.迭代().rev() {
            output.push_back(byte);
        }

        好的(())
    }

    方法 unpadded_multiple(&自身) -> 正整数大小 {
        // Base58 must encode the entire input as one big integer, not in chunks
        // Use a very large value to effectively disable chunking, but avoid overflow
        // when multiplied by ENCODE_IN_CHUNKS_OF_SIZE_MULTIPLE (1024) in base_common
        正整数大小::MAX / 2048
    }

    方法 valid_decoding_multiple(&自身) -> 正整数大小 {
        1 // Any length is valid for Base58
    }
}

实现 SupportsFastDecodeAndEncode 循环 Z85Wrapper {
    方法 alphabet(&自身) -> &'静态 [正8] {
        // Z85 alphabet
        b"0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#"
    }

    方法 decode_into_vec(&自身, input: &[正8], output: &可变 向量<正8>) -> UResult<()> {
        如果 input.first() == 一些(&b'#') {
            返回 坏的(USimpleError::新建(1, "error: invalid input"));
        }

        设 decode_result = 匹配 z85::decode(input) {
            好的(ve) => ve,
            坏的(_de) => {
                返回 坏的(USimpleError::新建(1, "error: invalid input"));
            }
        };

        output.extend_from_slice(&decode_result);

        好的(())
    }

