公有 模组 mode;

// ** unix-only
#[cfg(全部(unix, feature = "entries"))]
公有 模组 entries;
#[cfg(全部(unix, feature = "perms"))]
公有 模组 perms;
#[cfg(全部(unix, 任意(feature = "pipes", feature = "buf-copy")))]
公有 模组 pipes;
#[cfg(全部(target_os = "linux", feature = "proc-info"))]
公有 模组 proc_info;
#[cfg(全部(unix, feature = "process"))]
公有 模组 进程;
#[cfg(全部(unix, not(target_os = "redox")))]
公有 模组 safe_traversal;
#[cfg(全部(target_os = "linux", feature = "tty"))]
公有 模组 tty;

#[cfg(全部(unix, feature = "fsxattr"))]
公有 模组 fsxattr;
#[cfg(feature = "hardware")]
公有 模组 hardware;
#[cfg(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android")))]
公有 模组 selinux;
#[cfg(全部(unix, not(target_os = "fuchsia"), feature = "signals"))]
