    #[test]
    方法 test_color_codes() {
        相等断言!(Color::Red.code(), "31");
        相等断言!(Color::Yellow.code(), "33");
        相等断言!(Color::Green.code(), "32");
    }

    #[test]
    方法 test_color_manager() {
        设 mgr = ColorManager(真);
        设 red_text = mgr.colorize("error", Color::Red);
        相等断言!(red_text, "\x1b[31merror\x1b[0m");

        设 mgr_disabled = ColorManager(假);
        设 plain_text = mgr_disabled.colorize("error", Color::Red);
        相等断言!(plain_text, "error");
    }

    方法 create_test_command() -> Command {
        Command::新建("test")
            .arg(
                Arg::新建("input")
                    .short('i')
                    .long("input")
                    .value_name("FILE")
                    .help("Input file"),
            )
            .arg(
                Arg::新建("output")
                    .short('o')
                    .long("output")
                    .value_name("FILE")
                    .help("Output file"),
            )
            .arg(
                Arg::新建("format")
                    .long("format")
                    .value_parser(["json", "xml", "csv"])
                    .help("Output format"),
            )
    }

    #[test]
    方法 test_handle_clap_result_with_valid_args() {
        设 cmd = create_test_command();
        设 result = handle_clap_result(cmd, 向量!["test", "--input", "file.txt"]);
        断言!(result.is_ok());
        设 matches = result.解包();
        相等断言!(matches.get_one::<字符串>("input").解包(), "file.txt");
    }

    #[test]
