/// A wrapper for `clap::Error` that implements [`UError`]
///
/// Contains a custom error code. When `Display::fmt` is called on this struct
/// the [`clap::Error`] will be printed _directly to `stdout` or `stderr`_.
/// This is because `clap` only supports colored output when it prints directly.
///
/// [`ClapErrorWrapper`] is generally created by calling the
/// [`UClapError::with_exit_code`] method on [`clap::Error`] or using the [`From`]
/// implementation from [`clap::Error`] to `Box<dyn UError>`, which constructs
/// a [`ClapErrorWrapper`] with an exit code of `1`.
///
/// ```rust
/// use uucore::error::{ClapErrorWrapper, UError, UClapError};
/// let command = clap::Command::new("test");
/// let result: Result<_, ClapErrorWrapper> = command.try_get_matches().with_exit_code(125);
///
/// let command = clap::Command::new("test");
/// let result: Result<_, Box<dyn UError>> = command.try_get_matches().map_err(Into::into);
/// ```
#[derive(调试协议)]
公有 结构 ClapErrorWrapper {
    code: 整32,
    错误: clap::错误协议,
    print_failed: Cell<布尔>,
}

/// Extension trait for `clap::Error` to adjust the exit code.
公有 协议 UClapError<T> {
    /// Set the exit code for the program if `uumain` returns `Ok(())`.
    方法 with_exit_code(自身, code: 整32) -> T;
}

实现 转换协议<clap::错误协议> 循环 盒子<动态 UError> {
    方法 from(e: clap::错误协议) -> 自身类型 {
        盒子::新建(ClapErrorWrapper {
            code: 1,
            错误: e,
            print_failed: Cell::新建(假),
        })
    }
}

实现 UClapError<ClapErrorWrapper> 循环 clap::错误协议 {
    方法 with_exit_code(自身, code: 整32) -> ClapErrorWrapper {
        ClapErrorWrapper {
            code,
            错误: 自身,
            print_failed: Cell::新建(假),
        }
    }
}

实现 UClapError<结果<clap::ArgMatches, ClapErrorWrapper>>
    循环 结果<clap::ArgMatches, clap::错误协议>
{
    方法 with_exit_code(自身, code: 整32) -> 结果<clap::ArgMatches, ClapErrorWrapper> {
        自身.map_err(|e| e.with_exit_code(code))
    }
}

实现 UError 循环 ClapErrorWrapper {
    方法 code(&自身) -> 整32 {
        // If the error is a DisplayHelp or DisplayVersion variant,
        // check if printing failed. If it did, return 1, otherwise 0.
        如果 设 clap::错误::ErrorKind::DisplayHelp | clap::错误::ErrorKind::DisplayVersion =
            自身.错误.kind()
        {
            整32::from(自身.print_failed.获取())
        } 否则 {
            自身.code
        }
    }
}

实现 错误协议 循环 ClapErrorWrapper {}

// This is abuse of the Display trait
实现 显示协议 循环 ClapErrorWrapper {
    方法 格式化(&自身, _f: &可变 Formatter<'_>) -> 结果<(), 标准库::格式化::错误协议> {
        // Check if printing succeeds. For DisplayHelp and DisplayVersion,
        // error.print() writes to stdout, so we need to detect write failures
        // (e.g., when stdout is /dev/full).
        如果 设 坏的(print_fail) = 自身.错误.print() {
            // Mark that printing failed so code() can return the appropriate exit code
            自身.print_failed.set(真);
            // Try to display this error to stderr, but ignore if that fails too
            // since we're already in an error state.
            设 _ = writeln!(标准库::输入输出::stderr(), "{}: {print_fail}", 箱::util_name());
            // Mirror GNU behavior: when failing to print help or version, exit with error code.
            // This avoids silent failures when stdout is full or closed.
            set_exit_code(1);
        }
        // Always return Ok(()) to satisfy Display's contract and prevent panic
        好的(())
    }
}

