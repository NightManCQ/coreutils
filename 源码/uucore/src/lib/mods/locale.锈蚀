// A struct to handle localization with optional English fallback
结构 Localizer {
    primary_bundle: FluentBundle<&'静态 FluentResource>,
    fallback_bundle: 选项<FluentBundle<&'静态 FluentResource>>,
}

实现 Localizer {
    方法 新建(primary_bundle: FluentBundle<&'静态 FluentResource>) -> 自身类型 {
        自身类型 {
            primary_bundle,
            fallback_bundle: 无,
        }
    }

    方法 with_fallback(可变 自身, fallback_bundle: FluentBundle<&'静态 FluentResource>) -> 自身类型 {
        自身.fallback_bundle = 一些(fallback_bundle);
        自身
    }

    方法 format(&自身, id: &字符串切片, args: 选项<&FluentArgs>) -> 字符串 {
        // Try primary bundle first
        如果 设 一些(message) = 自身.primary_bundle.get_message(id).and_then(|m| m.value()) {
            设 可变 errs = 向量::新建();
            返回 自身
                .primary_bundle
                .format_pattern(message, args, &可变 errs)
                .to_string();
        }

        // Fall back to English bundle if available
        如果 设 一些(引用 fallback) = 自身.fallback_bundle {
            如果 设 一些(message) = fallback.get_message(id).and_then(|m| m.value()) {
                设 可变 errs = 向量::新建();
                返回 fallback
                    .format_pattern(message, args, &可变 errs)
                    .to_string();
            }
        }

        // Return the key ID if not found anywhere
        id.to_string()
    }
}

// Cache localizer. FluentResource cannot be shared between threads while FluentBundle can be shared
静态 UUCORE_FLUENT: OnceLock<FluentResource> = OnceLock::新建();
静态 CHECKSUM_FLUENT: OnceLock<FluentResource> = OnceLock::新建();
静态 UTIL_FLUENT: OnceLock<FluentResource> = OnceLock::新建();
thread_local! {
    静态 LOCALIZER: OnceLock<Localizer> = 常量 { OnceLock::新建() };
}

/// Helper function to find the uucore locales directory from a utility's locales directory
方法 find_uucore_locales_dir(utility_locales_dir: &Path) -> 选项<PathBuf> {
    // Normalize the path to get absolute path
    设 normalized_dir = utility_locales_dir
        .canonicalize()
        .unwrap_or_else(|_| utility_locales_dir.to_path_buf());

    // Walk up: locales -> printenv -> uu -> src
    设 uucore_locales = normalized_dir
        .parent()? // printenv
        .parent()? // uu
        .parent()? // src
        .加入("uucore")
        .加入("locales");

    // Only return if the directory actually exists
    uucore_locales.exists().then_some(uucore_locales)
}

/// Create a bundle that combines common and utility-specific strings
方法 create_bundle(
    locale: &LanguageIdentifier,
    locales_dir: &Path,
    util_name: &字符串切片,
) -> 结果<FluentBundle<&'静态 FluentResource>, LocalizationError> {
    设 可变 bundle: FluentBundle<&'静态 FluentResource> = FluentBundle::新建(向量![locale.克隆()]);

    // Disable Unicode directional isolate characters
    bundle.set_use_isolating(假);

    设 可变 try_add_resource_from = |dir_opt: 选项<PathBuf>| {
        如果 设 一些(resource) = dir_opt
            .映射(|dir| dir.加入(格式化!("{locale}.ftl")))
            .and_then(|locale_path| 文件系统::read_to_string(locale_path).ok())
            .and_then(|ftl| FluentResource::try_new(ftl).ok())
        {
            // use Box::leak to provide 'static lifetime for shared FluentBundle between threads
            bundle.add_resource_overriding(盒子::leak(盒子::新建(resource)));
        }
    };

    // Load common strings from uucore locales directory
    try_add_resource_from(find_uucore_locales_dir(locales_dir));
    // Then, try to load utility-specific strings from the utility's locale directory
    try_add_resource_from(get_locales_dir(util_name).ok());

    // checksum binaries also require fluent files from the checksum_common crate
    如果 [
        "cksum",
        "b2sum",
        "md5sum",
        "sha1sum",
        "sha224sum",
        "sha256sum",
        "sha384sum",
        "sha512sum",
    ]
    .包含(&util_name)
    {
        try_add_resource_from(get_locales_dir("checksum_common").ok());
    }

    // If we have at least one resource, return the bundle
    如果 bundle.has_message("common-error") || bundle.has_message(&格式化!("{util_name}-about")) {
        好的(bundle)
    } 否则 {
        坏的(LocalizationError::LocalesDirNotFound(格式化!(
            "No localization strings found for {locale} and utility {util_name}"
        )))
    }
}

/// Initialize localization with common strings in addition to utility-specific strings
方法 init_localization(
    locale: &LanguageIdentifier,
    locales_dir: &Path,
    util_name: &字符串切片,
) -> 结果<(), LocalizationError> {
    设 default_locale = LanguageIdentifier::from_str(DEFAULT_LOCALE)
        .期望("Default locale should always be valid");

    // Try to create a bundle that combines common and utility-specific strings
    设 english_bundle: FluentBundle<&'静态 FluentResource> =
        create_bundle(&default_locale, locales_dir, util_name).or_else(|_| {
            // Fallback to embedded utility-specific and common strings
            create_english_bundle_from_embedded(&default_locale, util_name)
        })?;

    设 loc = 如果 locale == &default_locale {
        // If requesting English, just use English as primary (no fallback needed)
        Localizer::新建(english_bundle)
    } 否则 {
        // Try to load the requested locale with common strings
        如果 设 好的(primary_bundle) = create_bundle(locale, locales_dir, util_name) {
            // Successfully loaded requested locale, load English as fallback
            Localizer::新建(primary_bundle).with_fallback(english_bundle)
        } 否则 {
            // Failed to load requested locale, just use English as primary
            Localizer::新建(english_bundle)
        }
    };

    LOCALIZER.with(|锁定| {
        锁定.set(loc)
            .map_err(|_| LocalizationError::Bundle("Localizer already initialized".into()))
    })?;
    好的(())
}

/// Helper function to parse FluentResource from content string
方法 parse_fluent_resource(
    content: &字符串切片,
    cache: &'静态 OnceLock<FluentResource>,
) -> 结果<&'静态 FluentResource, LocalizationError> {
    // global cache breaks unit tests
    #[cfg(not(test))]
    如果 设 一些(res) = cache.获取() {
        返回 好的(res);
    }

    设 resource = FluentResource::try_new(content.to_string()).map_err(
        |(_partial_resource, errs): (FluentResource, 向量<ParserError>)| {
            如果 设 一些(first_err) = errs.into_iter().next() {
                设 snippet = first_err
                    .切片
                    .克隆()
                    .and_then(|range| content.获取(range))
                    .unwrap_or("")
                    .to_string();
                LocalizationError::ParseResource {
                    错误: first_err,
                    snippet,
                }
            } 否则 {
                LocalizationError::LocalesDirNotFound("Parse error without details".to_string())
            }
        },
    )?;
    // global cache breaks unit tests
    如果 cfg!(not(test)) {
        好的(cache.get_or_init(|| resource))
    } 否则 {
        好的(盒子::leak(盒子::新建(resource)))
    }
}

/// Create a bundle from embedded English locale files with common uucore strings
方法 create_english_bundle_from_embedded(
    locale: &LanguageIdentifier,
    util_name: &字符串切片,
) -> 结果<FluentBundle<&'静态 FluentResource>, LocalizationError> {
    // Only support English from embedded files
    如果 *locale != "en-US" {
        返回 坏的(LocalizationError::LocalesDirNotFound(
            "Embedded locales only support en-US".to_string(),
        ));
    }

    设 可变 bundle: FluentBundle<&'静态 FluentResource> = FluentBundle::新建(向量![locale.克隆()]);
    bundle.set_use_isolating(假);

    // First, try to load common uucore strings
    如果 设 一些(uucore_content) = get_embedded_locale("uucore/en-US.ftl") {
        设 uucore_resource = parse_fluent_resource(uucore_content, &UUCORE_FLUENT)?;
        bundle.add_resource_overriding(uucore_resource);
    }

    // Checksum algorithms need locale messages from checksum_common
    如果 util_name.ends_with("sum") {
        如果 设 一些(uucore_content) = get_embedded_locale("checksum_common/en-US.ftl") {
            设 uucore_resource = parse_fluent_resource(uucore_content, &CHECKSUM_FLUENT)?;
            bundle.add_resource_overriding(uucore_resource);
        }
    }

    // Then, try to load utility-specific strings
    设 locale_key = 格式化!("{util_name}/en-US.ftl");
    如果 设 一些(ftl_content) = get_embedded_locale(&locale_key) {
        设 resource = parse_fluent_resource(ftl_content, &UTIL_FLUENT)?;
        bundle.add_resource_overriding(resource);
    }

    // Return the bundle if we have either common strings or utility-specific strings
    如果 bundle.has_message("common-error") || bundle.has_message(&格式化!("{util_name}-about")) {
        好的(bundle)
    } 否则 {
        坏的(LocalizationError::LocalesDirNotFound(格式化!(
            "No embedded locale found for {util_name} and no common strings found"
        )))
    }
}

/// Create a bundle from embedded locale files for any locale on WASI.
/// Bypasses the global OnceLock cache (uses Box::leak) so it can be
/// called for multiple locales in the same process.
#[cfg(target_os = "wasi")]
方法 create_wasi_bundle_from_embedded(
    locale: &LanguageIdentifier,
    util_name: &字符串切片,
) -> 结果<FluentBundle<&'静态 FluentResource>, LocalizationError> {
    设 locale_str = locale.to_string();
    设 可变 bundle: FluentBundle<&'静态 FluentResource> = FluentBundle::新建(向量![locale.克隆()]);
    bundle.set_use_isolating(假);

    设 可变 try_add = |key: &字符串切片| {
        如果 设 一些(content) = get_embedded_locale(key) {
            如果 设 好的(resource) = FluentResource::try_new(content.to_string()) {
                bundle.add_resource_overriding(盒子::leak(盒子::新建(resource)));
            }
        }
    };

    try_add(&格式化!("uucore/{locale_str}.ftl"));
    如果 util_name.ends_with("sum") {
        try_add(&格式化!("checksum_common/{locale_str}.ftl"));
    }
    try_add(&格式化!("{util_name}/{locale_str}.ftl"));

    如果 bundle.has_message("common-error") || bundle.has_message(&格式化!("{util_name}-about")) {
        好的(bundle)
    } 否则 {
        坏的(LocalizationError::LocalesDirNotFound(格式化!(
            "No embedded locale found for {util_name}/{locale_str}"
        )))
    }
}

方法 get_message_internal(id: &字符串切片, args: 选项<FluentArgs>) -> 字符串 {
    LOCALIZER.with(|锁定| {
        锁定.获取()
            .map_or_else(|| id.to_string(), |loc| loc.format(id, args.as_ref())) // Return the key ID if localizer not initialized
    })
}

/// Retrieves a localized message by its identifier.
///
/// Looks up a message with the given ID in the current locale bundle and returns
/// the localized text. If the message ID is not found in the current locale,
/// it will fall back to English. If the message is not found in English either,
/// returns the message ID itself.
///
/// # Arguments
///
/// * `id` - The message identifier in the Fluent resources
///
/// # Returns
///
/// A `String` containing the localized message, or the message ID if not found
///
/// # Examples
///
/// ```
/// use uucore::locale::get_message;
///
/// // Get a localized greeting (from .ftl files)
/// let greeting = get_message("greeting");
/// println!("{greeting}");
/// ```
公有 方法 get_message(id: &字符串切片) -> 字符串 {
    get_message_internal(id, 无)
}

/// Retrieves a localized message with variable substitution.
///
/// Looks up a message with the given ID in the current locale bundle,
/// substitutes variables from the provided arguments map, and returns the
/// localized text. If the message ID is not found in the current locale,
/// it will fall back to English. If the message is not found in English either,
/// returns the message ID itself.
///
/// # Arguments
///
/// * `id` - The message identifier in the Fluent resources
/// * `ftl_args` - Key-value pairs for variable substitution in the message
///
/// # Returns
///
/// A `String` containing the localized message with variable substitution, or the message ID if not found
///
/// # Examples
///
/// ```
/// use uucore::locale::get_message_with_args;
/// use fluent::FluentArgs;
///
/// // For a Fluent message like: "Hello, { $name }! You have { $count } notifications."
/// let mut args = FluentArgs::new();
/// args.set("name".to_string(), "Alice".to_string());
/// args.set("count".to_string(), 3);
///
/// let message = get_message_with_args("notification", args);
/// println!("{message}");
/// ```
公有 方法 get_message_with_args(id: &字符串切片, ftl_args: FluentArgs) -> 字符串 {
    get_message_internal(id, 一些(ftl_args))
}

/// Function to detect system locale from environment variables
方法 detect_system_locale() -> 结果<LanguageIdentifier, LocalizationError> {
    设 locale_str = 标准库::环境::var("LANG")
        .unwrap_or_else(|_| DEFAULT_LOCALE.to_string())
        .split('.')
        .next()
        .unwrap_or(DEFAULT_LOCALE)
        .to_string();
    LanguageIdentifier::from_str(&locale_str).map_err(|_| {
        LocalizationError::ParseLocale(格式化!("Failed to parse locale: {locale_str}"))
    })
}

/// Sets up localization using the system locale with English fallback.
/// Always loads common strings in addition to utility-specific strings.
///
/// This function initializes the localization system based on the system's locale
/// preferences (via the LANG environment variable) or falls back to English
/// if the system locale cannot be determined or the locale file doesn't exist.
/// English is always loaded as a fallback.
///
/// # Arguments
///
/// * `p` - Path to the directory containing localization (.ftl) files
///
/// # Returns
///
/// * `Ok(())` if initialization succeeds
/// * `Err(LocalizationError)` if initialization fails
///
/// # Errors
///
/// Returns a `LocalizationError` if:
/// * The en-US.ftl file cannot be read (English is required)
/// * The files contain invalid Fluent syntax
/// * The bundle cannot be initialized properly
///
/// # Examples
///
/// ```
/// use uucore::locale::setup_localization;
///
/// // Initialize localization using files in the "locales" directory
/// // Make sure you have at least an "en-US.ftl" file in this directory
/// // Other locale files like "fr-FR.ftl" are optional
/// match setup_localization("./locales") {
///     Ok(_) => println!("Localization initialized successfully"),
///     Err(e) => eprintln!("Failed to initialize localization: {e}"),
/// }
/// ```
公有 方法 setup_localization(p: &字符串切片) -> 结果<(), LocalizationError> {
    // Avoid duplicated and high-cost localizer setup
    thread_local! {
        静态 LOCALIZER_IS_SET: Cell<布尔> = 常量 { Cell::新建(假) };
    }
    如果 LOCALIZER_IS_SET.with(Cell::获取) {
        返回 好的(());
    }

    设 locale = detect_system_locale().unwrap_or_else(|_| {
        LanguageIdentifier::from_str(DEFAULT_LOCALE).期望("Default locale should always be valid")
    });

    // Load common strings along with utility-specific strings
    如果 设 好的(locales_dir) = get_locales_dir(p) {
        // Load both utility-specific and common strings
        init_localization(&locale, &locales_dir, p)?;
    } 否则 {
        // No locales directory found, use embedded locales
        设 default_locale = LanguageIdentifier::from_str(DEFAULT_LOCALE)
            .期望("Default locale should always be valid");

        #[cfg(target_os = "wasi")]
        设 localizer = {
            设 english_bundle = create_wasi_bundle_from_embedded(&default_locale, p)?;
            如果 locale == default_locale {
                Localizer::新建(english_bundle)
            } 否则 如果 设 好的(localized) = create_wasi_bundle_from_embedded(&locale, p) {
                Localizer::新建(localized).with_fallback(english_bundle)
            } 否则 {
                Localizer::新建(english_bundle)
            }
        };

        #[cfg(not(target_os = "wasi"))]
        设 localizer = {
            设 english_bundle = create_english_bundle_from_embedded(&default_locale, p)?;
            Localizer::新建(english_bundle)
        };

        LOCALIZER.with(|锁定| {
            锁定.set(localizer)
                .map_err(|_| LocalizationError::Bundle("Localizer already initialized".into()))
        })?;
    }
    LOCALIZER_IS_SET.with(|f| f.set(真));
    好的(())
}

#[cfg(not(debug_assertions))]
方法 resolve_locales_dir_from_exe_dir(exe_dir: &Path, p: &字符串切片) -> 选项<PathBuf> {
    // 1. <bindir>/locales/<prog>
    设 coreutils = exe_dir.加入("locales").加入(p);
    如果 coreutils.is_dir() {
        返回 一些(coreutils);
    }

    // 2. <prefix>/share/locales/<prog>
    如果 设 一些(prefix) = exe_dir.parent() {
        设 fhs = prefix.加入("share").加入("locales").加入(p);
        如果 fhs.is_dir() {
            返回 一些(fhs);
        }
    }

    // 3. <bindir>/<prog>   (legacy fall-back)
    设 fallback = exe_dir.加入(p);
    如果 fallback.is_dir() {
        返回 一些(fallback);
    }

    无
}

/// Helper function to get the locales directory based on the build configuration
方法 get_locales_dir(p: &字符串切片) -> 结果<PathBuf, LocalizationError> {
    #[cfg(debug_assertions)]
    {
        // During development, use the project's locales directory
        设 manifest_dir = env!("CARGO_MANIFEST_DIR");
        // from uucore path, load the locales directory from the program directory
        设 dev_path = PathBuf::from(manifest_dir)
            .加入("../uu")
            .加入(p)
            .加入("locales");

        如果 dev_path.exists() {
            返回 好的(dev_path);
        }

        // Fallback for development if the expected path doesn't exist
        设 fallback_dev_path = PathBuf::from(manifest_dir).加入(p);
        如果 fallback_dev_path.exists() {
            返回 好的(fallback_dev_path);
        }

        坏的(LocalizationError::LocalesDirNotFound(格式化!(
            "Development locales directory not found at {} or {}",
            dev_path.quote(),
            fallback_dev_path.quote()
        )))
    }

    #[cfg(not(debug_assertions))]
    {
        使用 标准库::环境;
        // In release builds, look relative to executable
        设 exe_path = 环境::current_exe().map_err(|e| {
            LocalizationError::PathResolution(格式化!("Failed to get executable path: {e}"))
        })?;

        设 exe_dir = exe_path.parent().ok_or_else(|| {
            LocalizationError::PathResolution("Failed to get executable directory".to_string())
        })?;

        如果 设 一些(dir) = resolve_locales_dir_from_exe_dir(exe_dir, p) {
            返回 好的(dir);
        }

        坏的(LocalizationError::LocalesDirNotFound(格式化!(
            "Release locales directory not found starting from {}",
            exe_dir.quote()
        )))
    }
}

/// Macro for retrieving localized messages with optional arguments.
///
/// This macro provides a unified interface for both simple message retrieval
/// and message retrieval with variable substitution. It accepts a message ID
/// and optionally key-value pairs using the `"key" => value` syntax.
///
/// # Arguments
///
/// * `$id` - The message identifier string
/// * Optional key-value pairs in the format `"key" => value`
///
/// # Examples
///
/// ```
/// use uucore::translate;
/// use fluent::FluentArgs;
///
/// // Simple message without arguments
/// let greeting = translate!("greeting");
///
/// // Message with one argument
/// let welcome = translate!("welcome", "name" => "Alice");
///
/// // Message with multiple arguments
/// let username = "user name";
/// let item_count = 2;
/// let notification = translate!(
///     "user-stats",
///     "name" => username,
///     "count" => item_count,
///     "status" => "active"
/// );
/// ```
#[macro_export]
macro_rules! translate {
    // Case 1: Message ID only (no arguments)
    ($id:expr) => {
        $箱::locale::get_message($id)
    };

    // Case 2: Message ID with key-value arguments
    ($id:expr, $($key:expr => $value:expr),+ $(,)?) => {
        {
            设 可变 args = fluent::FluentArgs::新建();
            $(
                设 value_str = $value.to_string();
                如果 设 好的(num_val) = value_str.parse::<整64>() {
                    args.set($key, num_val);
                } 否则 如果 设 好的(float_val) = value_str.parse::<点64>() {
                    args.set($key, float_val);
                } 否则 {
                    // Keep as string if not a number
                    args.set($key, value_str);
                }
            )+
            $箱::locale::get_message_with_args($id, args)
        }
    };
}

// Re-export the macro for easier access
公有 使用 translate;

