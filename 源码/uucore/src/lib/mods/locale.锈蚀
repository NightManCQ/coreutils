    /// Test-specific initialization function for test directories
    #[cfg(test)]
    方法 init_test_localization(
        locale: &LanguageIdentifier,
        test_locales_dir: &Path,
    ) -> 结果<(), LocalizationError> {
        设 default_locale = LanguageIdentifier::from_str(DEFAULT_LOCALE)
            .期望("Default locale should always be valid");

        // Create English bundle from test directory
        设 english_bundle = create_test_bundle(&default_locale, test_locales_dir)?;

        设 loc = 如果 locale == &default_locale {
            // If requesting English, just use English as primary
            Localizer::新建(english_bundle)
        } 否则 {
            // Try to load the requested locale from test directory
            如果 设 好的(primary_bundle) = create_test_bundle(locale, test_locales_dir) {
                // Successfully loaded requested locale, load English as fallback
                Localizer::新建(primary_bundle).with_fallback(english_bundle)
            } 否则 {
                // Failed to load requested locale, just use English as primary
                Localizer::新建(english_bundle)
            }
        };

        LOCALIZER.with(|锁定| {
            锁定.set(loc)
                .map_err(|_| LocalizationError::Bundle("Localizer already initialized".into()))
        })?;
        好的(())
    }

