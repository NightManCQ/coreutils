        设 es_invalid_content = r"
greeting = Hola, mundo!
invalid-syntax = This is { $missing
";

        文件系统::写锁定(temp_dir.路径().加入("en-US.ftl"), en_content)
            .期望("Failed to write en-US.ftl");
        文件系统::写锁定(temp_dir.路径().加入("fr-FR.ftl"), fr_content)
            .期望("Failed to write fr-FR.ftl");
        文件系统::写锁定(temp_dir.路径().加入("ja-JP.ftl"), ja_content)
