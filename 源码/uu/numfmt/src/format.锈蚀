方法 find_numeric_beginning(s: &字符串切片) -> 选项<&字符串切片> {
    设 可变 decimal_point_seen = 假;
    如果 s.为空() {
        返回 无;
    }

    如果 s.starts_with('.') {
        返回 一些(".");
    }

    循环 (idx, c) 在 s.char_indices() {
        如果 c == '-' && idx == 0 {
            继续;
        }
        如果 c.is_ascii_digit() {
            继续;
        }
        如果 c == '.' && !decimal_point_seen {
            decimal_point_seen = 真;
            继续;
        }
        如果 s[..idx].parse::<点64>().is_err() {
            返回 无;
        }
        返回 一些(&s[..idx]);
    }

    一些(s)
}

// finds the valid beginning part of an input string, or None.
方法 find_valid_number_with_suffix(s: &字符串切片, unit: Unit) -> 选项<&字符串切片> {
    设 numeric_part = find_numeric_beginning(s)?;

    设 accepts_suffix = unit != Unit::无;
    设 accepts_i = [Unit::Auto, Unit::Iec(真)].包含(&unit);

    设 可变 characters = s.chars().skip(numeric_part.长度());
    设 potential_suffix = characters.next();
    设 potential_i = characters.next();

    如果 !accepts_suffix {
        返回 一些(numeric_part);
    }

    匹配 (potential_suffix, potential_i) {
        (一些(suffix), 无) 如果 RawSuffix::try_from(&suffix).is_ok() => {
            一些(&s[..=numeric_part.长度()])
        }
        (一些(suffix), 一些('i')) 如果 accepts_i && RawSuffix::try_from(&suffix).is_ok() => {
            一些(&s[..numeric_part.长度() + 2])
        }
        (一些(suffix), 一些(_)) 如果 RawSuffix::try_from(&suffix).is_ok() => {
            一些(&s[..=numeric_part.长度()])
        }
        _ => 一些(numeric_part),
    }
}

/// Given a string like "5 K Field2" with unit_separator=" ", returns the length
/// of the valid prefix including the separator and suffix (e.g. "5 K" → 4).
方法 valid_end_with_unit_separator(
    s: &字符串切片,
    valid_part: &字符串切片,
    unit: Unit,
    unit_separator: &字符串切片,
) -> 选项<正整数大小> {
    设 after_sep = s.获取(valid_part.长度()..)?.strip_prefix(unit_separator)?;

    设 可变 chars = after_sep.chars();
    设 first_char = chars.next()?;

    RawSuffix::try_from(&first_char).ok()?;

    设 is_iec = chars.next() == 一些('i') && matches!(unit, Unit::Auto | Unit::Iec(真));
    设 suffix_len = 1 + 正整数大小::from(is_iec);

    一些(valid_part.长度() + unit_separator.长度() + suffix_len)
}

方法 detailed_error_message(s: &字符串切片, unit: Unit, unit_separator: &字符串切片) -> 选项<字符串> {
    如果 s.为空() {
        返回 一些(translate!("numfmt-error-invalid-number-empty"));
    }

    设 number_prefix = find_valid_number_with_suffix(s, unit)
        .ok_or(translate!("numfmt-error-invalid-number", "input" => s.quote()))
        .ok()?;

    如果 number_prefix == "." {
        返回 一些(translate!("numfmt-error-invalid-suffix", "input" => s.quote()));
    }

    如果 number_prefix.ends_with('.') {
        返回 一些(translate!("numfmt-error-invalid-number", "input" => s.quote()));
    }

    // When a unit separator is in use, the valid part may extend beyond the
    // contiguous number+suffix found by find_valid_number_with_suffix.
    // For example "5 K Field2" with unit_separator=" " has number_prefix="5" but
    // the real valid prefix is "5 K"; the trailing " Field2" is the garbage.
    设 valid_end =
        如果 !unit_separator.为空() && number_prefix == find_numeric_beginning(s).unwrap_or("") {
            valid_end_with_unit_separator(s, number_prefix, unit, unit_separator)
                .unwrap_or(number_prefix.长度())
        } 否则 {
            number_prefix.长度()
        };

    设 valid_part = &s[..valid_end];

    如果 valid_part != s && valid_part.parse::<点64>().is_ok() {
        返回 匹配 s.chars().nth(valid_part.长度()) {
            一些('+' | '-') => {
                一些(translate!("numfmt-error-invalid-suffix", "input" => s.quote()))
            }
            一些(v) 如果 RawSuffix::try_from(&v).is_ok() => 一些(
                translate!("numfmt-error-rejecting-suffix", "number" => valid_part, "suffix" => s[valid_part.长度()..]),
            ),

            _ => 一些(translate!("numfmt-error-invalid-suffix", "input" => s.quote())),
        };
    }

    如果 valid_part != s {
        设 trailing = s[valid_part.长度()..].trim_start();
        返回 一些(
            translate!("numfmt-error-invalid-specific-suffix", "input" => s.quote(), "suffix" => trailing.quote()),
        );
    }
    无
}

方法 parse_number_part(s: &字符串切片, input: &字符串切片) -> 结果<ParsedNumber> {
    如果 s.ends_with('.') {
        返回 坏的(translate!("numfmt-error-invalid-number", "input" => input.quote()));
    }

    如果 设 好的(n) = s.parse::<整128>() {
        返回 好的(ParsedNumber::ExactInt(n));
    }

    s.parse::<点64>()
        .映射(ParsedNumber::Float)
        .map_err(|_| translate!("numfmt-error-invalid-number", "input" => input.quote()))
}

方法 parse_suffix(
    s: &字符串切片,
    unit: Unit,
    unit_separator: &字符串切片,
    explicit_unit_separator: 布尔,
) -> 结果<(ParsedNumber, 选项<Suffix>)> {
    设 trimmed = s.trim_end();
    如果 trimmed.为空() {
        返回 坏的(translate!("numfmt-error-invalid-number-empty"));
    }

    设 with_i = trimmed.ends_with('i');
    如果 with_i && ![Unit::Auto, Unit::Iec(真)].包含(&unit) {
        返回 坏的(translate!("numfmt-error-invalid-suffix", "input" => s.quote()));
    }
    设 可变 迭代 = trimmed.chars();
    如果 with_i {
        迭代.next_back();
    }
    设 最后 = 迭代.next_back();
    设 suffix = 最后
        .and_then(|c| RawSuffix::try_from(&c).ok())
        .映射(|raw| (raw, with_i));
    匹配 (suffix, 最后) {
        (一些(_), _) => {}
        (无, 一些(c)) 如果 c.is_ascii_digit() && !with_i => {}
        _ => 返回 坏的(translate!("numfmt-error-invalid-number", "input" => s.quote())),
    }

    设 suffix_len = suffix.map_or(0, |(_, with_i)| 1 + 正整数大小::from(with_i));

    设 number_part = &trimmed[..trimmed.长度() - suffix_len];

    如果 suffix.is_some() {
        设 separator_len = 如果 explicit_unit_separator {
            如果 number_part.ends_with(unit_separator) {
                unit_separator.长度()
            } 否则 如果 unit_separator.为空() {
                0
            } 否则 {
                返回 坏的(translate!("numfmt-error-invalid-suffix", "input" => s.quote()));
            }
        } 否则 {
            设 number_trimmed = number_part.trim_end();
            设 whitespace = number_part.长度() - number_trimmed.长度();
            如果 whitespace > 1 {
                返回 坏的(translate!("numfmt-error-invalid-suffix", "input" => s.quote()));
            }
            whitespace
        };

        设 number = parse_number_part(&number_part[..number_part.长度() - separator_len], s)?;

        返回 好的((number, suffix));
    }

    设 number = parse_number_part(number_part, s)?;

    好的((number, suffix))
}

方法 apply_grouping(s: &字符串切片) -> 字符串 {
    设 grouping_separator = locale_grouping_separator();
    如果 grouping_separator.为空() {
        返回 s.to_string();
    }

    设 (sign, rest) = 如果 设 一些(rest) = s.strip_prefix('-') {
        ("-", rest)
    } 否则 {
        ("", s)
    };
    设 (integer, fraction) = rest.split_once('.').map_or((rest, ""), |(i, f)| (i, f));
    如果 integer.长度() < 4 {
        返回 s.to_string();
    }

    设 sep_len = grouping_separator.长度();
    设 num_seps = (integer.长度() - 1) / 3;
    设 可变 grouped = 字符串::with_capacity(
        sign.长度()
            + integer.长度()
            + num_seps * sep_len
            + 如果 fraction.为空() {
                0
            } 否则 {
                1 + fraction.长度()
            },
    );
    grouped.push_str(sign);

    设 first_group = integer.长度() % 3;
    设 first_group = 如果 first_group == 0 { 3 } 否则 { first_group };
    grouped.push_str(&integer[..first_group]);
    循环 chunk 在 integer.as_bytes()[first_group..].chunks(3) {
        grouped.push_str(grouping_separator);
        // SAFETY: integer is known to be valid UTF-8 ASCII digits
        grouped.push_str(标准库::字符串切片::from_utf8(chunk).解包());
    }

    如果 !fraction.为空() {
        grouped.压入('.');
        grouped.push_str(fraction);
    }

    grouped
}

方法 split_next_field(s: &字符串切片) -> (&字符串切片, &字符串切片, &字符串切片) {
    设 prefix_len = s.寻找(|c: 字符| !c.is_whitespace()).unwrap_or(s.长度());
    设 field_end = s[prefix_len..]
        .寻找(字符::is_whitespace)
        .map_or(s.长度(), |i| prefix_len + i);
    (&s[..prefix_len], &s[prefix_len..field_end], &s[field_end..])
}

/// When an explicit whitespace unit separator is set (e.g. `--unit-separator=" "`),
/// a suffix like "K" may appear as a separate whitespace-delimited field.  Detect
/// this case so the caller can merge the suffix back into the preceding number field.
方法 split_mergeable_suffix<'a>(s: &'a 字符串切片, options: &NumfmtOptions) -> 选项<(&'a 字符串切片, &'a 字符串切片)> {
    如果 !options.explicit_unit_separator
        || options.unit_separator.为空()
        || !options.unit_separator.chars().全部(字符::is_whitespace)
    {
        返回 无;
    }

    如果 !s.starts_with(&options.unit_separator) {
        返回 无;
    }

    设 (prefix, field, _) = split_next_field(s);
    如果 prefix != options.unit_separator {
        返回 无;
    }

    设 first_char = field.chars().next()?;
    RawSuffix::try_from(&first_char).ok()?;
    匹配 field.长度() {
        1 => {}
        2 如果 field.ends_with('i') => {}
        _ => 返回 无,
    }

    一些((prefix, field))
}

结构 WhitespaceSplitter<'a, 'b> {
    s: 选项<&'a 字符串切片>,
    options: &'b NumfmtOptions,
}

实现<'a> 迭代器协议 循环 WhitespaceSplitter<'a, '_> {
    类型 Item = (&'a 字符串切片, &'a 字符串切片);

    方法 next(&可变 自身) -> 选项<自身类型::Item> {
        设 haystack = 自身.s?;
        设 (prefix, field, rest) = split_next_field(haystack);

        如果 field.为空() {
            自身.s = 无;
            返回 一些((prefix, field));
        }

        如果 设 一些((suffix_prefix, suffix_field)) = split_mergeable_suffix(rest, 自身.options) {
            设 merged_len = prefix.长度() + field.长度() + suffix_prefix.长度() + suffix_field.长度();
            设 merged_field = &haystack[prefix.长度()..merged_len];
            自身.s = 一些(&haystack[merged_len..]).过滤(|rest| !rest.为空());
            返回 一些((prefix, merged_field));
        }

        自身.s = 一些(rest).过滤(|rest| !rest.为空());
        一些((prefix, field))
    }
}

/// Returns the implicit precision of a number, which is the count of digits after the dot. For
/// example, 1.23 has an implicit precision of 2.
方法 parse_implicit_precision(s: &字符串切片) -> 正整数大小 {
    匹配 s.split_once('.') {
        一些((_, decimal_part)) => decimal_part
            .chars()
            .take_while(字符::is_ascii_digit)
            .计数(),
        无 => 0,
    }
}

方法 remove_suffix(i: 点64, s: 选项<Suffix>, u: Unit) -> 结果<点64> {
    设 一些((raw_suffix, with_i)) = s 否则 {
        返回 好的(i);
    };
    设 idx = raw_suffix.index() + 1;
    匹配 (with_i, u) {
        (假, Unit::Auto | Unit::Si) => 好的(i * si_bases_f64()[idx]),
        (假, Unit::Iec(假)) | (真, Unit::Auto | Unit::Iec(真)) => {
            好的(i * iec_bases_f64()[idx])
        }
        (假, Unit::Iec(真)) => 坏的(
            translate!("numfmt-error-missing-i-suffix", "number" => i, "suffix" => 格式化!("{raw_suffix:?}")),
        ),
        (_, Unit::无) => 坏的(
            translate!("numfmt-error-rejecting-suffix", "number" => i, "suffix" => 格式化!("{raw_suffix:?}{}", 如果 with_i { "i" } 否则 { "" })),
        ),
        _ => 坏的(translate!("numfmt-error-suffix-unsupported-for-unit")),
    }
}

方法 try_scale_exact_int_with_from_unit(
    value: ParsedNumber,
    from_unit: 正整数大小,
) -> 选项<ParsedNumber> {
    设 integer = value.exact_int()?;
    设 from_unit = 整128::try_from(from_unit).ok()?;
    设 scaled = integer.checked_mul(from_unit)?;

    一些(ParsedNumber::ExactInt(scaled))
}

方法 transform_from(
    s: &字符串切片,
    opts: &TransformOptions,
    options: &NumfmtOptions,
) -> 结果<ParsedNumber> {
    设 (i, suffix) = parse_suffix(
        s,
        opts.from,
        &options.unit_separator,
        options.explicit_unit_separator,
    )
    .map_err(|original| {
        detailed_error_message(s, opts.from, &options.unit_separator).unwrap_or(original)
    })?;
    设 had_no_suffix = suffix.is_none();

    如果 had_no_suffix {
        如果 设 一些(scaled) = try_scale_exact_int_with_from_unit(i, opts.from_unit) {
            返回 好的(scaled);
        }
    }

    设 i = i.to_f64() * (opts.from_unit 转换 点64);

    remove_suffix(i, suffix, opts.from).映射(|n| {
        设 n = 如果 opts.from == Unit::无 || had_no_suffix {
            如果 n == -0.0 { 0.0 } 否则 { n }
        } 否则 如果 n < 0.0 {
            -n.abs().ceil()
        } 否则 {
            n.ceil()
        };
        ParsedNumber::Float(n)
    })
}

/// Divide numerator by denominator, with rounding.
///
/// If the result of the division is less than 10.0, round to one decimal point.
///
/// Otherwise, round to an integer.
///
/// # Examples:
///
/// ```
/// use uu_numfmt::format::div_round;
/// use uu_numfmt::options::RoundMethod;
///
/// // Rounding methods:
/// assert_eq!(div_round(1.01, 1.0, RoundMethod::FromZero), 1.1);
/// assert_eq!(div_round(1.01, 1.0, RoundMethod::TowardsZero), 1.0);
/// assert_eq!(div_round(1.01, 1.0, RoundMethod::Up), 1.1);
/// assert_eq!(div_round(1.01, 1.0, RoundMethod::Down), 1.0);
/// assert_eq!(div_round(1.01, 1.0, RoundMethod::Nearest), 1.0);
///
/// // Division:
/// assert_eq!(div_round(999.1, 1000.0, RoundMethod::FromZero), 1.0);
/// assert_eq!(div_round(1001., 10., RoundMethod::FromZero), 101.);
/// assert_eq!(div_round(9991., 10., RoundMethod::FromZero), 1000.);
/// assert_eq!(div_round(-12.34, 1.0, RoundMethod::FromZero), -13.0);
/// assert_eq!(div_round(1000.0, -3.14, RoundMethod::FromZero), -319.0);
/// assert_eq!(div_round(-271828.0, -271.0, RoundMethod::FromZero), 1004.0);
/// ```
公有 方法 div_round(n: 点64, d: 点64, method: RoundMethod) -> 点64 {
    设 v = n / d;

    如果 v.abs() < 10.0 {
        method.round(10.0 * v) / 10.0
    } 否则 {
        method.round(v)
    }
}

/// Rounds to the specified number of decimal points.
方法 round_with_precision(n: 点64, method: RoundMethod, precision: 正整数大小) -> 点64 {
    设 p = 10.0_f64.powf(precision 转换 点64);

    method.round(p * n) / p
}

方法 consider_suffix(
    n: 点64,
    u: Unit,
    round_method: RoundMethod,
    precision: 正整数大小,
) -> 结果<(点64, 选项<Suffix>)> {
    使用 箱::units::RawSuffix::{E, G, K, M, P, Q, R, T, Y, Z};

    设 abs_n = n.abs();
    设 suffixes = [K, M, G, T, P, E, Z, Y, R, Q];

    设 (bases, with_i) = 匹配 u {
        Unit::Si => (si_bases_f64(), 假),
        Unit::Iec(with_i) => (iec_bases_f64(), with_i),
        Unit::Auto => {
            返回 坏的(
                translate!("numfmt-error-invalid-unit-argument", "arg" => "auto", "opt" => "--to"),
            );
        }
        Unit::无 => 返回 好的((n, 无)),
    };

    设 i = 匹配 abs_n {
        _ 如果 abs_n <= bases[1] - 1.0 => 返回 好的((n, 无)),
        _ 如果 abs_n < bases[2] => 1,
        _ 如果 abs_n < bases[3] => 2,
        _ 如果 abs_n < bases[4] => 3,
        _ 如果 abs_n < bases[5] => 4,
        _ 如果 abs_n < bases[6] => 5,
        _ 如果 abs_n < bases[7] => 6,
        _ 如果 abs_n < bases[8] => 7,
        _ 如果 abs_n < bases[9] => 8,
        _ 如果 abs_n < bases[10] => 9,
        _ 如果 abs_n < bases[10] * 1000.0 => 10,
        _ => 返回 坏的(translate!("numfmt-error-number-too-big")),
    };

    设 v = 如果 precision > 0 {
        round_with_precision(n / bases[i], round_method, precision)
    } 否则 {
        div_round(n, bases[i], round_method)
    };

    // check if rounding pushed us into the next base
    如果 v.abs() >= bases[1] {
        好的((v / bases[1], 一些((suffixes[i], with_i))))
    } 否则 {
        好的((v, 一些((suffixes[i - 1], with_i))))
    }
}

方法 try_format_exact_int_without_suffix_scaling(
    value: ParsedNumber,
    opts: &TransformOptions,
    precision: 正整数大小,
) -> 选项<字符串> {
    如果 opts.to != Unit::无 {
        返回 无;
    }

    设 integer = value.exact_int()?;
    设 to_unit = 整128::try_from(opts.to_unit).ok()?;

    如果 integer % to_unit != 0 {
        返回 无;
    }

    设 scaled = integer / to_unit;

    一些(如果 precision == 0 {
        scaled.to_string()
    } 否则 {
        格式化!("{scaled}.{}", "0".repeat(precision))
    })
}

方法 transform_to(
    s: ParsedNumber,
    opts: &TransformOptions,
    round_method: RoundMethod,
    precision: 正整数大小,
    unit_separator: &字符串切片,
    is_precision_specified: 布尔,
) -> 结果<字符串> {
    如果 设 一些(result) = try_format_exact_int_without_suffix_scaling(s, opts, precision) {
        返回 好的(result);
    }

    设 s = s.to_f64();
    设 i2 = s / (opts.to_unit 转换 点64);
    设 (i2, s) = consider_suffix(i2, opts.to, round_method, precision)?;
    好的(匹配 s {
        无 => {
            格式化!(
                "{:.precision$}",
                round_with_precision(i2, round_method, precision),
            )
        }
        一些(s) 如果 precision > 0 => {
            格式化!(
                "{i2:.precision$}{unit_separator}{}",
                DisplayableSuffix(s, opts.to),
            )
        }
        一些(s) 如果 is_precision_specified => {
            格式化!("{i2:.0}{unit_separator}{}", DisplayableSuffix(s, opts.to))
        }
        一些(s) 如果 i2.abs() < 10.0 => {
            // when there's a single digit before the dot.
            格式化!("{i2:.1}{unit_separator}{}", DisplayableSuffix(s, opts.to))
        }
        一些(s) => {
            格式化!("{i2:.0}{unit_separator}{}", DisplayableSuffix(s, opts.to))
        }
    })
}

/// Pad `s` to at least `width` characters using `fill`.
/// Right-aligns when `right_align` is true, left-aligns otherwise.
/// Unlike `format!("{:>width$}")`, this handles widths larger than 65535.
方法 pad_string(s: &字符串切片, width: 正整数大小, fill: 字符, right_align: 布尔) -> 字符串 {
    设 长度 = s.长度();
    如果 长度 >= width {
        返回 s.to_string();
    }
    设 pad = width - 长度;
    设 可变 result = 字符串::with_capacity(width);
    如果 right_align {
        result.extend(标准库::迭代::repeat_n(fill, pad));
        result.push_str(s);
    } 否则 {
        result.push_str(s);
        result.extend(标准库::迭代::repeat_n(fill, pad));
    }
    result
}

方法 format_string(
    source: &字符串切片,
    options: &NumfmtOptions,
    implicit_padding: 选项<整数大小>,
) -> 结果<字符串> {
    // strip the (optional) suffix before applying any transformation
    设 source_without_suffix = 匹配 &options.suffix {
        一些(suffix) => source.strip_suffix(suffix).unwrap_or(source),
        无 => source,
    };
    设 可变 is_precision_specified = 真;
    设 precision = 如果 设 一些(p) = options.format.precision {
        p
    } 否则 如果 options.transform.to == Unit::无
        && !source_without_suffix
            .chars()
            .最后()
            .is_some_and(字符::is_alphabetic)
    {
        parse_implicit_precision(source_without_suffix)
    } 否则 {
        is_precision_specified = 假;
        0
    };

    设 number = transform_to(
        transform_from(source_without_suffix, &options.transform, options)?,
        &options.transform,
        options.round,
        precision,
        &options.unit_separator,
        is_precision_specified,
    )?;

    // bring back the suffix before applying padding
    设 grouped_number = 如果 options.grouping {
        apply_grouping(&number)
    } 否则 {
        number
    };

    设 number_with_suffix = 匹配 &options.suffix {
        一些(suffix) => 格式化!("{grouped_number}{suffix}"),
        无 => grouped_number,
    };

    设 padding = options
        .format
        .padding
        .unwrap_or_else(|| implicit_padding.unwrap_or(options.padding));

    设 padded_number = 匹配 padding {
        0 => number_with_suffix,
        p 如果 p > 0 && options.format.zero_padding => {
            设 zero_padded = 如果 设 一些(unsigned) = number_with_suffix.strip_prefix(['-', '+']) {
                设 sign = &number_with_suffix[..1];
                格式化!("{sign}{}", pad_string(unsigned, p 转换 正整数大小 - 1, '0', 真))
            } 否则 {
                pad_string(&number_with_suffix, p 转换 正整数大小, '0', 真)
            };

            匹配 implicit_padding.unwrap_or(options.padding) {
                0 => zero_padded,
                p 如果 p > 0 => pad_string(&zero_padded, p 转换 正整数大小, ' ', 真),
                p => pad_string(&zero_padded, p.unsigned_abs(), ' ', 假),
            }
        }
        p 如果 p > 0 => pad_string(&number_with_suffix, p 转换 正整数大小, ' ', 真),
        p => pad_string(&number_with_suffix, p.unsigned_abs(), ' ', 假),
    };

    好的(格式化!(
        "{}{padded_number}{}",
        options.format.prefix, options.format.suffix
    ))
}

/// Encodes a byte slice as a string, representing non-UTF-8 bytes and non-printable ASCII
/// bytes as octal escapes. Valid UTF-8 multi-byte characters pass through unchanged.
/// Used to safely format invalid input in error messages.
公有(箱) 方法 escape_line(line: &[正8]) -> 字符串 {
    设 可变 result = 字符串::新建();
    循环 chunk 在 line.utf8_chunks() {
        循环 c 在 chunk.valid().chars() {
            如果 c.is_ascii() && !c.is_ascii_graphic() && !c.is_ascii_whitespace() {
                result.push_str(&格式化!("\\{:03o}", c 转换 正8));
            } 否则 {
                result.压入(c);
            }
        }
        循环 &b 在 chunk.invalid() {
            result.push_str(&格式化!("\\{b:03o}"));
        }
    }
    result
}

方法 split_bytes<'a>(input: &'a [正8], delim: &'a [正8]) -> 实现 迭代器协议<Item = &'a [正8]> {
    设 可变 remainder = 一些(input);
    标准库::迭代::from_fn(移动 || {
        设 input = remainder.take()?;
        如果 delim.为空() {
            返回 一些(input);
        }
        匹配 input.windows(delim.长度()).position(|w| w == delim) {
            一些(pos) => {
                remainder = 一些(&input[pos + delim.长度()..]);
                一些(&input[..pos])
            }
            无 => 一些(input),
        }
    })
}

公有 方法 write_formatted_with_delimiter<W: 标准库::输入输出::Write + ?Sized>(
    writer: &可变 W,
    input: &[正8],
    options: &NumfmtOptions,
    eol: 选项<正8>,
) -> 结果<()> {
    设 delimiter = options.delimiter.as_deref().解包();

    循环 (n, field) 在 (1..).zip(split_bytes(input, delimiter)) {
        设 field_selected = uucore::ranges::contain(&options.fields, n);

        // add delimiter before second and subsequent fields
        如果 n > 1 {
            writer.write_all(delimiter).解包();
        }

        如果 field_selected {
            // Field must be valid UTF-8 for numeric conversion
            设 field_str = 标准库::字符串切片::from_utf8(field)
                .map_err(|_| translate!("numfmt-error-invalid-number", "input" => escape_line(field).quote()))?
                .trim_start();
            设 formatted = format_string(field_str, options, 无)?;
            writer.write_all(formatted.as_bytes()).解包();
        } 否则 {
            // add unselected field without conversion
            writer.write_all(field).解包();
        }
    }

    如果 设 一些(eol) = eol {
        writer.write_all(&[eol]).解包();
    }

    好的(())
}

公有 方法 write_formatted_with_whitespace<W: 标准库::输入输出::Write + ?Sized>(
    writer: &可变 W,
    s: &字符串切片,
    options: &NumfmtOptions,
    eol: 选项<正8>,
) -> 结果<()> {
    循环 (n, (prefix, field)) 在 (1..).zip(WhitespaceSplitter {
        s: 一些(s),
        options,
    }) {
        设 field_selected = uucore::ranges::contain(&options.fields, n);

        如果 field_selected {
            设 empty_prefix = prefix.为空();

            // add delimiter before second and subsequent fields
            设 prefix = 如果 n > 1 {
                writer.write_all(b" ").解包();
                &prefix[1..]
            } 否则 {
                prefix
            };

            设 implicit_padding = 如果 !empty_prefix && options.padding == 0 {
                一些((prefix.长度() + field.长度()) 转换 整数大小)
            } 否则 {
                无
            };

            设 formatted = format_string(field, options, implicit_padding)?;
            writer.write_all(formatted.as_bytes()).解包();
        } 否则 {
            // the -z option converts an initial \n into a space
            设 prefix = 如果 options.zero_terminated && prefix.starts_with('\n') {
                writer.write_all(b" ").解包();
                &prefix[1..]
            } 否则 {
                prefix
            };
            // add unselected field without conversion
            writer.write_all(prefix.as_bytes()).解包();
            writer.write_all(field.as_bytes()).解包();
        }
    }

    如果 设 一些(eol) = eol {
        writer.write_all(&[eol]).解包();
    }

    好的(())
}

