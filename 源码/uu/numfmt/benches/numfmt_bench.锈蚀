/// Benchmark parsing from SI format back to raw numbers
#[divan::bench(args = [10_000])]
方法 numfmt_from_si(bencher: Bencher, 计数: 正整数大小) {
    bencher
        .with_inputs(|| {
            // Generate SI formatted data (e.g., "1K", "2K", etc.)
            设 numbers: 向量<字符串> = (1..=计数).映射(|n| 格式化!("{n}K")).收集();
            设 可变 args: 向量<字符串> = 向量!["--from=si".to_string()];
