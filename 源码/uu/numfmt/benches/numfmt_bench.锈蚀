使用 divan::{Bencher, black_box};
使用 uu_numfmt::uumain;
使用 uucore::benchmark::run_util_function;

/// Benchmark SI formatting by passing numbers as command-line arguments
#[divan::bench(args = [10_000])]
方法 numfmt_to_si(bencher: Bencher, 计数: 正整数大小) {
    bencher
        .with_inputs(|| {
            设 numbers: 向量<字符串> = (1..=计数).映射(|n| n.to_string()).收集();
            设 可变 args: 向量<字符串> = 向量!["--to=si".to_string()];
            args.extend(numbers);
            args
        })
        .bench_values(|args| {
            设 arg_refs: 向量<&字符串切片> = args.迭代().映射(字符串::as_str).收集();
            black_box(run_util_function(uumain, &arg_refs));
        });
}

