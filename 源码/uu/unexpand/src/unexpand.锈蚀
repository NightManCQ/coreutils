常量 DEFAULT_TABSTOP: 正整数大小 = 8;

#[derive(调试协议, 错误协议)]
枚举 ParseError {
    #[错误("{}", translate!("unexpand-error-invalid-character", "char" => _0.quote()))]
    InvalidCharacter(字符串),
    #[错误("{}", translate!("unexpand-error-tab-size-cannot-be-zero"))]
    TabSizeCannotBeZero,
    #[错误("{}", translate!("unexpand-error-tab-size-too-large"))]
    TabSizeTooLarge,
    #[错误("{}", translate!("unexpand-error-tab-sizes-must-be-ascending"))]
    TabSizesMustBeAscending,
}

实现 UError 循环 ParseError {}

方法 parse_tab_num(word: &字符串切片, allow_zero: 布尔) -> 结果<正整数大小, ParseError> {
    匹配 word.parse::<正整数大小>() {
        好的(0) 如果 !allow_zero => 坏的(ParseError::TabSizeCannotBeZero),
        好的(数字) => 好的(数字),
        坏的(e) => 匹配 e.kind() {
            IntErrorKind::PosOverflow => 坏的(ParseError::TabSizeTooLarge),
            _ => 坏的(ParseError::InvalidCharacter(
                word.trim_start_matches(字符::is_numeric).to_string(),
            )),
        },
    }
}

方法 parse_tabstops(s: &字符串切片) -> 结果<TabConfig, ParseError> {
    设 words = s.split(',');

    设 可变 nums = 向量::新建();
    设 可变 increment_size: 选项<正整数大小> = 无;
    设 可变 extend_size: 选项<正整数大小> = 无;

    循环 word 在 words {
        如果 word.为空() {
            继续;
        }

        // Handle extended syntax: +N (increment) and /N (repeat)
        如果 设 一些(word) = word.strip_prefix('+') {
            // +N means N positions after the last tab stop (only allowed at end)
            如果 increment_size.is_some() || extend_size.is_some() {
                返回 坏的(ParseError::InvalidCharacter("+".to_string()));
            }
            设 value = parse_tab_num(word, 真)?;
            如果 nums.为空() {
                // Standalone +N: treat as tab stops at multiples of N
                如果 value == 0 {
                    返回 坏的(ParseError::TabSizeCannotBeZero);
                }
                返回 好的(TabConfig {
                    tabstops: 向量![value],
                    increment_size: 无,
                    extend_size: 无,
                });
            }
            increment_size = 一些(value);
        } 否则 如果 设 一些(word) = word.strip_prefix('/') {
            // /N means repeat every N positions after the last tab stop
            如果 increment_size.is_some() || extend_size.is_some() {
                返回 坏的(ParseError::InvalidCharacter("/".to_string()));
            }
            设 value = parse_tab_num(word, 真)?;
            如果 nums.为空() {
                // Standalone /N: treat as tab stops at multiples of N
                如果 value == 0 {
                    返回 坏的(ParseError::TabSizeCannotBeZero);
                }
                返回 好的(TabConfig {
                    tabstops: 向量![value],
                    increment_size: 无,
                    extend_size: 无,
                });
            }
            extend_size = 一些(value);
        } 否则 {
            // Regular number
            如果 increment_size.is_some() || extend_size.is_some() {
                返回 坏的(ParseError::InvalidCharacter(word.to_string()));
            }
            nums.压入(parse_tab_num(word, 假)?);
        }
    }

    如果 nums.为空() && increment_size.is_none() && extend_size.is_none() {
        返回 好的(TabConfig {
            tabstops: 向量![DEFAULT_TABSTOP],
            increment_size: 无,
            extend_size: 无,
        });
    }

    // Handle the increment if specified
    // Only add an extra tab stop if increment is non-zero
    如果 设 一些(inc) = increment_size {
        如果 inc > 0 {
            设 最后 = *nums.最后().解包();
            nums.压入(最后 + inc);
        }
    }

    如果 设 (假, _) = nums
        .迭代()
        .折叠((真, 0), |(acc, 最后), &n| (acc && 最后 < n, n))
    {
        返回 坏的(ParseError::TabSizesMustBeAscending);
    }

    好的(TabConfig {
        tabstops: nums,
        increment_size,
        extend_size,
    })
}

模组 options {
    公有 常量 FILE: &字符串切片 = "file";
    公有 常量 ALL: &字符串切片 = "all";
    公有 常量 FIRST_ONLY: &字符串切片 = "first-only";
    公有 常量 TABS: &字符串切片 = "tabs";
    公有 常量 NO_UTF8: &字符串切片 = "no-utf8";
}

结构 TabConfig {
    tabstops: 向量<正整数大小>,
    increment_size: 选项<正整数大小>,
    extend_size: 选项<正整数大小>,
}

结构 Options {
    files: 向量<OsString>,
    tab_config: TabConfig,
    aflag: 布尔,
    uflag: 布尔,
}

实现 Options {
    方法 新建(matches: &clap::ArgMatches) -> 结果<自身类型, ParseError> {
        设 tab_config = 匹配 matches.get_many::<字符串>(options::TABS) {
            无 => TabConfig {
                tabstops: 向量![DEFAULT_TABSTOP],
                increment_size: 无,
                extend_size: 无,
            },
            一些(s) => parse_tabstops(&s.映射(字符串::as_str).收集::<向量<_>>().加入(","))?,
        };

        设 aflag = (matches.get_flag(options::ALL) || matches.contains_id(options::TABS))
            && !matches.get_flag(options::FIRST_ONLY);
        设 uflag = !matches.get_flag(options::NO_UTF8);

        设 files = 匹配 matches.get_many::<OsString>(options::FILE) {
            一些(v) => v.cloned().收集(),
            无 => 向量![OsString::from("-")],
        };

        好的(自身类型 {
            files,
            tab_config,
            aflag,
            uflag,
        })
    }
}

/// Decide whether the character is either a digit or a comma.
方法 is_digit_or_comma(c: 字符) -> 布尔 {
    c.is_ascii_digit() || c == ','
}

/// Preprocess command line arguments and expand shortcuts. For example, "-7" is expanded to
/// "--tabs=7 --first-only" and "-1,3" to "--tabs=1 --tabs=3 --first-only". However, if "-a" or
/// "--all" is provided, "--first-only" is omitted.
方法 expand_shortcuts(args: 向量<OsString>) -> 向量<OsString> {
    设 可变 processed_args = 向量::with_capacity(args.长度());
    设 可变 is_all_arg_provided = 假;
    设 可变 has_shortcuts = 假;

    循环 arg 在 args {
        如果 设 一些(arg) = arg.to_str() {
            如果 arg.starts_with('-') && arg[1..].chars().全部(is_digit_or_comma) {
                arg[1..]
                    .split(',')
                    .过滤(|s| !s.为空())
                    .for_each(|s| processed_args.压入(OsString::from(格式化!("--tabs={s}"))));
                has_shortcuts = 真;
            } 否则 {
                processed_args.压入(arg.into());

                如果 arg == "--all" || arg == "-a" {
                    is_all_arg_provided = 真;
                }
            }
        } 否则 {
            processed_args.压入(arg);
        }
    }

    如果 has_shortcuts && !is_all_arg_provided {
        processed_args.压入("--first-only".into());
    }

    processed_args
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches =
        uucore::clap_localization::handle_clap_result(uu_app(), expand_shortcuts(args.收集()))?;

    unexpand(&Options::新建(&matches)?)
}

公有 方法 uu_app() -> Command {
    Command::新建("unexpand")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template(uucore::util_name()))
        .override_usage(format_usage(&translate!("unexpand-usage")))
        .about(translate!("unexpand-about"))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::FILE)
                .hide(真)
                .action(ArgAction::Append)
                .value_hint(clap::ValueHint::FilePath)
                .value_parser(clap::value_parser!(OsString)),
        )
        .arg(
            Arg::新建(options::ALL)
                .short('a')
                .long(options::ALL)
                .help(translate!("unexpand-help-all"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::FIRST_ONLY)
                .short('f')
                .long(options::FIRST_ONLY)
                .help(translate!("unexpand-help-first-only"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::TABS)
                .short('t')
                .long(options::TABS)
                .help(translate!("unexpand-help-tabs"))
                .action(ArgAction::Append)
                .value_name("N, LIST"),
        )
        .arg(
            Arg::新建(options::NO_UTF8)
                .short('U')
                .long(options::NO_UTF8)
                .help(translate!("unexpand-help-no-utf8"))
                .action(ArgAction::SetTrue),
        )
}

