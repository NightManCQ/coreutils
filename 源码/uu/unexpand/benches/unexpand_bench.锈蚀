使用 divan::{Bencher, black_box};
使用 uu_unexpand::uumain;
使用 uucore::benchmark::{create_test_file, run_util_function};

/// Generate text data with leading spaces (typical unexpand use case)
方法 generate_indented_text(num_lines: 正整数大小) -> 向量<正8> {
    设 可变 data = 向量::新建();
    循环 i 在 0..num_lines {
        // Add varying amounts of leading spaces (4, 8, 12, etc.)
        设 indent = (i % 4 + 1) * 4;
        data.extend(向量![b' '; indent]);
        data.extend_from_slice(b"This is a line of text with leading spaces\n");
    }
    data
}

/// Benchmark unexpanding many lines with leading spaces (most common use case)
#[divan::bench(args = [100_000])]
方法 unexpand_many_lines(bencher: Bencher, num_lines: 正整数大小) {
    设 temp_dir = tempfile::tempdir().解包();
    设 data = generate_indented_text(num_lines);
    设 file_path = create_test_file(&data, temp_dir.路径());
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path_str]));
    });
}

/// Benchmark large file with spaces (tests performance on large files)
#[divan::bench(args = [10])]
方法 unexpand_large_file(bencher: Bencher, size_mb: 正整数大小) {
    设 temp_dir = tempfile::tempdir().解包();

    // Generate approximately size_mb worth of indented lines
    设 line_size = 50; // approximate bytes per line
    设 num_lines = (size_mb * 1024 * 1024) / line_size;
    设 data = generate_indented_text(num_lines);
    设 file_path = create_test_file(&data, temp_dir.路径());
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path_str]));
    });
}

