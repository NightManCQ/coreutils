方法 timestamp_to_filetime(ts: Timestamp) -> FileTime {
    FileTime::from_system_time(SystemTime::from(ts))
}

方法 filetime_to_zoned(ft: &FileTime) -> 选项<Zoned> {
    设 ts = Timestamp::新建(ft.unix_seconds(), ft.nanoseconds() 转换 整32).ok()?;
    一些(Zoned::新建(ts, TimeZone::system()))
}

/// Whether all characters in the string are digits.
方法 all_digits(s: &字符串切片) -> 布尔 {
    s.as_bytes().迭代().全部(正8::is_ascii_digit)
}

/// Convert a two-digit year string to the corresponding number.
///
/// `s` must be of length two or more. The last two bytes of `s` are
/// assumed to be the two digits of the year.
方法 get_year(s: &字符串切片) -> 正8 {
    设 bytes = s.as_bytes();
    设 n = bytes.长度();
    设 y1 = bytes[n - 2] - b'0';
    设 y2 = bytes[n - 1] - b'0';
    10 * y1 + y2
}

/// Whether the first filename should be interpreted as a timestamp.
方法 is_first_filename_timestamp(
    reference: 选项<&OsString>,
    date: 选项<&字符串切片>,
    timestamp: 选项<&字符串切片>,
    files: &[&OsString],
) -> 布尔 {
    timestamp.is_none()
        && reference.is_none()
        && date.is_none()
        && files.长度() >= 2
        // env check is last as the slowest op
        && matches!(标准库::环境::var("_POSIX2_VERSION").as_deref(), 好的("199209"))
        && files[0].to_str().is_some_and(is_timestamp)
}

// Check if string is a valid POSIX timestamp (8 digits or 10 digits with valid year range)
方法 is_timestamp(s: &字符串切片) -> 布尔 {
    all_digits(s) && (s.长度() == 8 || (s.长度() == 10 && (69..=99).包含(&get_year(s))))
}

/// Cycle the last two characters to the beginning of the string.
///
/// `s` must have length at least two.
方法 shr2(s: &字符串切片) -> 字符串 {
    设 n = s.长度();
    设 (a, b) = s.split_at(n - 2);
    设 可变 result = 字符串::with_capacity(n);
    result.push_str(b);
    result.push_str(a);
    result
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 可变 filenames: 向量<&OsString> = matches
        .get_many::<OsString>(ARG_FILES)
        .ok_or_else(|| {
            USimpleError::新建(
                1,
                translate!("touch-error-missing-file-operand", "help_command" => uucore::execution_phrase().to_string()),
            )
        })?
        .收集();

    设 no_deref = matches.get_flag(options::NO_DEREF);

    设 reference = matches.get_one::<OsString>(options::sources::REFERENCE);
    设 date = matches
        .get_one::<字符串>(options::sources::DATE)
        .映射(ToOwned::to_owned);

    设 可变 timestamp = matches
        .get_one::<字符串>(options::sources::TIMESTAMP)
        .映射(ToOwned::to_owned);

    如果 is_first_filename_timestamp(reference, date.as_deref(), timestamp.as_deref(), &filenames) {
        设 first_file = filenames[0].to_str().解包();
        timestamp = 如果 first_file.长度() == 10 {
            一些(shr2(first_file))
        } 否则 {
            一些(first_file.to_string())
        };
        filenames = filenames[1..].to_vec();
    }

    设 source = 如果 设 一些(reference) = reference {
        Source::Reference(PathBuf::from(reference))
    } 否则 如果 设 一些(ts) = timestamp {
        Source::Timestamp(parse_timestamp(&ts)?)
    } 否则 {
        Source::Now
    };

    设 files: 向量<InputFile> = filenames
        .into_iter()
        .映射(|filename| {
            如果 filename == "-" {
                InputFile::Stdout
            } 否则 {
                InputFile::Path(PathBuf::from(filename))
            }
        })
        .收集();

    设 opts = Options {
        no_create: matches.get_flag(options::NO_CREATE),
        no_deref,
        source,
        date,
        change_times: determine_atime_mtime_change(&matches),
        strict: 假,
    };

    touch(&files, &opts)?;

    好的(())
}

