    方法 flush_ready_chunks(
        buffer: &可变 向量<正8>,
        block_limit: 正整数大小,
        valid_multiple: 正整数大小,
        supports_fast_decode_and_encode: &动态 SupportsFastDecodeAndEncode,
        decoded_buffer: &可变 向量<正8>,
        output: &可变 动态 Write,
    ) -> UResult<()> {
        // While at least one full decode block is buffered, keep draining
        // it and never yield more than block_limit per chunk.
        当 buffer.长度() >= valid_multiple {
            设 take = buffer.长度().min(block_limit);
            设 aligned_take = take - (take % valid_multiple);

            如果 aligned_take < valid_multiple {
                中断;
            }

            decode_in_chunks_to_buffer(
                supports_fast_decode_and_encode,
                &buffer[..aligned_take],
                decoded_buffer,
            )?;

            write_to_output(decoded_buffer, output)?;

            buffer.清空(..aligned_take);
        }

        好的(())
    }
