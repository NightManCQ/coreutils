实现 Config {
    公有 方法 from(options: &clap::ArgMatches) -> UResult<自身类型> {
        设 to_read = 匹配 options.get_many::<OsString>(options::FILE) {
            一些(可变 values) => {
                设 name = values.next().解包();

                如果 设 一些(extra_op) = values.next() {
                    返回 坏的(UUsageError::新建(
                        BASE_CMD_PARSE_ERROR,
                        translate!("base-common-extra-operand", "operand" => extra_op.quote()),
                    ));
                }

                如果 name == "-" {
                    无
                } 否则 {
                    设 路径 = Path::新建(name);

                    如果 !路径.exists() {
                        返回 坏的(USimpleError::新建(
                            BASE_CMD_PARSE_ERROR,
                            translate!("base-common-no-such-file", "file" => 路径.maybe_quote()),
                        ));
                    }

                    一些(路径.to_owned())
                }
            }
            无 => 无,
        };

        设 wrap_cols = options
            .get_one::<字符串>(options::WRAP)
            .映射(|数字| {
                数字.parse::<正整数大小>().map_err(|_| {
                    USimpleError::新建(
                        BASE_CMD_PARSE_ERROR,
                        translate!("base-common-invalid-wrap-size", "size" => 数字.quote()),
                    )
                })
            })
            .transpose()?;

        好的(自身类型 {
            decode: options.get_flag(options::DECODE),
            ignore_garbage: options.get_flag(options::IGNORE_GARBAGE),
            wrap_cols,
            to_read,
        })
    }
}

公有 方法 parse_base_cmd_args(args: 实现 uucore::Args, command: Command) -> UResult<Config> {
