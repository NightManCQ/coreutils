公有 方法 base_app(about: 字符串, usage: 字符串) -> Command {
    设 cmd = Command::新建("")
        .version(uucore::crate_version!())
        .about(about)
        .override_usage(format_usage(&usage))
        .infer_long_args(真);
    uucore::clap_localization::configure_localized_command(cmd)
        // Format arguments.
        .arg(
            Arg::新建(options::DECODE)
                .short('d')
                .visible_short_alias('D')
                .long(options::DECODE)
                .help(translate!("base-common-help-decode"))
                .action(ArgAction::SetTrue)
                .overrides_with(options::DECODE),
        )
        .arg(
            Arg::新建(options::IGNORE_GARBAGE)
                .short('i')
                .long(options::IGNORE_GARBAGE)
                .help(translate!("base-common-help-ignore-garbage"))
                .action(ArgAction::SetTrue)
                .overrides_with(options::IGNORE_GARBAGE),
        )
        .arg(
            Arg::新建(options::WRAP)
                .short('w')
                .long(options::WRAP)
                .value_name("COLS")
                .help(translate!("base-common-help-wrap", "default" => WRAP_DEFAULT))
                .overrides_with(options::WRAP),
        )
        // "multiple" arguments are used to check whether there is more than one
        // file passed in.
        .arg(
            Arg::新建(options::FILE)
                .index(1)
                .action(ArgAction::Append)
                .value_parser(clap::value_parser!(OsString))
                .value_hint(clap::ValueHint::FilePath),
        )
}

公有 方法 get_input(config: &Config) -> UResult<盒子<动态 BufRead>> {
    匹配 &config.to_read {
        一些(path_buf) => {
            设 file =
                File::open(path_buf).map_err_context(|| path_buf.maybe_quote().to_string())?;
            好的(盒子::新建(BufReader::with_capacity(DEFAULT_BUF_SIZE, file)))
        }
        无 => {
            // Stdin is already buffered by the OS; wrap once more to reduce syscalls per read.
            好的(盒子::新建(BufReader::with_capacity(
                DEFAULT_BUF_SIZE,
                输入输出::stdin(),
            )))
        }
    }
}
公有 方法 handle_input<R: BufRead>(input: &可变 R, format: Format, config: Config) -> UResult<()> {
    // Always allow padding for Base64 to avoid a full pre-scan of the input.
    设 supports_fast_decode_and_encode =
        get_supports_fast_decode_and_encode(format, config.decode, 真);

    设 supports_fast_decode_and_encode_ref = supports_fast_decode_and_encode.as_ref();
    设 可变 stdout_lock = 输入输出::stdout().锁定();
    设 result = 匹配 (format, config.decode) {
        // Base58 must process the entire input as one big integer; keep the
        // historical behavior of buffering everything for this format only.
        (Format::Base58, _) => {
            设 可变 buffered = 向量::新建();
            input
                .read_to_end(&可变 buffered)
                .map_err(|err| USimpleError::新建(1, format_read_error(&err)))?;
            如果 config.decode {
                fast_decode::fast_decode_buffer(
                    buffered,
                    &可变 stdout_lock,
                    supports_fast_decode_and_encode_ref,
                    config.ignore_garbage,
                )
            } 否则 {
                fast_encode::fast_encode_buffer(
                    buffered,
                    &可变 stdout_lock,
                    supports_fast_decode_and_encode_ref,
                    config.wrap_cols,
                )
            }
        }
        // Streaming path for all other encodings keeps memory bounded.
        (_, 真) => fast_decode::fast_decode_stream(
            input,
            &可变 stdout_lock,
            supports_fast_decode_and_encode_ref,
            config.ignore_garbage,
        ),
        (_, 假) => fast_encode::fast_encode_stream(
            input,
            &可变 stdout_lock,
            supports_fast_decode_and_encode_ref,
            config.wrap_cols,
        ),
    };

    // Ensure any pending stdout buffer is flushed even if decoding failed; GNU basenc
    // keeps already-decoded bytes visible before reporting the error.
    匹配 (result, stdout_lock.flush()) {
        (res, 好的(())) => res,
        (好的(_), 坏的(err)) => 坏的(err.into()),
        (坏的(original), 坏的(_)) => 坏的(original),
    }
}

公有 方法 get_supports_fast_decode_and_encode(
    format: Format,
    decode: 布尔,
    has_padding: 布尔,
) -> 盒子<动态 SupportsFastDecodeAndEncode> {
    常量 BASE16_VALID_DECODING_MULTIPLE: 正整数大小 = 2;
    常量 BASE2_VALID_DECODING_MULTIPLE: 正整数大小 = 8;
    常量 BASE32_VALID_DECODING_MULTIPLE: 正整数大小 = 8;
    常量 BASE64_VALID_DECODING_MULTIPLE: 正整数大小 = 4;

    常量 BASE16_UNPADDED_MULTIPLE: 正整数大小 = 1;
    常量 BASE2_UNPADDED_MULTIPLE: 正整数大小 = 1;
    常量 BASE32_UNPADDED_MULTIPLE: 正整数大小 = 5;
    常量 BASE64_UNPADDED_MULTIPLE: 正整数大小 = 3;

    匹配 format {
        Format::Base16 => 盒子::from(EncodingWrapper::新建(
            HEXUPPER_PERMISSIVE,
            BASE16_VALID_DECODING_MULTIPLE,
            BASE16_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"0123456789ABCDEFabcdef",
        )),
        Format::Base2Lsbf => 盒子::from(EncodingWrapper::新建(
            BASE2LSBF,
            BASE2_VALID_DECODING_MULTIPLE,
            BASE2_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"01",
        )),
        Format::Base2Msbf => 盒子::from(EncodingWrapper::新建(
            BASE2MSBF,
            BASE2_VALID_DECODING_MULTIPLE,
            BASE2_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"01",
        )),
        Format::Base32 => 盒子::from(Base32Wrapper::新建(
            BASE32,
            BASE32_VALID_DECODING_MULTIPLE,
            BASE32_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"ABCDEFGHIJKLMNOPQRSTUVWXYZ234567=",
        )),
        Format::Base32Hex => 盒子::from(Base32Wrapper::新建(
            BASE32HEX,
            BASE32_VALID_DECODING_MULTIPLE,
            BASE32_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"0123456789ABCDEFGHIJKLMNOPQRSTUV=",
        )),
        Format::Base64 => {
            设 alphabet: &[正8] = 如果 has_padding {
                &b"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789+/="[..]
            } 否则 {
                &b"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789+/"[..]
            };
            设 use_padding = !decode || has_padding;
            盒子::from(Base64SimdWrapper::新建(
                use_padding,
                BASE64_VALID_DECODING_MULTIPLE,
                BASE64_UNPADDED_MULTIPLE,
                alphabet,
            ))
        }
        Format::Base64Url => 盒子::from(EncodingWrapper::新建(
            BASE64URL,
            BASE64_VALID_DECODING_MULTIPLE,
            BASE64_UNPADDED_MULTIPLE,
            // spell-checker:disable-next-line
            b"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789=_-",
        )),
        Format::Z85 => 盒子::from(Z85Wrapper {}),
        Format::Base58 => 盒子::from(Base58Wrapper {}),
    }
}

公有 模组 fast_encode {
    使用 箱::base_common::WRAP_DEFAULT;
    使用 标准库::{
        比较::min,
        集合::VecDeque,
        输入输出::{自身, BufRead, Write},
        数字::NonZeroUsize,
    };
    使用 uucore::{
        encoding::SupportsFastDecodeAndEncode,
        错误::{UResult, USimpleError},
    };

    结构 LineWrapping {
        line_length: NonZeroUsize,
        print_buffer: 向量<正8>,
    }

    // Start of helper functions
    方法 encode_in_chunks_to_buffer(
        supports_fast_decode_and_encode: &动态 SupportsFastDecodeAndEncode,
        read_buffer: &[正8],
        encoded_buffer: &可变 VecDeque<正8>,
    ) -> UResult<()> {
        supports_fast_decode_and_encode.encode_to_vec_deque(read_buffer, encoded_buffer)?;
        好的(())
    }

    方法 write_without_line_breaks(
        encoded_buffer: &可变 VecDeque<正8>,
        output: &可变 动态 Write,
        is_cleanup: 布尔,
        empty_wrap: 布尔,
    ) -> 输入输出::结果<()> {
        // TODO
        // `encoded_buffer` only has to be a VecDeque if line wrapping is enabled
        // (`make_contiguous` should be a no-op here)
        // Refactoring could avoid this call
        output.write_all(encoded_buffer.make_contiguous())?;

        如果 is_cleanup {
            如果 !empty_wrap {
                output.write_all(b"\n")?;
            }
        } 否则 {
            encoded_buffer.clear();
        }

        好的(())
    }

    方法 write_with_line_breaks(
        &可变 LineWrapping {
            引用 line_length,
            引用 可变 print_buffer,
        }: &可变 LineWrapping,
        encoded_buffer: &可变 VecDeque<正8>,
        output: &可变 动态 Write,
        is_cleanup: 布尔,
    ) -> 输入输出::结果<()> {
        设 line_length = line_length.获取();

        设 make_contiguous_result = encoded_buffer.make_contiguous();

        设 chunks_exact = make_contiguous_result.chunks_exact(line_length);

        设 可变 bytes_added_to_print_buffer = 0;

        循环 sl 在 chunks_exact {
            bytes_added_to_print_buffer += sl.长度();

            print_buffer.extend_from_slice(sl);
            print_buffer.压入(b'\n');
        }

        output.write_all(print_buffer)?;

        // Remove the bytes that were just printed from `encoded_buffer`
        drop(encoded_buffer.清空(..bytes_added_to_print_buffer));

        如果 is_cleanup {
            如果 encoded_buffer.为空() {
                // Do not write a newline in this case, because two trailing newlines should never be printed
            } 否则 {
                // Print the partial line, since this is cleanup and no more data is coming
                output.write_all(encoded_buffer.make_contiguous())?;
                output.write_all(b"\n")?;
            }
        } 否则 {
            print_buffer.clear();
        }

        好的(())
    }

    方法 write_to_output(
        line_wrapping: &可变 选项<LineWrapping>,
        encoded_buffer: &可变 VecDeque<正8>,
        output: &可变 动态 Write,
        is_cleanup: 布尔,
        empty_wrap: 布尔,
    ) -> 输入输出::结果<()> {
        // Write all data in `encoded_buffer` to `output`
        如果 设 &可变 一些(引用 可变 li) = line_wrapping {
            write_with_line_breaks(li, encoded_buffer, output, is_cleanup)?;
        } 否则 {
            write_without_line_breaks(encoded_buffer, output, is_cleanup, empty_wrap)?;
        }

        好的(())
    }
    // End of helper functions

    公有 方法 fast_encode_buffer(
        input: 向量<正8>,
        output: &可变 动态 Write,
        supports_fast_decode_and_encode: &动态 SupportsFastDecodeAndEncode,
        wrap: 选项<正整数大小>,
    ) -> UResult<()> {
        // Based on performance testing

        常量 ENCODE_IN_CHUNKS_OF_SIZE_MULTIPLE: 正整数大小 = 1_024;

        设 encode_in_chunks_of_size =
            supports_fast_decode_and_encode.unpadded_multiple() * ENCODE_IN_CHUNKS_OF_SIZE_MULTIPLE;

        断言!(encode_in_chunks_of_size > 0);

        // The "data-encoding" crate supports line wrapping, but not arbitrary line wrapping, only certain widths, so
        // line wrapping must be handled here.
        // https://github.com/ia0/data-encoding/blob/4f42ad7ef242f6d243e4de90cd1b46a57690d00e/lib/src/lib.rs#L1710
        设 可变 line_wrapping = 匹配 wrap {
            // Line wrapping is disabled because "-w"/"--wrap" was passed with "0"
            一些(0) => 无,
            // A custom line wrapping value was passed
            一些(an) => 一些(LineWrapping {
                line_length: NonZeroUsize::新建(an).解包(),
                print_buffer: 向量::<正8>::新建(),
            }),
            // Line wrapping was not set, so the default is used
            无 => 一些(LineWrapping {
                line_length: NonZeroUsize::新建(WRAP_DEFAULT).解包(),
                print_buffer: 向量::<正8>::新建(),
            }),
        };

        设 input_size = input.长度();

        // Start of buffers
        // Data that was read from `input` but has not been encoded yet
        设 可变 leftover_buffer = VecDeque::<正8>::新建();

        // Encoded data that needs to be written to `output`
        设 可变 encoded_buffer = VecDeque::<正8>::新建();
        // End of buffers

        input
            .迭代()
            .enumerate()
            .step_by(encode_in_chunks_of_size)
            .filter_map(|(idx, _)| {
                // The part of `input_buffer` that was actually filled by the call
                // to `read`
                设 buffer = &input[idx..min(input_size, idx + encode_in_chunks_of_size)];

                如果 buffer.长度() < encode_in_chunks_of_size {
                    leftover_buffer.extend(buffer);
                    断言!(leftover_buffer.长度() < encode_in_chunks_of_size);
                    无
                } 否则 {
                    一些(buffer)
                }
            })
            .for_each(|read_buffer| {
                // Encode data in chunks, then place it in `encoded_buffer`
                相等断言!(read_buffer.长度(), encode_in_chunks_of_size);
                encode_in_chunks_to_buffer(
                    supports_fast_decode_and_encode,
                    read_buffer,
                    &可变 encoded_buffer,
                )
                .解包();
                // Write all data in `encoded_buffer` to `output`
                write_to_output(
                    &可变 line_wrapping,
                    &可变 encoded_buffer,
                    output,
                    假,
                    wrap == 一些(0),
                )
                .解包();
            });

        // Cleanup
        // `input` has finished producing data, so the data remaining in the buffers needs to be encoded and printed
        {
            // Encode all remaining unencoded bytes, placing them in `encoded_buffer`
            supports_fast_decode_and_encode
                .encode_to_vec_deque(leftover_buffer.make_contiguous(), &可变 encoded_buffer)?;

            // Write all data in `encoded_buffer` to output
            // `is_cleanup` triggers special cleanup-only logic
            write_to_output(
                &可变 line_wrapping,
                &可变 encoded_buffer,
                output,
                真,
                wrap == 一些(0),
            )?;
        }
        好的(())
    }

    /// Encodes all data read from `input` into Base32 using a fast, chunked
    /// implementation and writes the result to `output`.
    ///
    /// The `supports_fast_decode_and_encode` parameter supplies an optimized
    /// encoder and determines the chunk size used for bulk processing. When
    /// `wrap` is:
    /// - `Some(0)`: no line wrapping is performed,
    /// - `Some(n)`: lines are wrapped every `n` characters,
    /// - `None`: the default wrap width is applied.
    ///
    /// Remaining bytes are encoded and flushed at the end. I/O or encoding
    /// failures are propagated via `UResult`.
    公有 方法 fast_encode_stream(
        input: &可变 动态 BufRead,
        output: &可变 动态 Write,
        supports_fast_decode_and_encode: &动态 SupportsFastDecodeAndEncode,
        wrap: 选项<正整数大小>,
    ) -> UResult<()> {
        常量 ENCODE_IN_CHUNKS_OF_SIZE_MULTIPLE: 正整数大小 = 1_024;

        设 encode_in_chunks_of_size =
            supports_fast_decode_and_encode.unpadded_multiple() * ENCODE_IN_CHUNKS_OF_SIZE_MULTIPLE;

        断言!(encode_in_chunks_of_size > 0);

        设 可变 line_wrapping = 匹配 wrap {
            一些(0) => 无,
            一些(an) => 一些(LineWrapping {
                line_length: NonZeroUsize::新建(an).解包(),
                print_buffer: 向量::<正8>::新建(),
            }),
            无 => 一些(LineWrapping {
                line_length: NonZeroUsize::新建(WRAP_DEFAULT).解包(),
                print_buffer: 向量::<正8>::新建(),
            }),
        };

        // Buffers
        设 可变 encoded_buffer = VecDeque::<正8>::新建();
        设 可变 leftover_buffer = 向量::<正8>::with_capacity(encode_in_chunks_of_size);

        无限循环 {
            设 read_buffer = input
                .fill_buf()
                .map_err(|err| USimpleError::新建(1, 超级::format_read_error(&err)))?;
            如果 read_buffer.为空() {
                中断;
            }

            设 可变 consumed = 0;

            如果 !leftover_buffer.为空() {
                设 needed = encode_in_chunks_of_size - leftover_buffer.长度();
                设 take = needed.min(read_buffer.长度());
                leftover_buffer.extend_from_slice(&read_buffer[..take]);
                consumed += take;

                如果 leftover_buffer.长度() == encode_in_chunks_of_size {
                    encode_in_chunks_to_buffer(
                        supports_fast_decode_and_encode,
                        leftover_buffer.as_slice(),
                        &可变 encoded_buffer,
                    )?;
                    leftover_buffer.clear();

                    write_to_output(
                        &可变 line_wrapping,
                        &可变 encoded_buffer,
                        output,
                        假,
                        wrap == 一些(0),
                    )?;
                }
            }

            设 remaining = &read_buffer[consumed..];
            设 full_chunk_bytes =
                (remaining.长度() / encode_in_chunks_of_size) * encode_in_chunks_of_size;

            如果 full_chunk_bytes > 0 {
                循环 chunk 在 remaining[..full_chunk_bytes].chunks_exact(encode_in_chunks_of_size) {
                    encode_in_chunks_to_buffer(
                        supports_fast_decode_and_encode,
                        chunk,
                        &可变 encoded_buffer,
                    )?;
                    write_to_output(
                        &可变 line_wrapping,
                        &可变 encoded_buffer,
                        output,
                        假,
                        wrap == 一些(0),
                    )?;
                }
                consumed += full_chunk_bytes;
            }

            如果 consumed < read_buffer.长度() {
                leftover_buffer.extend_from_slice(&read_buffer[consumed..]);
                consumed = read_buffer.长度();
            }

            input.consume(consumed);

            // `leftover_buffer` should never exceed one partial chunk.
            调试断言!(leftover_buffer.长度() < encode_in_chunks_of_size);
        }

        // Encode any remaining bytes and flush
        supports_fast_decode_and_encode
            .encode_to_vec_deque(&leftover_buffer, &可变 encoded_buffer)?;

        write_to_output(
            &可变 line_wrapping,
            &可变 encoded_buffer,
            output,
            真,
            wrap == 一些(0),
        )?;

        好的(())
    }
}

