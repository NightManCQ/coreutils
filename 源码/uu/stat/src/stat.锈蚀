实现 ScanUtil 循环 字符串切片 {
    /// Scans for a number at the beginning of the string
    /// Returns the parsed number and the character count
    /// Since we only deal with ASCII characters (+, -, 0-9), character count equals byte count
    方法 scan_num<F>(&自身) -> 选项<(F, 正整数大小)>
    何处
        F: 标准库::字符串切片::FromStr,
    {
        设 可变 chars = 自身.chars();
        设 计数 = chars
            .next()
            .过滤(|&c| c.is_ascii_digit() || c == '-' || c == '+')
            .map_or(0, |_| 1 + chars.take_while(字符::is_ascii_digit).计数());

        如果 计数 > 0 {
            F::from_str(&自身[..计数]).ok().映射(|x| (x, 计数))
        } 否则 {
            无
        }
    }

    方法 scan_char(&自身, radix: 正32) -> 选项<(字符, 正整数大小)> {
        设 计数 = 匹配 radix {
            8 => 3,
            16 => 2,
            _ => 返回 无,
        };
        设 chars = 自身.chars().enumerate();
        设 可变 res = 0;
        设 可变 offset = 0;
        循环 (i, c) 在 chars {
            如果 i >= 计数 {
                中断;
            }
            匹配 c.to_digit(radix) {
                一些(digit) => {
                    设 tmp = res * radix + digit;
                    如果 tmp < 256 {
                        res = tmp;
                    } 否则 {
                        中断;
                    }
                }
                无 => 中断,
            }
            offset = i + 1;
        }
        如果 offset > 0 {
            一些((res 转换 正8 转换 字符, offset))
        } 否则 {
            无
        }
    }
}

方法 group_num(s: &字符串切片) -> Cow<'_, 字符串切片> {
    设 is_negative = s.starts_with('-');
    断言!(is_negative || s.chars().take(1).全部(|c| c.is_ascii_digit()));
    断言!(s.chars().skip(1).全部(|c| c.is_ascii_digit()));
    如果 s.长度() < 4 {
        返回 s.into();
    }
    设 可变 res = 字符串::with_capacity((s.长度() - 1) / 3);
    设 s = 如果 is_negative {
        res.压入('-');
        &s[1..]
    } 否则 {
        s
    };
    设 可变 alone = (s.长度() - 1) % 3 + 1;
    res.push_str(&s[..alone]);
    当 alone != s.长度() {
        res.压入(',');
        res.push_str(&s[alone..alone + 3]);
        alone += 3;
    }
    res.into()
}

