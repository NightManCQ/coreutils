    #[allow(clippy::too_many_arguments)]
    方法 process_token_files(
        &自身,
        t: &Token,
        meta: &Metadata,
        display_name: &字符串切片,
        file: &OsString,
        file_type: FileType,
        from_user: 布尔,
        #[cfg(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android")))]
        follow_symbolic_links: 布尔,
        #[cfg(not(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android"))))]
        _: 布尔,
    ) -> 结果<(), 整32> {
        匹配 *t {
            Token::Byte(byte) => write_raw_byte(byte),
            Token::Char(c) => 打印!("{c}"),

            Token::Directive {
                flag,
                width,
                precision,
                format,
            } => {
                设 output = 匹配 format {
                    // access rights in octal
                    'a' => OutputType::UnsignedOct(0o7777 & meta.mode()),
                    // access rights in human readable form
                    'A' => OutputType::Str(display_permissions(meta, 真)),
                    // number of blocks allocated (see %B)
                    'b' => OutputType::Unsigned(meta.blocks()),

                    // the size in bytes of each block reported by %b
                    // FIXME: blocksize differs on various platform
                    // See coreutils/gnulib/lib/stat-size.h ST_NBLOCKSIZE // spell-checker:disable-line
                    'B' => OutputType::Unsigned(512),
                    // SELinux security context string
                    'C' => {
                        #[cfg(全部(
                            feature = "selinux",
                            任意(target_os = "linux", target_os = "android")
                        ))]
                        {
                            如果 uucore::selinux::is_selinux_enabled() {
                                匹配 uucore::selinux::get_selinux_security_context(
                                    Path::新建(file),
                                    follow_symbolic_links,
                                ) {
                                    好的(ctx) => OutputType::Str(ctx),
                                    坏的(_) => OutputType::Str(translate!(
                                        "stat-selinux-failed-get-context"
                                    )),
                                }
                            } 否则 {
                                OutputType::Str(translate!("stat-selinux-unsupported-system"))
                            }
                        }
                        #[cfg(not(全部(
                            feature = "selinux",
                            任意(target_os = "linux", target_os = "android")
                        )))]
                        {
                            OutputType::Str(translate!("stat-selinux-unsupported-os"))
                        }
                    }
                    // device number in decimal
                    'd' 如果 flag.major => OutputType::Unsigned(major(meta.dev() 转换 _) 转换 正64),
                    'd' 如果 flag.minor => OutputType::Unsigned(minor(meta.dev() 转换 _) 转换 正64),
                    'd' => OutputType::Unsigned(meta.dev()),
                    // device number in hex
                    'D' => OutputType::UnsignedHex(meta.dev()),
                    // raw mode in hex
                    'f' => OutputType::UnsignedHex(meta.mode() 转换 正64),
                    // file type
                    'F' => OutputType::Str(pretty_filetype(meta.mode() 转换 mode_t, meta.长度())),
                    // group ID of owner
                    'g' => OutputType::Unsigned(meta.gid() 转换 正64),
                    // group name of owner
                    'G' => {
                        设 group_name =
                            entries::gid2grp(meta.gid()).unwrap_or_else(|_| "UNKNOWN".to_owned());
                        OutputType::Str(group_name)
                    }
                    // number of hard links
                    'h' => OutputType::Unsigned(meta.nlink()),
                    // inode number
                    'i' => OutputType::Unsigned(meta.ino()),
                    // mount point
                    'm' => 匹配 自身.find_mount_point(file) {
                        一些(s) => OutputType::OsStr(s),
                        无 => OutputType::Str(字符串::新建()),
                    },
                    // file name
                    'n' => OutputType::Str(display_name.to_string()),
                    // quoted file name with dereference if symbolic link
                    'N' => {
                        设 file_name =
                            get_quoted_file_name(display_name, file, file_type, from_user)?;
                        OutputType::Str(file_name)
                    }
                    // optimal I/O transfer size hint
                    'o' => OutputType::Unsigned(meta.blksize()),
                    // total size, in bytes
                    's' => OutputType::Integer(meta.长度() 转换 整64),
                    // major device type in hex, for character/block device special
                    // files
                    't' => OutputType::UnsignedHex(major(meta.rdev() 转换 _) 转换 正64),
                    // minor device type in hex, for character/block device special
                    // files
                    'T' => OutputType::UnsignedHex(minor(meta.rdev() 转换 _) 转换 正64),
                    // user ID of owner
                    'u' => OutputType::Unsigned(meta.uid() 转换 正64),
                    // user name of owner
                    'U' => {
                        设 user_name =
                            entries::uid2usr(meta.uid()).unwrap_or_else(|_| "UNKNOWN".to_owned());
                        OutputType::Str(user_name)
                    }

                    // time of file birth, human-readable; - if unknown
                    'w' => OutputType::Str(pretty_time(meta, MetadataTimeField::Birth)),

                    // time of file birth, seconds since Epoch; 0 if unknown
                    'W' => OutputType::Integer(
                        metadata_get_time(meta, MetadataTimeField::Birth)
                            .map_or(0, |x| system_time_to_sec(x).0),
                    ),

                    // time of last access, human-readable
                    'x' => OutputType::Str(pretty_time(meta, MetadataTimeField::Access)),
                    // time of last access, seconds since Epoch
                    'X' => {
                        设 (sec, nsec) = metadata_get_time(meta, MetadataTimeField::Access)
                            .map_or((0, 0), system_time_to_sec);
                        OutputType::Float(sec 转换 点64 + nsec 转换 点64 / 1_000_000_000.0)
                    }
                    // time of last data modification, human-readable
                    'y' => OutputType::Str(pretty_time(meta, MetadataTimeField::Modification)),
                    // time of last data modification, seconds since Epoch
                    'Y' => {
                        设 (sec, nsec) = metadata_get_time(meta, MetadataTimeField::Modification)
                            .map_or((0, 0), system_time_to_sec);
                        OutputType::Float(sec 转换 点64 + nsec 转换 点64 / 1_000_000_000.0)
                    }
                    // time of last status change, human-readable
                    'z' => OutputType::Str(pretty_time(meta, MetadataTimeField::Change)),
                    // time of last status change, seconds since Epoch
                    'Z' => {
                        设 (sec, nsec) = metadata_get_time(meta, MetadataTimeField::Change)
                            .map_or((0, 0), system_time_to_sec);
                        OutputType::Float(sec 转换 点64 + nsec 转换 点64 / 1_000_000_000.0)
                    }
                    'R' => OutputType::UnsignedHex(meta.rdev()),
                    'r' 如果 flag.major => OutputType::Unsigned(major(meta.rdev() 转换 _) 转换 正64),
                    'r' 如果 flag.minor => OutputType::Unsigned(minor(meta.rdev() 转换 _) 转换 正64),
                    'r' => OutputType::Unsigned(meta.rdev()),
                    _ => OutputType::Unknown,
                };
                print_it(&output, flag, width, precision);
            }
        }
        好的(())
    }

    方法 do_stat(&自身, file: &OsStr, stdin_is_fifo: 布尔) -> 整32 {
        设 display_name = file.to_string_lossy();
        设 file = 如果 cfg!(unix) && display_name == "-" {
            如果 自身.show_fs {
                show_error!("{}", StatError::StdinFilesystemMode);
                返回 1;
            }
            如果 设 好的(p) = Path::新建("/dev/stdin").canonicalize() {
                p.into_os_string()
            } 否则 {
                OsString::from("/dev/stdin")
            }
        } 否则 {
            OsString::from(file)
        };
        如果 自身.show_fs {
            匹配 statfs(&file) {
                好的(meta) => {
                    设 tokens = &自身.default_tokens;

                    // Usage
                    循环 t 在 tokens {
                        process_token_filesystem(t, &meta, &display_name);
                    }
                }
                坏的(错误) => {
                    show_error!(
                        "{}",
                        StatError::CannotReadFilesystemInfo {
                            file: display_name.quote().to_string(),
                            错误
                        }
                    );
                    返回 1;
                }
            }
        } 否则 {
            设 follow_symbolic_links = 自身.follow || stdin_is_fifo && display_name == "-";
            设 result = 如果 follow_symbolic_links {
                文件系统::metadata(&file)
            } 否则 {
                文件系统::symlink_metadata(&file)
            };
            匹配 result {
                好的(meta) => {
                    设 file_type = meta.file_type();
                    设 tokens = 如果 自身.from_user
                        || !(file_type.is_char_device() || file_type.is_block_device())
                    {
                        &自身.default_tokens
                    } 否则 {
                        &自身.default_dev_tokens
                    };

                    循环 t 在 tokens {
                        如果 设 坏的(code) = 自身.process_token_files(
                            t,
                            &meta,
                            &display_name,
                            &file,
                            file_type,
                            自身.from_user,
                            follow_symbolic_links,
                        ) {
                            返回 code;
                        }
                    }
                }
                坏的(e) => {
                    show_error!(
                        "{}",
                        StatError::CannotStat {
                            file: display_name.quote().to_string(),
                            错误: e.to_string()
                        }
                    );
                    返回 1;
                }
            }
        }
        0
    }

    方法 default_format(show_fs: 布尔, terse: 布尔, show_dev_type: 布尔) -> 字符串 {
        // SELinux related format is *ignored*

        如果 show_fs {
            如果 terse {
                "%n %i %l %t %s %S %b %f %a %c %d\n".into()
            } 否则 {
                格式化!(
                    "  {}: \"%n\"\n    {}: %-8i {}: %-7l {}: %T\n{} \
