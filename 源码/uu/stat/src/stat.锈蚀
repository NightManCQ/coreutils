                         {}: %-10f {}: %a\n{}: {}: %-10c {}: %d\n",
                    translate!("stat-word-file"),
                    translate!("stat-word-id"),
                    translate!("stat-word-namelen"),
                    translate!("stat-word-type"),
                    translate!("stat-word-block"),
                    translate!("stat-word-size"),
