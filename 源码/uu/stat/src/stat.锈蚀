    Zero,
    Space,
}

/// pads the string with zeroes or spaces and prints it
///
/// # Example
/// ```ignore
/// uu_stat::pad_and_print("1", false, 5, Padding::Zero) == "00001";
/// ```
/// currently only supports '0' & ' ' as the padding character
/// because the format specification of print! does not support general
/// fill characters.
方法 pad_and_print(result: &字符串切片, left: 布尔, width: 正整数大小, padding: Padding) {
    匹配 (left, padding) {
        (假, Padding::Zero) => 打印!("{result:0>width$}"),
        (假, Padding::Space) => 打印!("{result:>width$}"),
        (真, Padding::Zero) => 打印!("{result:0<width$}"),
        (真, Padding::Space) => 打印!("{result:<width$}"),
    }
}

/// Pads and prints raw bytes (Unix-specific) or falls back to string printing
///
/// On Unix systems, this preserves non-UTF8 data by printing raw bytes
/// On other platforms, falls back to lossy string conversion
方法 pad_and_print_bytes<W: Write>(
    可变 writer: W,
    bytes: &[正8],
    left: 布尔,
    width: 正整数大小,
    precision: Precision,
) -> 结果<(), 标准库::输入输出::错误协议> {
    设 display_bytes = 匹配 precision {
        Precision::Number(p) 如果 p < bytes.长度() => &bytes[..p],
        _ => bytes,
    };

    设 display_len = display_bytes.长度();
    设 padding_needed = width.saturating_sub(display_len);

    设 (left_pad, right_pad) = 如果 left {
        (0, padding_needed)
    } 否则 {
        (padding_needed, 0)
    };

    如果 left_pad > 0 {
        write_padding(&可变 writer, left_pad)?;
    }
    writer.write_all(display_bytes)?;
    如果 right_pad > 0 {
        write_padding(&可变 writer, right_pad)?;
    }

    好的(())
}

/// write padding based on a writer W and n size
/// writer is genric to be any buffer like: `std::io::stdout`
/// n is the calculated padding size
方法 write_padding<W: Write>(writer: &可变 W, n: 正整数大小) -> 结果<(), 标准库::输入输出::错误协议> {
    循环 _ 在 0..n {
        writer.write_all(b" ")?;
    }
    好的(())
}

