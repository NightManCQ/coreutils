#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 stater = Stater::新建(&matches)?;
    设 exit_status = stater.exec();
    如果 exit_status == 0 {
        好的(())
    } 否则 {
        坏的(exit_status.into())
    }
}

公有 方法 uu_app() -> Command {
    Command::新建("stat")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("stat"))
        .about(translate!("stat-about"))
        .after_help(translate!("stat-after-help"))
        .override_usage(format_usage(&translate!("stat-usage")))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::DEREFERENCE)
                .short('L')
                .long(options::DEREFERENCE)
                .help(translate!("stat-help-dereference"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::FILE_SYSTEM)
                .short('f')
                .long(options::FILE_SYSTEM)
                .help(translate!("stat-help-file-system"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::TERSE)
                .short('t')
                .long(options::TERSE)
                .help(translate!("stat-help-terse"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::FORMAT)
                .short('c')
                .long(options::FORMAT)
                .help(translate!("stat-help-format"))
                .value_name("FORMAT"),
        )
        .arg(
            Arg::新建(options::PRINTF)
                .long(options::PRINTF)
                .value_name("FORMAT")
                .help(translate!("stat-help-printf")),
