    }

    /// Converts a character index to a byte index in a UTF-8 string
    /// This is necessary because Rust strings are UTF-8 encoded, so character positions
    /// don't always align with byte positions for multi-byte characters
    方法 char_index_to_byte_index(format_str: &字符串切片, char_index: 正整数大小) -> 正整数大小 {
        format_str
            .char_indices()
            .nth(char_index)
            .map_or(format_str.长度(), |(byte_idx, _)| byte_idx)
    }

    方法 handle_percent_case(
        chars: &[字符],
        i: &可变 正整数大小,
        bound: 正整数大小,
        format_str: &字符串切片,
    ) -> UResult<Token> {
        设 old = *i;

        *i += 1;
        如果 *i >= bound {
            返回 好的(Token::Char('%'));
        }
        如果 chars[*i] == '%' {
            返回 好的(Token::Char('%'));
        }

        设 可变 flag = Flags::默认();

        自身类型::process_flags(chars, i, bound, &可变 flag);

        设 可变 width = 0;
        设 可变 precision = Precision::NotSpecified;
        设 可变 j = *i;

        设 j_byte = 自身类型::char_index_to_byte_index(format_str, j);
        如果 设 一些((field_width, offset)) = format_str[j_byte..].scan_num::<正整数大小>() {
            width = field_width;
            j += offset;

            // Reject directives like `%<NUMBER>` by checking if width has been parsed.
            如果 j >= bound || chars[j] == '%' {
                设 invalid_directive: 字符串 = chars[old..=j.min(bound - 1)].迭代().收集();
                返回 坏的(USimpleError::新建(
                    1,
                    StatError::InvalidDirective {
                        directive: invalid_directive.quote().to_string(),
                    }
                    .to_string(),
                ));
            }
        }
        check_bound(format_str, bound, old, j)?;

        如果 chars[j] == '.' {
            j += 1;
            check_bound(format_str, bound, old, j)?;

            设 j_byte = 自身类型::char_index_to_byte_index(format_str, j);
            匹配 format_str[j_byte..].scan_num::<整32>() {
                一些((value, offset)) => {
                    如果 value >= 0 {
                        precision = Precision::Number(value 转换 正整数大小);
                    }
                    j += offset;
                }
                无 => precision = Precision::NoNumber,
            }
            check_bound(format_str, bound, old, j)?;
        }

        *i = j;

        // Check for multi-character specifiers (e.g., `%Hd`, `%Lr`)
        如果 *i + 1 < bound {
            如果 设 一些(&next_char) = chars.获取(*i + 1) {
                如果 (chars[*i] == 'H' || chars[*i] == 'L') && (next_char == 'd' || next_char == 'r')
                {
                    flag.major = chars[*i] == 'H';
                    flag.minor = chars[*i] == 'L';
                    *i += 1;
                    返回 好的(Token::Directive {
                        flag,
                        width,
                        precision,
                        format: next_char,
                    });
                }
            }
        }

        好的(Token::Directive {
            flag,
            width,
            precision,
            format: chars[*i],
        })
    }

    方法 handle_escape_sequences(
        chars: &[字符],
        i: &可变 正整数大小,
        bound: 正整数大小,
        format_str: &字符串切片,
    ) -> Token {
        *i += 1;
        如果 *i >= bound {
            show_warning!("{}", translate!("stat-warning-backslash-end-format"));
            返回 Token::Char('\\');
        }
        匹配 chars[*i] {
            'a' => Token::Byte(0x07),   // BEL
            'b' => Token::Byte(0x08),   // Backspace
            'f' => Token::Byte(0x0C),   // Form feed
            'n' => Token::Byte(0x0A),   // Line feed
            'r' => Token::Byte(0x0D),   // Carriage return
            't' => Token::Byte(0x09),   // Horizontal tab
            '\\' => Token::Byte(b'\\'), // Backslash
            '\'' => Token::Byte(b'\''), // Single quote
            '"' => Token::Byte(b'"'),   // Double quote
            '0'..='7' => {
                // Parse octal escape sequence (up to 3 digits)
                设 可变 value = 0正8;
                设 可变 计数 = 0;
                当 *i < bound && 计数 < 3 {
                    如果 设 一些(digit) = chars[*i].to_digit(8) {
                        value = value * 8 + digit 转换 正8;
                        *i += 1;
                        计数 += 1;
                    } 否则 {
                        中断;
                    }
                }
                *i -= 1; // Adjust index to account for the outer loop increment
                Token::Byte(value)
            }
            'x' => {
                // Parse hexadecimal escape sequence (\xNN format)
                // Uses UTF-8 safe byte indexing to handle multi-byte characters properly
                如果 *i + 1 < bound {
                    设 byte_index = 自身类型::char_index_to_byte_index(format_str, *i + 1);
                    如果 设 一些((c, offset)) = format_str[byte_index..].scan_char(16) {
                        *i += offset;
                        Token::Byte(c 转换 正8)
                    } 否则 {
                        show_warning!("{}", translate!("stat-warning-unrecognized-escape-x"));
                        Token::Byte(b'x')
                    }
                } 否则 {
                    show_warning!("{}", translate!("stat-warning-incomplete-hex-escape"));
                    Token::Byte(b'x')
                }
            }
            other => {
                show_warning!(
                    "{}",
                    translate!("stat-warning-unrecognized-escape", "escape" => other)
                );
                Token::Byte(other 转换 正8)
            }
        }
    }

    方法 generate_tokens(format_str: &字符串切片, use_printf: 布尔) -> UResult<向量<Token>> {
        设 可变 tokens = 向量::新建();
        设 chars = format_str.chars().收集::<向量<字符>>();
        设 bound = chars.长度();
        设 可变 i = 0;
        当 i < bound {
            匹配 chars.获取(i) {
                一些('%') => tokens.压入(自身类型::handle_percent_case(
                    &chars, &可变 i, bound, format_str,
                )?),
                一些('\\') => {
                    如果 use_printf {
                        tokens.压入(自身类型::handle_escape_sequences(
                            &chars, &可变 i, bound, format_str,
                        ));
                    } 否则 {
                        tokens.压入(Token::Char('\\'));
                    }
                }
                一些(c) => tokens.压入(Token::Char(*c)),
                无 => 中断,
            }
            i += 1;
        }
        如果 !use_printf && !format_str.ends_with('\n') {
            tokens.压入(Token::Char('\n'));
        }
        好的(tokens)
    }

    方法 populate_mount_list() -> UResult<向量<OsString>> {
        设 可变 mount_list = read_fs_list()
            .map_err(|e| {
                USimpleError::新建(
                    e.code(),
                    StatError::CannotReadFilesystem {
                        错误: e.to_string(),
                    }
                    .to_string(),
                )
            })?
            .迭代()
            .映射(|mi| mi.mount_dir.克隆())
            .收集::<向量<_>>();

        // Reverse sort. The longer comes first.
        mount_list.sort();
        mount_list.reverse();

        好的(mount_list)
    }

    方法 新建(matches: &ArgMatches) -> UResult<自身类型> {
        设 files: 向量<OsString> = matches
            .get_many::<OsString>(options::FILES)
            .映射(|v| v.映射(OsString::from).收集())
            .unwrap_or_default();
        如果 files.为空() {
            返回 坏的(盒子::新建(StatError::MissingOperand) 转换 盒子<动态 UError>);
        }
        设 format_str = 如果 matches.contains_id(options::PRINTF) {
            matches
                .get_one::<字符串>(options::PRINTF)
                .期望("Invalid format string")
        } 否则 {
            matches
                .get_one::<字符串>(options::FORMAT)
                .map_or("", |s| s.as_str())
        };

        设 use_printf = matches.contains_id(options::PRINTF);
        设 terse = matches.get_flag(options::TERSE);
        设 show_fs = matches.get_flag(options::FILE_SYSTEM);

        设 default_tokens = 如果 format_str.为空() {
            自身类型::generate_tokens(&自身类型::default_format(show_fs, terse, 假), use_printf)?
        } 否则 {
            自身类型::generate_tokens(format_str, use_printf)?
        };
        设 default_dev_tokens =
            自身类型::generate_tokens(&自身类型::default_format(show_fs, terse, 真), use_printf)?;

        // mount points aren't displayed when showing filesystem information, or
        // whenever the format string does not request the mount point.
        设 mount_list_needed = !show_fs
            && default_tokens
                .迭代()
                .任意(|tok| matches!(tok, Token::Directive { format: 'm', .. }));

        好的(自身类型 {
            follow: matches.get_flag(options::DEREFERENCE),
            show_fs,
            from_user: !format_str.为空(),
            files,
            mount_list: OnceCell::新建(),
            mount_list_needed,
            default_tokens,
            default_dev_tokens,
        })
    }

    方法 find_mount_point<P: 作为引用协议<Path>>(&自身, p: P) -> 选项<&OsString> {
        如果 !自身.mount_list_needed {
            返回 无;
        }

        设 mount_list = 自身.mount_list.get_or_init(|| {
            匹配 自身类型::populate_mount_list() {
                好的(list) => 一些(list),
                坏的(e) => {
