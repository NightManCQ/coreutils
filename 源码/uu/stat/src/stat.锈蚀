        .arg(
            Arg::新建(options::FILES)
                .action(ArgAction::Append)
                .value_parser(ValueParser::os_string())
                .value_hint(clap::ValueHint::FilePath),
        )
}

常量 PRETTY_DATETIME_FORMAT: &字符串切片 = "%Y-%m-%d %H:%M:%S.%N %z";

方法 pretty_time(meta: &Metadata, md_time_field: MetadataTimeField) -> 字符串 {
    如果 设 一些(时间) = metadata_get_time(meta, md_time_field) {
        设 可变 tmp = 向量::新建();
        如果 format_system_time(
            &可变 tmp,
            时间,
            PRETTY_DATETIME_FORMAT,
            FormatSystemTimeFallback::Float,
        )
        .is_ok()
        {
            返回 字符串::from_utf8(tmp).解包();
        }
    }
    "-".to_string()
}

