        } 否则 如果 terse {
            "%n %s %b %f %u %g %D %i %h %t %T %X %Y %Z %W %o\n".into()
        } 否则 {
            设 device_line = 如果 show_dev_type {
                格式化!(
                    "{}: %Hd,%Ld\t{}: %-10i  {}: %-5h {} {}: %t,%T\n",
