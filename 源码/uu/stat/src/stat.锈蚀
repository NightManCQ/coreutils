实现 Stater {
    方法 process_flags(chars: &[字符], i: &可变 正整数大小, bound: 正整数大小, flag: &可变 Flags) {
        当 *i < bound {
            匹配 chars[*i] {
                '#' => flag.alter = 真,
                '0' => flag.zero = 真,
                '-' => flag.left = 真,
                ' ' => flag.space = 真,
                // This is not documented but the behavior seems to be
                // the same as a space. For example `stat -c "%I5s" f`
                // prints "    0".
                'I' => flag.space = 真,
                '+' => flag.sign = 真,
                '\'' => flag.group = 真,
