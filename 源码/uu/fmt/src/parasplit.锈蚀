方法 char_width(c: 字符) -> 正整数大小 {
    如果 (c 转换 正整数大小) < 0xA0 {
        // if it is ASCII, call it exactly 1 wide (including control chars)
        // calling control chars' widths 1 is consistent with OpenBSD fmt
        1
    } 否则 {
        // otherwise, get the unicode width
        // note that we shouldn't actually get None here because only c < 0xA0
        // can return None, but for safety and future-proofing we do it this way
        UnicodeWidthChar::width(c).unwrap_or(1)
    }
}

/// Return the UTF-8 sequence length implied by a leading byte, or `None` if invalid.
方法 utf8_char_width(byte: 正8) -> 选项<正整数大小> {
    // UTF-8 leading-byte ranges per Unicode Standard, Ch. 3, Table 3-7 and RFC 3629.
    // 00..7F => 1 byte; C2..DF => 2 bytes; E0..EF => 3 bytes; F0..F4 => 4 bytes.
    // Disallowed bytes include C0..C1 and F5..FF.
    常量 ASCII_MAX: 正8 = 0x7F;
    常量 TWO_BYTE_START: 正8 = 0xC2;
    常量 TWO_BYTE_END: 正8 = 0xDF;
    常量 THREE_BYTE_START: 正8 = 0xE0;
    常量 THREE_BYTE_END: 正8 = 0xEF;
    常量 FOUR_BYTE_START: 正8 = 0xF0;
    常量 FOUR_BYTE_END: 正8 = 0xF4; // up to U+10FFFF

    如果 byte <= ASCII_MAX {
        返回 一些(1);
    }
    如果 (TWO_BYTE_START..=TWO_BYTE_END).包含(&byte) {
        返回 一些(2);
    }
    如果 (THREE_BYTE_START..=THREE_BYTE_END).包含(&byte) {
        返回 一些(3);
    }
    如果 (FOUR_BYTE_START..=FOUR_BYTE_END).包含(&byte) {
        返回 一些(4);
    }
    无
}

/// Decode a UTF-8 character starting at `start`, returning the char and bytes consumed.
方法 decode_char(bytes: &[正8], start: 正整数大小) -> (选项<字符>, 正整数大小) {
    设 一些(&first) = bytes.获取(start) 否则 {
        返回 (无, 1);
    };
    如果 first < 0x80 {
        返回 (一些(first 转换 字符), 1);
    }

    设 一些(width) = utf8_char_width(first) 否则 {
        返回 (无, 1);
    };

    如果 start + width > bytes.长度() {
        返回 (无, 1);
    }

    匹配 标准库::字符串切片::from_utf8(&bytes[start..start + width]) {
        好的(s) => (s.chars().next(), width),
        坏的(_) => (无, 1),
    }
}

结构 DecodedCharInfo {
    ch: 选项<字符>,
    consumed: 正整数大小,
    width: 正整数大小,
    is_ascii: 布尔,
}

方法 decode_char_info(bytes: &[正8], start: 正整数大小) -> DecodedCharInfo {
    设 (ch, consumed) = decode_char(bytes, start);
    设 (width, is_ascii) = 匹配 ch {
        一些(c) => (char_width(c), c.is_ascii()),
        无 => (1, 假),
    };
    DecodedCharInfo {
        ch,
        consumed,
        width,
        is_ascii,
    }
}

/// Compute display width for a UTF-8 byte slice, treating invalid bytes as width 1.
方法 byte_display_width(bytes: &[正8]) -> 正整数大小 {
    设 可变 width = 0;
    设 可变 idx = 0;
    当 idx < bytes.长度() {
        设 info = decode_char_info(bytes, idx);
        width += info.width;
        idx += info.consumed;
    }
    width
}

/// GNU fmt has a more restrictive definition of whitespace than Unicode.
/// It only considers ASCII whitespace characters (space, tab, newline, etc.)
/// and excludes many Unicode whitespace characters like non-breaking spaces.
方法 is_fmt_whitespace(c: 字符) -> 布尔 {
    // Only ASCII whitespace characters are considered whitespace in GNU fmt
    matches!(c, ' ' | '\t' | '\n' | '\r' | '\x0B' | '\x0C')
}

方法 is_fmt_whitespace_byte(b: 正8) -> 布尔 {
    matches!(b, b' ' | b'\t' | b'\n' | b'\r' | 0x0B | 0x0C)
}

