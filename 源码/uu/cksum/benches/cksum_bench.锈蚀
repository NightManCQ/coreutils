/// Benchmark cksum processing multiple files
#[divan::bench]
方法 cksum_multiple_files(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 data1 = text_data::generate_by_size(50, 80);
            设 data2 = text_data::generate_by_size(50, 80);
            设 data3 = text_data::generate_by_size(50, 80);

            设 file1 = setup_test_file(&data1);
            设 file2 = setup_test_file(&data2);
            设 file3 = setup_test_file(&data3);

            (file1, file2, file3)
        })
        .bench_values(|(file1, file2, file3)| {
            black_box(run_util_function(
                uumain,
                &[
                    file1.to_str().解包(),
                    file2.to_str().解包(),
                    file3.to_str().解包(),
                ],
            ));
        });
}

