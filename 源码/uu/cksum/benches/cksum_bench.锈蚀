/// Benchmark cksum with default CRC algorithm
#[divan::bench]
方法 cksum_default(bencher: Bencher) {
    设 data = text_data::generate_by_size(100, 80);
    设 file_path = setup_test_file(&data);

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path.to_str().解包()]));
    });
}

