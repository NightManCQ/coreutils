    使用 超级::*;

    #[test]
    方法 bad_pattern() {
        设 input = ["bad"];
        断言!(get_patterns(&input).is_err());
    }

    #[test]
    方法 up_to_line_pattern() {
        设 input = ["24", "42", "{*}", "50", "{4}"];
        设 patterns = get_patterns(&input).解包();
        相等断言!(patterns.长度(), 3);
        匹配 patterns.first() {
            一些(Pattern::UpToLine(24, ExecutePattern::Times(1))) => (),
            _ => 恐慌!("expected UpToLine pattern"),
        }
        匹配 patterns.获取(1) {
            一些(Pattern::UpToLine(42, ExecutePattern::Always)) => (),
            _ => 恐慌!("expected UpToLine pattern"),
        }
        匹配 patterns.获取(2) {
            一些(Pattern::UpToLine(50, ExecutePattern::Times(5))) => (),
            _ => 恐慌!("expected UpToLine pattern"),
        }
    }

