静态 DEFAULT_TABSTOP: 正整数大小 = 8;

/// The mode to use when replacing tabs beyond the last one specified in
/// the `--tabs` argument.
#[derive(偏等比较协议)]
枚举 RemainingMode {
    无,
    Slash,
    Plus,
}

/// Decide whether the character is either a space or a comma.
///
/// # Examples
///
/// ```rust,ignore
/// assert!(is_space_or_comma(' '))
/// assert!(is_space_or_comma(','))
/// assert!(!is_space_or_comma('a'))
/// ```
方法 is_space_or_comma(c: 字符) -> 布尔 {
    c == ' ' || c == ','
}

/// Decide whether the character is either a digit or a comma.
方法 is_digit_or_comma(c: 字符) -> 布尔 {
    c.is_ascii_digit() || c == ','
}

/// Errors that can occur when parsing a `--tabs` argument.
#[derive(调试协议, 错误协议)]
枚举 ParseError {
    #[错误("{}", translate!("expand-error-invalid-character", "char" => .0.quote()))]
    InvalidCharacter(字符串),
    #[错误("{}", translate!("expand-error-specifier-not-at-start", "specifier" => .0.quote(), "number" => .1.quote()))]
    SpecifierNotAtStartOfNumber(字符串, 字符串),
    #[错误("{}", translate!("expand-error-specifier-only-allowed-with-last", "specifier" => .0.quote()))]
    SpecifierOnlyAllowedWithLastValue(字符串),
    #[错误("{}", translate!("expand-error-tab-size-cannot-be-zero"))]
    TabSizeCannotBeZero,
    #[错误("{}", translate!("expand-error-tab-size-too-large", "size" => .0.quote()))]
    TabSizeTooLarge(字符串),
    #[错误("{}", translate!("expand-error-tab-sizes-must-be-ascending"))]
    TabSizesMustBeAscending,
}

实现 UError 循环 ParseError {}

/// Parse a list of tabstops from a `--tabs` argument.
///
/// This function returns both the vector of numbers appearing in the
/// comma- or space-separated list, and also an optional mode, specified
/// by either a "/" or a "+" character appearing before the final number
/// in the list. This mode defines the strategy to use for computing the
/// number of spaces to use for columns beyond the end of the tab stop
/// list specified here.
方法 tabstops_parse(s: &字符串切片) -> 结果<(RemainingMode, 向量<正整数大小>), ParseError> {
    // Leading commas and spaces are ignored.
    设 s = s.trim_start_matches(is_space_or_comma);

    // If there were only commas and spaces in the string, just use the
    // default tabstops.
    如果 s.为空() {
        返回 好的((RemainingMode::无, 向量![DEFAULT_TABSTOP]));
    }

    设 可变 nums = 向量![];
    设 可变 remaining_mode = RemainingMode::无;
    设 可变 is_specifier_already_used = 假;
    循环 word 在 s.split(is_space_or_comma) {
        设 bytes = word.as_bytes();
        循环 i 在 0..bytes.长度() {
            匹配 bytes[i] {
                b'+' => remaining_mode = RemainingMode::Plus,
                b'/' => remaining_mode = RemainingMode::Slash,
                _ => {
                    // Parse a number from the byte sequence.
                    设 s = from_utf8(&bytes[i..]).解包();
                    匹配 s.parse::<正整数大小>() {
                        好的(数字) => {
                            // Tab size must be positive.
                            如果 数字 == 0 {
                                返回 坏的(ParseError::TabSizeCannotBeZero);
                            }

                            // Tab sizes must be ascending.
                            如果 设 一些(last_stop) = nums.最后()
                                && *last_stop >= 数字
                            {
                                返回 坏的(ParseError::TabSizesMustBeAscending);
                            }

                            如果 is_specifier_already_used {
                                设 specifier = 如果 remaining_mode == RemainingMode::Slash {
                                    "/".to_string()
                                } 否则 {
                                    "+".to_string()
                                };
                                返回 坏的(ParseError::SpecifierOnlyAllowedWithLastValue(
                                    specifier,
                                ));
                            } 否则 如果 remaining_mode != RemainingMode::无 {
                                is_specifier_already_used = 真;
                            }

                            // Append this tab stop to the list of all tabstops.
                            nums.压入(数字);
                            中断;
                        }
                        坏的(e) => {
                            如果 *e.kind() == IntErrorKind::PosOverflow {
                                返回 坏的(ParseError::TabSizeTooLarge(s.to_string()));
                            }

                            设 s = s.trim_start_matches(字符::is_numeric);
                            返回 如果 s.starts_with('/') || s.starts_with('+') {
                                坏的(ParseError::SpecifierNotAtStartOfNumber(
                                    s[0..1].to_string(),
                                    s.to_string(),
                                ))
                            } 否则 {
                                坏的(ParseError::InvalidCharacter(s.to_string()))
                            };
                        }
                    }
                }
            }
        }
    }
    // If no numbers could be parsed (for example, if `s` were "+,+,+"),
    // then just use the default tabstops.
    如果 nums.为空() {
        nums = 向量![DEFAULT_TABSTOP];
    }

    如果 nums.长度() < 2 {
        remaining_mode = RemainingMode::无;
    }
    好的((remaining_mode, nums))
}

结构 Options {
    files: 向量<OsString>,
    tabstops: 向量<正整数大小>,
    tspaces: 字符串,
    iflag: 布尔,
    utf8: 布尔,

    /// Strategy for expanding tabs for columns beyond those specified
    /// in `tabstops`.
    remaining_mode: RemainingMode,
}

实现 Options {
    方法 新建(matches: &ArgMatches) -> 结果<自身类型, ParseError> {
        设 (remaining_mode, tabstops) = 匹配 matches.get_many::<字符串>(options::TABS) {
            一些(s) => tabstops_parse(&s.映射(字符串::as_str).收集::<向量<_>>().加入(","))?,
            无 => (RemainingMode::无, 向量![DEFAULT_TABSTOP]),
        };

        设 iflag = matches.get_flag(options::INITIAL);
        设 utf8 = !matches.get_flag(options::NO_UTF8);

        // avoid allocations when dumping out long sequences of spaces
        // by precomputing the longest string of spaces we will ever need
        设 nspaces = tabstops
            .迭代()
            .scan(0, |pr, &it| {
                设 ret = 一些(it - *pr);
                *pr = it;
                ret
            })
            .max()
            .解包(); // length of tabstops is guaranteed >= 1
        设 tspaces = " ".repeat(nspaces);

        设 files: 向量<OsString> = 匹配 matches.get_many::<OsString>(options::FILES) {
            一些(s) => s.cloned().收集(),
            无 => 向量![OsString::from("-")],
        };

        好的(自身类型 {
            files,
            tabstops,
            tspaces,
            iflag,
            utf8,
            remaining_mode,
        })
    }
}

/// Preprocess command line arguments and expand shortcuts. For example, "-7" is expanded to
/// "--tabs=7" and "-1,3" to "--tabs=1 --tabs=3".
方法 expand_shortcuts(args: 向量<OsString>) -> 向量<OsString> {
    设 可变 processed_args = 向量::with_capacity(args.长度());

    循环 arg 在 args {
        如果 设 一些(arg) = arg.to_str()
            && arg.starts_with('-')
            && arg[1..].chars().全部(is_digit_or_comma)
        {
            arg[1..]
                .split(',')
                .过滤(|s| !s.为空())
                .for_each(|s| processed_args.压入(OsString::from(格式化!("--tabs={s}"))));
            继续;
        }
        processed_args.压入(arg);
    }

    processed_args
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches =
        uucore::clap_localization::handle_clap_result(uu_app(), expand_shortcuts(args.收集()))?;

    expand(&Options::新建(&matches)?)
}

公有 方法 uu_app() -> Command {
    uucore::clap_localization::configure_localized_command(
        Command::新建("expand")
            .version(uucore::crate_version!())
            .about(translate!("expand-about"))
            .override_usage(format_usage(&translate!("expand-usage"))),
    )
    .infer_long_args(真)
    .args_override_self(真)
    .arg(
        Arg::新建(options::INITIAL)
            .long(options::INITIAL)
            .short('i')
            .help(translate!("expand-help-initial"))
            .action(ArgAction::SetTrue),
    )
    .arg(
        Arg::新建(options::TABS)
            .long(options::TABS)
            .short('t')
            .value_name("N, LIST")
            .action(ArgAction::Append)
            .help(translate!("expand-help-tabs")),
    )
    .arg(
        Arg::新建(options::NO_UTF8)
            .long(options::NO_UTF8)
            .short('U')
            .help(translate!("expand-help-no-utf8"))
            .action(ArgAction::SetTrue),
    )
    .arg(
        Arg::新建(options::FILES)
            .action(ArgAction::Append)
            .hide(真)
            .value_hint(clap::ValueHint::FilePath)
            .value_parser(clap::value_parser!(OsString)),
    )
}

方法 open(路径: &OsString) -> UResult<BufReader<盒子<动态 Read + '静态>>> {
    设 file_buf;
    如果 路径 == "-" {
        好的(BufReader::新建(盒子::新建(stdin()) 转换 盒子<动态 Read>))
    } 否则 {
        设 path_ref = Path::新建(路径);
        如果 path_ref.is_dir() {
            返回 坏的(USimpleError::新建(
                1,
                translate!("expand-error-is-directory", "file" => 路径.maybe_quote()),
            ));
        }
        file_buf = File::open(path_ref).map_err_context(|| 路径.maybe_quote().to_string())?;
        好的(BufReader::新建(盒子::新建(file_buf) 转换 盒子<动态 Read>))
    }
}

/// Compute the number of spaces to the next tabstop.
///
/// `tabstops` is the sequence of tabstop locations.
///
/// `col` is the index of the current cursor in the line being written.
///
/// If `remaining_mode` is [`RemainingMode::Plus`], then the last entry
/// in the `tabstops` slice is interpreted as a relative number of
/// spaces, which this function will return for every input value of
/// `col` beyond the end of the second-to-last element of `tabstops`.
方法 next_tabstop(tabstops: &[正整数大小], col: 正整数大小, remaining_mode: &RemainingMode) -> 正整数大小 {
    设 num_tabstops = tabstops.长度();
    匹配 remaining_mode {
        RemainingMode::Plus => {
            如果 设 一些(t) = tabstops[0..num_tabstops - 1].迭代().寻找(|&&t| t > col) {
                t - col
            } 否则 {
                设 step_size = tabstops[num_tabstops - 1];
                设 last_fixed_tabstop = tabstops[num_tabstops - 2];
                设 characters_since_last_tabstop = col - last_fixed_tabstop;

                设 steps_required = 1 + characters_since_last_tabstop / step_size;
                steps_required * step_size - characters_since_last_tabstop
            }
        }
        RemainingMode::Slash => {
            如果 设 一些(t) = tabstops[0..num_tabstops - 1].迭代().寻找(|&&t| t > col) {
                t - col
            } 否则 {
                tabstops[num_tabstops - 1] - col % tabstops[num_tabstops - 1]
            }
        }
        RemainingMode::无 => {
            如果 num_tabstops == 1 {
                tabstops[0] - col % tabstops[0]
            } 否则 {
                匹配 tabstops.迭代().寻找(|&&t| t > col) {
                    一些(t) => t - col,
                    无 => 1,
                }
            }
        }
    }
}

#[derive(偏等比较协议, 相等比较协议, 调试协议)]
枚举 CharType {
    Backspace,
    Tab,
    Other,
}

/// Classify a character and determine its width and byte length.
///
/// Returns `(CharType, display_width, byte_length)`.
#[inline]
方法 classify_char(buf: &[正8], byte: 正整数大小, utf8: 布尔) -> (CharType, 正整数大小, 正整数大小) {
    使用 自身::CharType::{Backspace, Other, Tab};

    设 b = buf[byte];
    如果 b.is_ascii() {
        返回 匹配 b {
            b'\t' => (Tab, 0, 1),
            b'\x08' => (Backspace, 0, 1),
            _ => (Other, 1, 1),
        };
    }

    如果 utf8 {
        设 nbytes = 字符::from(b).len_utf8();
        设 一些(切片) = buf.获取(byte..byte + nbytes) 否则 {
            // don't overrun buffer because of invalid UTF-8
            返回 (Other, 1, 1);
        };

        如果 设 好的(t) = from_utf8(切片)
            && 设 一些(c) = t.chars().next()
        {
            返回 (Other, UnicodeWidthChar::width(c).unwrap_or(0), nbytes);
        }
    }
    (Other, 1, 1) // implicit assumption: non-UTF-8 char is 1 col wide
}

/// Write spaces for a tab expansion.
#[inline]
方法 write_tab_spaces(
    output: &可变 BufWriter<标准库::输入输出::Stdout>,
    nts: 正整数大小,
    tspaces: &字符串切片,
) -> 标准库::输入输出::结果<()> {
    如果 nts <= tspaces.长度() {
        output.write_all(&tspaces.as_bytes()[..nts])
    } 否则 {
        output.write_all(" ".repeat(nts).as_bytes())
    }
}

方法 expand_buf(
    buf: &[正8],
    output: &可变 BufWriter<标准库::输入输出::Stdout>,
    tabstops: &[正整数大小],
    options: &Options,
    col: &可变 正整数大小,
) -> 标准库::输入输出::结果<()> {
    使用 自身::CharType::{Backspace, Other, Tab};

    // Fast path: if there are no tabs, backspaces, and (in UTF-8 mode or no carriage returns),
    // we can write the buffer directly without character-by-character processing
    如果 !buf.包含(&b'\t') && !buf.包含(&b'\x08') && (options.utf8 || !buf.包含(&b'\r')) {
        output.write_all(buf)?;
        如果 设 一些(n) = buf.迭代().rposition(|&b| b == b'\n') {
            *col = buf.长度() - n - 1;
        }
        返回 好的(());
    }

    设 可变 byte = 0;
    设 可变 init = 真;

    当 byte < buf.长度() {
        设 (ctype, cwidth, nbytes) = classify_char(buf, byte, options.utf8);

        // figure out how many columns this char takes up
        匹配 ctype {
            Tab => {
                // figure out how many spaces to the next tabstop
                设 nts = next_tabstop(tabstops, *col, &options.remaining_mode);
                *col += nts;

                // now dump out either spaces if we're expanding, or a literal tab if we're not
                如果 init || !options.iflag {
                    write_tab_spaces(output, nts, &options.tspaces)?;
                } 否则 {
                    output.write_all(&buf[byte..byte + nbytes])?;
                }
            }
            Backspace => {
                *col = col.saturating_sub(1);

                // if we're writing anything other than a space, then we're
                // done with the line's leading spaces
                如果 buf[byte] != b' ' {
                    init = 假;
                }

                output.write_all(&buf[byte..byte + nbytes])?;
            }
            Other => {
                *col += cwidth;

                // if we're writing anything other than a space, then we're
                // done with the line's leading spaces
                如果 buf[byte] != b' ' {
                    init = 假;
                }

                如果 buf[byte] == b'\n' {
                    *col = 0;
                    init = 真;
                }

                output.write_all(&buf[byte..byte + nbytes])?;
            }
        }

        byte += nbytes; // advance the pointer
    }

    好的(())
}

方法 expand_file(
    file: &OsString,
    output: &可变 BufWriter<标准库::输入输出::Stdout>,
    options: &Options,
) -> UResult<()> {
    设 可变 buf = [0正8; 4096];
    设 可变 input = open(file)?;
    设 ts = options.tabstops.as_ref();
    设 可变 col = 0;
    无限循环 {
        匹配 input.读锁定(&可变 buf) {
            好的(0) => 中断,
            好的(n) => {
                expand_buf(&buf[..n], output, ts, options, &可变 col)
                    .map_err_context(|| translate!("expand-error-failed-to-write-output"))?;
            }
            坏的(e) => 返回 坏的(e.map_err_context(|| file.maybe_quote().to_string())),
        }
    }
    好的(())
}

方法 expand(options: &Options) -> UResult<()> {
    设 可变 output = BufWriter::新建(stdout());

    循环 file 在 &options.files {
        如果 设 坏的(e) = expand_file(file, &可变 output, options) {
            show!(e);
            set_exit_code(1);
        }
    }
    // Flush once at the end
    output
        .flush()
        .map_err_context(|| translate!("expand-error-failed-to-write-output"))?;
    好的(())
}

