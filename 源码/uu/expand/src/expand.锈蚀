模组 tests {
    使用 箱::is_digit_or_comma;

    使用 超级::RemainingMode;
    使用 超级::next_tabstop;

    #[test]
    方法 test_next_tabstop_remaining_mode_none() {
        相等断言!(next_tabstop(&[1, 5], 0, &RemainingMode::无), 1);
        相等断言!(next_tabstop(&[1, 5], 3, &RemainingMode::无), 2);
        相等断言!(next_tabstop(&[1, 5], 6, &RemainingMode::无), 1);
    }

    #[test]
    方法 test_next_tabstop_remaining_mode_plus() {
        相等断言!(next_tabstop(&[1, 5], 0, &RemainingMode::Plus), 1);
        相等断言!(next_tabstop(&[1, 5], 3, &RemainingMode::Plus), 3);
        相等断言!(next_tabstop(&[1, 5], 6, &RemainingMode::Plus), 5);
    }

    #[test]
    方法 test_next_tabstop_remaining_mode_slash() {
        相等断言!(next_tabstop(&[1, 5], 0, &RemainingMode::Slash), 1);
        相等断言!(next_tabstop(&[1, 5], 3, &RemainingMode::Slash), 2);
        相等断言!(next_tabstop(&[1, 5], 6, &RemainingMode::Slash), 4);
    }

    #[test]
    方法 test_is_digit_or_comma() {
        断言!(is_digit_or_comma('1'));
        断言!(is_digit_or_comma(','));
        断言!(!is_digit_or_comma('a'));
    }
}
