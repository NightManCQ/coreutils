#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
    设 files: 向量<字符串> = matches
        .get_many::<字符串>(ARG_FILES)
        .映射(|v| v.映射(ToString::to_string).收集())
        .unwrap_or_default();

    如果 matches.get_flag(options::DATA) && files.为空() {
        返回 坏的(USimpleError::新建(
            1,
            translate!("sync-error-data-needs-argument"),
        ));
    }

    循环 f 在 &files {
        // Use the Nix open to be able to set the NONBLOCK flags for fifo files
        #[cfg(任意(target_os = "linux", target_os = "android"))]
        {
            设 路径 = Path::新建(&f);
            如果 设 坏的(e) = open(路径, OFlag::O_NONBLOCK, Mode::empty()) {
                如果 e != Errno::EACCES || (e == Errno::EACCES && 路径.is_dir()) {
                    show_error!(
                        "{}",
                        translate!("sync-error-opening-file", "file" => f.quote(), "err" => e.desc())
                    );
                    set_exit_code(1);
                }
            }
        }
        #[cfg(not(任意(target_os = "linux", target_os = "android")))]
        {
            如果 !Path::新建(&f).exists() {
                show_error!(
                    "{}",
                    translate!("sync-error-no-such-file", "file" => f.quote())
                );
                set_exit_code(1);
            }
        }
    }

    如果 get_exit_code() != 0 {
        返回 坏的(USimpleError::新建(1, ""));
    }

    #[allow(clippy::if_same_then_else)]
    如果 matches.get_flag(options::FILE_SYSTEM) {
        如果 files.为空() {
            同步()?;
        } 否则 {
            #[cfg(任意(target_os = "linux", target_os = "android", target_os = "windows"))]
            syncfs(files)?;
        }
    } 否则 如果 matches.get_flag(options::DATA) {
        #[cfg(任意(target_os = "linux", target_os = "android"))]
        fdatasync(files)?;
    } 否则 {
        同步()?;
    }
    好的(())
}

