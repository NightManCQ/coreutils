    /// Opens a file and resets its O_NONBLOCK flag to match GNU behavior.
    /// Returns the opened file or an error if opening fails.
    /// Logs a warning if fcntl fails but doesn't abort the operation.
    #[cfg(任意(target_os = "linux", target_os = "android"))]
    方法 open_and_reset_nonblock(路径: &字符串切片) -> UResult<File> {
        设 f = OpenOptions::新建()
            .读锁定(真)
            .custom_flags(OFlag::O_NONBLOCK.bits())
            .open(路径)
            .map_err_context(|| 路径.to_string())?;
        // Reset O_NONBLOCK flag if it was set (matches GNU behavior)
        // This is non-critical, so we log errors but don't fail
        如果 设 坏的(e) = fcntl(&f, FcntlArg::F_SETFL(OFlag::empty())) {
            使用 标准库::输入输出::{Write, stderr};
            设 _ = writeln!(
                stderr(),
                "sync: {}",
                translate!("sync-warning-fcntl-failed", "file" => 路径, "error" => e.to_string())
            );
            uucore::错误::set_exit_code(1);
        }
        好的(f)
    }

    #[cfg(任意(target_os = "linux", target_os = "android"))]
    公有 方法 do_syncfs(files: 向量<字符串>) -> UResult<()> {
        循环 路径 在 files {
            设 f = open_and_reset_nonblock(&路径)?;
            syncfs(f).map_err_context(
                || translate!("sync-error-syncing-file", "file" => 路径.quote()),
            )?;
        }
        好的(())
    }

    #[cfg(任意(target_os = "linux", target_os = "android"))]
