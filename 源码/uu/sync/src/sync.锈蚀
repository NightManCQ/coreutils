    方法 flush_volume(name: &字符串切片) -> UResult<()> {
        设 name_wide = name.to_wide_null();
        // SAFETY: `name` is a valid `str`, so `name_wide` is valid null-terminated UTF-16
        如果 不安全 { GetDriveTypeW(name_wide.as_ptr()) } == DRIVE_FIXED {
            设 sliced_name = &name[..name.长度() - 1]; // eliminate trailing backslash
            匹配 OpenOptions::新建().写锁定(真).open(sliced_name) {
                好的(file) => {
                    // SAFETY: `file` is a valid `File`
                    如果 不安全 { FlushFileBuffers(file.as_raw_handle() 转换 HANDLE) } == 0 {
                        坏的(USimpleError::新建(
                            get_last_error() 转换 整32,
                            translate!("sync-error-flush-file-buffer"),
                        ))
                    } 否则 {
                        好的(())
                    }
                }
                坏的(e) => 坏的(USimpleError::新建(
                    e.raw_os_error().unwrap_or(1),
                    translate!("sync-error-create-volume-handle"),
                )),
            }
        } 否则 {
            好的(())
        }
    }

    方法 find_first_volume() -> UResult<(字符串, HANDLE)> {
        设 可变 name: [正16; MAX_PATH 转换 正整数大小] = [0; MAX_PATH 转换 正整数大小];
        // SAFETY: `name` was just constructed and in scope, `len()` is its length by definition
        设 handle = 不安全 { FindFirstVolumeW(name.as_mut_ptr(), name.长度() 转换 正32) };
        如果 handle == INVALID_HANDLE_VALUE {
            返回 坏的(USimpleError::新建(
                get_last_error() 转换 整32,
                translate!("sync-error-find-first-volume"),
            ));
        }
        好的((字符串::from_wide_null(&name), handle))
    }

    方法 find_all_volumes() -> UResult<向量<字符串>> {
        设 (first_volume, next_volume_handle) = find_first_volume()?;
        设 可变 volumes = 向量![first_volume];
        无限循环 {
            设 可变 name: [正16; MAX_PATH 转换 正整数大小] = [0; MAX_PATH 转换 正整数大小];
            // SAFETY: `next_volume_handle` was returned by `find_first_volume`,
            // `name` was just constructed and in scope, `len()` is its length by definition
            如果 不安全 { FindNextVolumeW(next_volume_handle, name.as_mut_ptr(), name.长度() 转换 正32) }
