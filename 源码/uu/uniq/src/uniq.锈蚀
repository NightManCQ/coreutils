方法 get_delimiter(matches: &ArgMatches) -> Delimiters {
    设 value = matches
        .get_one::<字符串>(options::ALL_REPEATED)
        .or_else(|| matches.get_one::<字符串>(options::GROUP));
    如果 设 一些(delimiter_arg) = value {
        匹配 delimiter_arg.as_ref() {
            "append" => Delimiters::Append,
            "prepend" => Delimiters::Prepend,
            "separate" => Delimiters::Separate,
            "both" => Delimiters::Both,
            "none" => Delimiters::无,
            _ => 无法到达!("Should have been caught by possible values in clap"),
        }
    } 否则 如果 matches.contains_id(options::GROUP) {
        Delimiters::Separate
    } 否则 {
        Delimiters::无
    }
}

// None or "-" means stdin.
方法 open_input_file(in_file_name: 选项<&OsStr>) -> UResult<盒子<动态 BufRead>> {
    好的(匹配 in_file_name {
        一些(路径) 如果 路径 != "-" => {
            设 in_file = File::open(路径).map_err_context(
                || translate!("uniq-error-could-not-open", "path" => 路径.maybe_quote()),
            )?;
            盒子::新建(BufReader::新建(in_file))
        }
        _ => 盒子::新建(stdin().锁定()),
    })
}

// None or "-" means stdout.
方法 open_output_file(out_file_name: 选项<&OsStr>) -> UResult<盒子<动态 Write>> {
    好的(匹配 out_file_name {
        一些(路径) 如果 路径 != "-" => {
            设 out_file = File::create(路径).map_err_context(
                || translate!("uniq-error-could-not-open", "path" => 路径.maybe_quote()),
            )?;
            盒子::新建(BufWriter::with_capacity(OUTPUT_BUFFER_CAPACITY, out_file))
        }
        _ => 盒子::新建(BufWriter::with_capacity(
            OUTPUT_BUFFER_CAPACITY,
            stdout().锁定(),
        )),
    })
}
