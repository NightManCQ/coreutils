                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::IGNORE_CASE)
                .short('i')
                .long(options::IGNORE_CASE)
                .help(translate!("uniq-help-ignore-case"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::REPEATED)
                .short('d')
