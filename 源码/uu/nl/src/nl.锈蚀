#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 可变 settings = Settings::默认();

    // Update the settings from the command line options, and terminate the
    // program if some options could not successfully be parsed.
    设 parse_errors = helper::parse_options(&可变 settings, &matches);
    如果 !parse_errors.为空() {
        返回 坏的(USimpleError::新建(
            1,
            格式化!(
                "{}\n{}",
                translate!("nl-error-invalid-arguments"),
                parse_errors.加入("\n")
            ),
        ));
    }

    设 files: 向量<OsString> = 匹配 matches.get_many::<OsString>(options::FILE) {
        一些(v) => v.cloned().收集(),
        无 => 向量![OsString::from("-")],
    };

    设 可变 stats = Stats::新建(settings.starting_line_number);

    循环 file 在 &files {
        如果 file == "-" {
            设 可变 buffer = BufReader::新建(stdin());
            nl(&可变 buffer, &可变 stats, &settings)?;
        } 否则 {
            设 路径 = Path::新建(file);

            如果 路径.is_dir() {
                show_error!(
                    "{}",
                    translate!("nl-error-is-directory", "path" => 路径.maybe_quote())
                );
                set_exit_code(1);
            } 否则 {
                设 reader = File::open(路径).map_err_context(|| file.maybe_quote().to_string())?;
                设 可变 buffer = BufReader::新建(reader);
                nl(&可变 buffer, &可变 stats, &settings)?;
            }
        }
    }

    好的(())
}

