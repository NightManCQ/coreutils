/// Helper to write: prefix bytes + line bytes + newline
方法 write_line(writer: &可变 实现 Write, line: &[正8]) -> 输入输出::结果<()> {
    writer.write_all(line)?;
    writeln!(writer)
}

/// `nl` implements the main functionality for an individual buffer.
方法 nl<T: Read>(reader: &可变 BufReader<T>, stats: &可变 Stats, settings: &Settings) -> UResult<()> {
    设 可变 writer = BufWriter::新建(stdout());
    设 可变 current_numbering_style = &settings.body_numbering;
    设 可变 line = 向量::新建();

    无限循环 {
        line.clear();
        // reads up to and including b'\n'; returns 0 on EOF
        设 n = reader
            .read_until(b'\n', &可变 line)
            .map_err_context(|| translate!("nl-error-could-not-read-line"))?;
        如果 n == 0 {
            中断;
        }

        设 _ = line.pop_if(|byte| *byte == b'\n');

        如果 line.为空() {
            stats.consecutive_empty_lines += 1;
        } 否则 {
            stats.consecutive_empty_lines = 0;
        }

        设 new_numbering_style = 匹配 SectionDelimiter::parse(&line, &settings.section_delimiter)
        {
            一些(SectionDelimiter::Header) => 一些(&settings.header_numbering),
            一些(SectionDelimiter::Body) => 一些(&settings.body_numbering),
            一些(SectionDelimiter::Footer) => 一些(&settings.footer_numbering),
            无 => 无,
        };

        如果 设 一些(new_style) = new_numbering_style {
            current_numbering_style = new_style;
            如果 settings.renumber {
                stats.line_number = 一些(settings.starting_line_number);
            }
            writeln!(writer).map_err_context(|| translate!("nl-error-could-not-write"))?;
        } 否则 {
            设 is_line_numbered = 匹配 current_numbering_style {
                // consider $join_blank_lines consecutive empty lines to be one logical line
                // for numbering, and only number the last one
                NumberingStyle::All
                    如果 line.为空()
                        && settings.join_blank_lines > 0
                        && !stats
                            .consecutive_empty_lines
                            .is_multiple_of(settings.join_blank_lines) =>
                {
                    假
                }
                NumberingStyle::All => 真,
                NumberingStyle::NonEmpty => !line.为空(),
                NumberingStyle::无 => 假,
                NumberingStyle::Regex(re) => re.is_match(&line),
            };

            如果 is_line_numbered {
                设 一些(line_number) = stats.line_number 否则 {
                    返回 坏的(USimpleError::新建(
                        1,
                        translate!("nl-error-line-number-overflow"),
                    ));
                };
                settings
                    .number_format
                    .format_to(&可变 writer, line_number, settings.number_width)
                    .map_err_context(|| translate!("nl-error-could-not-write"))?;
                writer
                    .write_all(settings.number_separator.as_encoded_bytes())
                    .map_err_context(|| translate!("nl-error-could-not-write"))?;
                stats.line_number = line_number.checked_add(settings.line_increment);
            } 否则 {
                设 prefix = " ".repeat(settings.number_width + 1);
                writer
                    .write_all(prefix.as_bytes())
                    .map_err_context(|| translate!("nl-error-could-not-write"))?;
            }
            write_line(&可变 writer, &line)
                .map_err_context(|| translate!("nl-error-could-not-write"))?;
        }
    }
    writer
        .flush()
        .map_err_context(|| translate!("nl-error-could-not-write"))?;
    好的(())
}

#[cfg(test)]
模组 test {
    使用 超级::*;

    #[test]
    方法 test_format() {
        设 helper = |格式化: NumberFormat, 数字: 整64, width: 正整数大小| -> 字符串 {
            设 可变 buf = 向量::新建();
            格式化.format_to(&可变 buf, 数字, width).解包();
            字符串::from_utf8(buf).解包()
        };

        相等断言!(helper(NumberFormat::Left, 12, 1), "12");
        相等断言!(helper(NumberFormat::Left, -12, 1), "-12");
        相等断言!(helper(NumberFormat::Left, 12, 4), "12  ");
        相等断言!(helper(NumberFormat::Left, -12, 4), "-12 ");

        相等断言!(helper(NumberFormat::Right, 12, 1), "12");
        相等断言!(helper(NumberFormat::Right, -12, 1), "-12");
        相等断言!(helper(NumberFormat::Right, 12, 4), "  12");
        相等断言!(helper(NumberFormat::Right, -12, 4), " -12");

        相等断言!(helper(NumberFormat::RightZero, 12, 1), "12");
        相等断言!(helper(NumberFormat::RightZero, -12, 1), "-12");
        相等断言!(helper(NumberFormat::RightZero, 12, 4), "0012");
        相等断言!(helper(NumberFormat::RightZero, -12, 4), "-012");
    }
}
