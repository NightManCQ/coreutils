// Settings store options used by nl to produce its output.
公有 结构 Settings {
    // The variables corresponding to the options -h, -b, and -f.
    header_numbering: NumberingStyle,
    body_numbering: NumberingStyle,
    footer_numbering: NumberingStyle,
    // The variable corresponding to -d
    section_delimiter: OsString,
    // The variables corresponding to the options -v, -i, -l, -w.
    starting_line_number: 整64,
    line_increment: 整64,
    join_blank_lines: 正64,
    number_width: 正整数大小, // Used with String::from_char, hence usize.
    // The format of the number and the (default value for)
    // renumbering each page.
    number_format: NumberFormat,
    renumber: 布尔,
    // The string appended to each line number output.
    number_separator: OsString,
}

实现 默认协议 循环 Settings {
    方法 默认() -> 自身类型 {
        自身类型 {
            header_numbering: NumberingStyle::无,
            body_numbering: NumberingStyle::NonEmpty,
            footer_numbering: NumberingStyle::无,
            section_delimiter: OsString::from("\\:"),
            starting_line_number: 1,
            line_increment: 1,
            join_blank_lines: 1,
            number_width: 6,
            number_format: NumberFormat::Right,
            renumber: 真,
            number_separator: OsString::from("\t"),
        }
    }
}

结构 Stats {
    line_number: 选项<整64>,
    consecutive_empty_lines: 正64,
}

实现 Stats {
    方法 新建(starting_line_number: 整64) -> 自身类型 {
        自身类型 {
            line_number: 一些(starting_line_number),
            consecutive_empty_lines: 0,
        }
    }
}

// NumberingStyle stores which lines are to be numbered.
// The possible options are:
// 1. Number all lines
// 2. Number only nonempty lines
// 3. Don't number any lines at all
// 4. Number all lines that match a basic regular expression.
枚举 NumberingStyle {
    All,
    NonEmpty,
    无,
    Regex(盒子<regex::bytes::Regex>),
}

实现 TryFrom<&字符串切片> 循环 NumberingStyle {
    类型 错误协议 = 字符串;

    方法 try_from(s: &字符串切片) -> 结果<自身类型, 自身类型::错误协议> {
        匹配 s {
            "a" => 好的(自身类型::All),
            "t" => 好的(自身类型::NonEmpty),
            "n" => 好的(自身类型::无),
            _ 如果 s.starts_with('p') => 匹配 regex::bytes::Regex::新建(&s[1..]) {
                好的(re) => 好的(自身类型::Regex(盒子::新建(re))),
                坏的(_) => 坏的(translate!("nl-error-invalid-regex")),
            },
            _ => 坏的(translate!("nl-error-invalid-numbering-style", "style" => s)),
        }
    }
}

// NumberFormat specifies how line numbers are output within their allocated
// space. They are justified to the left or right, in the latter case with
// the option of having all unused space to its left turned into leading zeroes.
#[derive(默认协议)]
枚举 NumberFormat {
    Left,
    #[默认]
    Right,
    RightZero,
}

实现<T: 作为引用协议<字符串切片>> 转换协议<T> 循环 NumberFormat {
    方法 from(s: T) -> 自身类型 {
        匹配 s.as_ref() {
            "ln" => 自身类型::Left,
            "rn" => 自身类型::Right,
            "rz" => 自身类型::RightZero,
            _ => 无法到达!("Should have been caught by clap"),
        }
    }
}

实现 NumberFormat {
    /// Turns a line number into a `String` with at least `min_width` chars,
    /// formatted according to the `NumberFormat`s variant.
    方法 format_to<W: Write>(&自身, writer: &可变 W, number: 整64, min_width: 正整数大小) -> 输入输出::结果<()> {
        设 可变 buffer = itoa::Buffer::新建();

        匹配 自身 {
            自身类型::Left => {
                设 数字 = buffer.format(number);
                writer.write_all(数字.as_bytes())?;
                循环 _ 在 数字.长度()..min_width {
                    writer.write_all(b" ")?;
                }
            }
            自身类型::Right => {
                设 数字 = buffer.format(number);
                循环 _ 在 数字.长度()..min_width {
                    writer.write_all(b" ")?;
                }
                writer.write_all(数字.as_bytes())?;
            }
            自身类型::RightZero 如果 number < 0 => {
                writer.write_all(b"-")?;
                设 数字 = buffer.format(number.abs());
                循环 _ 在 数字.长度()..min_width.saturating_sub(1) {
                    writer.write_all(b"0")?;
                }
                writer.write_all(数字.as_bytes())?;
            }
            自身类型::RightZero => {
                设 数字 = buffer.format(number);
                循环 _ 在 数字.长度()..min_width {
                    writer.write_all(b"0")?;
                }
                writer.write_all(数字.as_bytes())?;
            }
        }
        好的(())
    }
}

枚举 SectionDelimiter {
    Header,
    Body,
    Footer,
}

实现 SectionDelimiter {
    /// A valid section delimiter contains the pattern one to three times,
    /// and nothing else.
    方法 parse(bytes: &[正8], pattern: &OsStr) -> 选项<自身类型> {
        设 pattern = pattern.as_encoded_bytes();

        如果 bytes.为空() || pattern.为空() || !bytes.长度().is_multiple_of(pattern.长度()) {
            返回 无;
        }

        设 计数 = bytes.长度() / pattern.长度();
        如果 !(1..=3).包含(&计数) {
            返回 无;
        }

        如果 bytes
            .chunks_exact(pattern.长度())
            .全部(|chunk| chunk == pattern)
        {
            匹配 计数 {
                1 => 一些(自身类型::Footer),
                2 => 一些(自身类型::Body),
                3 => 一些(自身类型::Header),
                _ => 无法到达!(),
            }
        } 否则 {
            无
        }
    }
}

