使用 divan::{Bencher, black_box};
使用 uu_nl::uumain;
使用 uucore::benchmark::{create_test_file, run_util_function, text_data};

/// Benchmark numbering many lines (default mode - most common use case)
#[divan::bench(args = [100_000])]
方法 nl_many_lines(bencher: Bencher, num_lines: 正整数大小) {
    设 temp_dir = tempfile::tempdir().解包();
    设 data = text_data::generate_by_lines(num_lines, 80);
    设 file_path = create_test_file(&data, temp_dir.路径());
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path_str]));
    });
}

/// Benchmark large file with -ba option (number all lines - most common argument)
#[divan::bench(args = [10])]
方法 nl_large_file(bencher: Bencher, size_mb: 正整数大小) {
    设 temp_dir = tempfile::tempdir().解包();
    设 data = text_data::generate_by_size(size_mb, 80);
    设 file_path = create_test_file(&data, temp_dir.路径());
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-ba", file_path_str]));
    });
}

方法 主函数() {
    divan::主函数();
}
