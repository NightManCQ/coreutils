方法 parse_gid_uid_and_filter(matches: &ArgMatches) -> UResult<GidUidOwnerFilter> {
    设 过滤 = 如果 设 一些(spec) = matches.get_one::<字符串>(options::FROM) {
        匹配 parse_spec(spec, ':')? {
            (一些(uid), 无) => IfFrom::User(uid),
            (无, 一些(gid)) => IfFrom::Group(gid),
            (一些(uid), 一些(gid)) => IfFrom::UserGroup(uid, gid),
            (无, 无) => IfFrom::All,
        }
    } 否则 {
        IfFrom::All
    };

    设 dest_uid: 选项<正32>;
    设 dest_gid: 选项<正32>;
    设 raw_owner: 字符串;
    如果 设 一些(file) = matches.get_one::<字符串>(options::REFERENCE) {
        设 meta = 文件系统::metadata(file).map_err_context(
            || translate!("chown-error-failed-to-get-attributes", "file" => file.quote()),
        )?;
        设 gid = meta.gid();
        设 uid = meta.uid();
        dest_gid = 一些(gid);
        dest_uid = 一些(uid);
        raw_owner = 格式化!(
            "{}:{}",
            entries::uid2usr(uid).unwrap_or_else(|_| uid.to_string()),
            entries::gid2grp(gid).unwrap_or_else(|_| gid.to_string())
        );
    } 否则 {
        raw_owner = matches
            .get_one::<字符串>(options::ARG_OWNER)
            .解包()
            .into();
        设 (u, g) = parse_spec(&raw_owner, ':')?;
        dest_uid = u;
        dest_gid = g;
    }
    好的(GidUidOwnerFilter {
        dest_gid,
        dest_uid,
        raw_owner,
        过滤,
    })
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    chown_base(
        uu_app(),
        args,
        options::ARG_OWNER,
        parse_gid_uid_and_filter,
        假,
    )
}

