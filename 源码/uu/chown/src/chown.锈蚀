/// Parses the user string to extract the UID.
方法 parse_uid(user: &字符串切片, spec: &字符串切片) -> UResult<选项<正32>> {
    如果 user.为空() {
        返回 好的(无);
    }

    如果 设 好的(u) = Passwd::locate(user) {
        返回 好的(一些(u.uid));
    }

    // Fallback: `user` string contains a numeric user ID
    user.parse().映射(一些).map_err(|_| {
        USimpleError::新建(
            1,
            translate!("chown-error-invalid-user", "user" => spec.quote()),
        )
    })
}

/// Parses the group string to extract the GID.
方法 parse_gid(group: &字符串切片, spec: &字符串切片) -> UResult<选项<正32>> {
    如果 group.为空() {
        返回 好的(无);
    }
    匹配 Group::locate(group) {
        好的(g) => 好的(一些(g.gid)),
        坏的(_) => 匹配 group.parse() {
            好的(gid) => 好的(一些(gid)),
            坏的(_) => 坏的(USimpleError::新建(
                1,
                translate!("chown-error-invalid-group", "group" => spec.quote()),
            )),
        },
    }
}

/// Parse the owner/group specifier string into a user ID and a group ID.
///
/// The `spec` can be of the form:
///
/// * `"owner:group"`,
/// * `"owner"`,
/// * `":group"`,
///
/// and the owner or group can be specified either as an ID or a
/// name. The `sep` argument specifies which character to use as a
/// separator between the owner and group; calling code should set
/// this to `':'`.
方法 parse_spec(spec: &字符串切片, sep: 字符) -> UResult<(选项<正32>, 选项<正32>)> {
    断言!(['.', ':'].包含(&sep));
    设 可变 args = spec.splitn(2, sep);
    设 user = args.next().unwrap_or("");
    设 group = args.next().unwrap_or("");

    // dot separator: try as username first, fall back to owner.group (like GNU)
    如果 sep == ':' && !spec.包含(':') && spec.包含('.') {
        如果 设 好的(uid) = parse_uid(user, spec) {
            设 gid = parse_gid(group, spec)?;
            返回 好的((uid, gid));
        }
        show_warning!(
            "{}",
            translate!("chown-warning-dot-separator", "spec" => spec.quote())
        );
        返回 parse_spec(spec, '.');
    }

    设 uid = parse_uid(user, spec)?;
    设 gid = parse_gid(group, spec)?;

    如果 user.chars().next().is_some_and(字符::is_numeric) && group.为空() && spec != user {
        // if the arg starts with an id numeric value, the group isn't set but the separator is provided,
        // we should fail with an error
        返回 坏的(USimpleError::新建(
            1,
            translate!("chown-error-invalid-spec", "spec" => spec.quote()),
        ));
    }

    好的((uid, gid))
}

#[cfg(test)]
模组 test {
    使用 超级::*;
    使用 标准库::环境;
    使用 uucore::locale;

    #[test]
    方法 test_parse_spec() {
        不安全 {
            环境::set_var("LANG", "C");
        }
        设 _ = locale::setup_localization("chown");
        断言!(matches!(parse_spec(":", ':'), 好的((无, 无))));
        断言!(matches!(parse_spec(".", ':'), 好的((无, 无))));
        断言!(matches!(parse_spec(".", '.'), 好的((无, 无))));
        断言!(格式化!("{}", parse_spec("::", ':').err().解包()).starts_with("invalid group: "));
        断言!(格式化!("{}", parse_spec("..", ':').err().解包()).starts_with("invalid group: "));
    }

    /// Test for parsing IDs that don't correspond to a named user or group.
    #[test]
    方法 test_parse_spec_nameless_ids() {
        // This assumes that there is no named user with ID 12345.
        断言!(matches!(parse_spec("12345", ':'), 好的((一些(12345), 无))));
        // This assumes that there is no named group with ID 54321.
        断言!(matches!(parse_spec(":54321", ':'), 好的((无, 一些(54321)))));
        断言!(matches!(
            parse_spec("12345:54321", ':'),
            好的((一些(12345), 一些(54321)))
        ));
    }
}
