// spell-checker:ignore bytestream
使用 超级::{Incomplete, 字符串切片};
使用 标准库::输入输出::{自身, BufRead};
使用 thiserror::错误协议;
使用 uucore::translate;

/// Wraps a `std::io::BufRead` buffered byte stream and decode it as UTF-8.
公有 结构 BufReadDecoder<B: BufRead> {
    buf_read: B,
    bytes_consumed: 正整数大小,
    incomplete: Incomplete,
}

#[derive(调试协议, 错误协议)]
公有 枚举 BufReadDecoderError<'a> {
    /// Represents one UTF-8 error in the byte stream.
    ///
    /// In lossy decoding, each such error should be replaced with U+FFFD.
    /// (See `BufReadDecoder::next_lossy` and `BufReadDecoderError::lossy`.)
    #[错误("{}", translate!("decoder-error-invalid-byte-sequence", "bytes" => 格式化!("{:02x?}", .0)))]
    InvalidByteSequence(&'a [正8]),

    /// An I/O error from the underlying byte stream
    #[错误("{}", translate!("decoder-error-io", "error" => .0))]
    Io(#[source] 输入输出::错误协议),
}

实现<B: BufRead> BufReadDecoder<B> {
    公有 方法 新建(buf_read: B) -> 自身类型 {
        自身类型 {
            buf_read,
            bytes_consumed: 0,
            incomplete: Incomplete::empty(),
        }
    }

    /// Decode and consume the next chunk of UTF-8 input.
    ///
    /// This method is intended to be called repeatedly until it returns `None`,
    /// which represents EOF from the underlying byte stream.
    /// This is similar to `Iterator::next`,
    /// except that decoded chunks borrow the decoder (~iterator)
    /// so they need to be handled or copied before the next chunk can start decoding.
    #[allow(clippy::cognitive_complexity)]
    公有 方法 next_strict(&可变 自身) -> 选项<结果<&字符串切片, BufReadDecoderError<'_>>> {
        枚举 BytesSource {
            BufRead(正整数大小),
            Incomplete,
        }
        macro_rules! try_io {
            ($io_result: expr) => {
                匹配 $io_result {
                    好的(value) => value,
                    坏的(错误) => 返回 一些(坏的(BufReadDecoderError::Io(错误))),
                }
            };
        }
        设 (source, result) = 无限循环 {
            如果 自身.bytes_consumed > 0 {
                自身.buf_read.consume(自身.bytes_consumed);
                自身.bytes_consumed = 0;
            }
            设 buf = try_io!(自身.buf_read.fill_buf());

            // Force loop iteration to go through an explicit `continue`
            枚举 Unreachable {}
            设 _: Unreachable = 如果 自身.incomplete.为空() {
                如果 buf.为空() {
                    返回 无; // EOF
                }
                匹配 字符串切片::from_utf8(buf) {
                    好的(_) => 中断 (BytesSource::BufRead(buf.长度()), 好的(())),
                    坏的(错误) => {
                        设 valid_up_to = 错误.valid_up_to();
                        如果 valid_up_to > 0 {
                            中断 (BytesSource::BufRead(valid_up_to), 好的(()));
                        }
                        如果 设 一些(invalid_sequence_length) = 错误.error_len() {
                            中断 (BytesSource::BufRead(invalid_sequence_length), 坏的(()));
                        }
                        自身.bytes_consumed = buf.长度();
                        自身.incomplete = Incomplete::新建(buf);
                        // need more input bytes
                        继续;
                    }
                }
            } 否则 {
                如果 buf.为空() {
                    中断 (BytesSource::Incomplete, 坏的(())); // EOF with incomplete code point
                }
                设 (consumed, opt_result) = 自身.incomplete.try_complete_offsets(buf);
                自身.bytes_consumed = consumed;
                匹配 opt_result {
                    无 => {
                        // need more input bytes
                        继续;
                    }
                    一些(result) => 中断 (BytesSource::Incomplete, result),
                }
            };
        };
        设 bytes = 匹配 source {
            BytesSource::BufRead(byte_count) => {
                自身.bytes_consumed = byte_count;
                设 buf = try_io!(自身.buf_read.fill_buf());
                &buf[..byte_count]
            }
            BytesSource::Incomplete => 自身.incomplete.take_buffer(),
        };
        匹配 result {
            好的(()) => 一些(好的(不安全 { 字符串切片::from_utf8_unchecked(bytes) })),
            坏的(()) => 一些(坏的(BufReadDecoderError::InvalidByteSequence(bytes))),
        }
    }
}
