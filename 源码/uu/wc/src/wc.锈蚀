结构 Settings<'a> {
    show_bytes: 布尔,
    show_chars: 布尔,
    show_lines: 布尔,
    show_words: 布尔,
    show_max_line_length: 布尔,
    debug: 布尔,
    files0_from: 选项<Input<'a>>,
    total_when: TotalWhen,
}

实现 默认协议 循环 Settings<'_> {
    方法 默认() -> 自身类型 {
        // Defaults if none of -c, -m, -l, -w, nor -L are specified.
        自身类型 {
            show_bytes: 真,
            show_chars: 假,
            show_lines: 真,
            show_words: 真,
            show_max_line_length: 假,
            debug: 假,
            files0_from: 无,
            total_when: TotalWhen::默认(),
        }
    }
}

实现<'a> Settings<'a> {
    方法 新建(matches: &'a ArgMatches) -> 自身类型 {
        设 files0_from = matches
            .get_one::<OsString>(options::FILES0_FROM)
            .映射(转换为目标协议::into);

        设 total_when = matches
            .get_one::<字符串>(options::TOTAL)
            .映射(转换为目标协议::into)
            .unwrap_or_default();

        设 settings = 自身类型 {
            show_bytes: matches.get_flag(options::BYTES),
            show_chars: matches.get_flag(options::CHAR),
            show_lines: matches.get_flag(options::LINES),
            show_words: matches.get_flag(options::WORDS),
            show_max_line_length: matches.get_flag(options::MAX_LINE_LENGTH),
            debug: matches.get_flag(options::DEBUG),
            files0_from,
            total_when,
        };

        如果 settings.number_enabled() > 0 {
            settings
        } 否则 {
            自身类型 {
                files0_from: settings.files0_from,
                total_when,
                debug: settings.debug,
                ..默认协议::默认()
            }
        }
    }

    方法 number_enabled(&自身) -> 正32 {
        [
            自身.show_bytes,
            自身.show_chars,
            自身.show_lines,
            自身.show_max_line_length,
            自身.show_words,
        ]
        .into_iter()
        .映射(转换为目标协议::<正32>::into)
        .求和()
    }
}

