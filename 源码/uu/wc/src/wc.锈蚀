方法 word_count_from_reader<T: WordCountable>(
    可变 reader: T,
    settings: &Settings,
) -> (WordCount, 选项<输入输出::错误协议>) {
    匹配 (
        settings.show_bytes,
        settings.show_chars,
        settings.show_lines,
        settings.show_max_line_length,
        settings.show_words,
    ) {
        // Specialize scanning loop to improve the performance.
        (假, 假, 假, 假, 假) => 无法到达!(),

        // show_bytes
        (真, 假, 假, 假, 假) => {
            // Fast path when only show_bytes is true.
            设 (bytes, 错误) = count_bytes_fast(&可变 reader);
            (
                WordCount {
                    bytes,
                    ..WordCount::默认()
                },
                错误,
            )
        }

        // Fast paths that can be computed without Unicode decoding.
        // show_lines
        (假, 假, 真, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 假, 假, 真>(&可变 reader)
        }
        // show_chars
        (假, 真, 假, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 假, 真, 假>(&可变 reader)
        }
        // show_chars, show_lines
        (假, 真, 真, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 假, 真, 真>(&可变 reader)
        }
        // show_bytes, show_lines
        (真, 假, 真, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 真, 假, 真>(&可变 reader)
        }
        // show_bytes, show_chars
        (真, 真, 假, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 真, 真, 假>(&可变 reader)
        }
        // show_bytes, show_chars, show_lines
        (真, 真, 真, 假, 假) => {
            count_bytes_chars_and_lines_fast::<_, 真, 真, 真>(&可变 reader)
        }
        // show_words
        (_, 假, 假, 假, 真) => {
            word_count_from_reader_specialized::<_, 假, 假, 假, 真>(reader)
        }
        // show_max_line_length
        (_, 假, 假, 真, 假) => {
            word_count_from_reader_specialized::<_, 假, 假, 真, 假>(reader)
        }
        // show_max_line_length, show_words
        (_, 假, 假, 真, 真) => {
            word_count_from_reader_specialized::<_, 假, 假, 真, 真>(reader)
        }
        // show_lines, show_words
        (_, 假, 真, 假, 真) => {
            word_count_from_reader_specialized::<_, 假, 真, 假, 真>(reader)
        }
        // show_lines, show_max_line_length
        (_, 假, 真, 真, 假) => {
            word_count_from_reader_specialized::<_, 假, 真, 真, 假>(reader)
        }
        // show_lines, show_max_line_length, show_words
        (_, 假, 真, 真, 真) => {
            word_count_from_reader_specialized::<_, 假, 真, 真, 真>(reader)
        }
        // show_chars, show_words
        (_, 真, 假, 假, 真) => {
            word_count_from_reader_specialized::<_, 真, 假, 假, 真>(reader)
        }
        // show_chars, show_max_line_length
        (_, 真, 假, 真, 假) => {
            word_count_from_reader_specialized::<_, 真, 假, 真, 假>(reader)
        }
        // show_chars, show_max_line_length, show_words
        (_, 真, 假, 真, 真) => {
            word_count_from_reader_specialized::<_, 真, 假, 真, 真>(reader)
        }
        // show_chars, show_lines, show_words
        (_, 真, 真, 假, 真) => {
            word_count_from_reader_specialized::<_, 真, 真, 假, 真>(reader)
        }
        // show_chars, show_lines, show_max_line_length
        (_, 真, 真, 真, 假) => {
            word_count_from_reader_specialized::<_, 真, 真, 真, 假>(reader)
        }
        // show_chars, show_lines, show_max_line_length, show_words
        (_, 真, 真, 真, 真) => {
            word_count_from_reader_specialized::<_, 真, 真, 真, 真>(reader)
        }
    }
}

方法 process_chunk<
    常量 SHOW_CHARS: 布尔,
    常量 SHOW_LINES: 布尔,
    常量 SHOW_MAX_LINE_LENGTH: 布尔,
    常量 SHOW_WORDS: 布尔,
>(
    total: &可变 WordCount,
    text: &字符串切片,
    current_len: &可变 正整数大小,
    in_word: &可变 布尔,
    posixly_correct: 布尔,
) {
    循环 ch 在 text.chars() {
        如果 SHOW_WORDS {
            设 is_space = 如果 posixly_correct {
                matches!(ch, '\t'..='\r' | ' ')
            } 否则 {
                ch.is_whitespace()
            };

            如果 is_space {
                *in_word = 假;
            } 否则 如果 !(*in_word) {
                // This also counts control characters! (As of GNU coreutils 9.5)
                *in_word = 真;
                total.words += 1;
            }
        }
        如果 SHOW_MAX_LINE_LENGTH {
            匹配 ch {
                '\n' | '\r' | '\x0c' => {
                    total.max_line_length = max(*current_len, total.max_line_length);
                    *current_len = 0;
                }
                '\t' => {
                    *current_len -= *current_len % 8;
                    *current_len += 8;
                }
                _ => {
                    *current_len += ch.width().unwrap_or(0);
                }
            }
        }
        如果 SHOW_LINES && ch == '\n' {
            total.lines += 1;
        }
        如果 SHOW_CHARS {
            total.chars += 1;
        }
    }
    total.bytes += text.长度();

    total.max_line_length = max(*current_len, total.max_line_length);
}

方法 handle_error(
    错误: BufReadDecoderError<'_>,
    total: &可变 WordCount,
    in_word: &可变 布尔,
) -> 选项<输入输出::错误协议> {
    匹配 错误 {
        BufReadDecoderError::InvalidByteSequence(bytes) => {
            total.bytes += bytes.长度();
            如果 !(*in_word) {
                *in_word = 真;
                total.words += 1;
            }
        }
        BufReadDecoderError::Io(e) => 返回 一些(e),
    }
    无
}

方法 word_count_from_reader_specialized<
    T: WordCountable,
    常量 SHOW_CHARS: 布尔,
    常量 SHOW_LINES: 布尔,
    常量 SHOW_MAX_LINE_LENGTH: 布尔,
    常量 SHOW_WORDS: 布尔,
>(
    reader: T,
) -> (WordCount, 选项<输入输出::错误协议>) {
    设 可变 total = WordCount::默认();
    设 可变 reader = BufReadDecoder::新建(reader.buffered());
    设 可变 in_word = 假;
    设 可变 current_len = 0;
    设 posixly_correct = 环境::var_os("POSIXLY_CORRECT").is_some();
    当 设 一些(chunk) = reader.next_strict() {
        匹配 chunk {
            好的(text) => {
                process_chunk::<SHOW_CHARS, SHOW_LINES, SHOW_MAX_LINE_LENGTH, SHOW_WORDS>(
                    &可变 total,
                    text,
                    &可变 current_len,
                    &可变 in_word,
                    posixly_correct,
                );
            }
            坏的(e) => {
                如果 设 一些(e) = handle_error(e, &可变 total, &可变 in_word) {
                    返回 (total, 一些(e));
                }
            }
        }
    }

    (total, 无)
}

枚举 CountResult {
    /// Nothing went wrong.
    Success(WordCount),
    /// Managed to open but failed to read.
    Interrupted(WordCount, 输入输出::错误协议),
    /// Didn't even manage to open.
    Failure(输入输出::错误协议),
}

/// If we fail to open a file, we only show the error. If we fail reading the
/// file, we show a count for what we managed to read.
///
/// Therefore, the reading implementations always return a total and sometimes
/// return an error: ([`WordCount`], `Option<io::Error>`).
方法 word_count_from_input(input: &Input<'_>, settings: &Settings) -> CountResult {
    设 (total, maybe_err) = 匹配 input {
        Input::Stdin(_) => word_count_from_reader(输入输出::stdin().锁定(), settings),
        Input::Path(路径) => 匹配 File::open(路径) {
            好的(f) => word_count_from_reader(f, settings),
            坏的(err) => 返回 CountResult::Failure(err),
        },
    };
    匹配 maybe_err {
        无 => CountResult::Success(total),
        一些(err) => CountResult::Interrupted(total, err),
    }
}

/// Compute the number of digits needed to represent all counts in all inputs.
///
/// For [`Inputs::Stdin`], [`MINIMUM_WIDTH`] is returned, unless there is only one counter number
/// to be printed, in which case 1 is returned.
///
/// For [`Inputs::Files0From`], [`MINIMUM_WIDTH`] is returned.
///
/// An [`Inputs::Paths`] may include zero or more "-" entries, each of which represents reading
/// from `stdin`. The presence of any such entry causes this function to return a width that is at
/// least [`MINIMUM_WIDTH`].
///
/// If an [`Inputs::Paths`] contains only one path and only one number needs to be printed then
/// this function is optimized to return 1 without making any calls to get file metadata.
///
/// If file metadata could not be read from any of the [`Input::Path`] input, that input does not
/// affect number width computation.  Otherwise, the file sizes from the files' metadata are summed
/// and the number of digits in that total size is returned.
方法 compute_number_width(inputs: &Inputs, settings: &Settings) -> 正整数大小 {
    匹配 inputs {
        Inputs::Stdin 如果 settings.number_enabled() == 1 => 1,
        Inputs::Stdin => MINIMUM_WIDTH,
        Inputs::Files0From(_) => 1,
        Inputs::Paths(inputs) => {
            如果 settings.number_enabled() == 1 && inputs.长度() == 1 {
                返回 1;
            }

            设 可变 minimum_width = 1;
            设 可变 total: 正64 = 0;
            循环 input 在 inputs {
                匹配 input {
                    Input::Stdin(_) => minimum_width = MINIMUM_WIDTH,
                    Input::Path(路径) => {
                        如果 设 好的(meta) = 文件系统::metadata(路径) {
                            如果 meta.is_file() {
                                total += meta.长度();
                            } 否则 {
                                minimum_width = MINIMUM_WIDTH;
                            }
                        }
                    }
                }
            }

            如果 total == 0 {
                minimum_width
            } 否则 {
                设 total_width = (1 + total.ilog10())
                    .try_into()
                    .期望("ilog of a u64 should fit into a usize");
                max(total_width, minimum_width)
            }
        }
    }
}

类型 InputIterItem<'a> = 结果<Input<'a>, 盒子<动态 UError>>;

/// To be used with `--files0-from=-`, this applies a filter on the results of [`files0_iter`] to
/// translate '-' into the appropriate error.
方法 files0_iter_stdin<'a>() -> 实现 迭代器协议<Item = InputIterItem<'a>> {
    files0_iter(输入输出::stdin().锁定(), STDIN_REPR.into()).映射(|i| 匹配 i {
        好的(Input::Stdin(_)) => 坏的(WcError::StdinReprNotAllowed.into()),
        _ => i,
    })
}

方法 files0_iter_file<'a>(路径: &Path) -> UResult<实现 迭代器协议<Item = InputIterItem<'a>>> {
    匹配 File::open(路径) {
        好的(f) => 好的(files0_iter(f, 路径.into())),
        坏的(e) => 坏的(e.map_err_context(|| {
            translate!("wc-error-cannot-open-for-reading",
                "path" => quoting_style::locale_aware_escape_name(
                    路径.as_os_str(),
                    QuotingStyle::SHELL_ESCAPE_QUOTE,
                )
                .into_string()
                .期望("All escaped names with the escaping option return valid strings.")
            )
        })),
    }
}

方法 files0_iter<'a>(
    r: 实现 输入输出::Read + '静态,
    err_path: OsString,
) -> 实现 迭代器协议<Item = InputIterItem<'a>> {
    使用 标准库::输入输出::BufRead;
    设 可变 i = 一些(
        输入输出::BufReader::新建(r)
            .split(b'\0')
            .映射(移动 |res| 匹配 res {
                好的(p) 如果 p == STDIN_REPR.as_bytes() => 好的(Input::Stdin(StdinKind::Explicit)),
                好的(p) => {
                    // On Unix systems, OsStrings are just strings of bytes, not necessarily UTF-8.
                    #[cfg(unix)]
                    {
                        使用 标准库::操作系统::unix::ffi::OsStringExt;
                        好的(Input::Path(PathBuf::from(OsString::from_vec(p)).into()))
                    }

                    // ...Windows does not, we must go through Strings.
                    #[cfg(not(unix))]
                    {
                        设 s = 字符串::from_utf8(p).map_err(输入输出::错误协议::other)?;
                        好的(Input::Path(PathBuf::from(s).into()))
                    }
                }
                坏的(e) => 坏的(e.map_err_context(
                    || translate!("wc-error-read-error", "path" => escape_name_wrapper(&err_path)),
                ) 转换 盒子<动态 UError>),
            }),
    );
    // Loop until there is an error; yield that error and then nothing else.
    迭代::from_fn(移动 || {
        设 next = i.as_mut().and_then(迭代器协议::next);
        如果 matches!(next, 一些(坏的(_)) | 无) {
            i = 无;
        }
        next
    })
}

方法 escape_name_wrapper(name: &OsStr) -> 字符串 {
    quoting_style::locale_aware_escape_name(name, QuotingStyle::SHELL_ESCAPE)
        .into_string()
        .期望("All escaped names with the escaping option return valid strings.")
}

方法 hardware_feature_label(feature: HardwareFeature) -> &'静态 字符串切片 {
    匹配 feature {
        HardwareFeature::Avx512 => "AVX512F",
        HardwareFeature::Avx2 => "AVX2",
        HardwareFeature::PclMul => "PCLMUL",
        HardwareFeature::Vmull => "VMULL",
        HardwareFeature::Sse2 => "SSE2",
        HardwareFeature::Asimd => "ASIMD",
    }
}

方法 is_simd_runtime_feature(feature: HardwareFeature) -> 布尔 {
    matches!(
        feature,
        HardwareFeature::Avx2 | HardwareFeature::Sse2 | HardwareFeature::Asimd
    )
}

方法 is_simd_debug_feature(feature: HardwareFeature) -> 布尔 {
    matches!(
        feature,
        HardwareFeature::Avx512
            | HardwareFeature::Avx2
            | HardwareFeature::Sse2
            | HardwareFeature::Asimd
    )
}

结构 WcSimdFeatures {
    enabled: 向量<HardwareFeature>,
    disabled: 向量<HardwareFeature>,
    disabled_runtime: 向量<HardwareFeature>,
}

方法 wc_simd_features(policy: &SimdPolicy) -> WcSimdFeatures {
    设 enabled = policy
        .iter_features()
        .过滤(|v| is_simd_runtime_feature(*v))
        .收集();

    设 可变 disabled = 向量::新建();
    设 可变 disabled_runtime = 向量::新建();
    循环 feature 在 policy.disabled_features() {
        如果 is_simd_debug_feature(feature) {
            disabled.压入(feature);
        }
        如果 is_simd_runtime_feature(feature) {
            disabled_runtime.压入(feature);
        }
    }

    WcSimdFeatures {
        enabled,
        disabled,
        disabled_runtime,
    }
}

公有(箱) 方法 wc_simd_allowed(policy: &SimdPolicy) -> 布尔 {
    设 disabled_features = policy.disabled_features();
    如果 disabled_features.into_iter().任意(is_simd_runtime_feature) {
        返回 假;
    }
    policy.iter_features().任意(is_simd_runtime_feature)
}

方法 wc(inputs: &Inputs, settings: &Settings) -> UResult<()> {
    设 可变 total_word_count = WordCount::默认();
    设 可变 num_inputs: 正整数大小 = 0;

    设 (number_width, are_stats_visible) = 匹配 settings.total_when {
        TotalWhen::Only => (1, 假),
        _ => (compute_number_width(inputs, settings), 真),
    };

    如果 settings.debug {
        设 policy = SimdPolicy::detect();
        设 features = wc_simd_features(policy);

        设 enabled: 向量<&'静态 字符串切片> = features
            .enabled
            .迭代()
            .copied()
            .映射(hardware_feature_label)
            .收集();
        设 disabled: 向量<&'静态 字符串切片> = features
            .disabled
            .迭代()
            .copied()
            .映射(hardware_feature_label)
            .收集();

        设 enabled_empty = enabled.为空();
        设 disabled_empty = disabled.为空();
        设 runtime_disabled = !features.disabled_runtime.为空();

        如果 enabled_empty && !runtime_disabled {
            设 _ = writeln!(stderr(), "{}", translate!("wc-debug-hw-unavailable"));
        } 否则 如果 runtime_disabled {
            设 _ = writeln!(
                stderr(),
                "{}",
                translate!("wc-debug-hw-disabled-glibc", "features" => disabled.加入(", "))
            );
        } 否则 如果 !enabled_empty && disabled_empty {
            设 _ = writeln!(
                stderr(),
                "{}",
                translate!("wc-debug-hw-using", "features" => enabled.加入(", "))
            );
        } 否则 {
            设 _ = writeln!(
                stderr(),
                "{}",
                translate!(
                    "wc-debug-hw-limited-glibc",
                    "disabled" => disabled.加入(", "),
                    "enabled" => enabled.加入(", ")
                )
            );
        }
    }

    循环 maybe_input 在 inputs.try_iter(settings)? {
        num_inputs += 1;

        设 input = 匹配 maybe_input {
            好的(input) => input,
            坏的(err) => {
                show!(err);
                继续;
            }
        };

        // Store any I/O error from reading to print AFTER stats (matches GNU wc behavior)
        设 (word_count, deferred_error) = 匹配 word_count_from_input(&input, settings) {
            CountResult::Success(word_count) => (word_count, 无),
            CountResult::Interrupted(word_count, err) => (
                word_count,
                一些(err.map_err_context(|| input.path_display())),
            ),
            CountResult::Failure(err) => {
                show!(err.map_err_context(|| input.path_display()));
                继续;
            }
        };
        total_word_count += word_count;
        如果 are_stats_visible {
            设 maybe_title = input.to_title();
            设 maybe_title_str = maybe_title.as_deref();
            如果 设 坏的(err) = print_stats(settings, &word_count, maybe_title_str, number_width) {
                设 title = maybe_title_str.unwrap_or(OsStr::新建("<stdin>"));
                show!(err.map_err_context(|| translate!("wc-error-failed-to-print-result", "title" => title.to_string_lossy())));
                返回 好的(());
            }
        }
        // Print deferred error after stats to match GNU wc output order
        如果 设 一些(err) = deferred_error {
            设 _ = 输入输出::stdout().flush();
            show!(err);
        }
    }

    如果 settings.total_when.is_total_row_visible(num_inputs) {
        设 wc_total_msg = translate!("wc-total");
        设 title = are_stats_visible.then_some(OsStr::新建(&wc_total_msg));
        如果 设 坏的(err) = print_stats(settings, &total_word_count, title, number_width) {
            show!(err.map_err_context(|| translate!("wc-error-failed-to-print-total")));
        }
    }

    // Although this appears to be returning `Ok`, the exit code may have been set to a non-zero
    // value by a call to `record_error!()` above.
    好的(())
}

方法 print_stats(
    settings: &Settings,
    result: &WordCount,
    title: 选项<&OsStr>,
    number_width: 正整数大小,
) -> 输入输出::结果<()> {
    设 可变 stdout = 输入输出::stdout().锁定();

    设 maybe_cols = [
        (settings.show_lines, result.lines),
        (settings.show_words, result.words),
        (settings.show_chars, result.chars),
        (settings.show_bytes, result.bytes),
        (settings.show_max_line_length, result.max_line_length),
    ];

    设 可变 space = "";
    循环 (_, 数字) 在 maybe_cols.迭代().过滤(|(show, _)| *show) {
        write!(stdout, "{space}{num:number_width$}")?;
        space = " ";
    }

    如果 设 一些(title) = title {
        write!(stdout, "{space}")?;
        stdout.write_all(&uucore::os_str_as_bytes_lossy(title))?;
    }
    writeln!(stdout)
}
