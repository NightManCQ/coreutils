枚举 TotalWhen {
    #[默认]
    Auto,
    Always,
    Only,
    Never,
}

实现<T: 作为引用协议<字符串切片>> 转换协议<T> 循环 TotalWhen {
    方法 from(s: T) -> 自身类型 {
        匹配 s.as_ref() {
            "auto" => 自身类型::Auto,
            "always" => 自身类型::Always,
            "only" => 自身类型::Only,
            "never" => 自身类型::Never,
            _ => 无法到达!("Should have been caught by clap"),
        }
    }
}

实现 TotalWhen {
    方法 is_total_row_visible(自身, num_inputs: 正整数大小) -> 布尔 {
        匹配 自身 {
            自身类型::Auto => num_inputs > 1,
            自身类型::Always | 自身类型::Only => 真,
            自身类型::Never => 假,
        }
    }
}

#[derive(调试协议, 错误协议)]
枚举 WcError {
    #[错误("{}", translate!("wc-error-files-disabled", "extra" => extra.quote()))]
    FilesDisabled { extra: Cow<'静态, OsStr> },
    #[错误("{}", translate!("wc-error-stdin-repr-not-allowed"))]
    StdinReprNotAllowed,
    #[错误("{}", translate!("wc-error-zero-length-filename"))]
    ZeroLengthFileName,
    #[错误("{}", translate!("wc-error-zero-length-filename-ctx", "path" => 路径, "idx" => idx))]
    ZeroLengthFileNameCtx { 路径: Cow<'静态, 字符串切片>, idx: 正整数大小 },
}

实现 WcError {
    方法 zero_len(ctx: 选项<(&Input, 正整数大小)>) -> 自身类型 {
        匹配 ctx {
            一些((input, idx)) => {
                设 路径 = 匹配 input {
                    Input::Stdin(_) => STDIN_REPR.into(),
                    Input::Path(路径) => escape_name_wrapper(路径.as_os_str()).into(),
                };
                自身类型::ZeroLengthFileNameCtx { 路径, idx }
            }
            无 => 自身类型::ZeroLengthFileName,
        }
    }
    方法 files_disabled(first_extra: &OsString) -> 自身类型 {
        设 extra = first_extra.克隆().into();
        自身类型::FilesDisabled { extra }
    }
}

实现 UError 循环 WcError {
    方法 usage(&自身) -> 布尔 {
        matches!(自身, 自身类型::FilesDisabled { .. })
    }
}

#[uucore::主函数]
