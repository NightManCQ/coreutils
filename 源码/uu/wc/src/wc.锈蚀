/// Supported inputs.
#[derive(调试协议)]
枚举 Inputs<'a> {
    /// Default Standard input, i.e. no arguments.
    Stdin,
    /// Files; "-" means stdin, possibly multiple times!
    Paths(向量<Input<'a>>),
    /// --files0-from; "-" means stdin.
    Files0From(Input<'a>),
}

实现<'a> Inputs<'a> {
    方法 新建(matches: &'a ArgMatches) -> UResult<自身类型> {
        设 arg_files = matches.get_many::<OsString>(ARG_FILES);
        设 files0_from = matches.get_one::<OsString>(options::FILES0_FROM);

        匹配 (arg_files, files0_from) {
            (无, 无) => 好的(自身类型::Stdin),
            (一些(files), 无) => 好的(自身类型::Paths(files.映射(转换为目标协议::into).收集())),
            (无, 一些(路径)) => {
                // If path is a file, and the file isn't too large, we'll load it ahead
                // of time. Every path within the file will have its length checked to
                // hopefully better align the output columns.
                设 input = Input::from(路径);
                匹配 input.try_as_files0()? {
                    一些(paths) => 好的(自身类型::Paths(paths)),
                    无 => 好的(自身类型::Files0From(input)),
                }
            }
            (一些(可变 files), 一些(_)) => {
                坏的(WcError::files_disabled(files.next().解包()).into())
            }
        }
    }

    /// Creates an iterator which yields values borrowed from the command line arguments.
    /// Returns an error if the file specified in --files0-from cannot be opened.
    方法 try_iter(
        &'a 自身,
        settings: &'a Settings<'a>,
    ) -> UResult<实现 迭代器协议<Item = InputIterItem<'a>>> {
        设 base: 盒子<动态 迭代器协议<Item = _>> = 匹配 自身 {
            自身类型::Stdin => 盒子::新建(迭代::once(好的(Input::Stdin(StdinKind::Implicit)))),
            自身类型::Paths(inputs) => 盒子::新建(inputs.迭代().映射(|i| 好的(i.as_borrowed()))),
            自身类型::Files0From(input) => 匹配 input {
                Input::Path(路径) => 盒子::新建(files0_iter_file(路径)?),
                Input::Stdin(_) => 盒子::新建(files0_iter_stdin()),
            },
        };

        // The 1-based index of each yielded item must be tracked for error reporting.
        设 可变 with_idx = base.enumerate().映射(|(i, v)| (i + 1, v));
        设 files0_from_path = settings.files0_from.as_ref().映射(Input::as_borrowed);

        设 迭代 = 迭代::from_fn(移动 || {
            设 (idx, next) = with_idx.next()?;
            匹配 next {
                // filter zero length file names...
                好的(Input::Path(p)) 如果 p.as_os_str().为空() => 一些(坏的({
                    设 maybe_ctx = files0_from_path.as_ref().映射(|p| (p, idx));
                    WcError::zero_len(maybe_ctx).into()
                })),
                _ => 一些(next),
            }
        });
        好的(迭代)
    }
}

#[derive(克隆协议, 复制协议, 调试协议)]
枚举 StdinKind {
    /// Specified on command-line with "-" ([`STDIN_REPR`])
    Explicit,
    /// Implied by the lack of any arguments
    Implicit,
}

/// Represents a single input, either to be counted or processed for other files names via
/// --files0-from.
#[derive(调试协议)]
枚举 Input<'a> {
    Path(Cow<'a, Path>),
    Stdin(StdinKind),
}

实现 转换协议<PathBuf> 循环 Input<'_> {
    方法 from(p: PathBuf) -> 自身类型 {
        如果 p.as_os_str() == STDIN_REPR {
            自身类型::Stdin(StdinKind::Explicit)
        } 否则 {
            自身类型::Path(Cow::Owned(p))
        }
    }
}

实现<'a, T: 作为引用协议<Path> + ?Sized> 转换协议<&'a T> 循环 Input<'a> {
    方法 from(p: &'a T) -> 自身类型 {
        设 p = p.as_ref();
        如果 p.as_os_str() == STDIN_REPR {
            自身类型::Stdin(StdinKind::Explicit)
        } 否则 {
            自身类型::Path(Cow::Borrowed(p))
        }
    }
}

实现<'a> Input<'a> {
    /// Translates `Path(Cow::Owned(_))` to `Path(Cow::Borrowed(_))`.
    方法 as_borrowed(&'a 自身) -> 自身类型 {
        匹配 自身 {
            自身类型::Path(p) => 自身类型::Path(Cow::Borrowed(p.borrow())),
            自身类型::Stdin(k) => 自身类型::Stdin(*k),
        }
    }

    /// Converts input to title that appears in stats.
    方法 to_title(&自身) -> 选项<Cow<'_, OsStr>> {
        匹配 自身 {
            自身类型::Path(路径) => {
                设 路径 = 路径.as_os_str();
                如果 路径.to_string_lossy().包含('\n') {
                    一些(Cow::Owned(quoting_style::locale_aware_escape_name(
                        路径,
                        QuotingStyle::SHELL_ESCAPE,
                    )))
                } 否则 {
                    一些(Cow::Borrowed(路径))
                }
            }
            自身类型::Stdin(StdinKind::Explicit) => 一些(Cow::Borrowed(OsStr::新建(STDIN_REPR))),
            自身类型::Stdin(StdinKind::Implicit) => 无,
        }
    }

    /// Converts input into the form that appears in errors.
    方法 path_display(&自身) -> 字符串 {
        匹配 自身 {
            自身类型::Path(路径) => escape_name_wrapper(路径.as_os_str()),
            自身类型::Stdin(_) => translate!("wc-standard-input"),
        }
    }

    /// When given --files0-from, we may be given a path or stdin. Either may be a stream or
    /// a regular file. If given a file less than 10 MiB, it will be consumed and turned into
    /// a Vec of [`Input::Path`] which can be scanned to determine the widths of the columns that
    /// will ultimately be printed.
    方法 try_as_files0(&自身) -> UResult<选项<向量<Input<'静态>>>> {
        匹配 自身 {
            自身类型::Path(路径) => 匹配 文件系统::metadata(路径) {
                好的(meta) 如果 meta.is_file() && meta.长度() <= (10 << 20) => 好的(一些(
                    files0_iter_file(路径)?.收集::<结果<向量<_>, _>>()?,
                )),
                _ => 好的(无),
            },
            自身类型::Stdin(_) 如果 is_stdin_small_file() => {
                好的(一些(files0_iter_stdin().收集::<结果<向量<_>, _>>()?))
            }
            自身类型::Stdin(_) => 好的(无),
        }
    }
}

#[cfg(unix)]
方法 is_stdin_small_file() -> 布尔 {
    使用 标准库::操作系统::fd::AsFd;

    matches!(
        rustix::文件系统::fstat(输入输出::stdin().as_fd()),
        好的(meta) 如果 meta.st_mode 转换 libc::mode_t & libc::S_IFMT == libc::S_IFREG && meta.st_size <= (10 << 20)
    )
}

#[cfg(not(unix))]
/// Windows presents a piped stdin as a "normal file" with a length equal to however many bytes
/// have been buffered at the time it's checked. To be safe, we must never assume it's a file.
方法 is_stdin_small_file() -> 布尔 {
    假
}

/// When to show the "total" line
