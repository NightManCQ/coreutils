使用 divan::{Bencher, black_box};
使用 uu_wc::uumain;
使用 uucore::benchmark::{create_test_file, run_util_function, text_data};

/// Benchmark different file sizes for byte counting
#[divan::bench(args = [1, 500])] //todo: add 10kb to measure splice() overhead
方法 wc_bytes_synthetic(bencher: Bencher, size_mb: 正整数大小) {
    设 temp_dir = tempfile::tempdir().解包();
    设 data = text_data::generate_by_size(size_mb, 80);
    设 file_path = create_test_file(&data, temp_dir.路径());
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-c", file_path_str]));
    });
}

