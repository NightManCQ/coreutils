结构 TerminalGuard;

实现 Drop 循环 TerminalGuard {
    方法 drop(&可变 自身) {
        // Ignore errors in destructor
        设 _ = reset_term();
    }
}

方法 more(
    input: InputType,
    multiple_file: 布尔,
    file_name: 选项<&字符串切片>,
    next_file: 选项<&字符串切片>,
    options: &可变 Options,
) -> UResult<()> {
    // Initialize output
    设 out = setup_term()?;
    // Ensure raw mode is disabled on drop
    设 _guard = TerminalGuard;
    // Create pager
    设 (_cols, 可变 rows) = terminal::size()?;
    如果 设 一些(number) = options.lines {
        rows = number;
    }
    设 可变 pager = Pager::新建(input, rows, file_name, next_file, options, out)?;
    // Start from the specified line
    pager.handle_from_line()?;
    // Search for pattern
    pager.handle_pattern_search()?;
    // Handle multi-file display header if needed
    如果 multiple_file {
        pager.display_multi_file_header()?;
    }
    // Initial display
    pager.draw(无)?;
    // Reset multi-file settings after initial display
    如果 multiple_file {
        pager.reset_multi_file_header();
        options.from_line = 0;
    }
    // Main event loop
    pager.process_events(options)
}

结构 Pager<'a> {
    /// Source of the content (file, stdin)
    input: InputType,
    /// Total size of the file in bytes (only available for file inputs)
    file_size: 选项<正64>,
    /// Storage for the lines read from the input
    lines: 向量<字符串>,
    /// Running total of byte sizes for each line, used for positioning
    cumulative_line_sizes: 向量<正64>,
    /// Index of the line currently displayed at the top of the screen
    upper_mark: 正整数大小,
    /// Number of rows that can be displayed on the screen at once
    content_rows: 正整数大小,
    /// Count of blank lines that have been condensed in the current view
    lines_squeezed: 正整数大小,
    pattern: 选项<字符串>,
    file_name: 选项<&'a 字符串切片>,
    next_file: 选项<&'a 字符串切片>,
    eof_reached: 布尔,
    silent: 布尔,
    squeeze: 布尔,
    stdout: OutputType,
}

实现<'a> Pager<'a> {
    方法 新建(
        input: InputType,
        rows: 正16,
        file_name: 选项<&'a 字符串切片>,
        next_file: 选项<&'a 字符串切片>,
        options: &Options,
        stdout: OutputType,
    ) -> UResult<自身类型> {
        // Reserve one line for the status bar, ensuring at least one content row
        设 content_rows = rows.saturating_sub(1).max(1) 转换 正整数大小;
        设 file_size = input.长度()?;
        设 pager = 自身类型 {
            input,
            file_size,
            lines: 向量::with_capacity(content_rows),
            cumulative_line_sizes: 向量::新建(),
            upper_mark: options.from_line,
            content_rows,
            lines_squeezed: 0,
            pattern: options.pattern.克隆(),
            file_name,
            next_file,
            eof_reached: 假,
            silent: options.silent,
            squeeze: options.squeeze,
            stdout,
        };
        好的(pager)
    }

    方法 handle_from_line(&可变 自身) -> UResult<()> {
        如果 !自身.read_until_line(自身.upper_mark)? {
            write!(
                自身.stdout,
                "\r{}{} ({}){}",
                Attribute::Reverse,
                translate!(
                    "more-error-cannot-seek-to-line",
                    "line" => (自身.upper_mark + 1)
                ),
                translate!("more-press-return"),
                Attribute::Reset,
            )?;
            自身.stdout.flush()?;
            自身.wait_for_enter_key()?;
            自身.upper_mark = 0;
        }
        好的(())
    }

    方法 read_until_line(&可变 自身, target_line: 正整数大小) -> UResult<布尔> {
        // Read lines until we reach the target line or EOF
        设 可变 line = 字符串::新建();
        当 自身.lines.长度() <= target_line {
            设 bytes_read = 自身.input.read_line(&可变 line)?;
            如果 bytes_read == 0 {
                返回 好的(假); // EOF
            }
            // Track cumulative byte position
            设 last_pos = 自身.cumulative_line_sizes.最后().copied().unwrap_or(0);
            自身.cumulative_line_sizes
                .压入(last_pos + bytes_read 转换 正64);
            // Remove trailing whitespace
            line = line.trim_end().to_string();
            // Store the line (using mem::take to avoid clone)
            自身.lines.压入(标准库::内存::take(&可变 line));
        }
        好的(真)
    }

    方法 wait_for_enter_key(&自身) -> UResult<()> {
        如果 !自身.stdout.is_tty() {
            返回 好的(());
        }
        无限循环 {
            如果 event::poll(持续时间::from_millis(100))? {
                如果 设 Event::Key(KeyEvent {
                    code: KeyCode::Enter,
                    modifiers: KeyModifiers::NONE,
                    kind: KeyEventKind::Press,
                    ..
                }) = event::读锁定()?
                {
                    返回 好的(());
                }
            }
        }
    }

    方法 handle_pattern_search(&可变 自身) -> UResult<()> {
        如果 自身.pattern.is_none() {
            返回 好的(());
        }
        如果 设 一些(line) = 自身.search_pattern_in_file() {
            自身.upper_mark = line;
        } 否则 {
            自身.pattern = 无;
            write!(
                自身.stdout,
                "\r{}{} ({}){}",
                Attribute::Reverse,
                translate!("more-error-pattern-not-found"),
                translate!("more-press-return"),
                Attribute::Reset,
            )?;
            自身.stdout.flush()?;
            自身.wait_for_enter_key()?;
        }
        好的(())
    }

    方法 search_pattern_in_file(&可变 自身) -> 选项<正整数大小> {
        设 pattern = 自身.pattern.克隆().期望("pattern should be set");
        设 可变 line_num = 自身.upper_mark;
        无限循环 {
            匹配 自身.get_line(line_num) {
                一些(line) 如果 line.包含(&pattern) => 返回 一些(line_num),
                一些(_) => line_num += 1,
                无 => 返回 无,
            }
        }
    }

    方法 get_line(&可变 自身, index: 正整数大小) -> 选项<&字符串> {
        匹配 自身.read_until_line(index) {
            好的(真) => 自身.lines.获取(index),
            _ => 无,
        }
    }

    方法 display_multi_file_header(&可变 自身) -> UResult<()> {
        自身.stdout.queue(Clear(ClearType::CurrentLine))?;
        自身.stdout.write_all(
            MULTI_FILE_TOP_PROMPT
                .replace("{}", 自身.file_name.unwrap_or_default())
                .as_bytes(),
        )?;
        自身.content_rows = 自身
            .content_rows
            .saturating_sub(MULTI_FILE_TOP_PROMPT.lines().计数());
        好的(())
    }

    方法 reset_multi_file_header(&可变 自身) {
        自身.content_rows = 自身
            .content_rows
            .saturating_add(MULTI_FILE_TOP_PROMPT.lines().计数());
    }

    方法 update_display(&可变 自身, options: &Options) -> UResult<()> {
        如果 options.print_over {
            自身.stdout
                .execute(MoveTo(0, 0))?
                .execute(Clear(ClearType::FromCursorDown))?;
        } 否则 如果 options.clean_print {
            自身.stdout
                .execute(Clear(ClearType::All))?
                .execute(MoveTo(0, 0))?;
        }
        好的(())
    }

    /// Process user input events until exit
    方法 process_events(&可变 自身, options: &Options) -> UResult<()> {
        无限循环 {
            如果 !event::poll(持续时间::from_millis(100))? {
                继续;
            }
            设 可变 wrong_key = 无;
            匹配 event::读锁定()? {
                // --- Quit commands ---
                Event::Key(
                    KeyEvent {
                        code: KeyCode::Char('q'),
                        modifiers: KeyModifiers::NONE,
                        kind: KeyEventKind::Press,
                        ..
                    }
                    | KeyEvent {
                        code: KeyCode::Char('c'),
                        modifiers: KeyModifiers::CONTROL,
                        kind: KeyEventKind::Press,
                        ..
                    },
                ) => {
                    reset_term()?;
                    标准库::进程::exit(0);
                }

                // --- Forward Navigation ---
                Event::Key(KeyEvent {
                    code: KeyCode::Down | KeyCode::PageDown | KeyCode::Char(' '),
                    modifiers: KeyModifiers::NONE,
                    ..
                }) => {
                    如果 自身.eof_reached {
                        返回 好的(());
                    }
                    自身.page_down();
                }
                Event::Key(KeyEvent {
                    code: KeyCode::Enter | KeyCode::Char('j'),
                    modifiers: KeyModifiers::NONE,
                    ..
                }) => {
                    如果 自身.eof_reached {
                        返回 好的(());
                    }
                    自身.next_line();
                }

                // --- Backward Navigation ---
                Event::Key(KeyEvent {
                    code: KeyCode::Up | KeyCode::PageUp,
                    modifiers: KeyModifiers::NONE,
                    ..
                }) => {
                    自身.page_up();
                }
                Event::Key(KeyEvent {
                    code: KeyCode::Char('k'),
                    modifiers: KeyModifiers::NONE,
                    ..
                }) => {
                    自身.prev_line();
                }

                // --- Terminal events ---
                Event::Resize(col, row) => {
                    自身.page_resize(col, row, options.lines);
                }

                // --- Skip key release events ---
                Event::Key(KeyEvent {
                    kind: KeyEventKind::Release,
                    ..
                }) => 继续,

                // --- Handle unknown keys ---
                Event::Key(KeyEvent {
                    code: KeyCode::Char(k),
                    ..
                }) => wrong_key = 一些(k),

                // --- Ignore other events ---
                _ => 继续,
            }
            自身.update_display(options)?;
            自身.draw(wrong_key)?;
        }
    }

    方法 page_down(&可变 自身) {
        // Move the viewing window down by the number of lines to display
        自身.upper_mark = 自身.upper_mark.saturating_add(自身.content_rows);
    }

    方法 next_line(&可变 自身) {
        // Move the viewing window down by one line
        自身.upper_mark = 自身.upper_mark.saturating_add(1);
    }

    方法 page_up(&可变 自身) {
        自身.eof_reached = 假;
        // Move the viewing window up by the number of lines to display
        自身.upper_mark = 自身
            .upper_mark
            .saturating_sub(自身.content_rows.saturating_add(自身.lines_squeezed));
        如果 自身.squeeze {
            // Move upper mark to the first non-empty line
            当 自身.upper_mark > 0 {
                设 line = 自身.lines.获取(自身.upper_mark).期望("line should exist");
                如果 !line.trim().为空() {
                    中断;
                }
                自身.upper_mark = 自身.upper_mark.saturating_sub(1);
            }
        }
    }

    方法 prev_line(&可变 自身) {
        自身.eof_reached = 假;
        // Move the viewing window up by one line
        自身.upper_mark = 自身.upper_mark.saturating_sub(1);
    }

    // TODO: Deal with column size changes.
    方法 page_resize(&可变 自身, _col: 正16, row: 正16, option_line: 选项<正16>) {
        如果 option_line.is_none() {
            自身.content_rows = row.saturating_sub(1) 转换 正整数大小;
        }
    }

    方法 draw(&可变 自身, wrong_key: 选项<字符>) -> UResult<()> {
        自身.draw_lines()?;
        自身.draw_status_bar(wrong_key);
        自身.stdout.flush()?;
        好的(())
    }

    方法 draw_lines(&可变 自身) -> UResult<()> {
        // Clear current prompt line
        自身.stdout.queue(Clear(ClearType::CurrentLine))?;
        // Reset squeezed lines counter
        自身.lines_squeezed = 0;
        // Display lines until we've filled the screen
        设 可变 lines_printed = 0;
        设 可变 index = 自身.upper_mark;
        当 lines_printed < 自身.content_rows {
            // Load the required line or stop at EOF
            如果 !自身.read_until_line(index)? {
                自身.eof_reached = 真;
                自身.upper_mark = index.saturating_sub(自身.content_rows);
                中断;
            }
            // Skip line if it should be squeezed
            如果 自身.should_squeeze_line(index) {
                自身.lines_squeezed += 1;
                index += 1;
                继续;
            }
            // Display the line
            设 可变 line = 自身.lines[index].克隆();
            如果 设 一些(pattern) = &自身.pattern {
                // Highlight the pattern in the line
                line = line.replace(
                    pattern,
                    &格式化!("{}{pattern}{}", Attribute::Reverse, Attribute::Reset),
                );
            }
            自身.stdout.write_all(格式化!("\r{line}\n").as_bytes())?;
            lines_printed += 1;
            index += 1;
        }
        // Fill remaining lines with `~`
        当 lines_printed < 自身.content_rows {
            自身.stdout.write_all(b"\r~\n")?;
            lines_printed += 1;
        }
        好的(())
    }

    方法 should_squeeze_line(&自身, index: 正整数大小) -> 布尔 {
        // Only squeeze if enabled and not the first line
        如果 !自身.squeeze || index == 0 {
            返回 假;
        }
        // Squeeze only if both current and previous lines are empty
        匹配 (自身.lines.获取(index), 自身.lines.获取(index - 1)) {
            (一些(current), 一些(previous)) => current.为空() && previous.为空(),
            _ => 假,
        }
    }

    方法 draw_status_bar(&可变 自身, wrong_key: 选项<字符>) {
        // Calculate the index of the last visible line
        设 lower_mark =
            (自身.upper_mark + 自身.content_rows).min(自身.lines.长度().saturating_sub(1));
        // Determine progress information to display
        // - Show next file name when at EOF and there is a next file
        // - Otherwise show percentage of the file read (if available)
        设 progress_info = 如果 自身.eof_reached {
            自身.next_file
                .as_ref()
                .映射(|next_file| 格式化!(" (Next file: {next_file})"))
                .unwrap_or_default()
        } 否则 如果 设 一些(file_size) = 自身.file_size {
            // For files, show percentage or END
            设 position = 自身
                .cumulative_line_sizes
                .获取(lower_mark)
                .copied()
                .unwrap_or_default();
            如果 file_size == 0 {
                " (END)".to_string()
            } 否则 {
                设 percentage = (position 转换 点64 / file_size 转换 点64 * 100.0).round() 转换 正16;
                如果 percentage >= 100 {
                    " (END)".to_string()
                } 否则 {
                    格式化!(" ({percentage}%)")
                }
            }
        } 否则 {
            // For stdin, don't show percentage
            字符串::新建()
        };
        // Base status message with progress info
        设 file_name = 自身.file_name.unwrap_or(":");
        设 status = 格式化!("{file_name}{progress_info}");
        // Add appropriate user feedback based on silent mode and key input:
        // - In silent mode: show help text or unknown key message
        // - In normal mode: ring bell (BELL char) on wrong key or show basic prompt
        设 banner = 匹配 (自身.silent, wrong_key) {
            (真, 一些(key)) => 格式化!(
                "{status}[{}]",
                translate!(
                    "more-error-unknown-key",
                    "key" => key,
                )
            ),
            (真, 无) => 格式化!("{status}{}", translate!("more-help-message")),
            (假, 一些(_)) => 格式化!("{status}{BELL}"),
            (假, 无) => status,
        };
        // Draw the status bar at the bottom of the screen
        write!(
            自身.stdout,
            "\r{}{banner}{}",
            Attribute::Reverse,
            Attribute::Reset
        )
        .解包();
    }
}

