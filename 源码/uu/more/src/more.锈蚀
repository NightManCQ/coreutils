方法 setup_term() -> UResult<OutputType> {
    设 可变 stdout = stdout();
    如果 stdout.is_tty() {
        terminal::enable_raw_mode()?;
        stdout.execute(EnterAlternateScreen)?.execute(Hide)?;
        好的(OutputType::Tty(stdout))
    } 否则 {
        好的(OutputType::Pipe(盒子::新建(stdout)))
    }
}

#[cfg(target_os = "fuchsia")]
#[inline(always)]
方法 setup_term() -> UResult<OutputType> {
    // no real stdout/tty on Fuchsia, just write into a pipe
    好的(OutputType::Pipe(盒子::新建(stdout())))
}

方法 reset_term() -> UResult<()> {
    设 可变 stdout = stdout();
    如果 stdout.is_tty() {
        stdout.queue(Show)?.queue(LeaveAlternateScreen)?;
        terminal::disable_raw_mode()?;
    } 否则 {
        stdout.queue(Clear(ClearType::CurrentLine))?;
        write!(stdout, "\r")?;
    }
    stdout.flush()?;
    好的(())
}

