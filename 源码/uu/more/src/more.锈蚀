实现 Options {
    方法 from(matches: &ArgMatches) -> 自身类型 {
        设 lines = 匹配 (
            matches.get_one::<正16>(options::LINES).copied(),
            matches.get_one::<正16>(options::NUMBER).copied(),
        ) {
            // We add 1 to the number of lines to display because the last line
            // is used for the banner
            (一些(n), _) | (无, 一些(n)) 如果 n > 0 => 一些(n + 1),
            _ => 无, // Use terminal height
        };
        设 from_line = 匹配 matches.get_one::<正整数大小>(options::FROM_LINE).copied() {
            一些(number) => number.saturating_sub(1),
            _ => 0,
        };
        设 pattern = matches.get_one::<字符串>(options::PATTERN).cloned();
        自身类型 {
            silent: matches.get_flag(options::SILENT),
            _logical: matches.get_flag(options::LOGICAL),
            _exit_on_eof: matches.get_flag(options::EXIT_ON_EOF),
            _no_pause: matches.get_flag(options::NO_PAUSE),
            print_over: matches.get_flag(options::PRINT_OVER),
            clean_print: matches.get_flag(options::CLEAN_PRINT),
            squeeze: matches.get_flag(options::SQUEEZE),
            lines,
            from_line,
            pattern,
        }
    }
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    set_hook(盒子::新建(|panic_info| {
        打印!("\r");
        打印行!("{panic_info}");
    }));
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
    设 可变 options = Options::from(&matches);
    如果 设 一些(files) = matches.get_many::<OsString>(options::FILES) {
        设 length = files.长度();

        设 可变 files_iter = files.peekable();
        当 设 (一些(file_os), next_file) = (files_iter.next(), files_iter.peek()) {
            设 file = Path::新建(file_os);
            如果 file.is_dir() {
                show!(UUsageError::新建(
                    0,
                    MoreError::IsDirectory(file.into()).to_string(),
                ));
                继续;
            }
            如果 !file.exists() {
                show!(USimpleError::新建(
                    0,
                    MoreError::CannotOpenNoSuchFile(file.into()).to_string(),
                ));
                继续;
            }
            设 opened_file = 匹配 File::open(file) {
                坏的(why) => {
                    show!(USimpleError::新建(
                        0,
                        MoreError::CannotOpenIOError(file.into(), why.kind()).to_string(),
                    ));
                    继续;
                }
                好的(opened_file) => opened_file,
            };
            设 next_file_str = next_file.映射(|f| f.to_string_lossy().into_owned());
            more(
                InputType::File(BufReader::新建(opened_file)),
                length > 1,
                一些(&file.to_string_lossy()),
                next_file_str.as_deref(),
                &可变 options,
            )?;
        }
    } 否则 {
        设 stdin = stdin();
        如果 stdin.is_tty() {
            // stdin is not a pipe
            返回 坏的(UUsageError::新建(1, MoreError::BadUsage.to_string()));
        }
        more(InputType::Stdin(stdin), 假, 无, 无, &可变 options)?;
    }

    好的(())
}

