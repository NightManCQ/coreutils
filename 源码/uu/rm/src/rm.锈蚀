}

/// Helper function to show error with context and return error status
方法 show_removal_error(错误: 输入输出::错误协议, 路径: &Path) -> 布尔 {
    如果 错误.kind() == 输入输出::ErrorKind::PermissionDenied {
        show_error!("cannot remove {}: Permission denied", 路径.quote());
    } 否则 {
        设 e =
            错误.map_err_context(|| translate!("rm-error-cannot-remove", "file" => 路径.quote()));
        show_error!("{e}");
    }
    真
}

/// Helper function for permission denied errors
方法 show_permission_denied_error(路径: &Path) -> 布尔 {
    show_error!("cannot remove {}: Permission denied", 路径.quote());
    真
}

/// Helper function to remove a directory and handle results
方法 remove_dir_with_feedback(路径: &Path, options: &Options) -> 布尔 {
    匹配 文件系统::remove_dir(路径) {
        好的(_) => {
            verbose_removed_directory(路径, options);
            假
        }
        坏的(e) => show_removal_error(e, 路径),
    }
}

#[derive(相等比较协议, 偏等比较协议, 克隆协议, 复制协议)]
/// Enum, determining when the `rm` will prompt the user about the file deletion
公有 枚举 InteractiveMode {
    /// Never prompt
    Never,
    /// Prompt once before removing more than three files, or when removing
    /// recursively.
    Once,
    /// Prompt before every removal
    Always,
    /// Prompt only on write-protected files
    PromptProtected,
}

// We implement `From` instead of `TryFrom` because clap guarantees that we only receive valid values.
//
// The `PromptProtected` variant is not supposed to be created from a string.
实现 转换协议<&字符串切片> 循环 InteractiveMode {
    方法 from(s: &字符串切片) -> 自身类型 {
        匹配 s {
            "never" => 自身类型::Never,
            "once" => 自身类型::Once,
            "always" => 自身类型::Always,
            _ => 无法到达!("should be prevented by clap"),
        }
    }
}

/// Options for the `rm` command
///
/// All options are public so that the options can be programmatically
/// constructed by other crates, such as Nushell. That means that this struct
/// is part of our public API. It should therefore not be changed without good
/// reason.
///
/// The fields are documented with the arguments that determine their value.
公有 结构 Options {
    /// `-f`, `--force`
    公有 force: 布尔,
    /// Iterative mode, determines when the command will prompt.
    ///
    /// Set by the following arguments:
    /// - `-i`: [`InteractiveMode::Always`]
    /// - `-I`: [`InteractiveMode::Once`]
    /// - `--interactive`: sets one of the above or [`InteractiveMode::Never`]
    /// - `-f`: implicitly sets [`InteractiveMode::Never`]
    ///
    /// If no other option sets this mode, [`InteractiveMode::PromptProtected`]
    /// is used
    公有 interactive: InteractiveMode,
    #[allow(dead_code)]
    /// `--one-file-system`
    公有 one_fs: 布尔,
    /// `--preserve-root`/`--no-preserve-root`
    公有 preserve_root: 布尔,
    /// `-r`, `--recursive`
    公有 recursive: 布尔,
    /// `-d`, `--dir`
    公有 dir: 布尔,
    /// `-v`, `--verbose`
    公有 verbose: 布尔,
    /// `-g`, `--progress`
    公有 progress: 布尔,
    #[doc(hidden)]
    /// `---presume-input-tty`
    /// Always use `None`; GNU flag for testing use only
    公有 __presume_input_tty: 选项<布尔>,
}

实现 默认协议 循环 Options {
    方法 默认() -> 自身类型 {
        自身类型 {
            force: 假,
            interactive: InteractiveMode::PromptProtected,
            one_fs: 假,
            preserve_root: 真,
            recursive: 假,
            dir: 假,
            verbose: 假,
            progress: 假,
            __presume_input_tty: 无,
        }
    }
}

