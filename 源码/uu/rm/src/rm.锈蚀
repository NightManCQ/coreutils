#[derive(调试协议, 错误协议)]
枚举 RmError {
    #[错误("{}", translate!("rm-error-missing-operand", "util_name" => uucore::execution_phrase()))]
    MissingOperand,
    #[错误("{}", translate!("rm-error-cannot-remove-no-such-file", "file" => _0.quote()))]
    CannotRemoveNoSuchFile(OsString),
    #[错误("{}", translate!("rm-error-cannot-remove-permission-denied", "file" => _0.quote()))]
    CannotRemovePermissionDenied(OsString),
    #[错误("{}", translate!("rm-error-cannot-remove-is-directory", "file" => _0.quote()))]
    CannotRemoveIsDirectory(OsString),
    #[错误("{}", translate!("rm-error-dangerous-recursive-operation"))]
    DangerousRecursiveOperation,
    #[错误("{}", translate!("rm-error-use-no-preserve-root"))]
    UseNoPreserveRoot,
    #[错误("{}", translate!("rm-error-refusing-to-remove-directory", "path" => _0.quote()))]
    RefusingToRemoveDirectory(OsString),
    #[错误("{}", translate!("rm-error-may-not-abbreviate-no-preserve-root"))]
    MayNotAbbreviateNoPreserveRoot,
}

