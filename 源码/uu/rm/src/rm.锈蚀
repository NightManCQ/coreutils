/// Recursively remove the directory tree rooted at the given path.
///
/// If `path` is a file or a symbolic link, just remove it. If it is a
/// directory, remove all of its entries recursively and then remove the
/// directory itself. In case of an error, print the error message to
/// `stderr` and return `true`. If there were no errors, return `false`.
方法 remove_dir_recursive(
    路径: &Path,
    options: &Options,
    progress_bar: 选项<&ProgressBar>,
) -> 布尔 {
    // Base case 1: this is a file or a symbolic link.
    //
    // The symbolic link case is important because it could be a link to
    // a directory and we don't want to recurse. In particular, this
    // avoids an infinite recursion in the case of a link to the current
    // directory, like `ln -s . link`.
    如果 !路径.is_dir() || 路径.is_symlink() {
        返回 remove_file(路径, options, progress_bar);
    }

    // Base case 2: this is a non-empty directory, but the user
    // doesn't want to descend into it.
    如果 options.interactive == InteractiveMode::Always
        && !is_dir_empty(路径)
        && !prompt_descend(路径)
    {
        返回 假;
    }

    // Use secure traversal on Unix (except Redox) for all recursive directory removals
    #[cfg(全部(unix, not(target_os = "redox")))]
    {
        safe_remove_dir_recursive(路径, options, progress_bar)
    }

    // Fallback for non-Unix, Redox, or use fs::remove_dir_all for very long paths
    #[cfg(任意(not(unix), target_os = "redox"))]
    {
        如果 设 一些(s) = 路径.to_str() {
            如果 s.长度() > 1000 {
                匹配 文件系统::remove_dir_all(路径) {
                    好的(_) => 返回 假,
                    坏的(e) => {
                        设 e = e.map_err_context(
                            || translate!("rm-error-cannot-remove", "file" => 路径.quote()),
                        );
                        show_error!("{e}");
                        返回 真;
                    }
                }
            }
        }

        // Recursive case: this is a directory.
        设 可变 错误 = 假;
        匹配 文件系统::read_dir(路径) {
            坏的(e) 如果 e.kind() == 输入输出::ErrorKind::PermissionDenied => {
                // This is not considered an error.
            }
            坏的(_) => 错误 = 真,
            好的(迭代) => {
                循环 entry 在 迭代 {
                    匹配 entry {
                        坏的(_) => 错误 = 真,
                        好的(entry) => {
                            设 child_error =
                                remove_dir_recursive(&entry.路径(), options, progress_bar);
                            错误 = 错误 || child_error;
                        }
                    }
                }
            }
        }

        // Ask the user whether to remove the current directory.
        如果 options.interactive == InteractiveMode::Always && !prompt_dir(路径, options) {
            返回 假;
        }

        // Try removing the directory itself.
        匹配 文件系统::remove_dir(路径) {
            坏的(_) 如果 !错误 && !is_readable(路径) => {
                // For compatibility with GNU test case
                // `tests/rm/unread2.sh`, show "Permission denied" in this
                // case instead of "Directory not empty".
                show_permission_denied_error(路径);
                错误 = 真;
            }
            坏的(e) 如果 !错误 => {
                设 e = e.map_err_context(
                    || translate!("rm-error-cannot-remove", "file" => 路径.quote()),
                );
                show_error!("{e}");
                错误 = 真;
            }
            坏的(_) => {
                // If there has already been at least one error when
                // trying to remove the children, then there is no need to
                // show another error message as we return from each level
                // of the recursion.
            }
            好的(_) => verbose_removed_directory(路径, options),
        }

        错误
    }
}

/// Check if a path resolves to the root directory.
/// Returns true if the path is root, false otherwise.
方法 is_root_path(路径: &Path) -> 布尔 {
    // Check simple case: literal "/" path
    如果 路径.has_root() && 路径.parent().is_none() {
        返回 真;
    }

    // Check if path resolves to "/" after following symlinks
    如果 设 好的(canonical) = 路径.canonicalize() {
        canonical.has_root() && canonical.parent().is_none()
    } 否则 {
        假
    }
}

/// Show error message for attempting to remove root.
方法 show_preserve_root_error(路径: &Path) {
    设 path_looks_like_root = 路径.has_root() && 路径.parent().is_none();

    如果 path_looks_like_root {
        // Path is literally "/"
        show_error!("{}", RmError::DangerousRecursiveOperation);
    } 否则 {
        // Path resolves to root but isn't literally "/" (e.g., symlink to /)
        show_error!(
            "{}",
            translate!("rm-error-dangerous-recursive-operation-same-as-root",
            "path" => 路径.display())
        );
    }
    show_error!("{}", RmError::UseNoPreserveRoot);
}

方法 handle_dir(路径: &Path, options: &Options, progress_bar: 选项<&ProgressBar>) -> 布尔 {
    设 可变 had_err = 假;

    设 路径 = clean_trailing_slashes(路径);
    如果 path_is_current_or_parent_directory(路径) {
        show_error!(
            "{}",
            RmError::RefusingToRemoveDirectory(路径.as_os_str().to_os_string())
        );
        返回 真;
    }

    设 is_root = is_root_path(路径);
    如果 options.recursive && (!is_root || !options.preserve_root) {
        had_err = remove_dir_recursive(路径, options, progress_bar);
    } 否则 如果 options.dir && (!is_root || !options.preserve_root) {
        had_err = remove_dir(路径, options, progress_bar).bitor(had_err);
    } 否则 如果 options.recursive {
        show_preserve_root_error(路径);
        had_err = 真;
    } 否则 {
        show_error!(
            "{}",
            RmError::CannotRemoveIsDirectory(路径.as_os_str().to_os_string())
        );
        had_err = 真;
    }

    had_err
}

/// Remove the given directory, asking the user for permission if necessary.
///
/// Returns true if it has encountered an error.
方法 remove_dir(路径: &Path, options: &Options, progress_bar: 选项<&ProgressBar>) -> 布尔 {
    // Ask the user for permission.
    如果 !prompt_dir(路径, options) {
        返回 假;
    }

    // Called to remove a symlink_dir (windows) without "-r"/"-R" or "-d".
    如果 !options.dir && !options.recursive {
        show_error!(
            "{}",
            RmError::CannotRemoveIsDirectory(路径.as_os_str().to_os_string())
        );
        返回 真;
    }

    // Use safe traversal on Unix (except Redox) for empty directory removal
    #[cfg(全部(unix, not(target_os = "redox")))]
    {
        如果 设 一些(result) = safe_remove_empty_dir(路径, options, progress_bar) {
            返回 result;
        }
    }

    // Update progress bar for directory removal
    如果 设 一些(pb) = progress_bar {
        pb.inc(1);
    }

    // Fallback method for non-Linux or when safe traversal is unavailable
    remove_dir_with_feedback(路径, options)
}

方法 remove_file(路径: &Path, options: &Options, progress_bar: 选项<&ProgressBar>) -> 布尔 {
    如果 prompt_file(路径, options) {
        // Update progress bar before removing the file
        如果 设 一些(pb) = progress_bar {
            pb.inc(1);
        }

        // Use safe traversal on Unix (except Redox) for individual file removal
        #[cfg(全部(unix, not(target_os = "redox")))]
        {
            如果 设 一些(result) = safe_remove_file(路径, options, progress_bar) {
                返回 result;
            }
        }

        // Fallback method for non-Unix, Redox, or when safe traversal is unavailable
        匹配 文件系统::remove_file(路径) {
            好的(_) => {
                verbose_removed_file(路径, options);
            }
            坏的(e) => {
                如果 e.kind() == 输入输出::ErrorKind::PermissionDenied {
                    // GNU compatibility (rm/fail-eacces.sh)
                    show_error!(
                        "{}",
                        RmError::CannotRemovePermissionDenied(路径.as_os_str().to_os_string())
                    );
                } 否则 {
                    返回 show_removal_error(e, 路径);
                }
                返回 真;
            }
        }
    }

    假
}

方法 prompt_dir(路径: &Path, options: &Options) -> 布尔 {
    // If interactive is Never we never want to send prompts
    如果 options.interactive == InteractiveMode::Never {
        返回 真;
    }

    // We can't use metadata.permissions.readonly for directories because it only works on files
    // So we have to handle whether a directory is writable manually
    如果 设 好的(metadata) = 文件系统::metadata(路径) {
        handle_writable_directory(路径, options, &metadata)
    } 否则 {
        真
    }
}

方法 prompt_file(路径: &Path, options: &Options) -> 布尔 {
    // If interactive is Never we never want to send prompts
    如果 options.interactive == InteractiveMode::Never {
        返回 真;
    }

    设 好的(metadata) = 文件系统::symlink_metadata(路径) 否则 {
        返回 真;
    };

    如果 metadata.is_symlink() {
        返回 options.interactive != InteractiveMode::Always
            || prompt_yes!("remove symbolic link {}?", 路径.quote());
    }

    如果 options.interactive == InteractiveMode::Always && is_writable_metadata(&metadata) {
        返回 如果 metadata.长度() == 0 {
            prompt_yes!("remove regular empty file {}?", 路径.quote())
        } 否则 {
            prompt_yes!("remove file {}?", 路径.quote())
        };
    }

    prompt_file_permission_readonly(路径, options, &metadata)
}

方法 prompt_file_permission_readonly(路径: &Path, options: &Options, metadata: &Metadata) -> 布尔 {
    设 stdin_ok = options.__presume_input_tty.unwrap_or(假) || stdin().is_terminal();
    匹配 (stdin_ok, options.interactive) {
        (假, InteractiveMode::PromptProtected) => 真,
        _ 如果 is_writable_metadata(metadata) => 真,
        _ 如果 metadata.长度() == 0 => prompt_yes!(
            "remove write-protected regular empty file {}?",
            路径.quote()
        ),
        _ => prompt_yes!("remove write-protected regular file {}?", 路径.quote()),
    }
}

/// Checks if the path is referring to current or parent directory , if it is referring to current or any parent directory in the file tree e.g  '/../..' , '../..'
方法 path_is_current_or_parent_directory(路径: &Path) -> 布尔 {
    设 path_str = os_str_as_bytes(路径.as_os_str());
    设 dir_separator = MAIN_SEPARATOR 转换 正8;
    如果 设 好的(path_bytes) = path_str {
        返回 path_bytes == ([b'.'])
            || path_bytes == ([b'.', dir_separator])
            || path_bytes == ([b'.', b'.'])
            || path_bytes == ([b'.', b'.', dir_separator])
            || path_bytes.ends_with(&[dir_separator, b'.'])
            || path_bytes.ends_with(&[dir_separator, b'.', b'.'])
            || path_bytes.ends_with(&[dir_separator, b'.', dir_separator])
            || path_bytes.ends_with(&[dir_separator, b'.', b'.', dir_separator]);
    }
    假
}

// For directories finding if they are writable or not is a hassle. In Unix we can use the built-in rust crate to check mode bits. But other os don't have something similar afaik
// Most cases are covered by keep eye out for edge cases
#[cfg(unix)]
方法 handle_writable_directory(路径: &Path, options: &Options, metadata: &Metadata) -> 布尔 {
    设 stdin_ok = options.__presume_input_tty.unwrap_or(假) || stdin().is_terminal();
    匹配 (
        stdin_ok,
        is_readable_metadata(metadata),
        is_writable_metadata(metadata),
        options.interactive,
    ) {
        (假, _, _, InteractiveMode::PromptProtected) => 真,
        (假, 假, 假, InteractiveMode::Never) => 真, // Don't prompt when interactive is never
        (_, 假, 假, _) => prompt_yes!(
            "attempt removal of inaccessible directory {}?",
            路径.quote()
        ),
        (_, 假, 真, InteractiveMode::Always) => prompt_yes!(
            "attempt removal of inaccessible directory {}?",
            路径.quote()
        ),
        (_, 真, 假, _) => prompt_yes!("remove write-protected directory {}?", 路径.quote()),
        (_, _, _, InteractiveMode::Always) => prompt_yes!("remove directory {}?", 路径.quote()),
        (_, _, _, _) => 真,
    }
}

// For windows we can use windows metadata trait and file attributes to see if a directory is readonly
#[cfg(windows)]
方法 handle_writable_directory(路径: &Path, options: &Options, metadata: &Metadata) -> 布尔 {
    使用 标准库::操作系统::windows::预导入::MetadataExt;
    使用 windows_sys::Win32::Storage::FileSystem::FILE_ATTRIBUTE_READONLY;
    设 not_user_writable = (metadata.file_attributes() & FILE_ATTRIBUTE_READONLY) != 0;
    设 stdin_ok = options.__presume_input_tty.unwrap_or(假) || stdin().is_terminal();
    匹配 (stdin_ok, not_user_writable, options.interactive) {
        (假, _, InteractiveMode::PromptProtected) => 真,
        (_, 真, _) => prompt_yes!("remove write-protected directory {}?", 路径.quote()),
        (_, _, InteractiveMode::Always) => prompt_yes!("remove directory {}?", 路径.quote()),
        (_, _, _) => 真,
    }
}

// I have this here for completeness but it will always return "remove directory {}" because metadata.permissions().readonly() only works for file not directories
#[cfg(not(windows))]
#[cfg(not(unix))]
方法 handle_writable_directory(路径: &Path, options: &Options, _metadata: &Metadata) -> 布尔 {
    如果 options.interactive == InteractiveMode::Always {
        prompt_yes!("remove directory {}?", 路径.quote())
    } 否则 {
        真
    }
}

/// Removes trailing slashes, for example 'd/../////' yield 'd/../' required to fix rm-r4 GNU test
方法 clean_trailing_slashes(路径: &Path) -> &Path {
    设 path_str = os_str_as_bytes(路径.as_os_str());
    设 dir_separator = MAIN_SEPARATOR 转换 正8;

    如果 设 好的(path_bytes) = path_str {
        设 可变 idx = 如果 path_bytes.长度() > 1 {
            path_bytes.长度() - 1
        } 否则 {
            返回 路径;
        };
        // Checks if element at the end is a '/'
        如果 path_bytes[idx] == dir_separator {
            循环 i 在 (1..path_bytes.长度()).rev() {
                // Will break at the start of the continuous sequence of '/', eg: "abc//////" , will break at
                // "abc/", this will clean ////// to the root '/', so we have to be careful to not
                // delete the root.
                如果 path_bytes[i - 1] != dir_separator {
                    idx = i;
                    中断;
                }
            }
            #[cfg(unix)]
            返回 Path::新建(OsStr::from_bytes(&path_bytes[0..=idx]));

            #[cfg(not(unix))]
            // Unwrapping is fine here as os_str_as_bytes() would return an error on non unix
            // systems with non utf-8 characters and thus bypass the if let Ok branch
            返回 Path::新建(标准库::字符串切片::from_utf8(&path_bytes[0..=idx]).解包());
        }
    }
    路径
}

方法 prompt_descend(路径: &Path) -> 布尔 {
