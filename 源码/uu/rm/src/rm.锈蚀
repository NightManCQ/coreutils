/// Helper function to print verbose message for removed file
方法 verbose_removed_file(路径: &Path, options: &Options) {
    如果 options.verbose {
        打印行!(
            "{}",
            translate!("rm-verbose-removed", "file" => uucore::文件系统::normalize_path(路径).quote())
        );
    }
}

/// Helper function to print verbose message for removed directory
方法 verbose_removed_directory(路径: &Path, options: &Options) {
    如果 options.verbose {
        打印行!(
            "{}",
            translate!("rm-verbose-removed-directory", "file" => uucore::文件系统::normalize_path(路径).quote())
        );
