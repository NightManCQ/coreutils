#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 args: 向量<OsString> = args.收集();
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args.迭代())?;

    设 files: 向量<_> = matches
        .get_many::<OsString>(ARG_FILES)
        .映射(|v| v.映射(OsString::as_os_str).收集())
        .unwrap_or_default();

    设 force_flag = matches.get_flag(OPT_FORCE);

    如果 files.为空() && !force_flag {
        // Still check by hand and not use clap
        // Because "rm -f" is a thing
        返回 坏的(RmError::MissingOperand.into());
    }

    // If -f(--force) is before any -i (or variants) we want prompts else no prompts
    设 force_prompt_never = force_flag && {
        设 force_index = matches.index_of(OPT_FORCE).unwrap_or(0);
        ![OPT_PROMPT_ALWAYS, OPT_PROMPT_ONCE, OPT_INTERACTIVE]
            .迭代()
            .任意(|flag| {
                matches.value_source(flag) == 一些(ValueSource::CommandLine)
                    && matches.index_of(flag).unwrap_or(0) > force_index
            })
    };

    设 preserve_root = !matches.get_flag(OPT_NO_PRESERVE_ROOT);
    设 recursive = matches.get_flag(OPT_RECURSIVE);

    设 options = Options {
        force: force_flag,
        interactive: {
            如果 force_prompt_never {
                InteractiveMode::Never
            } 否则 如果 matches.get_flag(OPT_PROMPT_ALWAYS) {
                InteractiveMode::Always
            } 否则 如果 matches.get_flag(OPT_PROMPT_ONCE) {
                InteractiveMode::Once
            } 否则 如果 matches.contains_id(OPT_INTERACTIVE) {
                InteractiveMode::from(matches.get_one::<字符串>(OPT_INTERACTIVE).解包().as_str())
            } 否则 {
                InteractiveMode::PromptProtected
            }
        },
        one_fs: matches.get_flag(OPT_ONE_FILE_SYSTEM),
        preserve_root,
        recursive,
        dir: matches.get_flag(OPT_DIR),
        verbose: matches.get_flag(OPT_VERBOSE),
        progress: matches.get_flag(OPT_PROGRESS),
        __presume_input_tty: 如果 matches.get_flag(PRESUME_INPUT_TTY) {
            一些(真)
        } 否则 {
            无
        },
    };

    // manually parse all args to verify --no-preserve-root did not get abbreviated (clap does
    // allow this)
    如果 !options.preserve_root && !args.迭代().任意(|arg| arg == "--no-preserve-root") {
        返回 坏的(RmError::MayNotAbbreviateNoPreserveRoot.into());
    }

    如果 options.interactive == InteractiveMode::Once && (options.recursive || files.长度() > 3) {
        设 msg: 字符串 = 格式化!(
            "remove {} {}{}",
            files.长度(),
            如果 files.长度() > 1 {
                "arguments"
            } 否则 {
                "argument"
            },
            如果 options.recursive {
                " recursively?"
            } 否则 {
                "?"
            }
        );
        如果 !prompt_yes!("{msg}") {
            返回 好的(());
        }
    }

    如果 移除(&files, &options) {
        返回 坏的(1.into());
    }

    好的(())
}

