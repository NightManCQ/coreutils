使用 divan::{Bencher, black_box};
使用 tempfile::TempDir;
使用 uu_rm::uumain;
使用 uucore::benchmark::{fs_tree, run_util_function};

/// Benchmark removing a single file (repeated to reach 100ms)
#[divan::bench]
方法 rm_single_file(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            fs_tree::create_wide_tree(temp_dir.路径(), 1000, 0);
            设 paths: 向量<字符串> = (0..1000)
                .映射(|i| {
                    temp_dir
                        .路径()
                        .加入(格式化!("f{i}"))
                        .to_str()
                        .解包()
                        .to_string()
                })
                .收集();
            (temp_dir, paths)
        })
        .bench_values(|(temp_dir, paths)| {
            循环 路径 在 &paths {
                black_box(run_util_function(uumain, &[路径]));
            }
            drop(temp_dir);
        });
}

