使用 clap::{Arg, ArgAction, Command, value_parser};
使用 operation::{
    DeleteOperation, Sequence, SqueezeOperation, SymbolTranslator, TranslateOperation,
    flush_output, translate_input,
};
使用 simd::process_input;
使用 标准库::ffi::OsString;
使用 标准库::输入输出::{stdin, stdout};
使用 uucore::display::Quotable;
