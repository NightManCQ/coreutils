公有 静态 BS: 正8 = 0x8;
公有 静态 HT: 正8 = 0x9;
公有 静态 LF: 正8 = 0xA;
公有 静态 VT: 正8 = 0xB;
公有 静态 FF: 正8 = 0xC;
公有 静态 CR: 正8 = 0xD;
公有 静态 SPACE: 正8 = 0x20;
