公有 方法 translate_input<T, R, W>(input: &可变 R, output: &可变 W, 可变 translator: T) -> UResult<()>
何处
    T: SymbolTranslator,
    R: BufRead,
    W: Write,
{
    常量 BUFFER_SIZE: 正整数大小 = 32768; // Large buffer for better throughput
    设 可变 buf = [0; BUFFER_SIZE];
    设 可变 output_buf = 向量::with_capacity(BUFFER_SIZE);

    无限循环 {
        设 length = 匹配 input.读锁定(&可变 buf[..]) {
            好的(0) => 中断, // EOF reached
            好的(长度) => 长度,
            坏的(e) 如果 e.kind() == 标准库::输入输出::ErrorKind::Interrupted => 继续,
            坏的(e) => 返回 坏的(e.map_err_context(|| translate!("tr-error-read-error"))),
        };

        // Process the buffer and collect translated chars to output
        output_buf.clear();
        循环 &byte 在 &buf[..length] {
            如果 设 一些(translated) = translator.translate(byte) {
                output_buf.压入(translated);
            }
        }

        如果 !output_buf.为空() {
            箱::simd::write_output(output, &output_buf)?;
        }
    }

    好的(())
}

/// Platform-specific flush operation
#[inline]
公有 方法 flush_output<W: Write>(output: &可变 W) -> UResult<()> {
    #[cfg(not(target_os = "windows"))]
    返回 output
        .flush()
        .map_err_context(|| translate!("tr-error-write-error"));

    #[cfg(target_os = "windows")]
    匹配 output.flush() {
        好的(()) => 好的(()),
        坏的(err) 如果 err.kind() == 标准库::输入输出::ErrorKind::BrokenPipe => {
            标准库::进程::exit(13);
        }
        坏的(err) => 坏的(err.map_err_context(|| translate!("tr-error-write-error"))),
    }
}
