        // Initialize translation table with identity mapping
        设 可变 translation_table = 标准库::数组::from_fn(|i| i 转换 正8);

        如果 设 一些(fallback) = set2.最后().copied() {
            // Apply translations from set1 to set2
            循环 (from, to) 在 set1
                .into_iter()
                .zip(set2.into_iter().chain(标准库::迭代::repeat(fallback)))
            {
                translation_table[from 转换 正整数大小] = to;
            }

            好的(自身类型 { translation_table })
        } 否则 如果 set1.为空() && set2.为空() {
            // Identity mapping for empty sets
            好的(自身类型 { translation_table })
        } 否则 {
            坏的(BadSequence::EmptySet2WhenNotTruncatingSet1)
        }
    }
}

