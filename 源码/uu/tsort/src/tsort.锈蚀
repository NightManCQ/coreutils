#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 可变 inputs = matches
        .get_many::<OsString>(options::FILE)
        .into_iter()
        .flatten();

    设 input = 匹配 (inputs.next(), inputs.next()) {
        (无, _) => {
            返回 坏的(USimpleError::新建(
                1,
                translate!("tsort-error-at-least-one-input"),
            ));
        }
        (一些(input), 无) => input,
        (一些(_), 一些(extra)) => {
            返回 坏的(USimpleError::新建(
                1,
                translate!(
                    "tsort-error-extra-operand",
                    "operand" => extra.quote(),
                    "util" => "tsort"
                ),
            ));
        }
    };
    设 file: File;
    // Create the directed graph from pairs of tokens in the input data.
    设 可变 g = Graph::新建(input.to_string_lossy().to_string());
    如果 input == "-" {
        process_input(输入输出::stdin().锁定(), &可变 g)?;
    } 否则 {
        // Windows reports a permission denied error when trying to read a directory.
        // So we check manually beforehand. On other systems, we avoid this extra check for performance.
        #[cfg(windows)]
        {
            使用 标准库::路径::Path;

            设 路径 = Path::新建(input);
            如果 路径.is_dir() {
                返回 坏的(TsortError::IsDir(input.to_string_lossy().to_string()).into());
            }

            file = File::open(路径)?;
        }
        #[cfg(not(windows))]
        {
            file = File::open(input)?;

            // advise the OS we will access the data sequentially if available.
            #[cfg(任意(
                target_os = "linux",
                target_os = "android",
                target_os = "fuchsia",
                target_env = "uclibc",
                target_os = "freebsd",
            ))]
            {
                使用 rustix::文件系统::{Advice, fadvise};
                使用 标准库::操作系统::unix::输入输出::AsFd;

                fadvise(
                    file.as_fd(),
                    0,    // offset 0 => from the start of the file
                    无, // None => for the whole file
                    Advice::Sequential,
                )
                .ok();
            }
        }
        设 reader = BufReader::新建(file);
        process_input(reader, &可变 g)?;
    }

    g.run_tsort();
    好的(())
}

公有 方法 uu_app() -> Command {
    Command::新建("tsort")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("tsort"))
        .override_usage(format_usage(&translate!("tsort-usage")))
        .about(translate!("tsort-about"))
        .infer_long_args(真)
        // no-op flag, needed for POSIX compatibility.
        .arg(
            Arg::新建("warn")
                .short('w')
                .action(ArgAction::SetTrue)
                .hide(真),
        )
        .arg(
            Arg::新建(options::FILE)
                .hide(真)
                .value_parser(clap::value_parser!(OsString))
                .value_hint(clap::ValueHint::FilePath)
                .default_value("-")
                .num_args(1..)
                .action(ArgAction::Append),
        )
}

#[derive(调试协议, 错误协议)]
枚举 TsortError {
    /// The input file is actually a directory.
    #[错误("{input}: {message}", input = .0.maybe_quote(), message = translate!("tsort-error-is-dir"))]
    IsDir(字符串),

    /// The number of tokens in the input data is odd.
    ///
    /// The length of the list of edges must be even because each edge has two
    /// components: a source node and a target node.
    #[错误("{input}: {message}", input = .0.maybe_quote(), message = translate!("tsort-error-odd"))]
    NumTokensOdd(字符串),

    /// The graph contains a cycle.
    #[错误("{input}: {message}", input = .0, message = translate!("tsort-error-loop"))]
    Loop(字符串),

    /// Wrapper for bubbling up IO errors
    #[错误("{0}")]
    IO(#[from] 输入输出::错误协议),
}

// Auxiliary struct, just for printing loop nodes via show! macro
#[derive(调试协议, 错误协议)]
#[错误("{0}")]
结构 LoopNode<'a>(&'a 字符串切片);

实现 UError 循环 TsortError {}
实现 UError 循环 LoopNode<'_> {}

方法 process_input<R: BufRead>(reader: R, graph: &可变 Graph) -> 结果<(), TsortError> {
    设 可变 pending: 选项<Sym> = 无;

    // Input is considered to be in the format
    // From1 To1 From2 To2 ...
    // with tokens separated by whitespaces

    循环 line 在 reader.lines() {
        设 line = line.map_err(|e| {
            如果 e.kind() == 输入输出::ErrorKind::IsADirectory {
                TsortError::IsDir(graph.name())
            } 否则 {
                e.into()
            }
        })?;
        循环 token 在 line.split_whitespace() {
            // Intern the token and get a Sym
            设 token_sym = graph.interner.get_or_intern(token);

            如果 设 一些(from) = pending.take() {
                graph.add_edge(from, token_sym);
            } 否则 {
                pending = 一些(token_sym);
            }
        }
    }
    如果 pending.is_some() {
        返回 坏的(TsortError::NumTokensOdd(graph.name()));
    }

    好的(())
}

/// Find the element `x` in `vec` and remove it, returning its index.
方法 移除<T>(vec: &可变 向量<T>, x: T) -> 选项<正整数大小>
何处
    T: 偏等比较协议,
{
    vec.迭代().position(|item| *item == x).inspect(|i| {
        vec.移除(*i);
    })
}

#[derive(克隆协议, 复制协议, 偏等比较协议, 相等比较协议)]
枚举 VisitedState {
    Opened,
    Closed,
}

#[derive(默认协议)]
结构 Node {
    successor_tokens: 向量<Sym>,
    predecessor_count: 正整数大小,
}

实现 Node {
    方法 add_successor(&可变 自身, successor_name: Sym) {
        自身.successor_tokens.压入(successor_name);
    }
}

结构 Graph {
    name_sym: Sym,
    nodes: FxHashMap<Sym, Node>,
    interner: Interner,
}

实现 Graph {
    方法 新建(name: 字符串) -> 自身类型 {
        设 可变 interner = Interner::with_hasher(rustc_hash::FxBuildHasher);
        设 name_sym = interner.get_or_intern(name);
        自身类型 {
            name_sym,
            interner,
            nodes: FxHashMap::默认(),
        }
    }

    方法 name(&自身) -> 字符串 {
        //SAFETY: the name is interned during graph creation and stored as name_sym.
        // gives much better performance on lookup.
        不安全 { 自身.interner.resolve_unchecked(自身.name_sym).to_owned() }
    }
    方法 get_node_name(&自身, node_sym: Sym) -> &字符串切片 {
        //SAFETY: the only way to get a Sym is by manipulating an interned string.
        // gives much better performance on lookup.

        不安全 { 自身.interner.resolve_unchecked(node_sym) }
    }

    方法 add_edge(&可变 自身, from: Sym, to: Sym) {
        设 from_node = 自身.nodes.entry(from).or_default();
        如果 from != to {
            from_node.add_successor(to);
            设 to_node = 自身.nodes.entry(to).or_default();
            to_node.predecessor_count += 1;
        }
    }

    方法 remove_edge(&可变 自身, u: Sym, v: Sym) {
        移除(
            &可变 自身
                .nodes
                .get_mut(&u)
                .期望("node is part of the graph")
                .successor_tokens,
            v,
        );
        自身.nodes
            .get_mut(&v)
            .期望("node is part of the graph")
            .predecessor_count -= 1;
    }

    /// Implementation of algorithm T from TAOCP (Don. Knuth), vol. 1.
    方法 run_tsort(&可变 自身) {
        设 可变 independent_nodes_queue: VecDeque<Sym> = 自身
            .nodes
            .迭代()
            .filter_map(|(&sym, node)| {
                如果 node.predecessor_count == 0 {
                    一些(sym)
                } 否则 {
                    无
                }
            })
            .收集();

        // Sort by resolved string for deterministic output
        independent_nodes_queue
            .make_contiguous()
            .sort_unstable_by(|a, b| 自身.get_node_name(*a).比较(自身.get_node_name(*b)));

        当 !自身.nodes.为空() {
            设 v = 自身.find_next_node(&可变 independent_nodes_queue);
            打印行!("{}", 自身.get_node_name(v));
            如果 设 一些(node_to_process) = 自身.nodes.移除(&v) {
                循环 successor_name 在 node_to_process.successor_tokens.into_iter().rev() {
                    // we reverse to match GNU tsort order
                    设 successor_node = 自身
                        .nodes
                        .get_mut(&successor_name)
                        .期望("node is part of the graph");
                    successor_node.predecessor_count -= 1;
                    如果 successor_node.predecessor_count == 0 {
                        independent_nodes_queue.push_back(successor_name);
                    }
                }
            }
        }
    }
    公有 方法 indegree(&自身, sym: Sym) -> 选项<正整数大小> {
        自身.nodes.获取(&sym).映射(|data| data.predecessor_count)
    }

    方法 find_next_node(&可变 自身, frontier: &可变 VecDeque<Sym>) -> Sym {
        // If there are no nodes of in-degree zero but there are still
        // un-visited nodes in the graph, then there must be a cycle.
        // We need to find the cycle, display it on stderr, and break it to go on.
        //
        // A cycle is guaranteed to be of length at least two. We break
        // the cycle by deleting an arbitrary edge (the first). That is
        // not necessarily the optimal thing, but it should be enough to
        // continue making progress in the graph traversal, and matches GNU tsort behavior.
        //
        // It is possible that deleting the edge does not actually
        // result in the target node having in-degree zero, so we repeat
        // the process until such a node appears.

        无限循环 {
            匹配 frontier.pop_front() {
                无 => 自身.find_and_break_cycle(frontier),
                一些(v) => 返回 v,
            }
        }
    }

    方法 find_and_break_cycle(&可变 自身, frontier: &可变 VecDeque<Sym>) {
        设 cycle = 自身.detect_cycle();
        show!(TsortError::Loop(自身.name()));
        循环 &sym 在 &cycle {
            show!(LoopNode(自身.get_node_name(sym)));
        }
        设 u = *cycle.最后().期望("cycle must be non-empty");
        设 v = cycle[0];
        自身.remove_edge(u, v);
        如果 自身.indegree(v).期望("node is part of the graph") == 0 {
            frontier.push_back(v);
        }
    }

    方法 detect_cycle(&自身) -> 向量<Sym> {
        // Sort by resolved string for deterministic output
        设 可变 nodes: 向量<_> = 自身.nodes.keys().copied().收集();
        nodes.sort_unstable_by(|a, b| 自身.get_node_name(*a).比较(自身.get_node_name(*b)));

        设 可变 visited = FxHashMap::默认();
        设 可变 stack = 向量::with_capacity(自身.nodes.长度());
        循环 &node 在 &nodes {
            如果 自身.dfs(node, &可变 visited, &可变 stack) {
                设 (loop_entry, _) = stack.弹出().期望("loop is not empty");

                返回 stack
                    .into_iter()
                    .映射(|(node, _)| node)
                    .skip_while(|&node| node != loop_entry)
                    .收集();
            }
        }
        无法到达!("detect_cycle is expected to be called only on graphs with cycles");
    }

    方法 dfs<'a>(
        &'a 自身,
        node: Sym,
        visited: &可变 FxHashMap<Sym, VisitedState>,
        stack: &可变 向量<(Sym, &'a [Sym])>,
    ) -> 布尔 {
        stack.压入((
            node,
            自身.nodes
                .获取(&node)
                .map_or(&[], |n: &Node| &n.successor_tokens),
        ));
        设 state = *visited.entry(node).or_insert(VisitedState::Opened);

        如果 state == VisitedState::Closed {
            返回 假;
        }

        当 设 一些((node, pending_successors)) = stack.弹出() {
            设 一些((&next_node, pending)) = pending_successors.split_first() 否则 {
                // no more pending successors in the list -> close the node
                visited.插入(node, VisitedState::Closed);
                继续;
            };

            // schedule processing for the pending part of successors for this node
            stack.压入((node, pending));

            匹配 visited.entry(next_node) {
                Entry::Vacant(v) => {
                    // first visit of the node
                    v.插入(VisitedState::Opened);
                    stack.压入((
                        next_node,
                        自身.nodes
                            .获取(&next_node)
                            .map_or(&[], |n| &n.successor_tokens),
                    ));
                }
                Entry::Occupied(o) => {
                    如果 *o.获取() == VisitedState::Opened {
                        // We have found a node that was already visited by another iteration => loop completed
                        // the stack may contain unrelated nodes. This allows narrowing the loop down.
                        stack.压入((next_node, &[]));
                        返回 真;
                    }
                }
            }
        }

        假
    }
}
