#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 可变 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
    设 可变 config = get_config(&可变 matches)?;

    设 input_files;
    设 output_file: OsString;

    设 可变 files = matches
        .get_many::<OsString>(options::FILE)
        .into_iter()
        .flatten()
        .cloned();

    如果 config.gnu_ext {
        input_files = {
            设 可变 files = files.收集::<向量<_>>();
            如果 files.为空() {
                files.压入(OsString::from("-"));
            }
            files
        };
        output_file = OsString::from("-");
    } 否则 {
        input_files = 向量![files.next().unwrap_or(OsString::from("-"))];
        output_file = files.next().unwrap_or(OsString::from("-"));
        如果 设 一些(file) = files.next() {
            返回 坏的(UUsageError::新建(
                1,
                translate!("ptx-error-extra-operand", "operand" => file.quote()),
            ));
        }
    }

    设 word_filter = WordFilter::新建(&matches, &config)?;
    设 file_map = read_input(&input_files, &config).map_err_context(字符串::新建)?;
    设 word_set = create_word_set(&config, &word_filter, &file_map);
    write_traditional_output(&可变 config, &file_map, &word_set, &output_file)
}

