#[derive(调试协议)]
结构 WordFilter {
    only_specified: 布尔,
    ignore_specified: 布尔,
    only_set: 哈希集合<字符串>,
    ignore_set: 哈希集合<字符串>,
    word_regex: 字符串,
}

实现 WordFilter {
    #[allow(clippy::cognitive_complexity)]
    方法 新建(matches: &clap::ArgMatches, config: &Config) -> UResult<自身类型> {
        设 (o, oset): (布尔, 哈希集合<字符串>) = 如果 matches.contains_id(options::ONLY_FILE) {
            设 words =
                read_word_filter_file(matches, options::ONLY_FILE).map_err_context(字符串::新建)?;
            (真, words)
        } 否则 {
            (假, 哈希集合::新建())
        };
        设 (i, iset): (布尔, 哈希集合<字符串>) = 如果 matches.contains_id(options::IGNORE_FILE) {
            设 words = read_word_filter_file(matches, options::IGNORE_FILE)
                .map_err_context(字符串::新建)?;
            (真, words)
        } 否则 {
            (假, 哈希集合::新建())
        };
        设 break_set: 选项<哈希集合<字符>> = 如果 matches.contains_id(options::BREAK_FILE)
            && !matches.contains_id(options::WORD_REGEXP)
        {
            设 可变 chars =
                read_char_filter_file(matches, options::BREAK_FILE).map_err_context(字符串::新建)?;
            如果 !config.gnu_ext {
                // GNU off means at least these are considered
                chars.extend([' ', '\t', '\n']);
            }
            // else only chars found in file
            一些(chars)
        } 否则 {
            // if -W takes precedence or default
            无
        };
        // Ignore empty string regex from cmd-line-args
        设 arg_reg: 选项<字符串> = 如果 matches.contains_id(options::WORD_REGEXP) {
            匹配 matches.get_one::<字符串>(options::WORD_REGEXP) {
                一些(v) => {
                    如果 v.为空() {
                        无
                    } 否则 {
                        一些(v.to_owned())
                    }
                }
                无 => 无,
            }
        } 否则 {
            无
        };
        设 reg = 匹配 arg_reg {
            一些(arg_reg) => arg_reg,
            无 => {
                如果 设 一些(break_set) = break_set {
                    格式化!(
                        "[^{}]+",
                        regex::escape(&break_set.into_iter().收集::<字符串>())
                    )
                } 否则 如果 config.gnu_ext {
                    "\\w+".to_owned()
                } 否则 {
                    "[^ \t\n]+".to_owned()
                }
            }
        };
        好的(自身类型 {
            only_specified: o,
            ignore_specified: i,
            only_set: oset,
            ignore_set: iset,
            word_regex: reg,
        })
    }
}

