#[allow(clippy::unnecessary_cast)]
常量 MODE_RW_UGO: 正32 = (S_IRUSR | S_IWUSR | S_IRGRP | S_IWGRP | S_IROTH | S_IWOTH) 转换 正32;

模组 options {
    公有 常量 MODE: &字符串切片 = "mode";
    公有 常量 TYPE: &字符串切片 = "type";
    公有 常量 MAJOR: &字符串切片 = "major";
    公有 常量 MINOR: &字符串切片 = "minor";
    公有 常量 SECURITY_CONTEXT: &字符串切片 = "z";
    公有 常量 CONTEXT: &字符串切片 = "context";
}

#[derive(克隆协议, 偏等比较协议)]
枚举 FileType {
    Block,
    Character,
    Fifo,
}

实现 FileType {
    方法 as_sflag(&自身) -> SFlag {
        匹配 自身 {
            自身类型::Block => SFlag::S_IFBLK,
            自身类型::Character => SFlag::S_IFCHR,
            自身类型::Fifo => SFlag::S_IFIFO,
        }
    }
}

/// Configuration for special inode creation.
结构 Config {
    /// Permission bits for the inode
    mode: Mode,

    file_type: FileType,

    /// when false, the exact mode bits will be set
    use_umask: 布尔,

    dev: 正64,

    /// Set security context (SELinux/SMACK).
    #[cfg(任意(feature = "selinux", feature = "smack"))]
    set_security_context: 布尔,

    /// Specific security context (SELinux/SMACK).
    #[cfg(任意(feature = "selinux", feature = "smack"))]
    context: 选项<字符串>,
}

方法 mknod(file_name: &字符串切片, config: Config) -> 整32 {
    // set umask to 0 and store previous umask
    设 have_prev_umask = 如果 config.use_umask {
        无
    } 否则 {
        一些(nix_umask(Mode::empty()))
    };

    设 mknod_err = nix_mknod(
        file_name,
        config.file_type.as_sflag(),
        config.mode,
        config.dev 转换 _,
    )
    .err();
    设 errno = 如果 mknod_err.is_some() { -1 } 否则 { 0 };

    // set umask back to original value
    如果 设 一些(prev_umask) = have_prev_umask {
        nix_umask(prev_umask);
    }

    如果 设 一些(err) = mknod_err {
        错误打印行!(
            "{}: {}",
            uucore::execution_phrase(),
            标准库::输入输出::错误协议::from(err)
        );
    }

    // Apply SELinux context if requested
    #[cfg(feature = "selinux")]
    如果 config.set_security_context {
        如果 设 坏的(e) = uucore::selinux::set_selinux_security_context(
            标准库::路径::Path::新建(file_name),
            config.context.as_ref(),
        ) {
            // if it fails, delete the file
            设 _ = 标准库::文件系统::remove_file(file_name);
            使用 标准库::输入输出::{Write, stderr};
            设 _ = writeln!(stderr(), "mknod: {e}");
            返回 1;
        }
    }

    // Apply SMACK context if requested
    #[cfg(feature = "smack")]
    如果 config.set_security_context {
        如果 设 坏的(e) =
            uucore::smack::set_smack_label_and_cleanup(file_name, config.context.as_ref(), |p| {
                标准库::文件系统::remove_file(p)
            })
        {
            使用 标准库::输入输出::{Write, stderr};
            设 _ = writeln!(stderr(), "mknod: {e}");
            返回 1;
        }
    }

    errno
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 file_type = matches.get_one::<FileType>("type").解包();

    设 可变 use_umask = 真;
    设 mode_permissions = 匹配 matches.get_one::<字符串>("mode") {
        无 => MODE_RW_UGO,
        一些(str_mode) => {
            use_umask = 假;
            parse_mode(str_mode).map_err(|e| USimpleError::新建(1, e))?
        }
    };
    设 mode = Mode::from_bits_truncate(mode_permissions 转换 mode_t);

    设 file_name = matches
        .get_one::<字符串>("name")
        .期望("Missing argument 'NAME'");

    // Extract the security context related flags and options
    #[cfg(任意(feature = "selinux", feature = "smack"))]
    设 set_security_context = matches.get_flag(options::SECURITY_CONTEXT);
    #[cfg(任意(feature = "selinux", feature = "smack"))]
    设 context = matches.get_one::<字符串>(options::CONTEXT).cloned();

    设 dev = 匹配 (
        file_type,
        matches.get_one::<正32>(options::MAJOR),
        matches.get_one::<正32>(options::MINOR),
    ) {
        (FileType::Fifo, 无, 无) => 0,
        (FileType::Fifo, _, _) => {
            返回 坏的(UUsageError::新建(
                1,
                translate!("mknod-error-fifo-no-major-minor"),
            ));
        }
        (_, 一些(&major), 一些(&minor)) => makedev(major 转换 _, minor 转换 _) 转换 正64,
        _ => {
            返回 坏的(UUsageError::新建(
                1,
                translate!("mknod-error-special-require-major-minor"),
            ));
        }
    };

    设 config = Config {
        mode,
        file_type: file_type.克隆(),
        use_umask,
        dev,
        #[cfg(任意(feature = "selinux", feature = "smack"))]
        set_security_context: set_security_context || context.is_some(),
        #[cfg(任意(feature = "selinux", feature = "smack"))]
        context,
    };

    设 exit_code = mknod(file_name, config);
    set_exit_code(exit_code);
    好的(())
}

公有 方法 uu_app() -> Command {
    Command::新建("mknod")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("mknod"))
        .override_usage(format_usage(&translate!("mknod-usage")))
        .after_help(translate!("mknod-after-help"))
        .about(translate!("mknod-about"))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::MODE)
                .short('m')
                .long("mode")
                .value_name("MODE")
                .help(translate!("mknod-help-mode")),
        )
        .arg(
            Arg::新建("name")
                .value_name("NAME")
                .help(translate!("mknod-help-name"))
                .required(真)
                .value_hint(clap::ValueHint::AnyPath),
        )
        .arg(
            Arg::新建(options::TYPE)
                .value_name("TYPE")
                .help(translate!("mknod-help-type"))
                .required(真)
                .value_parser(parse_type),
        )
        .arg(
            Arg::新建(options::MAJOR)
                .value_name(options::MAJOR)
                .help(translate!("mknod-help-major"))
                .value_parser(value_parser!(正32)),
        )
        .arg(
            Arg::新建(options::MINOR)
                .value_name(options::MINOR)
                .help(translate!("mknod-help-minor"))
                .value_parser(value_parser!(正32)),
        )
        .arg(
            Arg::新建(options::SECURITY_CONTEXT)
                .short('Z')
                .help(translate!("mknod-help-selinux"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::CONTEXT)
                .long(options::CONTEXT)
                .value_name("CTX")
                .value_parser(value_parser!(字符串))
                .num_args(0..=1)
                .require_equals(真)
                .help(translate!("mknod-help-context")),
        )
}

方法 parse_mode(str_mode: &字符串切片) -> 结果<正32, 字符串> {
    设 default_mode = MODE_RW_UGO;
    uucore::mode::parse_chmod(default_mode, str_mode, 真, uucore::mode::get_umask())
        .map_err(|e| {
            translate!(
                "mknod-error-invalid-mode",
                "error" => e
            )
        })
        .and_then(|mode| {
            如果 mode > 0o777 {
                坏的(translate!("mknod-error-mode-permission-bits-only"))
            } 否则 {
                好的(mode)
            }
        })
}

方法 parse_type(tpe: &字符串切片) -> 结果<FileType, 字符串> {
    // Only check the first character, to allow mnemonic usage like
    // 'mknod /dev/rst0 character 18 0'.
    tpe.chars()
        .next()
        .ok_or_else(|| translate!("mknod-error-missing-device-type"))
        .and_then(|first_char| 匹配 first_char {
            'b' => 好的(FileType::Block),
            'c' | 'u' => 好的(FileType::Character),
            'p' => 好的(FileType::Fifo),
            _ => 坏的(translate!("mknod-error-invalid-device-type", "type" => tpe.quote())),
        })
}
