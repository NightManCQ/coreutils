模组 options {
    公有 常量 COLUMN_1: &字符串切片 = "1";
    公有 常量 COLUMN_2: &字符串切片 = "2";
    公有 常量 COLUMN_3: &字符串切片 = "3";
    公有 常量 DELIMITER: &字符串切片 = "output-delimiter";
    公有 常量 DELIMITER_DEFAULT: &字符串切片 = "\t";
    公有 常量 FILE_1: &字符串切片 = "FILE1";
    公有 常量 FILE_2: &字符串切片 = "FILE2";
    公有 常量 TOTAL: &字符串切片 = "total";
    公有 常量 ZERO_TERMINATED: &字符串切片 = "zero-terminated";
    公有 常量 CHECK_ORDER: &字符串切片 = "check-order";
    公有 常量 NO_CHECK_ORDER: &字符串切片 = "nocheck-order";
}

#[derive(调试协议, 克隆协议, 复制协议)]
枚举 FileNumber {
    One,
    Two,
}

实现 FileNumber {
    方法 as_str(自身) -> &'静态 字符串切片 {
        匹配 自身 {
            自身类型::One => "1",
            自身类型::Two => "2",
        }
    }
}

结构 OrderChecker {
    last_line: 向量<正8>,
    file_num: FileNumber,
    check_order: 布尔,
    has_error: 布尔,
}

枚举 Input {
    Stdin(StdinLock<'静态>),
    FileIn(BufReader<File>),
}

实现 Input {
    方法 stdin() -> 自身类型 {
        自身类型::Stdin(stdin().锁定())
    }

    方法 from_file(f: File) -> 自身类型 {
        自身类型::FileIn(BufReader::新建(f))
    }
}

结构 LineReader {
    line_ending: LineEnding,
    input: Input,
}

实现 LineReader {
    方法 新建(input: Input, line_ending: LineEnding) -> 自身类型 {
        自身类型 { line_ending, input }
    }

    方法 read_line(&可变 自身, buf: &可变 向量<正8>) -> 输入输出::结果<正整数大小> {
        设 line_ending = 自身.line_ending.into();

        设 result = 匹配 &可变 自身.input {
            Input::Stdin(r) => r.read_until(line_ending, buf),
            Input::FileIn(r) => r.read_until(line_ending, buf),
        };

        如果 !buf.ends_with(&[line_ending]) {
            buf.压入(line_ending);
        }

        result
    }
}

实现 OrderChecker {
    方法 新建(file_num: FileNumber, check_order: 布尔) -> 自身类型 {
        自身类型 {
            last_line: 向量::新建(),
            file_num,
            check_order,
            has_error: 假,
        }
    }

    方法 verify_order(&可变 自身, current_line: &[正8]) -> 布尔 {
        如果 自身.last_line.为空() {
            自身.last_line = current_line.to_vec();
            返回 真;
        }

        设 is_ordered = *current_line >= *自身.last_line;
        如果 !is_ordered && !自身.has_error {
            设 _ = writeln!(
                stderr(),
                "{}",
                translate!("comm-error-file-not-sorted", "file_num" => 自身.file_num.as_str())
            );
            自身.has_error = 真;
        }

        自身.last_line = current_line.to_vec();
        is_ordered || !自身.check_order
    }
}

// Check if two files are identical by comparing their contents
公有 方法 are_files_identical(path1: &Path, path2: &Path) -> 输入输出::结果<布尔> {
    // First compare file sizes
    设 metadata1 = metadata(path1)?;
    设 metadata2 = metadata(path2)?;

    如果 metadata1.长度() != metadata2.长度() {
        返回 好的(假);
    }

    // only proceed if both are regular files
    如果 !metadata1.is_file() || !metadata2.is_file() {
        返回 好的(假);
    }

    设 file1 = File::open(path1)?;
    设 file2 = File::open(path2)?;

    设 可变 reader1 = BufReader::新建(file1);
    设 可变 reader2 = BufReader::新建(file2);

    设 可变 buffer1 = [0; 8192];
    设 可变 buffer2 = [0; 8192];

    无限循环 {
        // Read from first file with EINTR retry handling
        // This loop retries the read operation if it's interrupted by signals (e.g., SIGUSR1)
        // instead of failing, which is the POSIX-compliant way to handle interrupted I/O
        设 bytes1 = 无限循环 {
            匹配 reader1.读锁定(&可变 buffer1) {
                坏的(e) 如果 e.kind() == 输入输出::ErrorKind::Interrupted => {}
                result => 中断 result?,
            }
        };

        // Read from second file with EINTR retry handling
        // Same retry logic as above for the second file to ensure consistent behavior
        设 bytes2 = 无限循环 {
            匹配 reader2.读锁定(&可变 buffer2) {
                坏的(e) 如果 e.kind() == 输入输出::ErrorKind::Interrupted => {}
                result => 中断 result?,
            }
        };

        如果 bytes1 != bytes2 {
            返回 好的(假);
        }

        如果 bytes1 == 0 {
            返回 好的(真);
        }

        如果 buffer1[..bytes1] != buffer2[..bytes2] {
            返回 好的(假);
        }
    }
}

方法 write_line_with_delimiter<W: Write>(writer: &可变 W, delim: &[正8], line: &[正8]) -> UResult<()> {
    writer
        .write_all(delim)
        .map_err_context(|| translate!("comm-error-write"))?;
    writer
        .write_all(line)
        .map_err_context(|| translate!("comm-error-write"))?;
    好的(())
}

方法 comm(
    a: &可变 LineReader,
    b: &可变 LineReader,
    filename1: &OsString,
    filename2: &OsString,
    delim: &字符串切片,
    opts: &ArgMatches,
) -> UResult<()> {
    设 width_col_1 = 正整数大小::from(!opts.get_flag(options::COLUMN_1));
    设 width_col_2 = 正整数大小::from(!opts.get_flag(options::COLUMN_2));

    设 delim_col_2 = delim.repeat(width_col_1);
    设 delim_col_3 = delim.repeat(width_col_1 + width_col_2);

    设 可变 writer = BufWriter::新建(输入输出::stdout().锁定());

    设 ra = &可变 向量::新建();
    设 可变 na = a
        .read_line(ra)
        .map_err_context(|| filename1.maybe_quote().to_string())?;
    设 rb = &可变 向量::新建();
    设 可变 nb = b
        .read_line(rb)
        .map_err_context(|| filename2.maybe_quote().to_string())?;

    设 可变 total_col_1 = 0;
    设 可变 total_col_2 = 0;
    设 可变 total_col_3 = 0;

    设 check_order = opts.get_flag(options::CHECK_ORDER);
    设 no_check_order = opts.get_flag(options::NO_CHECK_ORDER);

    // Determine if we should perform order checking
    设 should_check_order = !no_check_order
        && (check_order
            || !(paths_refer_to_same_file(filename1.as_os_str(), filename2.as_os_str(), 真)
                || are_files_identical(Path::新建(filename1), Path::新建(filename2))
                    .unwrap_or(假)));

    设 可变 checker1 = OrderChecker::新建(FileNumber::One, check_order);
    设 可变 checker2 = OrderChecker::新建(FileNumber::Two, check_order);
    设 可变 input_error = 假;

    当 na != 0 || nb != 0 {
        设 ord = 匹配 (na, nb) {
            (0, _) => 排序顺序::Greater,
            (_, 0) => 排序顺序::Less,
            (_, _) => ra.as_slice().比较(rb.as_slice()),
        };

        匹配 ord {
            排序顺序::Less => {
                如果 should_check_order && !checker1.verify_order(ra) {
                    中断;
                }
                如果 !opts.get_flag(options::COLUMN_1) {
                    writer
                        .write_all(ra)
                        .map_err_context(|| translate!("comm-error-write"))?;
                }
                ra.clear();
                na = a
                    .read_line(ra)
                    .map_err_context(|| filename1.maybe_quote().to_string())?;
                total_col_1 += 1;
            }
            排序顺序::Greater => {
                如果 should_check_order && !checker2.verify_order(rb) {
                    中断;
                }
                如果 !opts.get_flag(options::COLUMN_2) {
                    write_line_with_delimiter(&可变 writer, delim_col_2.as_bytes(), rb)?;
                }
                rb.clear();
                nb = b
                    .read_line(rb)
                    .map_err_context(|| filename2.maybe_quote().to_string())?;
                total_col_2 += 1;
            }
            排序顺序::Equal => {
                如果 should_check_order && (!checker1.verify_order(ra) || !checker2.verify_order(rb))
                {
                    中断;
                }
                如果 !opts.get_flag(options::COLUMN_3) {
                    write_line_with_delimiter(&可变 writer, delim_col_3.as_bytes(), ra)?;
                }
                ra.clear();
                rb.clear();
                na = a
                    .read_line(ra)
                    .map_err_context(|| filename1.maybe_quote().to_string())?;
                nb = b
                    .read_line(rb)
                    .map_err_context(|| filename2.maybe_quote().to_string())?;
                total_col_3 += 1;
            }
        }

        // Track if we've seen any order errors
        如果 (checker1.has_error || checker2.has_error) && !input_error && !check_order {
            input_error = 真;
        }
    }

    如果 opts.get_flag(options::TOTAL) {
        设 line_ending = LineEnding::from_zero_flag(opts.get_flag(options::ZERO_TERMINATED));
        write!(
            writer,
            "{total_col_1}{delim}{total_col_2}{delim}{total_col_3}{delim}{}{line_ending}",
            translate!("comm-total")
        )
        .map_err_context(|| translate!("comm-error-write"))?;
    }

    writer
        .flush()
        .map_err_context(|| translate!("comm-error-write"))?;

    如果 should_check_order && (checker1.has_error || checker2.has_error) {
        // Print the input error message once at the end
        如果 input_error {
            设 _ = writeln!(stderr(), "{}", translate!("comm-error-input-not-sorted"));
        }
        坏的(USimpleError::新建(1, ""))
    } 否则 {
        好的(())
    }
}

方法 open_file(name: &OsString, line_ending: LineEnding) -> 输入输出::结果<LineReader> {
    如果 name == "-" {
        好的(LineReader::新建(Input::stdin(), line_ending))
    } 否则 {
        如果 metadata(name)?.is_dir() {
            返回 坏的(输入输出::错误协议::other(translate!("comm-error-is-directory")));
        }
        设 f = File::open(name)?;
        好的(LineReader::新建(Input::from_file(f), line_ending))
    }
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
    设 line_ending = LineEnding::from_zero_flag(matches.get_flag(options::ZERO_TERMINATED));
    设 filename1 = matches.get_one::<OsString>(options::FILE_1).解包();
    设 filename2 = matches.get_one::<OsString>(options::FILE_2).解包();
    设 可变 f1 = open_file(filename1, line_ending)
        .map_err_context(|| filename1.maybe_quote().to_string())?;
    设 可变 f2 = open_file(filename2, line_ending)
        .map_err_context(|| filename2.maybe_quote().to_string())?;

    // Due to default_value(), there must be at least one value here, thus unwrap() must not panic.
    设 all_delimiters = matches
        .get_many::<字符串>(options::DELIMITER)
        .解包()
        .映射(字符串::from)
        .收集::<向量<_>>();
    循环 delim 在 &all_delimiters[1..] {
        // Note that this check is very different from ".conflicts_with_self(true).action(ArgAction::Set)",
        // as this accepts duplicate *identical* arguments.
        如果 delim != &all_delimiters[0] {
            // Note: This intentionally deviate from the GNU error message by inserting the word "conflicting".
            返回 坏的(USimpleError::新建(
                1,
                translate!("comm-error-multiple-conflicting-delimiters"),
            ));
        }
    }
    设 delim = 匹配 &*all_delimiters[0] {
        "" => "\0",
        delim => delim,
    };

    comm(&可变 f1, &可变 f2, filename1, filename2, delim, &matches)
}

公有 方法 uu_app() -> Command {
    Command::新建("comm")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("comm"))
        .about(translate!("comm-about"))
        .override_usage(format_usage(&translate!("comm-usage")))
        .infer_long_args(真)
        .args_override_self(真)
        .arg(
            Arg::新建(options::COLUMN_1)
                .short('1')
                .help(translate!("comm-help-column-1"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::COLUMN_2)
                .short('2')
                .help(translate!("comm-help-column-2"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::COLUMN_3)
                .short('3')
                .help(translate!("comm-help-column-3"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::DELIMITER)
                .long(options::DELIMITER)
                .help(translate!("comm-help-delimiter"))
                .value_name("STR")
                .default_value(options::DELIMITER_DEFAULT)
                .allow_hyphen_values(真)
                .action(ArgAction::Append)
                .hide_default_value(真),
        )
        .arg(
            Arg::新建(options::ZERO_TERMINATED)
                .long(options::ZERO_TERMINATED)
                .short('z')
                .overrides_with(options::ZERO_TERMINATED)
                .help(translate!("comm-help-zero-terminated"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::FILE_1)
                .required(真)
                .value_hint(clap::ValueHint::FilePath)
                .value_parser(clap::value_parser!(OsString)),
        )
        .arg(
            Arg::新建(options::FILE_2)
                .required(真)
                .value_hint(clap::ValueHint::FilePath)
                .value_parser(clap::value_parser!(OsString)),
        )
        .arg(
            Arg::新建(options::TOTAL)
                .long(options::TOTAL)
                .help(translate!("comm-help-total"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::CHECK_ORDER)
                .long(options::CHECK_ORDER)
                .help(translate!("comm-help-check-order"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::NO_CHECK_ORDER)
                .long(options::NO_CHECK_ORDER)
                .help(translate!("comm-help-no-check-order"))
                .action(ArgAction::SetTrue)
                .conflicts_with(options::CHECK_ORDER),
        )
}
