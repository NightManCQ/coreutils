方法 stty(opts: &Options) -> UResult<()> {
    如果 opts.save && opts.全部 {
        返回 坏的(USimpleError::新建(
            1,
            translate!("stty-error-options-mutually-exclusive"),
        ));
    }

    如果 opts.settings.is_some() && (opts.save || opts.全部) {
        返回 坏的(USimpleError::新建(
            1,
            translate!("stty-error-output-style-no-modes"),
        ));
    }

    设 可变 set_arg = SetArg::TCSADRAIN;
    设 可变 valid_args: 向量<ArgOptions> = 向量::新建();

    如果 设 一些(args) = &opts.settings {
        设 可变 args_iter = args.迭代();
        当 设 一些(&arg) = args_iter.next() {
            匹配 arg {
                "ispeed" => 匹配 args_iter.next() {
                    一些(speed) => {
                        如果 设 一些(baud_flag) = string_to_baud(speed, flags::BaudType::Input) {
                            valid_args.压入(ArgOptions::Flags(baud_flag));
                        } 否则 {
                            返回 invalid_speed(arg, speed);
                        }
                    }
                    无 => {
                        返回 missing_arg(arg);
                    }
                },
                "ospeed" => 匹配 args_iter.next() {
                    一些(speed) => {
                        如果 设 一些(baud_flag) = string_to_baud(speed, flags::BaudType::Output) {
                            valid_args.压入(ArgOptions::Flags(baud_flag));
                        } 否则 {
                            返回 invalid_speed(arg, speed);
                        }
                    }
                    无 => {
                        返回 missing_arg(arg);
                    }
                },
                "line" => 匹配 args_iter.next() {
                    一些(line) => 匹配 parse_u8_or_err(line) {
                        好的(n) => valid_args.压入(ArgOptions::Special(SpecialSetting::Line(n))),
                        坏的(e) => 返回 坏的(USimpleError::新建(1, e)),
                    },
                    无 => {
                        返回 missing_arg(arg);
                    }
                },
                "min" => 匹配 args_iter.next() {
                    一些(min) => 匹配 parse_u8_or_err(min) {
                        好的(n) => {
                            valid_args.压入(ArgOptions::Mapping((S::VMIN, n)));
                        }
                        坏的(e) => 返回 坏的(USimpleError::新建(1, e)),
                    },
                    无 => {
                        返回 missing_arg(arg);
                    }
                },
                "time" => 匹配 args_iter.next() {
                    一些(时间) => 匹配 parse_u8_or_err(时间) {
                        好的(n) => valid_args.压入(ArgOptions::Mapping((S::VTIME, n))),
                        坏的(e) => 返回 坏的(USimpleError::新建(1, e)),
                    },
                    无 => {
                        返回 missing_arg(arg);
                    }
                },
                "rows" => {
                    如果 设 一些(rows) = args_iter.next() {
                        如果 设 一些(n) = parse_rows_cols(rows) {
                            valid_args.压入(ArgOptions::Special(SpecialSetting::Rows(n)));
                        } 否则 {
                            返回 invalid_integer_arg(rows);
                        }
                    } 否则 {
                        返回 missing_arg(arg);
                    }
                }
                "columns" | "cols" => {
                    如果 设 一些(cols) = args_iter.next() {
                        如果 设 一些(n) = parse_rows_cols(cols) {
                            valid_args.压入(ArgOptions::Special(SpecialSetting::Cols(n)));
                        } 否则 {
                            返回 invalid_integer_arg(cols);
                        }
                    } 否则 {
                        返回 missing_arg(arg);
                    }
                }
                "drain" => {
                    set_arg = SetArg::TCSADRAIN;
                }
                "-drain" => {
                    set_arg = SetArg::TCSANOW;
                }
                "size" => {
                    valid_args.压入(ArgOptions::Print(PrintSetting::Size));
                }
                _ => {
                    // Try to parse saved format (hex string like "6d02:5:4bf:8a3b:...")
                    如果 设 一些(state) = parse_saved_state(arg) {
                        valid_args.压入(ArgOptions::SavedState(state));
                    }
                    // control char
                    否则 如果 设 一些(char_index) = cc_to_index(arg) {
                        如果 设 一些(mapping) = args_iter.next() {
                            设 cc_mapping = string_to_control_char(mapping).map_err(|e| {
                                设 message = 匹配 e {
                                    ControlCharMappingError::IntOutOfRange(val) => {
                                        translate!(
                                            "stty-error-invalid-integer-argument-value-too-large",
                                            "value" => 格式化!("'{val}'")
                                        )
                                    }
                                    ControlCharMappingError::MultipleChars(val) => {
                                        translate!(
                                            "stty-error-invalid-integer-argument",
                                            "value" => 格式化!("'{val}'")
                                        )
                                    }
                                };
                                UUsageError::新建(1, message)
                            })?;
                            valid_args.压入(ArgOptions::Mapping((char_index, cc_mapping)));
                        } 否则 {
                            返回 missing_arg(arg);
                        }
                    // baud rate
                    } 否则 如果 设 一些(baud_flag) = string_to_baud(arg, flags::BaudType::Both) {
                        valid_args.压入(ArgOptions::Flags(baud_flag));
                    // non control char flag
                    } 否则 如果 设 一些(flag) = string_to_flag(arg) {
                        设 remove_group = 匹配 flag {
                            AllFlags::Baud(_, _) => 假,
                            AllFlags::ControlFlags((flag, 移除)) => {
                                check_flag_group(flag, 移除)
                            }
                            AllFlags::InputFlags((flag, 移除)) => check_flag_group(flag, 移除),
                            AllFlags::LocalFlags((flag, 移除)) => check_flag_group(flag, 移除),
                            AllFlags::OutputFlags((flag, 移除)) => check_flag_group(flag, 移除),
                        };
                        如果 remove_group {
                            返回 invalid_arg(arg);
                        }
                        valid_args.压入(flag.into());
                    // combination setting
                    } 否则 如果 设 一些(combo) = string_to_combo(arg) {
                        valid_args.append(&可变 combo_to_flags(combo));
                    } 否则 {
                        返回 invalid_arg(arg);
                    }
                }
            }
        }

        设 可变 termios =
            tcgetattr(opts.file.as_fd()).map_err_context(|| opts.device_name.克隆())?;

        // iterate over valid_args, match on the arg type, do the matching apply function
        循环 arg 在 &valid_args {
            匹配 arg {
                ArgOptions::Mapping(mapping) => apply_char_mapping(&可变 termios, mapping),
                ArgOptions::Flags(flag) => apply_setting(&可变 termios, flag)?,
                ArgOptions::Special(setting) => {
                    apply_special_setting(&可变 termios, setting, opts.file.as_raw_fd())?;
                }
                ArgOptions::Print(setting) => {
                    print_special_setting(setting, opts.file.as_raw_fd())?;
                }
                ArgOptions::SavedState(state) => {
                    apply_saved_state(&可变 termios, state);
                }
            }
        }
        tcsetattr(opts.file.as_fd(), set_arg, &termios)?;
    } 否则 {
        设 termios = tcgetattr(opts.file.as_fd()).map_err_context(|| opts.device_name.克隆())?;
        print_settings(&termios, opts)?;
    }
    好的(())
}

