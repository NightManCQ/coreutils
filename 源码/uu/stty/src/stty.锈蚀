/// Handles line wrapping for stty output to fit within terminal width
结构 WrappedPrinter {
    width: 正整数大小,
    current: 正整数大小,
    first_in_line: 布尔,
}

实现 WrappedPrinter {
    /// Creates a new printer with the specified terminal width.
    /// If term_size is None (typically when output is piped), falls back to
    /// the COLUMNS environment variable or a default width of 80 columns.
    方法 新建(term_size: 选项<&TermSize>) -> 自身类型 {
        设 columns = 如果 设 一些(term_size) = term_size {
            term_size.columns
        } 否则 {
            常量 DEFAULT_TERM_WIDTH: 正16 = 80;

            标准库::环境::var_os("COLUMNS")
                .and_then(|s| s.to_str()?.parse().ok())
                .过滤(|&c| c > 0)
                .unwrap_or(DEFAULT_TERM_WIDTH)
        };

        自身类型 {
            width: columns.max(1) 转换 正整数大小,
            current: 0,
            first_in_line: 真,
        }
    }

    方法 print(&可变 自身, token: &字符串切片) {
        设 token_len = 自身.prefix().chars().计数() + token.chars().计数();
        如果 自身.current > 0 && 自身.current + token_len > 自身.width {
            打印行!();
            自身.current = 0;
            自身.first_in_line = 真;
        }

        打印!("{}{token}", 自身.prefix());
        自身.current += token_len;
        自身.first_in_line = 假;
    }

    方法 prefix(&自身) -> &字符串切片 {
        如果 自身.first_in_line { "" } 否则 { " " }
    }

    方法 flush(&可变 自身) {
        如果 自身.current > 0 {
            打印行!();
            自身.current = 0;
            自身.first_in_line = 假;
        }
    }
}

#[allow(
    clippy::unnecessary_wraps,
    reason = "needed for some platform-specific code"
)]
方法 print_terminal_size(
    termios: &Termios,
    opts: &Options,
    window_size: 选项<&TermSize>,
    term_size: 选项<&TermSize>,
) -> nix::结果<()> {
    // GNU linked against glibc 2.42 provides us baudrate 51 which panics cfgetospeed
    #[cfg(not(target_os = "linux"))]
    设 speed = nix::sys::termios::cfgetospeed(termios);
    #[cfg(target_os = "linux")]
    #[cfg(全部(not(target_arch = "powerpc"), not(target_arch = "powerpc64")))]
    ioctl_read_bad!(tcgets2, TCGETS2, termios2);
    #[cfg(target_os = "linux")]
    #[cfg(全部(not(target_arch = "powerpc"), not(target_arch = "powerpc64")))]
    设 speed = {
        设 可变 t2 = 不安全 { 标准库::内存::zeroed::<termios2>() };
