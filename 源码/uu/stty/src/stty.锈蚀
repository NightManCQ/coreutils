/// GNU stty defines some valid values for the control character mappings
/// 1. Standard character, can be a a single char (ie 'C') or hat notation (ie '^C')
/// 2. Integer
///    a. hexadecimal, prefixed by '0x'
///    b. octal, prefixed by '0'
///    c. decimal, no prefix
/// 3. Disabling the control character: '^-' or 'undef'
///
/// This function returns the ascii value of valid control chars, or [`ControlCharMappingError`] if invalid
方法 string_to_control_char(s: &字符串切片) -> 结果<正8, ControlCharMappingError> {
    如果 s == "undef" || s == "^-" || s.为空() {
        返回 好的(0);
    }

    // try to parse integer (hex, octal, or decimal)
    设 ascii_num = 如果 设 一些(hex) = s.strip_prefix("0x") {
        正32::from_str_radix(hex, 16).ok()
    } 否则 如果 设 一些(octal) = s.strip_prefix("0") {
        如果 octal.为空() {
            一些(0)
        } 否则 {
            正32::from_str_radix(octal, 8).ok()
        }
    } 否则 {
        s.parse::<正32>().ok()
    };

    如果 设 一些(val) = ascii_num {
        如果 val > 255 {
            返回 坏的(ControlCharMappingError::IntOutOfRange(s.to_string()));
        }
        返回 好的(val 转换 正8);
    }
    // try to parse ^<char> or just <char>
    设 可变 chars = s.chars();
    匹配 (chars.next(), chars.next()) {
        (一些('^'), 一些(c)) => {
            // special case: ascii value of '^?' is greater than '?'
            如果 c == '?' {
                返回 好的(ASCII_DEL);
            }
            // subtract by '@' to turn the char into the ascii value of '^<char>'
            好的((c.to_ascii_uppercase() 转换 正8).wrapping_sub(b'@'))
        }
        (一些(c), 无) => 好的(c 转换 正8),
        (一些(_), 一些(_)) => 坏的(ControlCharMappingError::MultipleChars(s.to_string())),
        _ => 无法到达!("No arguments provided: must have been caught earlier"),
    }
}

// decomposes a combination argument into a vec of corresponding flags
方法 combo_to_flags(combo: &字符串切片) -> 向量<ArgOptions<'_>> {
    设 可变 flags = 向量::新建();
    设 可变 ccs = 向量::新建();
    匹配 combo {
        "lcase" | "LCASE" => {
            flags = 向量!["xcase", "iuclc", "olcuc"];
        }
        "-lcase" | "-LCASE" => {
            flags = 向量!["-xcase", "-iuclc", "-olcuc"];
        }
        "cbreak" => {
            flags = 向量!["-icanon"];
        }
        "-cbreak" => {
            flags = 向量!["icanon"];
        }
        "cooked" | "-raw" => {
            flags = 向量![
                "brkint", "ignpar", "istrip", "icrnl", "ixon", "opost", "isig", "icanon",
            ];
            ccs = 向量![(S::VEOF, "^D"), (S::VEOL, "")];
        }
        "crt" => {
            flags = 向量!["echoe", "echoctl", "echoke"];
        }
        "dec" => {
            flags = 向量!["echoe", "echoctl", "echoke", "-ixany"];
            ccs = 向量![(S::VINTR, "^C"), (S::VERASE, "^?"), (S::VKILL, "^U")];
        }
        "decctlq" => {
            flags = 向量!["ixany"];
        }
        "-decctlq" => {
            flags = 向量!["-ixany"];
        }
        "ek" => {
            ccs = 向量![(S::VERASE, "^?"), (S::VKILL, "^U")];
        }
        "evenp" | "parity" => {
            flags = 向量!["parenb", "-parodd", "cs7"];
        }
        "-evenp" | "-parity" => {
            flags = 向量!["-parenb", "cs8"];
        }
        "litout" => {
            flags = 向量!["-parenb", "-istrip", "-opost", "cs8"];
        }
        "-litout" => {
            flags = 向量!["parenb", "istrip", "opost", "cs7"];
        }
        "nl" => {
            flags = 向量!["-icrnl", "-onlcr"];
        }
        "-nl" => {
            flags = 向量!["icrnl", "-inlcr", "-igncr", "onlcr", "-ocrnl", "-onlret"];
        }
        "oddp" => {
            flags = 向量!["parenb", "parodd", "cs7"];
        }
        "-oddp" => {
            flags = 向量!["-parenb", "cs8"];
        }
        "pass8" => {
            flags = 向量!["-parenb", "-istrip", "cs8"];
        }
        "-pass8" => {
            flags = 向量!["parenb", "istrip", "cs7"];
        }
        "raw" | "-cooked" => {
            flags = 向量![
                "-ignbrk", "-brkint", "-ignpar", "-parmrk", "-inpck", "-istrip", "-inlcr",
                "-igncr", "-icrnl", "-ixon", "-ixoff", "-icanon", "-opost", "-isig", "-iuclc",
                "-xcase", "-ixany", "-imaxbel",
            ];
            ccs = 向量![(S::VMIN, "1"), (S::VTIME, "0")];
        }
        "sane" => {
            flags = 向量![
                "cread", "-ignbrk", "brkint", "-inlcr", "-igncr", "icrnl", "icanon", "iexten",
                "echo", "echoe", "echok", "-echonl", "-noflsh", "-ixoff", "-iutf8", "-iuclc",
                "-xcase", "-ixany", "imaxbel", "-olcuc", "-ocrnl", "opost", "-ofill", "onlcr",
                "-onocr", "-onlret", "nl0", "cr0", "tab0", "bs0", "vt0", "ff0", "isig", "-tostop",
                "-ofdel", "-echoprt", "echoctl", "echoke", "-extproc", "-flusho",
            ];
            ccs = 向量![
                (S::VINTR, "^C"),
                (S::VQUIT, "^\\"),
                (S::VERASE, "^?"),
                (S::VKILL, "^U"),
                (S::VEOF, "^D"),
                (S::VEOL, ""),
                (S::VEOL2, ""),
                #[cfg(target_os = "linux")]
                (S::VSWTC, ""),
                (S::VSTART, "^Q"),
                (S::VSTOP, "^S"),
                (S::VSUSP, "^Z"),
                (S::VREPRINT, "^R"),
                (S::VWERASE, "^W"),
                (S::VLNEXT, "^V"),
                (S::VDISCARD, "^O"),
            ];
        }
        _ => 无法到达!("invalid combination setting: must have been caught earlier"),
    }
    设 可变 flags = flags
        .迭代()
        .filter_map(|f| string_to_flag(f).映射(ArgOptions::Flags))
        .收集::<向量<ArgOptions>>();
    设 可变 ccs = ccs
        .迭代()
        .映射(|cc| ArgOptions::Mapping((cc.0, string_to_control_char(cc.1).解包())))
        .收集::<向量<ArgOptions>>();
    flags.append(&可变 ccs);
    flags
}

