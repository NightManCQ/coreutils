方法 control_char_to_string(cc: nix::libc::cc_t) -> nix::结果<字符串> {
    如果 cc == 0 {
        返回 好的(translate!("stty-output-undef"));
    }

    设 (meta_prefix, code) = 如果 cc >= 0x80 {
        ("M-", cc - 0x80)
    } 否则 {
        ("", cc)
    };

    // Determine the '^'-prefix if applicable and character based on the code
    设 (ctrl_prefix, character) = 匹配 code {
        // Control characters in ASCII range
        0..=0x1f => 好的(("^", (b'@' + code) 转换 字符)),
        // Printable ASCII characters
        0x20..=0x7e => 好的(("", code 转换 字符)),
        // DEL character
        0x7f => 好的(("^", '?')),
        // Out of range (above 8 bits)
        _ => 坏的(nix::errno::Errno::ERANGE),
    }?;

    好的(格式化!("{meta_prefix}{ctrl_prefix}{character}"))
}

