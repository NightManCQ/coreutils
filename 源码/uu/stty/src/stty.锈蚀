    设 normalized = arg.trim().trim_start_matches('+');
    设 normalized = normalized.strip_suffix('.').unwrap_or(normalized);
    设 value = parse_baud_with_rounding(normalized)?;

    // BSDs use a u32 for the baud rate, so any decimal number applies.
    #[cfg(bsd)]
    返回 一些(AllFlags::Baud(value, baud_type));

    #[cfg(not(bsd))]
    {
