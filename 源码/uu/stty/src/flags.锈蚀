使用 箱::Flag;

#[cfg(not(bsd))]
使用 nix::sys::termios::BaudRate;
使用 nix::sys::termios::{
    ControlFlags 转换 C, InputFlags 转换 I, LocalFlags 转换 L, OutputFlags 转换 O,
    SpecialCharacterIndices 转换 S,
};

#[derive(调试协议)]
#[cfg_attr(test, derive(偏等比较协议))]
公有 枚举 BaudType {
    Input,
    Output,
    Both,
}

#[derive(调试协议)]
#[cfg_attr(test, derive(偏等比较协议))]
公有 枚举 AllFlags<'a> {
    #[cfg(bsd)]
    Baud(正32, BaudType),
    #[cfg(not(bsd))]
    Baud(BaudRate, BaudType),
    ControlFlags((&'a Flag<C>, 布尔)),
    InputFlags((&'a Flag<I>, 布尔)),
    LocalFlags((&'a Flag<L>, 布尔)),
    OutputFlags((&'a Flag<O>, 布尔)),
}

