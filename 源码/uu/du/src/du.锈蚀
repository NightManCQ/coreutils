实现 Stat {
    方法 新建(
        路径: &Path,
        dir_entry: 选项<&DirEntry>,
        options: &TraversalOptions,
    ) -> 标准库::输入输出::结果<自身类型> {
        // Determine whether to dereference (follow) the symbolic link
        设 should_dereference = 匹配 &options.dereference {
            Deref::All => 真,
            Deref::Args(paths) => paths.包含(&路径.to_path_buf()),
            Deref::无 => 假,
        };

        设 metadata = 如果 should_dereference {
            // Get metadata, following symbolic links if necessary
            文件系统::metadata(路径)
        } 否则 如果 设 一些(dir_entry) = dir_entry {
            // Get metadata directly from the DirEntry, which is faster on Windows
            dir_entry.metadata()
        } 否则 {
            // Get metadata from the filesystem without following symbolic links
            文件系统::symlink_metadata(路径)
        }?;

        设 file_info = get_file_info(路径, &metadata);
        设 blocks = get_blocks(路径, &metadata);

        好的(自身类型 {
            路径: 路径.to_path_buf(),
            size: 如果 metadata.is_dir() { 0 } 否则 { metadata.长度() },
            blocks,
            inodes: 1,
            inode: file_info,
            metadata,
        })
    }

    /// Create a Stat using safe traversal methods with `DirFd` for the root directory
    #[cfg(全部(unix, not(target_os = "redox")))]
    方法 new_from_dirfd(dir_fd: &DirFd, full_path: &Path) -> 标准库::输入输出::结果<自身类型> {
        // Get metadata for the directory itself using fstat
        设 safe_metadata = dir_fd.metadata()?;

        // Create file info from the safe metadata
        设 file_info = safe_metadata.file_info();
        设 file_info_option = 一些(FileInfo {
            file_id: file_info.inode() 转换 正128,
            dev_id: file_info.device(),
        });

        设 blocks = safe_metadata.blocks();

        // Create a temporary std::fs::Metadata by reading the same path
        // This is still needed for compatibility but should work since we're dealing with
        // the root path which should be accessible
        设 std_metadata = 文件系统::symlink_metadata(full_path)?;

        好的(自身类型 {
            路径: full_path.to_path_buf(),
            size: 如果 safe_metadata.is_dir() {
                0
            } 否则 {
                safe_metadata.长度()
            },
            blocks,
            inodes: 1,
            inode: file_info_option,
            metadata: std_metadata,
        })
    }
}

#[cfg(not(windows))]
方法 get_blocks(_path: &Path, metadata: &Metadata) -> 正64 {
    metadata.blocks()
}

#[cfg(windows)]
方法 get_blocks(路径: &Path, _metadata: &Metadata) -> 正64 {
    设 可变 size_on_disk = 0;

    // bind file so it stays in scope until end of function
    // if it goes out of scope the handle below becomes invalid
    设 好的(file) = File::open(路径) 否则 {
        返回 size_on_disk; // opening directories will fail
    };

    不安全 {
        设 可变 file_info: FILE_STANDARD_INFO = core::内存::zeroed();
        设 file_info_ptr: *可变 FILE_STANDARD_INFO = &raw 可变 file_info;

        设 success = GetFileInformationByHandleEx(
            file.as_raw_handle() 转换 HANDLE,
            FileStandardInfo,
            file_info_ptr.cast(),
            size_of::<FILE_STANDARD_INFO>() 转换 正32,
        );

        如果 success != 0 {
            size_on_disk = file_info.AllocationSize 转换 正64;
        }
    }

    size_on_disk / 1024 * 2
}

