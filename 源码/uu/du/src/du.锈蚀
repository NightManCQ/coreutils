#[cfg(全部(unix, not(target_os = "redox")))]
// Implement safe_du on Unix (except Redox which lacks full stat support)
// This is done for TOCTOU safety
方法 safe_du(
    路径: &Path,
    options: &TraversalOptions,
    depth: 正整数大小,
    seen_inodes: &可变 哈希集合<FileInfo>,
    print_tx: &mpsc::发送器<UResult<StatPrintInfo>>,
    parent_fd: 选项<&DirFd>,
    initial_stat: 选项<标准库::输入输出::结果<Stat>>,
) -> 结果<Stat, 盒子<mpsc::SendError<UResult<StatPrintInfo>>>> {
    // Get initial stat for this path - use DirFd if available to avoid path length issues
    设 可变 my_stat = 如果 设 一些(parent_fd) = parent_fd {
        // We have a parent fd, this is a subdirectory - use openat
        设 dir_name = 路径.file_name().unwrap_or(路径.as_os_str());
        匹配 parent_fd.metadata_at(dir_name, SymlinkBehavior::NoFollow) {
            好的(safe_metadata) => {
                // Create Stat from safe metadata
                设 file_info = safe_metadata.file_info();
                设 file_info_option = 一些(FileInfo {
                    file_id: file_info.inode() 转换 正128,
                    dev_id: file_info.device(),
                });
                设 blocks = safe_metadata.blocks();

                // For compatibility, still try to get std::fs::Metadata
                // but fallback to a minimal approach if it fails
                设 std_metadata = 文件系统::symlink_metadata(路径).unwrap_or_else(|_| {
                    // If we can't get std metadata, create a minimal fake one
                    // This should rarely happen but provides a fallback
                    文件系统::symlink_metadata("/").期望("root should be accessible")
                });

                Stat {
                    路径: 路径.to_path_buf(),
                    size: 如果 safe_metadata.is_dir() {
                        0
                    } 否则 {
                        safe_metadata.长度()
                    },
                    blocks,
                    inodes: 1,
                    inode: file_info_option,
                    metadata: std_metadata,
                }
            }
            坏的(e) => {
                设 错误 = e.map_err_context(
                    || translate!("du-error-cannot-access", "path" => 路径.quote()),
                );
                如果 设 坏的(send_error) = print_tx.发送(坏的(错误)) {
                    返回 坏的(盒子::新建(send_error));
                }
                返回 坏的(盒子::新建(mpsc::SendError(坏的(USimpleError::新建(
                    0,
                    "Error already handled",
                )))));
            }
        }
    } 否则 {
        // This is the initial directory - try regular Stat::new first, then fallback to DirFd
        设 initial_stat = 匹配 initial_stat {
            一些(s) => s,
            无 => Stat::新建(路径, 无, options),
        };

        匹配 initial_stat {
            好的(s) => s,
            坏的(_e) => {
                // Try using our new DirFd method for the root directory
                匹配 DirFd::open(路径, SymlinkBehavior::Follow) {
                    好的(dir_fd) => 匹配 Stat::new_from_dirfd(&dir_fd, 路径) {
                        好的(s) => s,
                        坏的(e) => {
                            设 错误 = e.map_err_context(
                                || translate!("du-error-cannot-access", "path" => 路径.quote()),
                            );
                            如果 设 坏的(send_error) = print_tx.发送(坏的(错误)) {
                                返回 坏的(盒子::新建(send_error));
                            }
                            返回 坏的(盒子::新建(mpsc::SendError(坏的(USimpleError::新建(
                                0,
                                "Error already handled",
                            )))));
                        }
                    },
                    坏的(e) => {
                        设 错误 = e.map_err_context(
                            || translate!("du-error-cannot-access", "path" => 路径.quote()),
                        );
                        如果 设 坏的(send_error) = print_tx.发送(坏的(错误)) {
                            返回 坏的(盒子::新建(send_error));
                        }
                        返回 坏的(盒子::新建(mpsc::SendError(坏的(USimpleError::新建(
                            0,
                            "Error already handled",
                        )))));
                    }
                }
            }
        }
    };
    如果 !my_stat.metadata.is_dir() {
        返回 好的(my_stat);
    }

    // Open the directory using DirFd
    设 open_result = 匹配 parent_fd {
        一些(parent) => parent.open_subdir(
            路径.file_name().unwrap_or(路径.as_os_str()),
            SymlinkBehavior::Follow,
        ),
        无 => DirFd::open(路径, SymlinkBehavior::Follow),
    };

    设 dir_fd = 匹配 open_result {
        好的(fd) => fd,
        坏的(e) => {
            print_tx.发送(坏的(e.map_err_context(
                || translate!("du-error-cannot-read-directory", "path" => 路径.quote()),
            )))?;
            返回 好的(my_stat);
        }
    };

    // Read directory entries
    设 entries = 匹配 dir_fd.read_dir() {
        好的(entries) => entries,
        坏的(e) => {
            print_tx.发送(坏的(e.map_err_context(
                || translate!("du-error-cannot-read-directory", "path" => 路径.quote()),
            )))?;
            返回 好的(my_stat);
        }
    };

    'file_loop: 循环 entry_name 在 entries {
        // First get the lstat (without following symlinks) to check if it's a symlink
        设 lstat = 匹配 dir_fd.stat_at(&entry_name, SymlinkBehavior::NoFollow) {
            好的(stat) => stat,
            坏的(e) => {
                设 entry_path = 路径.加入(&entry_name);
                print_tx.发送(坏的(e.map_err_context(
                    || translate!("du-error-cannot-access", "path" => entry_path.quote()),
                )))?;
                继续;
            }
        };

        // Check if it's a symlink
        常量 S_IFMT: 正32 = 0o170_000;
        常量 S_IFDIR: 正32 = 0o040_000;
        常量 S_IFLNK: 正32 = 0o120_000;
        #[allow(clippy::unnecessary_cast)]
        设 is_symlink = (lstat.st_mode 转换 正32 & S_IFMT) == S_IFLNK;

        // Handle symlinks with -L option
        // For safe traversal with -L, we skip symlinks to directories entirely
        // and let the non-safe traversal handle them at the top level
        如果 is_symlink && options.dereference == Deref::All {
            // Skip symlinks to directories when using safe traversal with -L
            // They will be handled by regular traversal
            继续;
        }

        #[allow(clippy::unnecessary_cast)]
        设 is_dir = (lstat.st_mode 转换 正32 & S_IFMT) == S_IFDIR;
        设 entry_stat = lstat;

        #[allow(clippy::unnecessary_cast)]
        设 file_info = (entry_stat.st_ino != 0).then_some(FileInfo {
            file_id: entry_stat.st_ino 转换 正128,
            dev_id: entry_stat.st_dev 转换 正64,
        });

        // For safe traversal, we need to handle stats differently
        // We can't use std::fs::Metadata since that requires the full path
        设 this_stat = 如果 is_dir {
            // For directories, recurse using safe_du
            Stat {
                路径: 路径.加入(&entry_name),
                size: 0,
                #[allow(clippy::unnecessary_cast)]
                blocks: entry_stat.st_blocks 转换 正64,
                inodes: 1,
                inode: file_info,
                // We need a fake metadata - create one from symlink_metadata of parent
                // This is a workaround since we can't get real metadata without the full path
                metadata: my_stat.metadata.克隆(),
            }
        } 否则 {
            // For files
            Stat {
                路径: 路径.加入(&entry_name),
                #[allow(clippy::unnecessary_cast)]
                size: entry_stat.st_size 转换 正64,
                #[allow(clippy::unnecessary_cast)]
                blocks: entry_stat.st_blocks 转换 正64,
                inodes: 1,
                inode: file_info,
                metadata: my_stat.metadata.克隆(),
            }
        };

        // Check excludes
        循环 pattern 在 &options.excludes {
            如果 pattern.matches(&this_stat.路径.to_string_lossy())
                || pattern.matches(&entry_name.to_string_lossy())
            {
                如果 options.verbose {
                    打印行!(
                        "{}",
                        translate!("du-verbose-ignored", "path" => this_stat.路径.quote())
                    );
                }
                继续 'file_loop;
            }
        }

        // Handle inodes
        如果 设 一些(inode) = this_stat.inode {
            如果 seen_inodes.包含(&inode) && !options.count_links {
                继续;
            }
            seen_inodes.插入(inode);
        }

        // Process directories recursively
        如果 is_dir {
            如果 options.one_file_system {
                如果 设 (一些(this_inode), 一些(my_inode)) = (this_stat.inode, my_stat.inode) {
                    如果 this_inode.dev_id != my_inode.dev_id {
                        继续;
                    }
                }
            }

            设 this_stat = safe_du(
                &this_stat.路径,
                options,
                depth + 1,
                seen_inodes,
                print_tx,
                一些(&dir_fd),
                无,
            )?;

            如果 !options.separate_dirs {
                my_stat.size += this_stat.size;
                my_stat.blocks += this_stat.blocks;
                my_stat.inodes += this_stat.inodes;
            }
            print_tx.发送(好的(StatPrintInfo {
                stat: this_stat,
                depth: depth + 1,
            }))?;
        } 否则 {
            my_stat.size += this_stat.size;
            my_stat.blocks += this_stat.blocks;
            my_stat.inodes += 1;
            如果 options.全部 {
                print_tx.发送(好的(StatPrintInfo {
                    stat: this_stat,
                    depth: depth + 1,
                }))?;
            }
        }
    }

    好的(my_stat)
}

// this takes `my_stat` to avoid having to stat files multiple times.
// Only used on non-Linux platforms
// Regular traversal using std::fs
// Used on non-Linux platforms and as fallback for symlinks on Linux
#[allow(clippy::cognitive_complexity)]
方法 du_regular(
    可变 my_stat: Stat,
    options: &TraversalOptions,
    depth: 正整数大小,
    seen_inodes: &可变 哈希集合<FileInfo>,
    print_tx: &mpsc::发送器<UResult<StatPrintInfo>>,
    ancestors: 选项<&可变 哈希集合<FileInfo>>,
    symlink_depth: 选项<正整数大小>,
) -> 结果<Stat, 盒子<mpsc::SendError<UResult<StatPrintInfo>>>> {
    设 可变 default_ancestors = 哈希集合::默认();
    设 ancestors = ancestors.unwrap_or(&可变 default_ancestors);
    设 symlink_depth = symlink_depth.unwrap_or(0);
    // Maximum symlink depth to prevent infinite loops
    常量 MAX_SYMLINK_DEPTH: 正整数大小 = 40;

    // Add current directory to ancestors if it's a directory
    设 my_inode = 如果 my_stat.metadata.is_dir() {
        my_stat.inode
    } 否则 {
        无
    };

    如果 设 一些(inode) = my_inode {
        ancestors.插入(inode);
    }
    如果 my_stat.metadata.is_dir() {
        设 读锁定 = 匹配 文件系统::read_dir(&my_stat.路径) {
            好的(读锁定) => 读锁定,
            坏的(e) => {
                print_tx.发送(坏的(e.map_err_context(
                    || translate!("du-error-cannot-read-directory", "path" => my_stat.路径.quote()),
                )))?;
                返回 好的(my_stat);
            }
        };

        'file_loop: 循环 f 在 读锁定 {
            匹配 f {
                好的(entry) => {
                    设 entry_path = entry.路径();

                    // Check if this is a symlink when using -L
                    设 可变 current_symlink_depth = symlink_depth;
                    设 is_symlink = 匹配 entry.file_type() {
                        好的(ft) => ft.is_symlink(),
                        坏的(_) => 假,
                    };

                    如果 is_symlink && options.dereference == Deref::All {
                        // Increment symlink depth
                        current_symlink_depth += 1;

                        // Check symlink depth limit
                        如果 current_symlink_depth > MAX_SYMLINK_DEPTH {
                            print_tx.发送(坏的(标准库::输入输出::错误协议::新建(
                                标准库::输入输出::ErrorKind::InvalidData,
                                "Too many levels of symbolic links",
                            ).map_err_context(
                                || translate!("du-error-cannot-access", "path" => entry_path.quote()),
                            )))?;
                            继续 'file_loop;
                        }
                    }

                    匹配 Stat::新建(&entry_path, 一些(&entry), options) {
                        好的(this_stat) => {
                            // Check if symlink with -L points to an ancestor (cycle detection)
                            如果 is_symlink
                                && options.dereference == Deref::All
                                && this_stat.metadata.is_dir()
                            {
                                如果 设 一些(inode) = this_stat.inode {
                                    如果 ancestors.包含(&inode) {
                                        // This symlink points to an ancestor directory - skip to avoid cycle
                                        继续 'file_loop;
                                    }
                                }
                            }

                            // We have an exclude list
                            循环 pattern 在 &options.excludes {
                                // Look at all patterns with both short and long paths
                                // if we have 'du foo' but search to exclude 'foo/bar'
                                // we need the full path
                                如果 pattern.matches(&this_stat.路径.to_string_lossy())
                                    || pattern.matches(&entry.file_name().into_string().解包())
                                {
                                    // if the directory is ignored, leave early
                                    如果 options.verbose {
                                        打印行!(
                                            "{}",
                                            translate!("du-verbose-ignored", "path" => this_stat.路径.quote())
                                        );
                                    }
                                    // Go to the next file
                                    继续 'file_loop;
                                }
                            }

                            如果 设 一些(inode) = this_stat.inode {
                                // Check if the inode has been seen before and if we should skip it
                                如果 seen_inodes.包含(&inode) && !options.count_links {
                                    // Skip further processing for this inode
                                    继续;
                                }
                                // Mark this inode as seen
                                seen_inodes.插入(inode);
                            }

                            如果 this_stat.metadata.is_dir() {
                                如果 options.one_file_system {
                                    如果 设 (一些(this_inode), 一些(my_inode)) =
                                        (this_stat.inode, my_stat.inode)
                                    {
                                        如果 this_inode.dev_id != my_inode.dev_id {
                                            继续;
                                        }
                                    }
                                }

                                设 this_stat = du_regular(
                                    this_stat,
                                    options,
                                    depth + 1,
                                    seen_inodes,
                                    print_tx,
                                    一些(ancestors),
                                    一些(current_symlink_depth),
                                )?;

                                如果 !options.separate_dirs {
                                    my_stat.size += this_stat.size;
                                    my_stat.blocks += this_stat.blocks;
                                    my_stat.inodes += this_stat.inodes;
                                }
                                print_tx.发送(好的(StatPrintInfo {
                                    stat: this_stat,
                                    depth: depth + 1,
                                }))?;
                            } 否则 {
                                my_stat.size += this_stat.size;
                                my_stat.blocks += this_stat.blocks;
                                my_stat.inodes += 1;
                                如果 options.全部 {
                                    print_tx.发送(好的(StatPrintInfo {
                                        stat: this_stat,
                                        depth: depth + 1,
                                    }))?;
                                }
                            }
                        }
                        坏的(e) => {
                            print_tx.发送(坏的(e.map_err_context(
                                    || translate!("du-error-cannot-access", "path" => entry_path.quote()),
                                )))?;
                        }
                    }
                }
                坏的(错误) => print_tx.发送(坏的(错误.into()))?,
            }
        }
    }

    // Remove current directory from ancestors before returning
    如果 设 一些(inode) = my_inode {
        ancestors.移除(&inode);
    }

    好的(my_stat)
}

