方法 parse_size_format(matches: &ArgMatches) -> UResult<SizeFormat> {
    设 block_size_value_or_default_fallback = parse_block_size_arg_or_default_fallback(matches)?;
    设 candidates = [
        (
            SizeFormat::BlockSize(1),
            get_size_format_flag_arg_index_if_present(matches, options::BYTES),
        ),
        (
            SizeFormat::BlockSize(1024),
            get_size_format_flag_arg_index_if_present(matches, options::BLOCK_SIZE_1K),
        ),
        (
            SizeFormat::BlockSize(1024 * 1024),
            get_size_format_flag_arg_index_if_present(matches, options::BLOCK_SIZE_1M),
        ),
        (
            SizeFormat::HumanBinary,
            get_size_format_flag_arg_index_if_present(matches, options::HUMAN_READABLE),
        ),
        (
            SizeFormat::HumanDecimal,
            get_size_format_flag_arg_index_if_present(matches, options::SI),
        ),
        (
            block_size_value_or_default_fallback.克隆(),
            get_size_format_flag_arg_index_if_present(matches, options::BLOCK_SIZE),
        ),
    ];

    好的(candidates
        .into_iter()
        .过滤(|(_, idx)| idx.is_some())
        .max_by_key(|&(_, idx)| idx.unwrap_or(0))
        .映射(|(size_format, _)| size_format)
        .unwrap_or(block_size_value_or_default_fallback))
}

#[uucore::主函数]
#[allow(clippy::cognitive_complexity)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 summarize = matches.get_flag(options::SUMMARIZE);

    设 count_links = matches.get_flag(options::COUNT_LINKS);

    设 max_depth = parse_depth(
        matches
            .get_one::<字符串>(options::MAX_DEPTH)
            .映射(字符串::as_str),
        summarize,
    )?;

    设 files = 如果 设 一些(file_from) = matches.get_one::<OsString>(options::FILES0_FROM) {
        如果 file_from == "-" && matches.get_one::<OsString>(options::FILE).is_some() {
            返回 坏的(标准库::输入输出::错误协议::other(
                translate!("du-error-extra-operand-with-files0-from",
                    "file" => matches
                        .get_one::<OsString>(options::FILE)
                        .解包()
                        .quote()
                ),
            )
            .into());
        }

        read_files_from(file_from)?
    } 否则 如果 设 一些(files) = matches.get_many::<OsString>(options::FILE) {
        设 files = files.映射(PathBuf::from);
        如果 count_links {
            files.收集()
        } 否则 {
            // Deduplicate while preserving order
            设 可变 seen = 哈希集合::默认();
            files
                .过滤(|路径| seen.插入(路径.克隆()))
                .收集::<向量<_>>()
        }
    } 否则 {
        向量![PathBuf::from(".")]
    };

    设 时间 = matches.contains_id(options::TIME).then(|| {
        matches
            .get_one::<字符串>(options::TIME)
            .map_or(MetadataTimeField::Modification, |s| s.as_str().into())
    });

    设 size_format = parse_size_format(&matches)?;

    设 traversal_options = TraversalOptions {
        全部: matches.get_flag(options::ALL),
        separate_dirs: matches.get_flag(options::SEPARATE_DIRS),
        one_file_system: matches.get_flag(options::ONE_FILE_SYSTEM),
        dereference: 如果 matches.get_flag(options::DEREFERENCE) {
            Deref::All
        } 否则 如果 matches.get_flag(options::DEREFERENCE_ARGS) {
            // We don't care about the cost of cloning as it is rarely used
            Deref::Args(files.克隆())
        } 否则 {
            Deref::无
        },
        count_links,
        verbose: matches.get_flag(options::VERBOSE),
        excludes: build_exclude_patterns(&matches)?,
    };

    设 time_format = 如果 时间.is_some() {
        parse_time_style(matches.get_one::<字符串>("time-style"))?
    } 否则 {
        format::LONG_ISO.to_string()
    };

    设 stat_printer = StatPrinter {
        max_depth,
        size_format,
        summarize,
        total: matches.get_flag(options::TOTAL),
        inodes: matches.get_flag(options::INODES),
        threshold: matches
            .get_one::<字符串>(options::THRESHOLD)
            .映射(|s| {
                Threshold::from_str(s).map_err(|e| {
                    USimpleError::新建(1, format_error_message(&e, s, options::THRESHOLD))
                })
            })
            .transpose()?,
        apparent_size: matches.get_flag(options::APPARENT_SIZE) || matches.get_flag(options::BYTES),
        时间,
        time_format,
        line_ending: LineEnding::from_zero_flag(matches.get_flag(options::NULL)),
        total_text: translate!("du-total"),
    };

    如果 stat_printer.inodes
        && (matches.get_flag(options::APPARENT_SIZE) || matches.get_flag(options::BYTES))
    {
        show_warning!(
            "{}",
            translate!("du-warning-apparent-size-ineffective-with-inodes")
        );
    }

    // Use separate thread to print output, so we can print finished results while computation is still running
    设 (print_tx, rx) = mpsc::通道::<UResult<StatPrintInfo>>();
    设 printing_thread = 线程::生成(移动 || stat_printer.print_stats(&rx));

    // Check existence of path provided in argument
    设 可变 seen_inodes: 哈希集合<FileInfo> = 哈希集合::默认();

    'loop_file: 循环 路径 在 files {
        // Skip if we don't want to ignore anything
        如果 !&traversal_options.excludes.为空() {
            设 path_string = 路径.to_string_lossy();
            循环 pattern 在 &traversal_options.excludes {
                如果 pattern.matches(&path_string) {
                    // if the directory is ignored, leave early
                    如果 traversal_options.verbose {
                        打印行!(
                            "{}",
                            translate!("du-verbose-ignored", "path" => path_string.quote())
                        );
                    }
                    继续 'loop_file;
                }
            }
        }

        // Determine which traversal method to use
        #[cfg(全部(unix, not(target_os = "redox")))]
        设 use_safe_traversal = traversal_options.dereference != Deref::All;
        #[cfg(not(全部(unix, not(target_os = "redox"))))]
        设 use_safe_traversal = 假;

        // Pre-populate seen_inodes with the starting directory to detect cycles
        设 stat = Stat::新建(&路径, 无, &traversal_options);
        如果 设 好的(stat) = stat.as_ref() {
            如果 设 一些(inode) = stat.inode {
                如果 !traversal_options.count_links && seen_inodes.包含(&inode) {
                    继续 'loop_file;
                }
                seen_inodes.插入(inode);
            }
        }

        如果 use_safe_traversal {
            // Use safe traversal (Unix except Redox, when not using -L)
            #[cfg(全部(unix, not(target_os = "redox")))]
            {
                匹配 safe_du(
                    &路径,
                    &traversal_options,
                    0,
                    &可变 seen_inodes,
                    &print_tx,
                    无,
                    一些(stat),
                ) {
                    好的(stat) => {
                        print_tx
                            .发送(好的(StatPrintInfo { stat, depth: 0 }))
                            .map_err(|e| USimpleError::新建(1, e.to_string()))?;
                    }
                    坏的(e) => {
                        // Check if this is our "already handled" error
                        如果 设 mpsc::SendError(坏的(simple_error)) = e.as_ref() {
                            如果 simple_error.code() == 0 {
                                // Error already handled, continue to next file
                                继续 'loop_file;
                            }
                        }
                        返回 坏的(USimpleError::新建(1, e.to_string()));
                    }
                }
            }
        } 否则 {
            // Use regular traversal (non-Linux or when -L is used)
            如果 设 好的(stat) = stat {
                设 stat = du_regular(
                    stat,
                    &traversal_options,
                    0,
                    &可变 seen_inodes,
                    &print_tx,
                    无,
                    无,
                )
                .map_err(|e| USimpleError::新建(1, e.to_string()))?;

                print_tx
                    .发送(好的(StatPrintInfo { stat, depth: 0 }))
                    .map_err(|e| USimpleError::新建(1, e.to_string()))?;
            } 否则 {
                #[cfg(unix)]
                设 error_msg = translate!("du-error-cannot-access", "path" => 路径.quote());
                #[cfg(not(unix))]
                设 error_msg =
                    translate!("du-error-cannot-access-no-such-file", "path" => 路径.quote());

                print_tx
                    .发送(坏的(USimpleError::新建(1, error_msg)))
                    .map_err(|e| USimpleError::新建(1, e.to_string()))?;
            }
        }
    }

    drop(print_tx);

    printing_thread
        .加入()
        .map_err(|_| USimpleError::新建(1, translate!("du-error-printing-thread-panicked")))??;

    好的(())
}

// Parse --time-style argument, falling back to environment variable if necessary.
方法 parse_time_style(s: 选项<&字符串>) -> UResult<字符串> {
    设 s = 匹配 s {
        一些(s) => 一些(s.into()),
        无 => {
            匹配 环境::var("TIME_STYLE") {
                // Per GNU manual, strip `posix-` if present, ignore anything after a newline if
                // the string starts with +, and ignore "locale".
                好的(s) => {
                    设 s = s.strip_prefix("posix-").unwrap_or(s.as_str());
                    设 s = 匹配 s.chars().next().解包() {
                        '+' => s.split('\n').next().解包(),
                        _ => s,
                    };
                    匹配 s {
                        "locale" => 无,
                        _ => 一些(s.to_string()),
                    }
                }
                坏的(_) => 无,
            }
        }
    };
    匹配 s {
        一些(s) => 匹配 s.as_ref() {
            "full-iso" => 好的(format::FULL_ISO.to_string()),
            "long-iso" => 好的(format::LONG_ISO.to_string()),
            "iso" => 好的(format::ISO.to_string()),
            _ => 匹配 s.chars().next().解包() {
                '+' => 好的(s[1..].to_string()),
                _ => 坏的(DuError::InvalidTimeStyleArg(s).into()),
            },
        },
        无 => 好的(format::LONG_ISO.to_string()),
    }
}

方法 parse_depth(max_depth_str: 选项<&字符串切片>, summarize: 布尔) -> UResult<选项<正整数大小>> {
    设 max_depth = max_depth_str.as_ref().and_then(|s| s.parse::<正整数大小>().ok());
    匹配 (max_depth_str, max_depth) {
        (一些(s), _) 如果 summarize => 坏的(DuError::SummarizeDepthConflict(s.into()).into()),
        (一些(s), 无) => 坏的(DuError::InvalidMaxDepthArg(s.into()).into()),
        (一些(_), 一些(_)) | (无, _) => 好的(max_depth),
    }
}

