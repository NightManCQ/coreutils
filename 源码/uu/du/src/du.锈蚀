#[derive(克隆协议, 复制协议)]
枚举 Threshold {
    Lower(正64),
    Upper(正64),
}

实现 FromStr 循环 Threshold {
    类型 坏的 = ParseSizeError;

    方法 from_str(s: &字符串切片) -> 结果<自身类型, 自身类型::坏的> {
        设 offset = 正整数大小::from(s.starts_with(&['-', '+'][..]));

        设 size = parse_size_u64(&s[offset..])?;

        如果 s.starts_with('-') {
            // Threshold of '-0' excludes everything besides 0 sized entries
            // GNU's du treats '-0' as an invalid argument
            如果 size == 0 {
                返回 坏的(ParseSizeError::ParseFailure(s.to_string()));
            }
            好的(自身类型::Upper(size))
        } 否则 {
            好的(自身类型::Lower(size))
        }
    }
}

实现 Threshold {
    方法 should_exclude(&自身, size: 正64) -> 布尔 {
        匹配 *自身 {
            自身类型::Upper(threshold) => size > threshold,
            自身类型::Lower(threshold) => size < threshold,
        }
    }
}

方法 format_error_message(错误: &ParseSizeError, s: &字符串切片, option: &字符串切片) -> 字符串 {
    // NOTE:
    // GNU's du echos affected flag, -B or --block-size (-t or --threshold), depending user's selection
    匹配 错误 {
        ParseSizeError::InvalidSuffix(_) => {
            translate!("du-error-invalid-suffix", "option" => option, "value" => s.quote())
        }
        ParseSizeError::ParseFailure(_) | ParseSizeError::PhysicalMem(_) => {
            translate!("du-error-invalid-argument", "option" => option, "value" => s.quote())
        }
        ParseSizeError::SizeTooBig(_) => {
            translate!("du-error-argument-too-large", "option" => option, "value" => s.quote())
        }
    }
}

