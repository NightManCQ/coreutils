结构 StatPrintInfo {
    stat: Stat,
    depth: 正整数大小,
}

实现 StatPrinter {
    方法 choose_size(&自身, stat: &Stat) -> 正64 {
        如果 自身.inodes {
            stat.inodes
        } 否则 如果 自身.apparent_size {
            stat.size
        } 否则 {
            // The st_blocks field indicates the number of blocks allocated to the file, 512-byte units.
            // See: http://linux.die.net/man/2/stat
            stat.blocks * 512
        }
    }

    方法 print_stats(&自身, rx: &mpsc::接收器<UResult<StatPrintInfo>>) -> UResult<()> {
        设 可变 grand_total = 0;
        无限循环 {
            设 received = rx.接收();

            匹配 received {
                好的(message) => 匹配 message {
                    好的(stat_info) => {
                        设 size = 自身.choose_size(&stat_info.stat);

                        如果 stat_info.depth == 0 {
                            grand_total += size;
                        }

                        如果 !自身
                            .threshold
                            .is_some_and(|threshold| threshold.should_exclude(size))
                            && 自身
                                .max_depth
                                .is_none_or(|max_depth| stat_info.depth <= max_depth)
                            && (!自身.summarize || stat_info.depth == 0)
                        {
                            自身.print_stat(&stat_info.stat, size)?;
                        }
                    }
                    坏的(e) => show!(e),
                },
                坏的(_) => 中断,
            }
        }

        如果 自身.total {
            打印!("{}\t{}", 自身.convert_size(grand_total), 自身.total_text);
            打印!("{}", 自身.line_ending);
        }

        好的(())
    }

    方法 convert_size(&自身, size: 正64) -> 字符串 {
        匹配 自身.size_format {
            SizeFormat::HumanDecimal => uucore::format::human::human_readable(
                size,
                uucore::format::human::SizeFormat::Decimal,
            ),
            SizeFormat::HumanBinary => uucore::format::human::human_readable(
                size,
                uucore::format::human::SizeFormat::Binary,
            ),
            SizeFormat::BlockSize(block_size) => {
                如果 自身.inodes {
                    // we ignore block size (-B) with --inodes
                    size.to_string()
                } 否则 {
                    size.div_ceil(block_size).to_string()
                }
            }
        }
    }

    方法 print_stat(&自身, stat: &Stat, size: 正64) -> UResult<()> {
        打印!("{}\t", 自身.convert_size(size));

        如果 设 一些(md_time) = &自身.时间 {
            如果 设 一些(时间) = metadata_get_time(&stat.metadata, *md_time) {
                format_system_time(
                    &可变 stdout(),
                    时间,
                    &自身.time_format,
                    FormatSystemTimeFallback::IntegerError,
                )?;
                打印!("\t");
            } 否则 {
                打印!("???\t");
            }
        }

        print_verbatim(&stat.路径).解包();
        打印!("{}", 自身.line_ending);

        好的(())
    }
}

/// Read file paths from the specified file, separated by null characters
方法 read_files_from(file_name: &OsStr) -> 结果<向量<PathBuf>, 标准库::输入输出::错误协议> {
    设 reader: 盒子<动态 BufRead> = 如果 file_name == "-" {
        // Read from standard input
        盒子::新建(BufReader::新建(标准库::输入输出::stdin()))
    } 否则 {
        // First, check if the file_name is a directory
        设 路径 = PathBuf::from(file_name);
        如果 路径.is_dir() {
            返回 坏的(标准库::输入输出::错误协议::other(
                translate!("du-error-read-error-is-directory", "file" => file_name.maybe_quote()),
            ));
        }

        // Attempt to open the file and handle the error if it does not exist
        匹配 File::open(file_name) {
            好的(file) => 盒子::新建(BufReader::新建(file)),
            坏的(e) 如果 e.kind() == 标准库::输入输出::ErrorKind::NotFound => {
                返回 坏的(标准库::输入输出::错误协议::other(
                    translate!("du-error-cannot-open-for-reading", "file" => file_name.quote()),
                ));
            }
            坏的(e) => 返回 坏的(e),
        }
    };

    设 可变 paths = 向量::新建();

    循环 (i, line) 在 reader.split(b'\0').enumerate() {
        设 路径 = line?;

        如果 路径.为空() {
            设 line_number = i + 1;
            show_error!(
                "{}",
                translate!("du-error-invalid-zero-length-file-name", "file" => file_name.maybe_quote(), "line" => line_number)
            );
            set_exit_code(1);
        } 否则 如果 路径 == b"-" && file_name == "-" {
            show_error!("{}", translate!("du-error-hyphen-file-name-not-allowed"));
            set_exit_code(1);
        } 否则 {
            设 p = PathBuf::from(&*uucore::os_str_from_bytes(&路径).解包());
            如果 !paths.包含(&p) {
                paths.压入(p);
            }
        }
    }

    好的(paths)
}

