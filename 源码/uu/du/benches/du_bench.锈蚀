使用 divan::{Bencher, black_box};
使用 tempfile::TempDir;
使用 uu_du::uumain;
使用 uucore::benchmark::{fs_tree, run_util_function};

/// Helper to run du with given arguments on a directory
方法 bench_du_with_args(bencher: Bencher, temp_dir: &TempDir, args: &[&字符串切片]) {
    设 temp_path_str = temp_dir.路径().to_str().解包();
    设 可变 full_args = args.to_vec();
    full_args.压入(temp_path_str);

    bencher.bench(|| {
        black_box(run_util_function(uumain, &full_args));
    });
}

