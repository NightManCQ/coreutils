/// Benchmark du on wide directory structures (many files/dirs, shallow)
#[divan::bench(args = [(5000, 500)])]
方法 du_wide_tree(bencher: Bencher, (total_files, total_dirs): (正整数大小, 正整数大小)) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            fs_tree::create_wide_tree(temp_dir.路径(), total_files, total_dirs);
            temp_dir
        })
        .bench_values(|temp_dir| {
            设 temp_path_str = temp_dir.路径().to_str().解包();
            设 args = 向量![temp_path_str];
            black_box(run_util_function(uumain, &args));
        });
}

