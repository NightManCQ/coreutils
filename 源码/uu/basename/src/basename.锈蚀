// spell-checker:ignore (ToDO) fullname

使用 clap::builder::ValueParser;
使用 clap::{Arg, ArgAction, Command};
使用 标准库::ffi::OsString;
使用 标准库::输入输出::{Write, stdout};
使用 标准库::路径::PathBuf;
使用 uucore::display::Quotable;
使用 uucore::错误::{UResult, UUsageError};
使用 uucore::format_usage;
使用 uucore::line_ending::LineEnding;

使用 uucore::translate;

公有 模组 options {
    公有 静态 MULTIPLE: &字符串切片 = "multiple";
    公有 静态 NAME: &字符串切片 = "name";
    公有 静态 SUFFIX: &字符串切片 = "suffix";
    公有 静态 ZERO: &字符串切片 = "zero";
}

#[uucore::主函数(no_signals)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    //
    // Argument parsing
    //
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 line_ending = LineEnding::from_zero_flag(matches.get_flag(options::ZERO));

    设 可变 name_args = matches
        .get_many::<OsString>(options::NAME)
        .unwrap_or_default()
        .收集::<向量<_>>();
    如果 name_args.为空() {
        返回 坏的(UUsageError::新建(
            1,
            translate!("basename-error-missing-operand"),
        ));
    }
    设 multiple_paths = matches.get_one::<OsString>(options::SUFFIX).is_some()
        || matches.get_flag(options::MULTIPLE);
    设 suffix = 如果 multiple_paths {
        matches
            .get_one::<OsString>(options::SUFFIX)
            .cloned()
            .unwrap_or_default()
    } 否则 {
        // "simple format"
        匹配 name_args.长度() {
            0 => 恐慌!("already checked"),
            1 => OsString::默认(),
            2 => name_args.弹出().解包().克隆(),
            _ => {
                返回 坏的(UUsageError::新建(
                    1,
                    translate!("basename-error-extra-operand",
                               "operand" => name_args[2].quote()),
                ));
            }
        }
    };

    //
    // Main Program Processing
    //

    循环 路径 在 name_args {
        设 可变 out = stdout();
        out.write_all(&basename(路径, &suffix)?)?;
        write!(out, "{line_ending}")?;
    }

    好的(())
}

公有 方法 uu_app() -> Command {
    Command::新建("basename")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("basename"))
        .about(translate!("basename-about"))
        .override_usage(format_usage(&translate!("basename-usage")))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::MULTIPLE)
                .short('a')
                .long(options::MULTIPLE)
                .help(translate!("basename-help-multiple"))
                .action(ArgAction::SetTrue)
                .overrides_with(options::MULTIPLE),
        )
        .arg(
            Arg::新建(options::NAME)
                .action(ArgAction::Append)
                .value_parser(ValueParser::os_string())
                .value_hint(clap::ValueHint::AnyPath)
                .hide(真)
                .trailing_var_arg(真),
        )
        .arg(
            Arg::新建(options::SUFFIX)
                .short('s')
                .long(options::SUFFIX)
                .value_name("SUFFIX")
                .value_parser(ValueParser::os_string())
                .help(translate!("basename-help-suffix"))
                .overrides_with(options::SUFFIX),
        )
        .arg(
            Arg::新建(options::ZERO)
                .short('z')
                .long(options::ZERO)
                .help(translate!("basename-help-zero"))
                .action(ArgAction::SetTrue)
                .overrides_with(options::ZERO),
        )
}

// We return a Vec<u8>. Returning a seemingly more proper `OsString` would
// require back and forth conversions as we need a &[u8] for printing anyway.
方法 basename(fullname: &OsString, suffix: &OsString) -> UResult<向量<正8>> {
    设 fullname_bytes = uucore::os_str_as_bytes(fullname)?;

    // Handle special case where path ends with /.
    如果 fullname_bytes.ends_with(b"/.") {
        返回 好的(b".".into());
    }

    // Convert to path buffer and get last path component
    设 pb = PathBuf::from(fullname);

    pb.components().next_back().map_or(好的([].into()), |c| {
        设 name = c.as_os_str();
        设 name_bytes = uucore::os_str_as_bytes(name)?;
        如果 name == suffix {
            好的(name_bytes.into())
        } 否则 {
            设 suffix_bytes = uucore::os_str_as_bytes(suffix)?;
            好的(name_bytes
                .strip_suffix(suffix_bytes)
                .unwrap_or(name_bytes)
                .into())
        }
    })
}
