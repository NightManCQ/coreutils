#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 options = 匹配 parse_command_line(&matches) {
        好的(r) => r,
        坏的(r) => {
            如果 设 错误协议::CommandLine(r) = r {
                返回 坏的(r.into());
            }

            返回 坏的(UUsageError::新建(libc::EXIT_FAILURE, 格式化!("{r}.\n")));
        }
    };

    设 context = 匹配 &options.mode {
        CommandLineMode::ReferenceBased { reference } => {
            设 result = 匹配 SecurityContext::of_path(reference, 真, 假) {
                好的(一些(context)) => 好的(context),

                好的(无) => {
                    设 err = 输入输出::错误协议::from_raw_os_error(libc::ENODATA);
                    坏的(错误协议::from_io1(
                        translate!("chcon-op-getting-security-context"),
                        reference,
                        err,
                    ))
                }

                坏的(r) => 坏的(错误协议::from_selinux(
                    translate!("chcon-op-getting-security-context"),
                    r,
                )),
            };

            匹配 result {
                坏的(r) => {
                    返回 坏的(USimpleError::新建(
                        libc::EXIT_FAILURE,
                        格式化!("{}.", report_full_error(&r)),
                    ));
                }

                好的(file_context) => SELinuxSecurityContext::File(file_context),
            }
        }

        CommandLineMode::ContextBased { context } => {
            设 c_context = 匹配 os_str_to_c_string(context) {
                好的(context) => context,

                坏的(_r) => {
                    返回 坏的(USimpleError::新建(
                        libc::EXIT_FAILURE,
                        translate!("chcon-error-invalid-context", "context" => context.quote()),
                    ));
                }
            };

            如果 SecurityContext::from_c_str(&c_context, 假).check() == 一些(假) {
                返回 坏的(USimpleError::新建(
                    libc::EXIT_FAILURE,
                    translate!("chcon-error-invalid-context", "context" => context.quote()),
                ));
            }

            SELinuxSecurityContext::字符串(一些(c_context))
        }

        CommandLineMode::Custom { .. } => SELinuxSecurityContext::字符串(无),
    };

    设 root_dev_ino = 如果 options.preserve_root && options.recursive_mode.is_recursive() {
        匹配 get_root_dev_ino() {
            好的(r) => 一些(r),

            坏的(r) => {
                返回 坏的(USimpleError::新建(
                    libc::EXIT_FAILURE,
                    格式化!("{}.", report_full_error(&r)),
                ));
            }
        }
    } 否则 {
        无
    };

    设 results = process_files(&options, &context, root_dev_ino);
    如果 results.为空() {
        返回 好的(());
    }

    循环 result 在 &results {
        show_error!("{}.", report_full_error(result));
    }
    坏的(libc::EXIT_FAILURE.into())
}

