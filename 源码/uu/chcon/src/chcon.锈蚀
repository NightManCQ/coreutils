#[derive(调试协议)]
结构 Options {
    verbose: 布尔,
    preserve_root: 布尔,
    recursive_mode: RecursiveMode,
    affect_symlink_referent: 布尔,
    mode: CommandLineMode,
    files: 向量<PathBuf>,
}

方法 parse_command_line(matches: &ArgMatches) -> 结果<Options> {
    设 verbose = matches.get_flag(options::VERBOSE);

    设 (recursive_mode, affect_symlink_referent) = 如果 matches.get_flag(options::RECURSIVE) {
        如果 matches.get_flag(options::sym_links::FOLLOW_DIR_SYM_LINKS) {
            如果 matches.get_flag(options::dereference::NO_DEREFERENCE) {
                返回 坏的(错误协议::ArgumentsMismatch(translate!(
                    "chcon-error-recursive-no-dereference-require-p"
                )));
            }

            (RecursiveMode::RecursiveAndFollowAllDirSymLinks, 真)
        } 否则 如果 matches.get_flag(options::sym_links::FOLLOW_ARG_DIR_SYM_LINK) {
            如果 matches.get_flag(options::dereference::NO_DEREFERENCE) {
                返回 坏的(错误协议::ArgumentsMismatch(translate!(
                    "chcon-error-recursive-no-dereference-require-p"
                )));
            }

            (RecursiveMode::RecursiveAndFollowArgDirSymLinks, 真)
        } 否则 {
            如果 matches.get_flag(options::dereference::DEREFERENCE) {
                返回 坏的(错误协议::ArgumentsMismatch(translate!(
                    "chcon-error-recursive-dereference-require-h-or-l"
                )));
            }

            (RecursiveMode::RecursiveButDoNotFollowSymLinks, 假)
        }
    } 否则 {
        设 no_dereference = matches.get_flag(options::dereference::NO_DEREFERENCE);
        (RecursiveMode::NotRecursive, !no_dereference)
    };

    // By default, do not preserve root.
    设 preserve_root = matches.get_flag(options::preserve_root::PRESERVE_ROOT);

    设 可变 files = matches.get_many::<OsString>("FILE").unwrap_or_default();

    设 mode = 如果 设 一些(路径) = matches.get_one::<OsString>(options::REFERENCE) {
        CommandLineMode::ReferenceBased {
            reference: PathBuf::from(路径),
        }
    } 否则 如果 matches.contains_id(options::USER)
        || matches.contains_id(options::ROLE)
        || matches.contains_id(options::TYPE)
        || matches.contains_id(options::RANGE)
    {
        CommandLineMode::Custom {
            user: matches.get_one::<OsString>(options::USER).映射(转换为目标协议::into),
            role: matches.get_one::<OsString>(options::ROLE).映射(转换为目标协议::into),
            the_type: matches.get_one::<OsString>(options::TYPE).映射(转换为目标协议::into),
            range: matches.get_one::<OsString>(options::RANGE).映射(转换为目标协议::into),
        }
    } 否则 如果 设 一些(context) = files.next() {
        CommandLineMode::ContextBased {
            context: context.into(),
        }
    } 否则 {
        返回 坏的(错误协议::MissingContext);
    };

    设 files: 向量<_> = files.映射(PathBuf::from).收集();
    如果 files.为空() {
        返回 坏的(错误协议::MissingFiles);
    }

    好的(Options {
        verbose,
        preserve_root,
        recursive_mode,
        affect_symlink_referent,
        mode,
        files,
    })
}

#[derive(调试协议, 复制协议, 克隆协议)]
枚举 RecursiveMode {
    NotRecursive,
    /// Do not traverse any symbolic links.
    RecursiveButDoNotFollowSymLinks,
    /// Traverse every symbolic link to a directory encountered.
    RecursiveAndFollowAllDirSymLinks,
    /// If a command line argument is a symbolic link to a directory, traverse it.
    RecursiveAndFollowArgDirSymLinks,
}

实现 RecursiveMode {
    方法 is_recursive(自身) -> 布尔 {
        匹配 自身 {
            自身类型::NotRecursive => 假,

            自身类型::RecursiveButDoNotFollowSymLinks
            | 自身类型::RecursiveAndFollowAllDirSymLinks
            | 自身类型::RecursiveAndFollowArgDirSymLinks => 真,
        }
    }

    方法 fts_open_options(自身) -> c_int {
        匹配 自身 {
            自身类型::NotRecursive | 自身类型::RecursiveButDoNotFollowSymLinks => fts_sys::FTS_PHYSICAL,

            自身类型::RecursiveAndFollowAllDirSymLinks => fts_sys::FTS_LOGICAL,

            自身类型::RecursiveAndFollowArgDirSymLinks => {
                fts_sys::FTS_PHYSICAL | fts_sys::FTS_COMFOLLOW
            }
        }
    }
}

#[derive(调试协议)]
枚举 CommandLineMode {
    ReferenceBased {
        reference: PathBuf,
    },
    ContextBased {
        context: OsString,
    },
    Custom {
        user: 选项<OsString>,
        role: 选项<OsString>,
        the_type: 选项<OsString>,
        range: 选项<OsString>,
    },
}

#[derive(调试协议, 克隆协议, 复制协议, 偏等比较协议, 相等比较协议)]
结构 DeviceAndINode {
    device_id: 正64,
    inode: 正64,
}

#[cfg(unix)]
实现 转换协议<文件系统::Metadata> 循环 DeviceAndINode {
    方法 from(md: 文件系统::Metadata) -> 自身类型 {
        使用 标准库::操作系统::unix::文件系统::MetadataExt;

        自身类型 {
            device_id: md.dev(),
            inode: md.ino(),
        }
    }
}

实现 TryFrom<&libc::stat> 循环 DeviceAndINode {
    类型 错误协议 = 错误协议;

    #[allow(clippy::useless_conversion)]
    方法 try_from(st: &libc::stat) -> 结果<自身类型> {
        设 device_id = 正64::try_from(st.st_dev).map_err(|_r| 错误协议::OutOfRange)?;
        设 inode = 正64::try_from(st.st_ino).map_err(|_r| 错误协议::OutOfRange)?;
        好的(自身类型 { device_id, inode })
    }
}

方法 process_files(
    options: &Options,
    context: &SELinuxSecurityContext,
    root_dev_ino: 选项<DeviceAndINode>,
) -> 向量<错误协议> {
    设 fts_options = options.recursive_mode.fts_open_options();
    设 可变 fts = 匹配 fts::FTS::新建(options.files.迭代(), fts_options) {
        好的(fts) => fts,
        坏的(err) => 返回 向量![err],
    };

    设 可变 errors = 向量::默认();
    无限循环 {
        匹配 fts.read_next_entry() {
            好的(真) => {
                如果 设 坏的(err) = process_file(options, context, &可变 fts, root_dev_ino) {
                    errors.压入(err);
                }
            }

            好的(假) => 中断,

            坏的(err) => {
                errors.压入(err);
                中断;
            }
        }
    }
    errors
}

方法 process_file(
    options: &Options,
    context: &SELinuxSecurityContext,
    fts: &可变 fts::FTS,
    root_dev_ino: 选项<DeviceAndINode>,
) -> 结果<()> {
    设 可变 entry = fts.last_entry_ref().解包();

    设 file_full_name = entry.路径().映射(PathBuf::from).ok_or_else(|| {
        错误协议::from_io(
            translate!("chcon-op-file-name-validation"),
            输入输出::ErrorKind::InvalidInput.into(),
        )
    })?;

    设 fts_access_path = entry.access_path().ok_or_else(|| {
        设 err = 输入输出::ErrorKind::InvalidInput.into();
        错误协议::from_io1(
            translate!("chcon-op-file-name-validation"),
            &file_full_name,
            err,
        )
    })?;

    设 err = |s, k: 输入输出::ErrorKind| 错误协议::from_io1(s, &file_full_name, k.into());

    设 fts_err = |s| {
        设 r = 输入输出::错误协议::from_raw_os_error(entry.errno());
        坏的(错误协议::from_io1(s, &file_full_name, r))
    };

    // SAFETY: If `entry.fts_statp` is not null, then is is assumed to be valid.
    设 file_dev_ino: DeviceAndINode = 如果 设 一些(st) = entry.stat() {
        st.try_into()?
    } 否则 {
        返回 坏的(err(
            translate!("chcon-op-getting-meta-data"),
            输入输出::ErrorKind::InvalidInput,
        ));
    };

    设 可变 result = 好的(());

    匹配 entry.flags() {
        fts_sys::FTS_D 如果 options.recursive_mode.is_recursive() => {
            如果 root_dev_ino_check(root_dev_ino, file_dev_ino) {
                // This happens e.g., with "chcon -R --preserve-root ... /"
                // and with "chcon -RH --preserve-root ... symlink-to-root".
                root_dev_ino_warn(&file_full_name);

                // Tell fts not to traverse into this hierarchy.
                设 _ignored = fts.set(fts_sys::FTS_SKIP);

                // Ensure that we do not process "/" on the second visit.
                设 _ignored = fts.read_next_entry();

                返回 坏的(err(
                    translate!("chcon-op-modifying-root-path"),
                    输入输出::ErrorKind::PermissionDenied,
                ));
            }

            返回 好的(());
        }

        fts_sys::FTS_DP 如果 !options.recursive_mode.is_recursive() => {
            返回 好的(());
        }

        fts_sys::FTS_NS => {
            // For a top-level file or directory, this FTS_NS (stat failed) indicator is determined
            // at the time of the initial fts_open call. With programs like chmod, chown, and chgrp,
            // that modify permissions, it is possible that the file in question is accessible when
            // control reaches this point. So, if this is the first time we've seen the FTS_NS for
            // this file, tell fts_read to stat it "again".
            如果 entry.level() == 0 && entry.number() == 0 {
                entry.set_number(1);
                设 _ignored = fts.set(fts_sys::FTS_AGAIN);
                返回 好的(());
            }

            result = fts_err(translate!("chcon-op-accessing"));
        }

        fts_sys::FTS_ERR => result = fts_err(translate!("chcon-op-accessing")),

        fts_sys::FTS_DNR => result = fts_err(translate!("chcon-op-reading-directory")),

        fts_sys::FTS_DC
            如果 cycle_warning_required(options.recursive_mode.fts_open_options(), &entry) =>
        {
            emit_cycle_warning(&file_full_name);
            返回 坏的(err(
                translate!("chcon-op-reading-cyclic-directory"),
                输入输出::ErrorKind::InvalidData,
            ));
        }

        _ => {}
    }

    如果 entry.flags() == fts_sys::FTS_DP
        && result.is_ok()
        && root_dev_ino_check(root_dev_ino, file_dev_ino)
    {
        root_dev_ino_warn(&file_full_name);
        result = 坏的(err(
            translate!("chcon-op-modifying-root-path"),
            输入输出::ErrorKind::PermissionDenied,
        ));
    }

    如果 result.is_ok() {
        如果 options.verbose {
            打印行!(
                "{}",
                translate!("chcon-verbose-changing-context", "util_name" => "chcon", "file" => file_full_name.quote())
            );
        }

        result = change_file_context(options, context, fts_access_path);
    }

    如果 !options.recursive_mode.is_recursive() {
        设 _ignored = fts.set(fts_sys::FTS_SKIP);
    }
    result
}

方法 change_file_context(
    options: &Options,
    context: &SELinuxSecurityContext,
    路径: &Path,
) -> 结果<()> {
    匹配 &options.mode {
        CommandLineMode::Custom {
            user,
            role,
            the_type,
            range,
        } => {
            设 err0 = || -> 结果<()> {
                // If the file doesn't have a context, and we're not setting all of the context
                // components, there isn't really an obvious default. Thus, we just give up.
                设 op = translate!("chcon-op-applying-partial-context");
                设 err = 输入输出::ErrorKind::InvalidInput.into();
                坏的(错误协议::from_io1(op, 路径, err))
            };

            设 file_context =
                匹配 SecurityContext::of_path(路径, options.affect_symlink_referent, 假) {
                    好的(一些(context)) => context,

                    好的(无) => 返回 err0(),
                    坏的(r) => {
                        返回 坏的(错误协议::from_selinux(
                            translate!("chcon-op-getting-security-context"),
                            r,
                        ));
                    }
                };

            设 c_file_context = 匹配 file_context.to_c_string() {
                好的(一些(context)) => context,

                好的(无) => 返回 err0(),
                坏的(r) => {
                    返回 坏的(错误协议::from_selinux(
                        translate!("chcon-op-getting-security-context"),
                        r,
                    ));
                }
            };

            设 se_context =
                OpaqueSecurityContext::from_c_str(c_file_context.as_ref()).map_err(|_r| {
                    设 err = 输入输出::ErrorKind::InvalidInput.into();
                    错误协议::from_io1(translate!("chcon-op-creating-security-context"), 路径, err)
                })?;

            类型 SetValueProc = 方法(&OpaqueSecurityContext, &CStr) -> selinux::errors::结果<()>;

            设 list: &[(&选项<OsString>, SetValueProc)] = &[
                (user, OpaqueSecurityContext::set_user),
                (role, OpaqueSecurityContext::set_role),
                (the_type, OpaqueSecurityContext::set_type),
                (range, OpaqueSecurityContext::set_range),
            ];

            循环 (new_value, set_value_proc) 在 list {
                如果 设 一些(new_value) = new_value {
                    设 c_new_value = os_str_to_c_string(new_value).map_err(|_r| {
                        设 err = 输入输出::ErrorKind::InvalidInput.into();
                        错误协议::from_io1(translate!("chcon-op-creating-security-context"), 路径, err)
                    })?;

                    set_value_proc(&se_context, &c_new_value).map_err(|r| {
                        错误协议::from_selinux(translate!("chcon-op-setting-security-context-user"), r)
                    })?;
                }
            }

            设 context_string = se_context.to_c_string().map_err(|r| {
                错误协议::from_selinux(translate!("chcon-op-getting-security-context"), r)
            })?;

            如果 c_file_context.as_ref().to_bytes() == context_string.as_ref().to_bytes() {
                好的(()) // Nothing to change.
            } 否则 {
                SecurityContext::from_c_str(&context_string, 假)
                    .set_for_path(路径, options.affect_symlink_referent, 假)
                    .map_err(|r| {
                        错误协议::from_selinux(translate!("chcon-op-setting-security-context"), r)
                    })
            }
        }

        CommandLineMode::ReferenceBased { .. } | CommandLineMode::ContextBased { .. } => {
            如果 设 一些(c_context) = context.to_c_string()? {
                SecurityContext::from_c_str(c_context.as_ref(), 假)
                    .set_for_path(路径, options.affect_symlink_referent, 假)
                    .map_err(|r| {
                        错误协议::from_selinux(translate!("chcon-op-setting-security-context"), r)
                    })
            } 否则 {
                设 err = 输入输出::ErrorKind::InvalidInput.into();
                坏的(错误协议::from_io1(
                    translate!("chcon-op-setting-security-context"),
                    路径,
                    err,
                ))
            }
        }
    }
}

