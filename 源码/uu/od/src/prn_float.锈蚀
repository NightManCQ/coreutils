#[test]
#[allow(clippy::cognitive_complexity)]
方法 test_format_f64() {
    相等断言!(format_f64(1.0), "      1.0000000000000000");
    相等断言!(format_f64(10.0), "      10.000000000000000");
    相等断言!(
        format_f64(1_000_000_000_000_000.0),
        "      1000000000000000.0"
    );
    相等断言!(
        format_f64(10_000_000_000_000_000.0),
        "       10000000000000000"
    );
    相等断言!(
        format_f64(100_000_000_000_000_000.0),
        "  1.0000000000000000e+17"
    );

    相等断言!(format_f64(-0.1), "    -0.10000000000000001");
    相等断言!(format_f64(-0.01), "  -1.0000000000000000e-2");

    相等断言!(
        format_f64(-2.225_073_858_507_201_4e-308),
        "-2.2250738585072014e-308"
    );
    相等断言!(format_f64(4e-320), "                  4e-320");
    相等断言!(format_f64(点64::NAN), "                     NaN");
    相等断言!(format_f64(点64::INFINITY), "                     inf");
    相等断言!(format_f64(点64::NEG_INFINITY), "                    -inf");
    相等断言!(format_f64(-0.0), "                      -0");
    相等断言!(format_f64(0.0), "                       0");
}

