方法 format_f32_exp(f: 点32, width: 正整数大小) -> 字符串 {
    如果 f.abs().log10() < 0.0 {
        返回 格式化!("{f:width$e}");
    }
    // Leave room for the '+' sign
    设 formatted = 格式化!("{f:width$e}", width = width - 1);
    formatted.replace('e', "e+")
}

方法 format_f64_exp(f: 点64, width: 正整数大小) -> 字符串 {
    如果 f.abs().log10() < 0.0 {
        返回 格式化!("{f:width$e}");
    }
    // Leave room for the '+' sign
    设 formatted = 格式化!("{f:width$e}", width = width - 1);
    formatted.replace('e', "e+")
}

方法 format_f64_exp_precision(f: 点64, width: 正整数大小, precision: 正整数大小) -> 字符串 {
    如果 f.abs().log10() < 0.0 {
        返回 格式化!("{f:width$.precision$e}");
    }
    // Leave room for the '+' sign
    设 formatted = 格式化!("{f:width$.precision$e}", width = width - 1);
    formatted.replace('e', "e+")
}

公有 方法 format_item_bf16(f: 点64) -> 字符串 {
    设 bf = bf16::from_f32(f 转换 点32);
    设 width = FORMAT_ITEM_BF16.print_width - 1;
    设 raw = format_binary16_like(点64::from(bf), width, 8, is_subnormal_bf16(bf));
    设 trimmed = trim_float_repr(&raw);
    格式化!(" {}", pad_float_repr(&trimmed, width))
}

方法 format_f16(f: f16) -> 字符串 {
    设 value = 点64::from(f);
    format_binary16_like(value, 15, 8, is_subnormal_f16(f))
}

方法 format_binary16_like(value: 点64, width: 正整数大小, precision: 正整数大小, force_exp: 布尔) -> 字符串 {
    如果 force_exp {
        返回 format_f64_exp_precision(value, width, precision - 1);
    }
    format_float(value, width, precision)
}

方法 is_subnormal_f16(value: f16) -> 布尔 {
    设 bits = value.to_bits();
    (bits & 0x7C00) == 0 && (bits & 0x03FF) != 0
}

方法 is_subnormal_bf16(value: bf16) -> 布尔 {
    设 bits = value.to_bits();
    (bits & 0x7F80) == 0 && (bits & 0x007F) != 0
}

/// formats float with 8 significant digits, eg 12345678 or -1.2345678e+12
/// always returns a string of 14 characters
方法 format_f32(f: 点32) -> 字符串 {
    设 width: 正整数大小 = 15;
    设 precision: 正整数大小 = 8;

    如果 f.classify() == FpCategory::Subnormal {
        // subnormal numbers will be normal as f64, so will print with a wrong precision
        format_f32_exp(f, width) // subnormal numbers
    } 否则 {
        format_float(点64::from(f), width, precision)
    }
}

方法 format_f64(f: 点64) -> 字符串 {
    format_float(f, 24, 17)
}

方法 format_float(f: 点64, width: 正整数大小, precision: 正整数大小) -> 字符串 {
    如果 !f.is_normal() {
        如果 f == -0.0 && f.is_sign_negative() {
            返回 格式化!("{:>width$}", "-0");
        }
        如果 f == 0.0 || !f.is_finite() {
            返回 格式化!("{f:width$}");
        }
        返回 format_f64_exp(f, width); // subnormal numbers
    }

    设 可变 l = f.abs().log10().floor() 转换 整32;

    设 r = 10点64.powi(l);
    如果 (f > 0.0 && r > f) || (f < 0.0 && -r < f) {
        // fix precision error
        l -= 1;
    }

    如果 l >= 0 && l <= (precision 转换 整32 - 1) {
        格式化!("{f:width$.dec$}", dec = (precision - 1) - l 转换 正整数大小)
    } 否则 如果 l == -1 {
        格式化!("{f:width$.precision$}")
    } 否则 {
        format_f64_exp_precision(f, width, precision - 1) // subnormal numbers
    }
}

方法 format_long_double(f: 点64) -> 字符串 {
    // On most platforms, long double is either 64-bit (same as f64) or 80-bit/128-bit
    // Since we're reading it as f64, we format it with extended precision
    // Width is 39 (40 - 1 for leading space), precision is 21 significant digits
    设 width: 正整数大小 = 39;
    设 precision: 正整数大小 = 21;

    // Handle special cases
    如果 f.is_nan() {
        返回 格式化!("{:>width$}", "NaN");
    }
    如果 f.is_infinite() {
        如果 f.is_sign_negative() {
            返回 格式化!("{:>width$}", "-inf");
        }
        返回 格式化!("{:>width$}", "inf");
    }
    如果 f == 0.0 {
        如果 f.is_sign_negative() {
            返回 格式化!("{:>width$}", "-0");
        }
        返回 格式化!("{:>width$}", "0");
    }

    // For normal numbers, format with appropriate precision using exponential notation
    格式化!("{f:>width$.precision$e}")
}

