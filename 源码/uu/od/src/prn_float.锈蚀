    相等断言!(format_f16(f16::from_bits(0x8401u16)), "  -6.1094761e-5");
    相等断言!(format_f16(f16::from_bits(0x8402u16)), "  -6.1154366e-5");
    相等断言!(format_f16(f16::from_bits(0x8403u16)), "  -6.1213970e-5");

    相等断言!(format_f16(f16::from_f32(1.0)), "      1.0000000");
    相等断言!(format_f16(f16::from_f32(10.0)), "      10.000000");
    相等断言!(format_f16(f16::from_f32(100.0)), "      100.00000");
    相等断言!(format_f16(f16::from_f32(1000.0)), "      1000.0000");
