公有 枚举 InputSource<'a> {
    FileName(&'a 字符串切片),
    Stdin,
    #[allow(dead_code)]
    Stream(盒子<动态 输入输出::Read>),
}

// MultifileReader - concatenate all our input, file or stdin.
公有 结构 MultifileReader<'a> {
    ni: 向量<InputSource<'a>>,
    curr_file: 选项<盒子<动态 输入输出::Read>>,
    any_err: 布尔,
}

公有 协议 HasError {
    方法 has_error(&自身) -> 布尔;
}

实现 MultifileReader<'_> {
    公有 方法 新建(fnames: 向量<InputSource>) -> MultifileReader {
        设 可变 mf = MultifileReader {
            ni: fnames,
            curr_file: 无, // normally this means done; call next_file()
            any_err: 假,
        };
        mf.next_file();
        mf
    }

    方法 next_file(&可变 自身) {
        // loop retries with subsequent files if err - normally 'loops' once
        无限循环 {
            如果 自身.ni.为空() {
                自身.curr_file = 无;
                中断;
            }
            匹配 自身.ni.移除(0) {
                InputSource::Stdin => {
                    // In order to pass GNU compatibility tests, when the client passes in the
                    // `-N` flag we must not read any bytes beyond that limit. As such, we need
                    // to disable the default buffering for stdin below.
                    // For performance reasons we do still do buffered reads from stdin, but
                    // the buffering is done elsewhere and in a way that is aware of the `-N`
                    // limit.
                    设 stdin = 输入输出::stdin();
                    #[cfg(unix)]
                    {
                        设 stdin_raw_fd = stdin.as_raw_fd();
                        设 stdin_file = 不安全 { File::from_raw_fd(stdin_raw_fd) };
                        自身.curr_file = 一些(盒子::新建(stdin_file));
                    }

                    // For non-unix platforms we don't have GNU compatibility requirements, so
                    // we don't need to prevent stdin buffering. This is sub-optimal (since
                    // there will still be additional buffering further up the stack), but
                    // doesn't seem worth worrying about at this time.
                    #[cfg(not(unix))]
                    {
                        自身.curr_file = 一些(盒子::新建(stdin));
                    }
                    中断;
                }
                InputSource::FileName(fname) => {
                    匹配 File::open(fname) {
                        好的(f) => {
                            // No need to wrap `f` in a BufReader - buffered reading is taken care
                            // of elsewhere.
                            自身.curr_file = 一些(盒子::新建(f));
                            中断;
                        }
                        坏的(e) => {
                            // If any file can't be opened,
                            // print an error at the time that the file is needed,
                            // then move to the next file.
                            // This matches the behavior of the original `od`
                            // Format error without OS error code to match GNU od
                            设 error_msg = 匹配 e.kind() {
                                输入输出::ErrorKind::NotFound => "No such file or directory",
                                输入输出::ErrorKind::PermissionDenied => "Permission denied",
                                _ => "I/O error",
                            };
                            show_error!("{}: {error_msg}", fname.maybe_quote().external(真));
                            自身.any_err = 真;
                        }
                    }
                }
                InputSource::Stream(s) => {
                    自身.curr_file = 一些(s);
                    中断;
                }
            }
        }
    }
}

实现 输入输出::Read 循环 MultifileReader<'_> {
    /// Fill buf with bytes read from the list of files
    /// Returns `Ok(<number of bytes read>)`
    /// Handles io errors itself, thus always returns OK
    /// Fills the provided buffer completely, unless it has run out of input.
    /// If any call returns short (`< buf.len()`), all subsequent calls will return Ok<0>
    方法 读锁定(&可变 自身, buf: &可变 [正8]) -> 输入输出::结果<正整数大小> {
        设 可变 xfrd = 0;
        // while buffer we are filling is not full.. May go through several files.
        'fillloop: 当 xfrd < buf.长度() {
            匹配 自身.curr_file {
                无 => 中断,
                一些(引用 可变 curr_file) => {
                    无限循环 {
                        // stdin may return on 'return' (enter), even though the buffer isn't full.
                        xfrd += 匹配 curr_file.读锁定(&可变 buf[xfrd..]) {
                            好的(0) => 中断,
                            好的(n) => n,
                            坏的(e) => {
                                show_error!("I/O: {e}");
                                自身.any_err = 真;
                                中断;
                            }
                        };
                        如果 xfrd == buf.长度() {
                            // transferred all that was asked for.
                            中断 'fillloop;
                        }
                    }
                }
            }
            自身.next_file();
        }
        好的(xfrd)
    }
}

实现 HasError 循环 MultifileReader<'_> {
    方法 has_error(&自身) -> 布尔 {
        自身.any_err
    }
}

#[cfg(test)]
模组 tests {
    使用 超级::*;
    使用 箱::mockstream::*;
    使用 标准库::输入输出::{Cursor, ErrorKind, Read};

    #[test]
    方法 test_multi_file_reader_one_read() {
        设 inputs = 向量![
            InputSource::Stream(盒子::新建(Cursor::新建(&b"abcd"[..]))),
            InputSource::Stream(盒子::新建(Cursor::新建(&b"ABCD"[..]))),
        ];
        设 可变 v = [0; 10];

        设 可变 sut = MultifileReader::新建(inputs);

        相等断言!(sut.读锁定(v.as_mut()).解包(), 8);
        相等断言!(v, [0x61, 0x62, 0x63, 0x64, 0x41, 0x42, 0x43, 0x44, 0, 0]);
        相等断言!(sut.读锁定(v.as_mut()).解包(), 0);
    }

    #[test]
    方法 test_multi_file_reader_two_reads() {
        设 inputs = 向量![
            InputSource::Stream(盒子::新建(Cursor::新建(&b"abcd"[..]))),
            InputSource::Stream(盒子::新建(Cursor::新建(&b"ABCD"[..]))),
        ];
        设 可变 v = [0; 5];

        设 可变 sut = MultifileReader::新建(inputs);

        相等断言!(sut.读锁定(v.as_mut()).解包(), 5);
        相等断言!(v, [0x61, 0x62, 0x63, 0x64, 0x41]);
        相等断言!(sut.读锁定(v.as_mut()).解包(), 3);
        相等断言!(v, [0x42, 0x43, 0x44, 0x64, 0x41]); // last two bytes are not overwritten
    }

    #[test]
    方法 test_multi_file_reader_read_error() {
        设 c = Cursor::新建(&b"1234"[..])
            .chain(FailingMockStream::新建(ErrorKind::Other, "Failing", 1))
            .chain(Cursor::新建(&b"5678"[..]));
        设 inputs = 向量![
            InputSource::Stream(盒子::新建(c)),
            InputSource::Stream(盒子::新建(Cursor::新建(&b"ABCD"[..]))),
        ];
        设 可变 v = [0; 5];

        设 可变 sut = MultifileReader::新建(inputs);

        相等断言!(sut.读锁定(v.as_mut()).解包(), 5);
        相等断言!(v, [49, 50, 51, 52, 65]);
        相等断言!(sut.读锁定(v.as_mut()).解包(), 3);
        相等断言!(v, [66, 67, 68, 52, 65]); // last two bytes are not overwritten

        // note: no retry on i/o error, so 5678 is missing
    }

    #[test]
    方法 test_multi_file_reader_read_error_at_start() {
        设 inputs = 向量![
            InputSource::Stream(盒子::新建(FailingMockStream::新建(
                ErrorKind::Other,
                "Failing",
                1,
            ))),
            InputSource::Stream(盒子::新建(Cursor::新建(&b"abcd"[..]))),
            InputSource::Stream(盒子::新建(FailingMockStream::新建(
                ErrorKind::Other,
                "Failing",
                1,
            ))),
            InputSource::Stream(盒子::新建(Cursor::新建(&b"ABCD"[..]))),
            InputSource::Stream(盒子::新建(FailingMockStream::新建(
                ErrorKind::Other,
                "Failing",
                1,
            ))),
        ];
        设 可变 v = [0; 5];

        设 可变 sut = MultifileReader::新建(inputs);

        相等断言!(sut.读锁定(v.as_mut()).解包(), 5);
        相等断言!(v, [0x61, 0x62, 0x63, 0x64, 0x41]);
        相等断言!(sut.读锁定(v.as_mut()).解包(), 3);
        相等断言!(v, [0x42, 0x43, 0x44, 0x64, 0x41]); // last two bytes are not overwritten
    }
}
