        .解包(),
        向量![
            ParsedFormatterItemInfo::新建(FORMAT_ITEM_DEC64S, 假), // I
            ParsedFormatterItemInfo::新建(FORMAT_ITEM_DEC8U, 真),   // tu1z
            ParsedFormatterItemInfo::新建(FORMAT_ITEM_HEX16, 假),  // x
