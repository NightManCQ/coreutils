使用 箱::peek_reader::PeekRead;

/// Processes an input and provides access to the data read in various formats
///
/// Currently only useful if the input implements `PeekRead`.
公有 结构 InputDecoder<'a, I>
何处
    I: 'a,
{
    /// The input from which data is read
    input: &'a 可变 I,

    /// A memory buffer, it's size is set in `new`.
    data: 向量<正8>,
    /// The number of bytes in the buffer reserved for the peek data from `PeekRead`.
    reserved_peek_length: 正整数大小,

    /// The number of (valid) bytes in the buffer.
    used_normal_length: 正整数大小,
    /// The number of peek bytes in the buffer.
    used_peek_length: 正整数大小,

    /// Byte order used to read data from the buffer.
    byte_order: ByteOrder,
}

实现<I> InputDecoder<'_, I> {
    /// Creates a new `InputDecoder` with an allocated buffer of `normal_length` + `peek_length` bytes.
    /// `byte_order` determines how to read multibyte formats from the buffer.
    公有 方法 新建(
        input: &可变 I,
        normal_length: 正整数大小,
        peek_length: 正整数大小,
        byte_order: ByteOrder,
    ) -> InputDecoder<'_, I> {
        设 bytes = 向量![0; normal_length + peek_length];

        InputDecoder {
            input,
            data: bytes,
            reserved_peek_length: peek_length,
            used_normal_length: 0,
            used_peek_length: 0,
            byte_order,
        }
    }
}

实现<I> InputDecoder<'_, I>
何处
    I: PeekRead,
{
    /// calls `peek_read` on the internal stream to (re)fill the buffer. Returns a
    /// `MemoryDecoder` providing access to the result or returns an i/o error.
    公有 方法 peek_read(&可变 自身) -> 输入输出::结果<MemoryDecoder<'_>> {
        匹配 自身
            .input
            .peek_read(自身.data.as_mut_slice(), 自身.reserved_peek_length)
        {
            好的((n, p)) => {
                自身.used_normal_length = n;
                自身.used_peek_length = p;
                好的(MemoryDecoder {
                    data: &可变 自身.data,
                    used_normal_length: 自身.used_normal_length,
                    used_peek_length: 自身.used_peek_length,
                    byte_order: 自身.byte_order,
                })
            }
            坏的(e) => 坏的(e),
        }
    }
}

实现<I> HasError 循环 InputDecoder<'_, I>
何处
    I: HasError,
{
    /// calls `has_error` on the internal stream.
    方法 has_error(&自身) -> 布尔 {
        自身.input.has_error()
    }
}

/// Provides access to the internal data in various formats
公有 结构 MemoryDecoder<'a> {
    /// A reference to the parents' data
    data: &'a 可变 向量<正8>,
    /// The number of (valid) bytes in the buffer.
    used_normal_length: 正整数大小,
    /// The number of peek bytes in the buffer.
    used_peek_length: 正整数大小,
    /// Byte order used to read data from the buffer.
    byte_order: ByteOrder,
}

实现 MemoryDecoder<'_> {
    /// Set a part of the internal buffer to zero.
    /// access to the whole buffer is possible, not just to the valid data.
    公有 方法 zero_out_buffer(&可变 自身, start: 正整数大小, end: 正整数大小) {
        循环 i 在 start..end {
            自身.data[i] = 0;
        }
    }

    /// Returns the current length of the buffer. (ie. how much valid data it contains.)
    公有 方法 length(&自身) -> 正整数大小 {
        自身.used_normal_length
    }

    /// Creates a clone of the internal buffer. The clone only contain the valid data.
    公有 方法 clone_buffer(&自身, other: &可变 向量<正8>) {
        other.clone_from(自身.data);
        other.resize(自身.used_normal_length, 0);
    }

    /// Returns a slice to the internal buffer starting at `start`.
    公有 方法 get_buffer(&自身, start: 正整数大小) -> &[正8] {
        &自身.data[start..自身.used_normal_length]
    }

    /// Returns a slice to the internal buffer including the peek data starting at `start`.
    公有 方法 get_full_buffer(&自身, start: 正整数大小) -> &[正8] {
        &自身.data[start..自身.used_normal_length + 自身.used_peek_length]
    }

    /// Returns a u8/u16/u32/u64 from the internal buffer at position `start`.
    公有 方法 read_uint(&自身, start: 正整数大小, byte_size: 正整数大小) -> 正64 {
        匹配 byte_size {
            1 => 正64::from(自身.data[start]),
            2 => 正64::from(自身.byte_order.read_u16(&自身.data[start..start + 2])),
            4 => 正64::from(自身.byte_order.read_u32(&自身.data[start..start + 4])),
            8 => 自身.byte_order.read_u64(&自身.data[start..start + 8]),
            _ => 恐慌!("Invalid byte_size: {byte_size}"),
        }
    }

    /// Returns a f32/f64 from the internal buffer at position `start`.
    公有 方法 read_float(&自身, start: 正整数大小, byte_size: 正整数大小) -> 点64 {
        匹配 byte_size {
            2 => 点64::from(f16::from_bits(
                自身.byte_order.read_u16(&自身.data[start..start + 2]),
            )),
            4 => 点64::from(自身.byte_order.read_f32(&自身.data[start..start + 4])),
            8 => 自身.byte_order.read_f64(&自身.data[start..start + 8]),
            _ => 恐慌!("Invalid byte_size: {byte_size}"),
        }
    }

    /// Returns a bfloat16 as f64 from the internal buffer at position `start`.
    公有 方法 read_bfloat(&自身, start: 正整数大小) -> 点64 {
        设 bits = 自身.byte_order.read_u16(&自身.data[start..start + 2]);
        设 val = 点32::from(bf16::from_bits(bits));
        点64::from(val)
    }

    /// Returns a long double from the internal buffer at position `start`.
    /// We read 16 bytes as u128 (respecting endianness) and convert to f64.
    /// This ensures that endianness swapping works correctly even if we lose precision.
    公有 方法 read_long_double(&自身, start: 正整数大小) -> 点64 {
        设 bits = 自身.byte_order.read_u128(&自身.data[start..start + 16]);
        u128_to_f64(bits)
    }
}

方法 u128_to_f64(u: 正128) -> 点64 {
    设 sign = (u >> 127) 转换 正64;
    设 exp = ((u >> 112) & 0x7FFF) 转换 正64;
    设 mant = u & ((1 << 112) - 1);

    如果 exp == 0x7FFF {
        // Infinity or NaN
        如果 mant == 0 {
            如果 sign == 0 {
                点64::INFINITY
            } 否则 {
                点64::NEG_INFINITY
            }
        } 否则 {
            点64::NAN
        }
    } 否则 如果 exp == 0 {
        // Subnormal or zero
        如果 mant == 0 {
            如果 sign == 0 { 0.0 } 否则 { -0.0 }
        } 否则 {
            // Subnormal f128 is too small for f64, flush to zero
            如果 sign == 0 { 0.0 } 否则 { -0.0 }
        }
    } 否则 {
        // Normal
        设 new_exp = exp 转换 整64 - 16383 + 1023;
        如果 new_exp >= 2047 {
            // Overflow to infinity
            如果 sign == 0 {
                点64::INFINITY
            } 否则 {
                点64::NEG_INFINITY
            }
        } 否则 如果 new_exp <= 0 {
            // Underflow to zero
            如果 sign == 0 { 0.0 } 否则 { -0.0 }
        } 否则 {
            // Normal f64
            // Mantissa: take top 52 bits of 112-bit mantissa
            设 new_mant = (mant >> (112 - 52)) 转换 正64;
            设 bits = (sign << 63) | ((new_exp 转换 正64) << 52) | new_mant;
            点64::from_bits(bits)
        }
    }
}

#[cfg(test)]
模组 tests {
    使用 超级::*;
    使用 箱::byteorder_io::ByteOrder;
    使用 箱::peek_reader::PeekReader;
    使用 标准库::输入输出::Cursor;

    #[test]
    #[allow(clippy::float_cmp)]
    #[allow(clippy::cognitive_complexity)]
    方法 smoke_test() {
        设 data = [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xC0, 0xff, 0xff];
        设 可变 input = PeekReader::新建(Cursor::新建(&data));
        设 可变 sut = InputDecoder::新建(&可变 input, 8, 2, ByteOrder::Little);

        // Peek normal length
        设 可变 内存 = sut.peek_read().解包();

        相等断言!(8, 内存.length());

        相等断言!(-2.0, 内存.read_float(0, 8));
        相等断言!(-2.0, 内存.read_float(4, 4));
        相等断言!(0xc000_0000_0000_0000, 内存.read_uint(0, 8));
        相等断言!(0xc000_0000, 内存.read_uint(4, 4));
        相等断言!(0xc000, 内存.read_uint(6, 2));
        相等断言!(0xc0, 内存.read_uint(7, 1));
        相等断言!(&[0, 0xc0], 内存.get_buffer(6));
        相等断言!(&[0, 0xc0, 0xff, 0xff], 内存.get_full_buffer(6));

        设 可变 copy: 向量<正8> = 向量::新建();
        内存.clone_buffer(&可变 copy);
        相等断言!(向量![0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xC0], copy);

        内存.zero_out_buffer(7, 8);
        相等断言!(&[0, 0, 0xff, 0xff], 内存.get_full_buffer(6));

        // Peek tail
        设 内存 = sut.peek_read().解包();
        相等断言!(2, 内存.length());
        相等断言!(0xffff, 内存.read_uint(0, 2));
    }
}
