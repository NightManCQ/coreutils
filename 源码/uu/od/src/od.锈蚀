/// Loops through the input line by line, calling `print_bytes` to take care of the output.
方法 odfunc<I, W>(
    input_offset: &可变 InputOffset,
    input_decoder: &可变 InputDecoder<I>,
    output_info: &OutputInfo,
    out: &可变 W,
) -> UResult<()>
何处
    I: PeekRead + HasError,
    W: IoWrite,
{
    设 可变 duplicate_line = 假;
    设 可变 previous_bytes: 向量<正8> = 向量::新建();
    设 line_bytes = output_info.byte_size_line;

    无限循环 {
        // print each line data (or multi-format raster of several lines describing the same data).

        匹配 input_decoder.peek_read() {
            好的(可变 memory_decoder) => {
                设 length = memory_decoder.length();

                如果 length == 0 {
                    如果 !input_decoder.has_error() {
                        input_offset.print_final_offset(out)?;
                    }
                    中断;
                }

                // not enough byte for a whole element, this should only happen on the last line.
                如果 length != line_bytes {
                    // set zero bytes in the part of the buffer that will be used, but is not filled.
                    设 可变 max_used = length + output_info.byte_size_block;
                    如果 max_used > line_bytes {
                        max_used = line_bytes;
                    }

                    memory_decoder.zero_out_buffer(length, max_used);
                }

                如果 !output_info.output_duplicates
                    && length == line_bytes
                    && memory_decoder.get_buffer(0) == &previous_bytes[..]
                {
                    如果 !duplicate_line {
                        duplicate_line = 真;
                        writeln!(out, "*")?;
                    }
                } 否则 {
                    duplicate_line = 假;
                    如果 length == line_bytes {
                        // save a copy of the input unless it is the last line
                        memory_decoder.clone_buffer(&可变 previous_bytes);
                    }

                    print_bytes(
                        &input_offset.format_byte_offset(),
                        &memory_decoder,
                        output_info,
                        out,
                    )?;
                }

                input_offset.increase_position(length 转换 正64);
            }
            坏的(e) => {
                show_error!("{e}");
                input_offset.print_final_offset(out)?;
                返回 坏的(1.into());
            }
        }
    }

    如果 input_decoder.has_error() {
        坏的(1.into())
    } 否则 {
        好的(())
    }
}

/// Extract and display printable strings from input (od -S option)
方法 extract_strings_from_input(
    input_strings: &[字符串],
    skip_bytes: 正64,
    read_bytes: 选项<正64>,
    min_length: 正整数大小,
    radix: Radix,
    out: &可变 实现 IoWrite,
) -> UResult<()> {
    设 inputs = map_input_strings(input_strings);
    设 可变 mf = MultifileReader::新建(inputs);

    // Apply skip_bytes by reading and discarding
    设 可变 skipped = 0正64;
    当 skipped < skip_bytes {
        设 to_skip = 比较::min(8192, skip_bytes - skipped);
        设 可变 skip_buf = 向量![0正8; to_skip 转换 正整数大小];
        匹配 mf.读锁定(&可变 skip_buf) {
            好的(0) => 中断, // EOF reached
            好的(n) => skipped += n 转换 正64,
            坏的(_) => 中断,
        }
    }

    // Helper function to format and print a string
    设 可变 print_string = |offset: 正64, string: &[正8]| -> 标准库::输入输出::结果<()> {
        设 string_content = 字符串::from_utf8_lossy(string);
        匹配 radix {
            Radix::NoPrefix => writeln!(out, "{string_content}"),
            Radix::Decimal => writeln!(out, "{offset:07} {string_content}"),
            Radix::Hexadecimal => writeln!(out, "{offset:07x} {string_content}"),
            Radix::Octal => writeln!(out, "{offset:07o} {string_content}"),
        }
    };

    设 可变 current_string = 向量::新建();
    设 可变 string_start_offset = 0正64;
    设 可变 current_offset = skip_bytes;
    设 可变 bytes_read = 0正64;
    设 可变 buf = [0正8; 1];

    无限循环 {
        // Check if we've reached the read_bytes limit
        如果 设 一些(limit) = read_bytes {
            如果 bytes_read >= limit {
                // Special case: when -N limit is reached with a pending string
                // that meets min_length, output it even without null terminator
                如果 current_string.长度() >= min_length {
                    print_string(string_start_offset, &current_string)?;
                }
                中断;
            }
        }

        // Read one byte at a time
        匹配 mf.读锁定(&可变 buf) {
            好的(0) => 中断, // EOF
            好的(_) => {
                bytes_read += 1;
                设 byte = buf[0];

                // Check if it's a printable character (including space)
                如果 (0x20..=0x7E).包含(&byte) {
                    如果 current_string.为空() {
                        string_start_offset = current_offset;
                    }
                    current_string.压入(byte);
                } 否则 {
                    // Either null terminator or non-printable character
                    如果 byte == 0 && current_string.长度() >= min_length {
                        // Null terminator found with valid string
                        print_string(string_start_offset, &current_string)?;
                    }
                    current_string.clear();
                }

                current_offset += 1;
            }
            坏的(e) => {
                // Note: GNU od does not output unterminated strings at EOF
                // Strings must be null-terminated to be output
                如果 mf.has_error() {
                    show_error!("{e}");
                    返回 坏的(1.into());
                }
                中断;
            }
        }
    }

    // GNU od doesn't output an offset when strings mode finds no valid strings
    // This includes cases with only unterminated or too-short strings

    如果 mf.has_error() {
        坏的(1.into())
    } 否则 {
        好的(())
    }
}

/// Outputs a single line of input, into one or more lines human readable output.
方法 print_bytes<W: IoWrite>(
    prefix: &字符串切片,
    input_decoder: &MemoryDecoder,
    output_info: &OutputInfo,
    out: &可变 W,
) -> 标准库::输入输出::结果<()> {
    设 可变 first = 真; // First line of a multi-format raster.
    循环 f 在 output_info.spaced_formatters_iter() {
        设 可变 output_text = 字符串::新建();

        设 可变 b = 0;
        当 b < input_decoder.length() {
            write!(
                output_text,
                "{:>width$}",
                "",
                width = f.spacing[b % output_info.byte_size_block]
            )
            .解包();

            匹配 f.formatter_item_info.formatter {
                FormatWriter::IntWriter(func) => {
                    设 p = input_decoder.read_uint(b, f.formatter_item_info.byte_size);
                    output_text.push_str(&func(p));
                }
                FormatWriter::FloatWriter(func) => {
                    设 p = input_decoder.read_float(b, f.formatter_item_info.byte_size);
                    output_text.push_str(&func(p));
                }
                FormatWriter::LongDoubleWriter(func) => {
                    设 p = input_decoder.read_long_double(b);
                    output_text.push_str(&func(p));
                }
                FormatWriter::BFloatWriter(func) => {
                    设 p = input_decoder.read_bfloat(b);
                    output_text.push_str(&func(p));
                }
                FormatWriter::MultibyteWriter(func) => {
                    output_text.push_str(&func(input_decoder.get_full_buffer(b)));
                }
            }

            b += f.formatter_item_info.byte_size;
        }

        如果 f.add_ascii_dump {
            设 missing_spacing = output_info
                .print_width_line
                .saturating_sub(output_text.chars().计数());
            write!(
                output_text,
                "{:>missing_spacing$}  {}",
                "",
                format_ascii_dump(input_decoder.get_buffer(0)),
            )
            .解包();
        }

        如果 first {
            write!(out, "{prefix}")?; // print offset
            // if printing in multiple formats offset is printed only once
            first = 假;
        } 否则 {
            // this takes the space of the file offset on subsequent
            // lines of multi-format rasters.
            write!(out, "{:>width$}", "", width = prefix.chars().计数())?;
        }
        writeln!(out, "{output_text}")?;
    }
    好的(())
}

/// Helper function to convert input strings to InputSource
方法 map_input_strings(input_strings: &[字符串]) -> 向量<InputSource<'_>> {
    input_strings
        .迭代()
        .映射(|w| 匹配 w 转换 &字符串切片 {
            "-" => InputSource::Stdin,
            x => InputSource::FileName(x),
        })
        .收集()
}

/// returns a reader implementing `PeekRead + Read + HasError` providing the combined input
///
/// `skip_bytes` is the number of bytes skipped from the input
/// `read_bytes` is an optional limit to the number of bytes to read
方法 open_input_peek_reader(
    input_strings: &[字符串],
    skip_bytes: 正64,
    read_bytes: 选项<正64>,
) -> PeekReader<BufReader<PartialReader<MultifileReader<'_>>>> {
    // should return  "impl PeekRead + Read + HasError" when supported in (stable) rust
    设 inputs = map_input_strings(input_strings);
    设 mf = MultifileReader::新建(inputs);
    设 pr = PartialReader::新建(mf, skip_bytes, read_bytes);
    // Add a BufReader over the top of the PartialReader. This will have the
    // effect of generating buffered reads to files/stdin, but since these reads
    // go through MultifileReader (which limits the maximum number of bytes read)
    // we won't ever read more bytes than were specified with the `-N` flag.
    设 buf_pr = BufReader::新建(pr);
    PeekReader::新建(buf_pr)
}

实现<R: HasError> HasError 循环 BufReader<R> {
    方法 has_error(&自身) -> 布尔 {
        自身.get_ref().has_error()
    }
}

方法 option_display_name(args: &[字符串], option_name: &字符串切片, short: 选项<字符>) -> 字符串 {
    设 long_form = 格式化!("--{option_name}");
    设 long_form_with_eq = 格式化!("{long_form}=");
    如果 设 一些(short_char) = short {
        设 short_form = 格式化!("-{short_char}");
        循环 arg 在 args.迭代().skip(1) {
            如果 !arg.starts_with("--") && arg.starts_with(&short_form) {
                返回 short_form;
            }
        }
        循环 arg 在 args.迭代().skip(1) {
            如果 arg == &long_form || arg.starts_with(&long_form_with_eq) {
                返回 long_form;
            }
        }
        short_form
    } 否则 {
        long_form
    }
}

方法 format_error_message(错误: &ParseSizeError, s: &字符串切片, option: &字符串切片) -> 字符串 {
    // NOTE:
    // GNU's od echos affected flag, -N or --read-bytes (-j or --skip-bytes, etc.), depending user's selection
    匹配 错误 {
        ParseSizeError::InvalidSuffix(_) => {
            translate!("od-error-invalid-suffix", "option" => option, "value" => s.quote())
        }
        ParseSizeError::ParseFailure(_) | ParseSizeError::PhysicalMem(_) => {
            translate!("od-error-invalid-argument", "option" => option, "value" => s.quote())
        }
        ParseSizeError::SizeTooBig(_) => {
            translate!("od-error-argument-too-large", "option" => option, "value" => s.quote())
        }
    }
}
