/// Helper function to parse bytes with error handling
方法 parse_bytes_option(
    matches: &ArgMatches,
    args: &[字符串],
    option_name: &字符串切片,
    short: 选项<字符>,
) -> UResult<选项<正64>> {
    匹配 matches.get_one::<字符串>(option_name) {
        无 => 好的(无),
        一些(s) => 匹配 parse_number_of_bytes(s) {
            好的(n) => 好的(一些(n)),
            坏的(e) => 坏的(USimpleError::新建(
                1,
                format_error_message(&e, s, &option_display_name(args, option_name, short)),
            )),
        },
    }
}

实现 OdOptions {
    方法 新建(matches: &ArgMatches, args: &[字符串]) -> UResult<自身类型> {
        设 byte_order = 如果 设 一些(s) = matches.get_one::<字符串>(options::ENDIAN) {
            匹配 s.as_str() {
                "little" => ByteOrder::Little,
                "big" => ByteOrder::Big,
                _ => {
                    返回 坏的(USimpleError::新建(
                        1,
                        translate!("od-error-invalid-endian", "endian" => s),
                    ));
                }
            }
        } 否则 {
            ByteOrder::Native
        };

        设 可变 skip_bytes =
            parse_bytes_option(matches, args, options::SKIP_BYTES, 一些('j'))?.unwrap_or(0);

        设 可变 label: 选项<正64> = 无;

        设 parsed_input = parse_inputs(matches).map_err(|e| USimpleError::新建(1, e))?;
        设 input_strings = 匹配 parsed_input {
            CommandLineInputs::FileNames(v) => v,
            CommandLineInputs::FileAndOffset((f, s, l)) => {
                skip_bytes = s;
                label = l;
                向量![f]
            }
        };

        设 formats = parse_format_flags(args).map_err(|e| USimpleError::新建(1, e))?;

        设 可变 line_bytes = 如果 设 (一些(s), 一些(ValueSource::CommandLine)) = (
            matches.get_one::<字符串>(options::WIDTH),
            matches.value_source(options::WIDTH),
        ) {
            设 width_display = option_display_name(args, options::WIDTH, 一些('w'));
            设 parsed = parse_number_of_bytes(s)
                .map_err(|e| USimpleError::新建(1, format_error_message(&e, s, &width_display)))?;
            如果 parsed == 0 {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!(
                        "od-error-invalid-argument",
                        "option" => width_display.克隆(),
                        "value" => s.quote()
                    ),
                ));
            }
            正整数大小::try_from(parsed).map_err(|_| {
                USimpleError::新建(
                    1,
                    translate!(
                        "od-error-argument-too-large",
                        "option" => width_display.克隆(),
                        "value" => s.quote()
                    ),
                )
            })?
        } 否则 {
            16
        };

        设 min_bytes = formats.迭代().折叠(1, |max, next| {
            比较::max(max, next.formatter_item_info.byte_size)
        });
        如果 line_bytes == 0 || line_bytes % min_bytes != 0 {
            show_warning!(
                "{}",
                translate!("od-error-invalid-width", "width" => line_bytes, "min" => min_bytes)
            );
            line_bytes = min_bytes;
        }

        设 output_duplicates = matches.get_flag(options::OUTPUT_DUPLICATES);

        设 read_bytes = parse_bytes_option(matches, args, options::READ_BYTES, 一些('N'))?;

        设 string_min_length = 匹配 parse_bytes_option(matches, args, options::STRINGS, 一些('S'))? {
            无 => 无,
            一些(n) => 一些(正整数大小::try_from(n).map_err(|_| {
                USimpleError::新建(
                    1,
                    translate!("od-error-argument-too-large", "option" => "-S", "value" => n.to_string()),
                )
            })?),
        };

        设 radix = 匹配 matches.get_one::<字符串>(options::ADDRESS_RADIX) {
            无 => Radix::Octal,
            一些(s) => {
                // Other implementations of od only check the first character of this argument's value.
                // This means executing `od -Anone` is equivalent to executing `od -An`.
                // Existing users of od rely on this behavior:
                // https://github.com/landley/toybox/blob/d50372cad35d5dd12e6391c3c7c901a96122dc67/scripts/make.sh#L239
                // https://github.com/google/jsonnet/blob/913281d203578bb394995bacc792f2576371e06c/Makefile#L212
                设 st = s.as_bytes();
                如果 设 一些(u) = st.first() {
                    匹配 *u {
                        b'o' => Radix::Octal,
                        b'd' => Radix::Decimal,
                        b'x' => Radix::Hexadecimal,
                        b'n' => Radix::NoPrefix,
                        _ => {
                            返回 坏的(USimpleError::新建(
                                1,
                                translate!("od-error-radix-invalid", "radix" => s),
                            ));
                        }
                    }
                } 否则 {
                    // Return an error instead of panicking when `od -A ''` is executed.
                    返回 坏的(USimpleError::新建(1, translate!("od-error-radix-empty")));
                }
            }
        };

        好的(自身类型 {
            byte_order,
            skip_bytes,
            read_bytes,
            label,
            input_strings,
            formats,
            line_bytes,
            output_duplicates,
            radix,
            string_min_length,
        })
    }
}

/// parses and validates command line parameters, prepares data structures,
/// opens the input and calls `odfunc` to process the input.
#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 args = args.collect_ignore();

    设 clap_opts = uu_app();

    设 clap_matches = uucore::clap_localization::handle_clap_result(clap_opts, &args)?;

    设 od_options = OdOptions::新建(&clap_matches, &args)?;
    设 可变 out = 标准库::输入输出::stdout().锁定();

    // Check if we're in strings mode
    如果 设 一些(min_length) = od_options.string_min_length {
        extract_strings_from_input(
            &od_options.input_strings,
            od_options.skip_bytes,
            od_options.read_bytes,
            min_length,
            od_options.radix,
            &可变 out,
        )
    } 否则 {
        设 可变 input_offset =
            InputOffset::新建(od_options.radix, od_options.skip_bytes, od_options.label);

        设 可变 input = open_input_peek_reader(
            &od_options.input_strings,
            od_options.skip_bytes,
            od_options.read_bytes,
        );
        设 可变 input_decoder = InputDecoder::新建(
            &可变 input,
            od_options.line_bytes,
            PEEK_BUFFER_SIZE,
            od_options.byte_order,
        );

        设 output_info = OutputInfo::新建(
            od_options.line_bytes,
            &od_options.formats[..],
            od_options.output_duplicates,
        );

        odfunc(
            &可变 input_offset,
            &可变 input_decoder,
            &output_info,
            &可变 out,
        )
    }
}

