使用 divan::{Bencher, black_box};
使用 tempfile::TempDir;
使用 uu_mv::uumain;
使用 uucore::benchmark::{fs_tree, run_util_function};

/// Benchmark moving a single file (repeated to reach 100ms)
#[divan::bench]
方法 mv_single_file(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            fs_tree::create_wide_tree(temp_dir.路径(), 1000, 0);
            设 files: 向量<(字符串, 字符串)> = (0..1000)
                .映射(|i| {
                    设 src = temp_dir.路径().加入(格式化!("f{i}"));
                    设 dst = temp_dir.路径().加入(格式化!("moved_{i}"));
                    (
                        src.to_str().解包().to_string(),
                        dst.to_str().解包().to_string(),
                    )
                })
                .收集();
            (temp_dir, files)
        })
        .bench_values(|(temp_dir, files)| {
            循环 (src, dst) 在 &files {
                black_box(run_util_function(uumain, &[src, dst]));
            }
            drop(temp_dir);
        });
}

/// Benchmark moving multiple files to directory
#[divan::bench]
方法 mv_multiple_to_dir(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            fs_tree::create_wide_tree(temp_dir.路径(), 1000, 0);
            设 dest_dir = temp_dir.路径().加入("dest");
            标准库::文件系统::create_dir(&dest_dir).解包();

            设 可变 args: 向量<字符串> = (0..1000)
                .映射(|i| {
                    temp_dir
                        .路径()
                        .加入(格式化!("f{i}"))
                        .to_str()
                        .解包()
                        .to_string()
                })
                .收集();
            args.压入(dest_dir.to_str().解包().to_string());
            (temp_dir, args)
        })
        .bench_values(|(temp_dir, args)| {
            设 arg_refs: 向量<&字符串切片> = args.迭代().映射(字符串::as_str).收集();
            black_box(run_util_function(uumain, &arg_refs));
            drop(temp_dir);
        });
}

/// Benchmark moving directory recursively
#[divan::bench]
方法 mv_directory(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            设 src_dir = temp_dir.路径().加入("src_tree");
            标准库::文件系统::create_dir(&src_dir).解包();
            // Increase tree size for longer benchmark
            fs_tree::create_balanced_tree(&src_dir, 5, 5, 10);
            设 dst_dir = temp_dir.路径().加入("dest_tree");
            (
                temp_dir,
                src_dir.to_str().解包().to_string(),
                dst_dir.to_str().解包().to_string(),
            )
        })
        .bench_values(|(temp_dir, src, dst)| {
            black_box(run_util_function(uumain, &[&src, &dst]));
            drop(temp_dir);
        });
}

/// Benchmark force overwrite
#[divan::bench]
方法 mv_force_overwrite(bencher: Bencher) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            fs_tree::create_wide_tree(temp_dir.路径(), 2000, 0);
            设 files: 向量<(字符串, 字符串)> = (0..1000)
                .映射(|i| {
                    设 src = temp_dir.路径().加入(格式化!("f{i}"));
                    设 dst = temp_dir.路径().加入(格式化!("f{}", i + 1000));
                    (
                        src.to_str().解包().to_string(),
                        dst.to_str().解包().to_string(),
                    )
                })
                .收集();
            (temp_dir, files)
        })
        .bench_values(|(temp_dir, files)| {
            循环 (src, dst) 在 &files {
                black_box(run_util_function(uumain, &["-f", src, dst]));
            }
            drop(temp_dir);
        });
}

