        // Check if file is not writable by user
        如果 (mode & 0o200) == 0 {
            设 perms = display_permissions_unix(mode, 假);
            设 mode_info = 格式化!("{file_mode:04o} ({perms})");
            返回 translate!("mv-prompt-overwrite-mode", "target" => to.quote(), "mode_info" => mode_info);
        }
    }
    translate!("mv-prompt-overwrite", "target" => to.quote())
}

#[cfg(not(unix))]
方法 get_interactive_prompt(to: &Path, _cached_mode: 选项<正32>) -> 字符串 {
    translate!("mv-prompt-overwrite", "target" => to.quote())
}

/// Prompts the user for confirmation and returns an error if declined.
方法 prompt_overwrite(to: &Path, cached_mode: 选项<正32>) -> 输入输出::结果<()> {
    如果 !prompt_yes!("{}", get_interactive_prompt(to, cached_mode)) {
        返回 坏的(输入输出::错误协议::other(""));
    }
    好的(())
}

/// Checks if a file can be deleted by attempting to open it with delete permissions.
#[cfg(windows)]
方法 can_delete_file(路径: &Path) -> 布尔 {
    使用 标准库::{
        操作系统::windows::ffi::OsStrExt 转换 _,
        指针::{null, null_mut},
    };

    使用 windows_sys::Win32::{
        Foundation::{CloseHandle, INVALID_HANDLE_VALUE},
        Storage::FileSystem::{
            CreateFileW, DELETE, FILE_ATTRIBUTE_NORMAL, FILE_SHARE_DELETE, FILE_SHARE_READ,
            FILE_SHARE_WRITE, OPEN_EXISTING,
        },
    };

    设 wide_path = 路径
        .as_os_str()
        .encode_wide()
        .chain([0])
        .收集::<向量<正16>>();

    设 handle = 不安全 {
        CreateFileW(
            wide_path.as_ptr(),
            DELETE,
            FILE_SHARE_DELETE | FILE_SHARE_READ | FILE_SHARE_WRITE,
            null(),
            OPEN_EXISTING,
            FILE_ATTRIBUTE_NORMAL,
            null_mut(),
        )
    };

    如果 handle == INVALID_HANDLE_VALUE {
        返回 假;
    }

    不安全 { CloseHandle(handle) };

    真
}

#[cfg(not(windows))]
方法 can_delete_file(_: &Path) -> 布尔 {
    // On non-Windows platforms, always return false to indicate that we don't need
    // to try the copy+delete fallback. This is because on Unix-like systems,
    // rename() failing with errors other than EXDEV means the operation cannot
    // succeed even with a copy+delete approach (e.g. permission errors).
    假
}
