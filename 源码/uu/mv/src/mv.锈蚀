公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 files: 向量<OsString> = matches
        .get_many::<OsString>(ARG_FILES)
        .unwrap_or_default()
        .cloned()
        .收集();

    如果 files.长度() == 1 && !matches.contains_id(OPT_TARGET_DIRECTORY) {
        设 err = uu_app().错误(
            ErrorKind::TooFewValues,
            translate!("mv-error-insufficient-arguments", "arg_files" => ARG_FILES),
        );
        uucore::clap_localization::handle_clap_error_with_exit_code(err, 1);
    }

    设 overwrite_mode = determine_overwrite_mode(&matches);
    设 backup_mode = backup_control::determine_backup_mode(&matches)?;
    设 update_mode = update_control::determine_update_mode(&matches);

    如果 backup_mode != BackupMode::无
        && (overwrite_mode == OverwriteMode::NoClobber
            || update_mode == UpdateMode::无
            || update_mode == UpdateMode::NoneFail)
    {
        返回 坏的(UUsageError::新建(
            1,
            translate!("mv-error-backup-with-no-clobber"),
        ));
    }

    设 backup_suffix = backup_control::determine_backup_suffix(&matches);

    设 target_dir = matches
        .get_one::<OsString>(OPT_TARGET_DIRECTORY)
        .映射(OsString::from);

    如果 设 一些(引用 maybe_dir) = target_dir {
        如果 !Path::新建(&maybe_dir).is_dir() {
            返回 坏的(MvError::TargetNotADirectory(maybe_dir.quote().to_string()).into());
        }
    }

    // Handle -Z and --context options
    // If -Z is used, use the default context (empty string)
    // If --context=value is used, use that specific value
    设 context = 如果 matches.get_flag(OPT_SELINUX) {
        一些(字符串::新建())
    } 否则 {
        matches.get_one::<字符串>(OPT_CONTEXT).cloned()
    };

    设 opts = Options {
        overwrite: overwrite_mode,
        backup: backup_mode,
        suffix: backup_suffix,
        update: update_mode,
        target_dir,
        no_target_dir: matches.get_flag(OPT_NO_TARGET_DIRECTORY),
        verbose: matches.get_flag(OPT_VERBOSE) || matches.get_flag(OPT_DEBUG),
        strip_slashes: matches.get_flag(OPT_STRIP_TRAILING_SLASHES),
        progress_bar: matches.get_flag(OPT_PROGRESS),
        debug: matches.get_flag(OPT_DEBUG),
        context,
    };

    mv(&files[..], &opts)
}

