/// A wrapper around `fs::rename`, so that if it fails, we try falling back on
/// copying and removing.
方法 rename_with_fallback(
    from: &Path,
    to: &Path,
    display_manager: 选项<&MultiProgress>,
    verbose: 布尔,
    #[cfg(unix)] hardlink_tracker: 选项<&可变 HardlinkTracker>,
    #[cfg(unix)] hardlink_scanner: 选项<&HardlinkGroupScanner>,
    #[cfg(not(unix))] _hardlink_tracker: 选项<()>,
    #[cfg(not(unix))] _hardlink_scanner: 选项<()>,
) -> 输入输出::结果<()> {
    文件系统::rename(from, to).or_else(|err| {
        #[cfg(windows)]
        常量 EXDEV: 整32 = windows_sys::Win32::Foundation::ERROR_NOT_SAME_DEVICE 转换 _;
        #[cfg(unix)]
        常量 EXDEV: 整32 = libc::EXDEV 转换 _;
        #[cfg(target_os = "wasi")]
        常量 EXDEV: 整32 = 18; // POSIX EXDEV value

        // We will only copy if:
        // 1. Files are on different devices (EXDEV error)
        // 2. On Windows, if the target file exists and source file is opened by another process
        //    (MoveFileExW fails with "Access Denied" even if the source file has FILE_SHARE_DELETE permission)
        设 should_fallback =
            matches!(err.raw_os_error(), 一些(EXDEV)) || (from.is_file() && can_delete_file(from));
        如果 !should_fallback {
            返回 坏的(err);
        }
        // Get metadata without following symlinks
        设 metadata = from.symlink_metadata()?;
        设 file_type = metadata.file_type();
        如果 file_type.is_symlink() {
            rename_symlink_fallback(from, to)
        } 否则 如果 file_type.is_dir() {
            #[cfg(unix)]
            {
                with_optional_hardlink_context(
                    hardlink_tracker,
                    hardlink_scanner,
                    |tracker, scanner| {
                        rename_dir_fallback(
                            from,
                            to,
                            display_manager,
                            verbose,
                            一些(tracker),
                            一些(scanner),
                        )
                    },
                )
            }
            #[cfg(not(unix))]
            {
                rename_dir_fallback(from, to, display_manager, verbose)
            }
        } 否则 如果 is_fifo(file_type) {
            rename_fifo_fallback(from, to)
        } 否则 {
            #[cfg(unix)]
            {
                with_optional_hardlink_context(
                    hardlink_tracker,
                    hardlink_scanner,
                    |tracker, scanner| rename_file_fallback(from, to, 一些(tracker), 一些(scanner)),
                )
            }
            #[cfg(not(unix))]
            {
                rename_file_fallback(from, to)
            }
        }
    })
}

