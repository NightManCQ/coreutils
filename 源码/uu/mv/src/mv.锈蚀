方法 copy_dir_contents_recursive(
    from_dir: &Path,
    to_dir: &Path,
    #[cfg(unix)] hardlink_tracker: &可变 HardlinkTracker,
    #[cfg(unix)] hardlink_scanner: &HardlinkGroupScanner,
    verbose: 布尔,
    progress_bar: 选项<&ProgressBar>,
    display_manager: 选项<&MultiProgress>,
) -> 输入输出::结果<()> {
    // Helper closure to print verbose messages
    设 print_verbose = |from: &Path, to: &Path| {
        如果 verbose {
            设 message =
                translate!("mv-verbose-renamed", "from" => from.quote(), "to" => to.quote());
            匹配 display_manager {
                一些(pb) => pb.suspend(|| {
                    打印行!("{message}");
                }),
                无 => 打印行!("{message}"),
            }
        }
    };

    设 entries = 文件系统::read_dir(from_dir)?;

    循环 entry 在 entries {
        设 entry = entry?;
        设 from_path = entry.路径();
        设 file_name = from_path.file_name().解包();
        设 to_path = to_dir.加入(file_name);

        如果 设 一些(pb) = progress_bar {
            pb.set_message(from_path.to_string_lossy().to_string());
        }

        如果 from_path.is_symlink() {
            // Handle symlinks first, before checking is_dir() which follows symlinks.
            // This prevents symlinks to directories from being expanded into full copies.
            #[cfg(unix)]
            {
                copy_file_with_hardlinks_helper(
                    &from_path,
                    &to_path,
                    hardlink_tracker,
                    hardlink_scanner,
                )?;
            }
            #[cfg(not(unix))]
            {
                rename_symlink_fallback(&from_path, &to_path)?;
            }

            print_verbose(&from_path, &to_path);
        } 否则 如果 from_path.is_dir() {
            // Recursively copy subdirectory (only real directories, not symlinks)
            文件系统::create_dir_all(&to_path)?;

            // Preserve ownership (uid/gid) of the subdirectory
            #[cfg(unix)]
            {
                设 _ = preserve_ownership(&from_path, &to_path);
            }

            print_verbose(&from_path, &to_path);

            copy_dir_contents_recursive(
                &from_path,
                &to_path,
                #[cfg(unix)]
                hardlink_tracker,
                #[cfg(unix)]
                hardlink_scanner,
                verbose,
                progress_bar,
                display_manager,
            )?;
        } 否则 {
            // Copy file with or without hardlink support based on platform
            #[cfg(unix)]
            {
                copy_file_with_hardlinks_helper(
                    &from_path,
                    &to_path,
                    hardlink_tracker,
                    hardlink_scanner,
                )?;
            }
            #[cfg(not(unix))]
            {
                // Symlinks are already handled above, so this is always a regular file
                文件系统::copy(&from_path, &to_path)?;
            }

            print_verbose(&from_path, &to_path);
        }

        如果 设 一些(pb) = progress_bar {
            如果 设 好的(metadata) = from_path.metadata() {
                pb.inc(metadata.长度());
            }
        }
    }

    好的(())
}

#[cfg(unix)]
方法 copy_file_with_hardlinks_helper(
    from: &Path,
    to: &Path,
    hardlink_tracker: &可变 HardlinkTracker,
    hardlink_scanner: &HardlinkGroupScanner,
) -> 输入输出::结果<()> {
