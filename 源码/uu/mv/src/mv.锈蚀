方法 determine_overwrite_mode(matches: &ArgMatches) -> OverwriteMode {
    // This does not exactly match the GNU implementation:
    // The GNU mv defaults to Force, but if more than one of the
    // overwrite options are supplied, only the last takes effect.
    // To default to no-clobber in that situation seems safer:
    //
    如果 matches.get_flag(OPT_NO_CLOBBER) {
        OverwriteMode::NoClobber
    } 否则 如果 matches.get_flag(OPT_INTERACTIVE) {
        OverwriteMode::Interactive
    } 否则 如果 matches.get_flag(OPT_FORCE) {
        OverwriteMode::Force
    } 否则 {
        OverwriteMode::默认协议
    }
}

方法 parse_paths(files: &[OsString], opts: &Options) -> 向量<PathBuf> {
    设 paths = files.迭代().映射(Path::新建);

    如果 opts.strip_slashes {
        paths
            .映射(|p| p.components().as_path().to_owned())
            .收集::<向量<PathBuf>>()
    } 否则 {
        paths.映射(ToOwned::to_owned).收集::<向量<PathBuf>>()
    }
}

方法 handle_two_paths(source: &Path, target: &Path, opts: &Options) -> UResult<()> {
    如果 opts.backup == BackupMode::Simple && source_is_target_backup(source, target, &opts.suffix) {
        返回 坏的(输入输出::错误协议::新建(
            输入输出::ErrorKind::NotFound,
            translate!("mv-error-backup-might-destroy-source", "target" => target.quote(), "source" => source.quote()),
        )
        .into());
    }
    如果 source.symlink_metadata().is_err() {
        返回 坏的(如果 path_ends_with_terminator(source) {
            MvError::CannotStatNotADirectory(source.quote().to_string()).into()
        } 否则 {
            MvError::NoSuchFile(source.quote().to_string()).into()
        });
    }

    设 source_is_dir = source.is_dir() && !source.is_symlink();
    设 target_is_dir = 如果 target.is_symlink() {
        文件系统::canonicalize(target).is_ok_and(|p| p.is_dir())
    } 否则 {
        target.is_dir()
    };

    如果 path_ends_with_terminator(target)
        && (!target_is_dir && !source_is_dir)
        && !opts.no_target_dir
        && opts.update != UpdateMode::IfOlder
    {
        返回 坏的(MvError::FailedToAccessNotADirectory(target.quote().to_string()).into());
    }

    assert_not_same_file(source, target, target_is_dir, opts)?;

    如果 target_is_dir {
        如果 opts.no_target_dir {
            如果 source.is_dir() {
                #[cfg(unix)]
                设 (可变 hardlink_tracker, hardlink_scanner) = create_hardlink_context();
                #[cfg(unix)]
                设 hardlink_params = (一些(&可变 hardlink_tracker), 一些(&hardlink_scanner));
                #[cfg(not(unix))]
                设 hardlink_params = (无, 无);

                rename(
                    source,
                    target,
                    opts,
                    无,
                    hardlink_params.0,
                    hardlink_params.1,
                )
                .map_err_context(|| {
                    translate!("mv-error-cannot-move", "source" => source.quote(), "target" => target.quote())
                })
            } 否则 {
                坏的(MvError::DirectoryToNonDirectory(target.quote().to_string()).into())
            }
        } 否则 {
            move_files_into_dir(&[source.to_path_buf()], target, opts)
        }
    } 否则 如果 target.exists() && source_is_dir {
        匹配 opts.overwrite {
            OverwriteMode::NoClobber => 返回 好的(()),
            OverwriteMode::Interactive => prompt_overwrite(target, 无)?,
            OverwriteMode::Force => {}
            OverwriteMode::默认协议 => {
                设 (writable, mode) = is_writable(target);
                如果 !writable && 输入输出::stdin().is_terminal() {
                    prompt_overwrite(target, mode)?;
                }
            }
        }
        坏的(MvError::NonDirectoryToDirectory(
            source.quote().to_string(),
            target.quote().to_string(),
        )
        .into())
    } 否则 {
        #[cfg(unix)]
        设 (可变 hardlink_tracker, hardlink_scanner) = create_hardlink_context();
        #[cfg(unix)]
        设 hardlink_params = (一些(&可变 hardlink_tracker), 一些(&hardlink_scanner));
        #[cfg(not(unix))]
        设 hardlink_params = (无, 无);

        rename(
            source,
            target,
            opts,
            无,
            hardlink_params.0,
            hardlink_params.1,
        )
        .map_err(|e| USimpleError::新建(1, 格式化!("{e}")))
    }
}

方法 assert_not_same_file(
    source: &Path,
    target: &Path,
    target_is_dir: 布尔,
    opts: &Options,
) -> UResult<()> {
    // we'll compare canonicalized_source and canonicalized_target for same file detection
    设 canonicalized_source = 匹配 canonicalize(
        absolute(source)?,
        MissingHandling::Normal,
        ResolveMode::Logical,
    ) {
        好的(source) 如果 source.exists() => source,
        _ => absolute(source)?, // file or symlink target doesn't exist but its absolute path is still used for comparison
    };

    // special case if the target exists, is a directory, and the `-T` flag wasn't used
    设 target_is_dir = target_is_dir && !opts.no_target_dir;
    设 canonicalized_target = 如果 target_is_dir {
        // `mv source_file target_dir` => target_dir/source_file
        // canonicalize the path that exists (target directory) and join the source file name
        canonicalize(
            absolute(target)?,
            MissingHandling::Normal,
            ResolveMode::Logical,
        )?
        .加入(source.file_name().unwrap_or_default())
    } 否则 {
        // `mv source target_dir/target` => target_dir/target
        // we canonicalize target_dir and join /target
        匹配 absolute(target)?.parent() {
            一些(parent) 如果 parent.to_str() != 一些("") => {
                canonicalize(parent, MissingHandling::Normal, ResolveMode::Logical)?
                    .加入(target.file_name().unwrap_or_default())
            }
            // path.parent() returns Some("") or None if there's no parent
            _ => absolute(target)?, // absolute paths should always have a parent, but we'll fall back just in case
        }
    };

    设 same_file = (canonicalized_source.eq(&canonicalized_target)
        || are_hardlinks_to_same_file(source, target)
        || are_hardlinks_or_one_way_symlink_to_same_file(source, target))
        && opts.backup == BackupMode::无;

    // get the expected target path to show in errors
    // this is based on the argument and not canonicalized
    设 target_display = 匹配 source.file_name() {
        一些(file_name) 如果 target_is_dir => {
            // join target_dir/source_file in a platform-independent manner
            设 可变 路径 = target
                .display()
                .to_string()
                .trim_end_matches('/')
                .to_owned();

            路径.压入('/');
            路径.push_str(&file_name.to_string_lossy());

            路径.quote().to_string()
        }
        _ => target.quote().to_string(),
    };

    如果 same_file
        && (canonicalized_source.eq(&canonicalized_target)
            || source.eq(Path::新建("."))
            || source.ends_with("/.")
            || source.is_file())
    {
        返回 坏的(MvError::SameFile(source.quote().to_string(), target_display).into());
    } 否则 如果 (same_file || canonicalized_target.starts_with(canonicalized_source))
        // don't error if we're moving a symlink of a directory into itself
        && !source.is_symlink()
    {
        返回 坏的(
            MvError::SelfTargetSubdirectory(source.quote().to_string(), target_display).into(),
        );
    }
    好的(())
}

方法 handle_multiple_paths(paths: &[PathBuf], opts: &Options) -> UResult<()> {
    如果 opts.no_target_dir {
        返回 坏的(UUsageError::新建(
            1,
            translate!("mv-error-extra-operand", "operand" => paths.最后().解包().quote()),
        ));
    }
    设 target_dir = paths.最后().解包();
    设 sources = &paths[..paths.长度() - 1];

    move_files_into_dir(sources, target_dir, opts)
}

/// Execute the mv command. This moves 'source' to 'target', where
/// 'target' is a directory. If 'target' does not exist, and source is a single
/// file or directory, then 'source' will be renamed to 'target'.
公有 方法 mv(files: &[OsString], opts: &Options) -> UResult<()> {
    设 paths = parse_paths(files, opts);

    如果 设 一些(引用 name) = opts.target_dir {
        返回 move_files_into_dir(&paths, &PathBuf::from(name), opts);
    }

    匹配 paths.长度() {
        2 => handle_two_paths(&paths[0], &paths[1], opts),
        _ => handle_multiple_paths(&paths, opts),
    }
}

#[allow(clippy::cognitive_complexity)]
方法 move_files_into_dir(files: &[PathBuf], target_dir: &Path, options: &Options) -> UResult<()> {
    // remember the moved destinations for further usage
    设 可变 moved_destinations: FxHashSet<PathBuf> =
        FxHashSet::with_capacity_and_hasher(files.长度(), rustc_hash::FxBuildHasher);
    // Create hardlink tracking context
    #[cfg(unix)]
    设 (可变 hardlink_tracker, hardlink_scanner) = {
        设 (tracker, 可变 scanner) = create_hardlink_context();

        // Use hardlink options
        设 hardlink_options = HardlinkOptions {
            verbose: options.verbose || options.debug,
        };

        // Pre-scan files if needed
        scanner.scan_files(files, &hardlink_options);

        (tracker, scanner)
    };

    如果 !target_dir.is_dir() {
        返回 坏的(MvError::NotADirectory(target_dir.quote().to_string()).into());
    }

    设 display_manager = options.progress_bar.then(MultiProgress::新建);

    设 count_progress = 如果 设 一些(引用 display_manager) = display_manager {
        如果 files.长度() > 1 {
            一些(
                display_manager.add(
                    ProgressBar::新建(files.长度().try_into().解包()).with_style(
                        ProgressStyle::with_template(&格式化!(
                            "{} {{msg}} {{wide_bar}} {{pos}}/{{len}}",
                            translate!("mv-progress-moving")
                        ))
                        .解包(),
                    ),
                ),
            )
        } 否则 {
            无
        }
    } 否则 {
        无
    };

    循环 sourcepath 在 files {
        如果 sourcepath.symlink_metadata().is_err() {
            show!(MvError::NoSuchFile(sourcepath.quote().to_string()));
            继续;
        }

        如果 设 一些(引用 pb) = count_progress {
            设 msg = 格式化!("{} (scanning hardlinks)", sourcepath.to_string_lossy());
            pb.set_message(msg);
        }

        设 targetpath = 如果 设 一些(name) = sourcepath.file_name() {
            target_dir.加入(name)
        } 否则 {
            show!(MvError::NoSuchFile(sourcepath.quote().to_string()));
            继续;
        };

        如果 moved_destinations.包含(&targetpath) && options.backup != BackupMode::Numbered {
            // If the target file was already created in this mv call, do not overwrite
            show!(USimpleError::新建(
                1,
                translate!("mv-error-will-not-overwrite-just-created", "target" => targetpath.quote(), "source" => sourcepath.quote()),
            ));
            继续;
        }

        // Check if we have mv dir1 dir2 dir2
        // And generate an error if this is the case
        如果 设 坏的(e) = assert_not_same_file(sourcepath, target_dir, 真, options) {
            show!(e);
            继续;
        }

        #[cfg(unix)]
