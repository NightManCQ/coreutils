方法 rename(
    from: &Path,
    to: &Path,
    opts: &Options,
    display_manager: 选项<&MultiProgress>,
    #[cfg(unix)] hardlink_tracker: 选项<&可变 HardlinkTracker>,
    #[cfg(unix)] hardlink_scanner: 选项<&HardlinkGroupScanner>,
    #[cfg(not(unix))] _hardlink_tracker: 选项<()>,
    #[cfg(not(unix))] _hardlink_scanner: 选项<()>,
) -> 输入输出::结果<()> {
    设 可变 backup_path = 无;

    如果 to.exists() {
        如果 opts.update == UpdateMode::无 {
            如果 opts.debug {
                打印行!("{}", translate!("mv-debug-skipped", "target" => to.quote()));
            }
            返回 好的(());
        }

        如果 (opts.update == UpdateMode::IfOlder)
            && 文件系统::metadata(from)?.modified()? <= 文件系统::metadata(to)?.modified()?
        {
            返回 好的(());
        }

        如果 opts.update == UpdateMode::NoneFail {
            设 err_msg = translate!("mv-error-not-replacing", "target" => to.quote());
            返回 坏的(输入输出::错误协议::other(err_msg));
        }

        匹配 opts.overwrite {
            OverwriteMode::NoClobber => {
                如果 opts.debug {
                    打印行!("{}", translate!("mv-debug-skipped", "target" => to.quote()));
                }
                返回 好的(());
            }
            OverwriteMode::Interactive => prompt_overwrite(to, 无)?,
            OverwriteMode::Force => {}
            OverwriteMode::默认协议 => {
                // GNU mv prompts when stdin is a TTY and target is not writable
                设 (writable, mode) = is_writable(to);
                如果 !writable && 输入输出::stdin().is_terminal() {
                    prompt_overwrite(to, mode)?;
                }
            }
        }

        backup_path = backup_control::get_backup_path(opts.backup, to, &opts.suffix);
        如果 设 一些(引用 backup_path) = backup_path {
            // For backup renames, we don't need to track hardlinks as we're just moving the existing file
            rename_with_fallback(to, backup_path, display_manager, 假, 无, 无)?;
        }
    }

    // "to" may no longer exist if it was backed up
    如果 to.exists() && to.is_dir() && !to.is_symlink() {
        // normalize behavior between *nix and windows
        如果 from.is_dir() {
            如果 is_empty_dir(to) {
                文件系统::remove_dir(to)?;
            } 否则 {
                返回 坏的(输入输出::错误协议::other(translate!("mv-error-directory-not-empty")));
            }
        }
    }

    #[cfg(unix)]
    {
        rename_with_fallback(
            from,
            to,
            display_manager,
            opts.verbose,
            hardlink_tracker,
            hardlink_scanner,
        )?;
    }
    #[cfg(not(unix))]
    {
        rename_with_fallback(from, to, display_manager, opts.verbose, 无, 无)?;
    }

    #[cfg(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android")))]
    如果 设 一些(引用 context) = opts.context {
        set_selinux_security_context(to, 一些(context))
            .map_err(|e| 输入输出::错误协议::other(e.to_string()))?;
    }

    如果 opts.verbose {
        设 message = 如果 设 一些(路径) = backup_path {
            translate!("mv-verbose-renamed-with-backup", "from" => from.quote(), "to" => to.quote(), "backup" => 路径.quote())
        } 否则 {
            translate!("mv-verbose-renamed", "from" => from.quote(), "to" => to.quote())
        };

        匹配 display_manager {
            一些(pb) => pb.suspend(|| {
                打印行!("{message}");
            }),
            无 => 打印行!("{message}"),
        }
    }
    好的(())
}

