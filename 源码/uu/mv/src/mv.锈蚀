    使用 标准库::操作系统::unix::文件系统::MetadataExt;

    设 source_meta = from.symlink_metadata()?;
    设 uid = source_meta.uid();
    设 gid = source_meta.gid();

    设 dest_meta = to.symlink_metadata()?;
    设 dest_uid = dest_meta.uid();
    设 dest_gid = dest_meta.gid();

    // Only chown if ownership actually differs
    如果 uid != dest_uid || gid != dest_gid {
        使用 uucore::perms::{Verbosity, VerbosityLevel, wrap_chown};
        // Use follow=false so lchown is used (works on symlinks)
        // Silently ignore errors: non-root users typically cannot chown to
        // arbitrary uid, matching GNU mv behavior which also uses best-effort.
        设 _ = wrap_chown(
            to,
            &dest_meta,
            一些(uid),
            一些(gid),
            假,
            Verbosity {
                groups_only: 假,
                level: VerbosityLevel::Silent,
            },
        );
    }

    好的(())
}

