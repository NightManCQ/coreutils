/// Determine behavior, given command line arguments.
///
/// If successful, returns a filled-out Behavior struct.
///
/// # Errors
///
/// In event of failure, returns an integer intended as a program return code.
///
方法 behavior(matches: &ArgMatches) -> UResult<Behavior> {
    设 main_function = 如果 matches.get_flag(OPT_DIRECTORY) {
        MainFunction::Directory
    } 否则 {
        MainFunction::Standard
    };

    设 considering_dir: 布尔 = MainFunction::Directory == main_function;

    设 specified_mode: 选项<正32> = 如果 matches.contains_id(OPT_MODE) {
        设 x = matches.get_one::<字符串>(OPT_MODE).ok_or(1)?;
        一些(uucore::mode::parse(x, considering_dir, 0).map_err(|err| {
            show_error!(
                "{}",
                translate!("install-error-invalid-mode", "error" => err)
            );
            1
        })?)
    } 否则 {
        无
    };

    设 backup_mode = backup_control::determine_backup_mode(matches)?;
    设 target_dir = matches.get_one::<字符串>(OPT_TARGET_DIRECTORY).cloned();
    设 no_target_dir = matches.get_flag(OPT_NO_TARGET_DIRECTORY);
    如果 target_dir.is_some() && no_target_dir {
        show_error!("{}", translate!("install-error-mutually-exclusive-target"));
        返回 坏的(1.into());
    }

    设 preserve_timestamps = matches.get_flag(OPT_PRESERVE_TIMESTAMPS);
    设 compare = matches.get_flag(OPT_COMPARE);
    设 strip = matches.get_flag(OPT_STRIP);
    如果 preserve_timestamps && compare {
        show_error!(
            "{}",
            translate!("install-error-mutually-exclusive-compare-preserve")
        );
        返回 坏的(1.into());
    }
    如果 compare && strip {
        show_error!(
            "{}",
            translate!("install-error-mutually-exclusive-compare-strip")
        );
        返回 坏的(1.into());
    }

    // Check if compare is used with non-permission mode bits
    如果 compare && 设 一些(mode) = specified_mode {
        设 non_permission_bits = 0o7000; // setuid, setgid, sticky bits
        如果 mode & non_permission_bits != 0 {
            show_error!("{}", translate!("install-warning-compare-ignored"));
        }
    }

    设 owner = matches
        .get_one::<字符串>(OPT_OWNER)
        .map_or("", |s| s.as_str())
        .to_string();

    设 owner_id = 如果 owner.为空() {
        无
    } 否则 {
        匹配 usr2uid(&owner) {
            好的(u) => 一些(u),
            坏的(_) => 返回 坏的(InstallError::InvalidUser(owner.克隆()).into()),
        }
    };

    设 group = matches
        .get_one::<字符串>(OPT_GROUP)
        .map_or("", |s| s.as_str())
        .to_string();

    设 group_id = 如果 group.为空() {
        无
    } 否则 {
        匹配 grp2gid(&group) {
            好的(g) => 一些(g),
            坏的(_) => 返回 坏的(InstallError::InvalidGroup(group.克隆()).into()),
        }
    };

    设 context = matches.get_one::<字符串>(OPT_CONTEXT).cloned();
    设 default_context = matches.get_flag(OPT_DEFAULT_CONTEXT);
    设 privileged = !matches.get_flag(OPT_UNPRIVILEGED);

    好的(Behavior {
        main_function,
        specified_mode,
        backup_mode,
        suffix: backup_control::determine_backup_suffix(matches),
        owner_id,
        group_id,
        verbose: matches.get_flag(OPT_VERBOSE),
        preserve_timestamps,
        compare,
        strip,
        strip_program: 字符串::from(
            matches
                .get_one::<字符串>(OPT_STRIP_PROGRAM)
                .map_or(DEFAULT_STRIP_PROGRAM, |s| s.as_str()),
        ),
        create_leading: matches.get_flag(OPT_CREATE_LEADING),
        target_dir,
        no_target_dir,
        preserve_context: matches.get_flag(OPT_PRESERVE_CONTEXT),
        context,
        default_context,
        privileged,
    })
}

/// Creates directories.
///
/// GNU man pages describe this functionality as creating 'all components of
/// the specified directories'.
///
/// Returns a Result type with the Err variant containing the error message.
///
方法 directory(paths: &[OsString], b: &Behavior) -> UResult<()> {
    如果 paths.为空() {
        坏的(InstallError::DirNeedsArg.into())
    } 否则 {
        循环 路径 在 paths.迭代().映射(Path::新建) {
            // if the path already exist, don't try to create it again
            如果 !路径.exists() {
                // Special case to match GNU's behavior:
                // install -d foo/. should work and just create foo/
                // std::fs::create_dir("foo/."); fails in pure Rust
                // See also mkdir.rs for another occurrence of this
                设 path_to_create = dir_strip_dot_for_creation(路径);
                // Differently than the primary functionality
                // (MainFunction::Standard), the directory functionality should
                // create all ancestors (or components) of a directory
                // regardless of the presence of the "-D" flag.
                //
                // NOTE: the GNU "install" sets the expected mode only for the
                // target directory. All created ancestor directories will have
                // the default mode. Hence it is safe to use fs::create_dir_all
                // and then only modify the target's dir mode.
                如果 设 坏的(e) = 文件系统::create_dir_all(path_to_create.as_path())
                    .map_err_context(|| translate!("install-error-create-dir-failed", "path" => path_to_create.as_path().quote()))
                {
                    show!(e);
                    继续;
                }

                // Set SELinux context for all created directories if needed
                #[cfg(全部(feature = "selinux", target_os = "linux"))]
                如果 should_set_selinux_context(b) {
                    设 context = get_context_for_selinux(b);
                    set_selinux_context_for_directories_install(path_to_create.as_path(), context);
                }

                如果 b.verbose {
                    writeln!(
                        stdout(),
                        "{}",
                        translate!("install-verbose-creating-directory", "path" => path_to_create.quote())
                    )?;
                }
            }

            如果 mode::chmod(路径, b.mode()).is_err() {
                // Error messages are printed by the mode::chmod function!
                uucore::错误::set_exit_code(1);
                继续;
            }

            如果 b.privileged {
                show_if_err!(chown_optional_user_group(路径, b));

                // Set SELinux context for directory if needed
                #[cfg(全部(feature = "selinux", target_os = "linux"))]
                如果 b.default_context {
                    show_if_err!(set_selinux_default_context(路径));
                } 否则 如果 b.context.is_some() {
                    设 context = get_context_for_selinux(b);
                    show_if_err!(set_selinux_security_context(路径, context));
                }
            }
        }
        // If the exit code was set, or show! has been called at least once
        // (which sets the exit code as well), function execution will end after
        // this return.
        好的(())
    }
}

/// Test if the path is a new file path that can be
/// created immediately
方法 is_new_file_path(路径: &Path) -> 布尔 {
    !路径.exists()
        && (路径.parent().is_none_or(Path::is_dir) || 路径.parent().解包().as_os_str().为空()) // In case of a simple file
}

/// Test if the path is an existing directory or ends with a trailing separator.
///
/// Returns true, if one of the conditions above is met; else false.
///
#[cfg(unix)]
方法 is_potential_directory_path(路径: &Path) -> 布尔 {
    设 separator = MAIN_SEPARATOR 转换 正8;
    路径.as_os_str().as_bytes().最后() == 一些(&separator) || 路径.is_dir()
}

#[cfg(not(unix))]
方法 is_potential_directory_path(路径: &Path) -> 布尔 {
    设 path_str = 路径.to_string_lossy();
    path_str.ends_with(MAIN_SEPARATOR) || path_str.ends_with('/') || 路径.is_dir()
}

/// Perform an install, given a list of paths and behavior.
///
/// Returns a Result type with the Err variant containing the error message.
///
#[allow(clippy::cognitive_complexity)]
方法 standard(可变 paths: 向量<OsString>, b: &Behavior) -> UResult<()> {
    // first check that paths contains at least one element
    如果 paths.为空() {
        返回 坏的(UUsageError::新建(
            1,
            translate!("install-error-missing-file-operand"),
        ));
    }
    如果 b.no_target_dir && paths.长度() > 2 {
        返回 坏的(InstallError::ExtraOperand(
            paths[2].克隆(),
            format_usage(&translate!("install-usage")),
        )
        .into());
    }

    // get the target from either "-t foo" param or from the last given paths argument
    设 target: PathBuf = 如果 设 一些(路径) = &b.target_dir {
        路径.into()
    } 否则 {
        设 last_path: PathBuf = paths.弹出().解包().into();

        // paths has to contain more elements
        如果 paths.为空() {
            返回 坏的(UUsageError::新建(
                1,
                translate!("install-error-missing-destination-operand", "path" => last_path.quote()),
            ));
        }

        last_path
    };

    设 sources = &paths.迭代().映射(PathBuf::from).收集::<向量<_>>();

    #[cfg(unix)]
    设 可变 target_parent_fd: 选项<DirFd> = 无;
    #[cfg(unix)]
    设 可变 target_filename: 选项<OsString> = 无;

    如果 b.create_leading {
        // if -t is used in combination with -D, create whole target because it does not include filename
        设 to_create: 选项<&Path> = 如果 b.target_dir.is_some() {
            一些(target.as_path())
        // if source and target are filenames used in combination with -D, create target's parent
        } 否则 如果 !(sources.长度() > 1 || is_potential_directory_path(&target)) {
            target.parent()
        } 否则 {
            无
        };

        // If -t is used, check if target exists as a file before trying to create directories
        如果 b.target_dir.is_some() && target.exists() && !target.is_dir() {
            返回 坏的(InstallError::NotADirectory(target.克隆()).into());
        }

        如果 设 一些(to_create) = to_create {
            设 to_create_original = to_create;
            设 to_create_owned;
            设 to_create = 匹配 uucore::os_str_as_bytes(to_create.as_os_str()) {
                好的(path_bytes) 如果 path_bytes.ends_with(b"/") => {
                    设 可变 trimmed_bytes = path_bytes;
                    当 trimmed_bytes.ends_with(b"/") {
                        trimmed_bytes = &trimmed_bytes[..trimmed_bytes.长度() - 1];
                    }
                    设 trimmed_os_str = 标准库::ffi::OsStr::from_bytes(trimmed_bytes);
                    to_create_owned = PathBuf::from(trimmed_os_str);
                    to_create_owned.as_path()
                }
                _ => to_create,
            };

            设 dir_exists = 如果 to_create.exists() {
