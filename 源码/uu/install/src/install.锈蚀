/// Main install utility function, called from main.rs.
///
/// Returns a program return code.
///
#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 paths: 向量<OsString> = matches
        .get_many::<OsString>(ARG_FILES)
        .映射(|v| v.cloned().收集())
        .unwrap_or_default();

    设 behavior = behavior(&matches)?;

    匹配 behavior.main_function {
        MainFunction::Directory => directory(&paths, &behavior),
        MainFunction::Standard => standard(paths, &behavior),
    }
}

