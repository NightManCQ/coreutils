/// chmod a file or directory on UNIX.
///
/// Adapted from mkdir.rs.  Handles own error printing.
///
#[cfg(任意(unix, target_os = "redox"))]
公有 方法 chmod(路径: &Path, mode: 正32) -> 结果<(), ()> {
    使用 标准库::操作系统::unix::文件系统::PermissionsExt;
    使用 uucore::{display::Quotable, show_error};
    文件系统::set_permissions(路径, 文件系统::Permissions::from_mode(mode)).map_err(|err| {
        show_error!(
            "{}",
            translate!("install-error-chmod-failed-detailed", "path" => 路径.maybe_quote(), "error" => err)
        );
    })
}

