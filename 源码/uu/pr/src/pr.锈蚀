实现 FileLine {
    方法 from_buf(
        file_id: 正整数大小,
        page_number: 正整数大小,
        line_number: 正整数大小,
        buf: &[正8],
        options: &OutputOptions,
    ) -> 自身类型 {
        设 line_content = 如果 设 一些(expand_tabs) = &options.expand_tabs {
            设 可变 result =
                向量::with_capacity(buf.长度() + buf.长度() / 20 * expand_tabs.width 转换 正整数大小);
            循环 b 在 buf {
                apply_expand_tab(&可变 result, *b, expand_tabs);
            }
            result
        } 否则 {
            buf.to_vec()
        };

        自身类型 {
            file_id,
            page_number,
            line_number,
            line_content,
        }
    }
}

