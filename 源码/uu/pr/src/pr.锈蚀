    content_lines_per_page: 正整数大小,
    columns: 正整数大小,
    lines: &[FileLine],
) -> 向量<向量<选项<&FileLine>>> {
    设 num_rows = lines.长度() / columns;
    设 可变 table: 向量<向量<_>> = (0..num_rows)
        .映射(|i| (0..columns).映射(|j| lines.获取(num_rows * j + i)).收集())
        .收集();
    // Fill the rest with Nones.
    循环 _ 在 num_rows..content_lines_per_page {
        table.压入(向量![无; columns]);
    }
    table
}

#[allow(clippy::cognitive_complexity)]
方法 write_columns(
    lines: &[FileLine],
    options: &OutputOptions,
    out: &可变 实现 Write,
) -> 结果<(), 标准库::输入输出::错误协议> {
    设 line_separator = options.content_line_separator.as_bytes();

    设 content_lines_per_page = 如果 options.double_space {
        options.content_lines_per_page / 2
    } 否则 {
        options.content_lines_per_page
    };

    设 columns = options
        .merge_files_print
        .unwrap_or_else(|| get_columns(options));
    设 line_width = options.line_width;
    设 feed_line_present = options.form_feed_used;
    设 可变 not_found_break = 假;

    设 across_mode = options
        .column_mode_options
        .as_ref()
        .is_some_and(|i| i.across_mode);

    设 可变 filled_lines: 向量<选项<&FileLine>> = 向量::新建();
    如果 options.merge_files_print.is_some() {
        设 可变 offset = 0;
        循环 col 在 0..columns {
            设 可变 inserted = 0;
            循环 line 在 &lines[offset..] {
                如果 line.file_id != col {
                    中断;
                }
                filled_lines.压入(一些(line));
                inserted += 1;
            }
            offset += inserted;

            循环 _i 在 inserted..content_lines_per_page {
                filled_lines.压入(无);
            }
        }
    }

    // Group the flat list of lines into a 2-dimensional table of
    // cells, where each row will be printed as a single line in the
    // output.
    设 merge = options.merge_files_print.is_some();
    设 table = 如果 !merge && (lines.长度() < (content_lines_per_page * columns)) {
        to_table_short_file(content_lines_per_page, columns, lines)
    } 否则 如果 across_mode {
        to_table_across(content_lines_per_page, columns, lines)
    } 否则 如果 merge {
        to_table_merged(content_lines_per_page, columns, filled_lines)
    } 否则 {
        to_table(content_lines_per_page, columns, lines)
    };

    设 blank_line = FileLine::默认();
    循环 row 在 table {
        设 indexes = row.长度();
        循环 (i, 单元格) 在 row.迭代().enumerate() {
            如果 单元格.is_none() && options.merge_files_print.is_some() {
                out.write_all(
                    get_line_for_printing(options, &blank_line, columns, i, line_width, indexes)
                        .as_bytes(),
                )?;
            } 否则 如果 单元格.is_none() {
                not_found_break = 真;
                中断;
            } 否则 如果 单元格.is_some() {
                设 file_line = 单元格.解包();

                out.write_all(
                    get_line_for_printing(options, file_line, columns, i, line_width, indexes)
                        .as_bytes(),
                )?;
            }
        }
        如果 not_found_break && feed_line_present {
            中断;
        }
        out.write_all(line_separator)?;
    }

    好的(())
}

方法 get_line_for_printing(
    options: &OutputOptions,
    file_line: &FileLine,
    columns: 正整数大小,
    index: 正整数大小,
    line_width: 选项<正整数大小>,
    indexes: 正整数大小,
) -> 字符串 {
    设 blank_line = 字符串::新建();
    设 formatted_line_number = get_formatted_line_number(options, file_line.line_number, index);

    // TODO: support non-UTF-8 bytes (currently replaced with U+FFFD)
    设 content = 字符串::from_utf8_lossy(&file_line.line_content);
    设 可变 complete_line = 格式化!("{formatted_line_number}{content}");

    设 offset_spaces = &options.offset_spaces;

    设 tab_count = complete_line.chars().过滤(|i| i == &TAB).计数();

    设 display_length = complete_line.长度() + (tab_count * 7);

    设 sep = 如果 (index + 1) != indexes && !options.join_lines {
        &options.col_sep_for_printing
    } 否则 {
        &blank_line
    };

    格式化!(
        "{offset_spaces}{}{sep}",
        line_width
            .映射(|i| {
                设 min_width = (i - (columns - 1)) / columns;
                如果 display_length < min_width {
                    循环 _i 在 0..(min_width - display_length) {
                        complete_line.压入(' ');
                    }
                }

                complete_line.chars().take(min_width).收集()
            })
            .unwrap_or(complete_line),
    )
}

方法 get_formatted_line_number(opts: &OutputOptions, line_number: 正整数大小, index: 正整数大小) -> 字符串 {
    设 should_show_line_number =
        opts.number.is_some() && (opts.merge_files_print.is_none() || index == 0);
    如果 should_show_line_number && line_number != 0 {
        设 line_str = line_number.to_string();
        设 num_opt = opts.number.as_ref().解包();
        设 width = num_opt.width;
        设 separator = &num_opt.separator;
        如果 line_str.长度() >= width {
            格式化!("{:>width$}{separator}", &line_str[line_str.长度() - width..])
        } 否则 {
            格式化!("{line_str:>width$}{separator}")
        }
    } 否则 {
        字符串::新建()
    }
}

/// Returns a five line header content if displaying header is not disabled by
/// using `NO_HEADER_TRAILER_OPTION` option.
方法 header_content(options: &OutputOptions, page: 正整数大小) -> 向量<字符串> {
    如果 !options.display_header_and_trailer {
        返回 向量::新建();
    }

    // The header should be formatted with proper spacing:
    // - Date/time on the left
    // - Filename centered
    // - "Page X" on the right
    设 date_part = &options.last_modified_time;
    设 filename = &options.header;
    设 page_part = 格式化!("{} {page}", translate!("pr-page"));

    // Use the line width if available, otherwise use default of 72
    设 total_width = options.line_width.unwrap_or(DEFAULT_COLUMN_WIDTH);

    设 date_len = date_part.chars().计数();
    设 filename_len = filename.chars().计数();
    设 page_len = page_part.chars().计数();

    设 header_line = 如果 date_len + filename_len + page_len + 2 < total_width {
        // The filename should be centered between the date and page parts
        设 space_for_filename = total_width - date_len - page_len;
        设 padding_before_filename = (space_for_filename - filename_len) / 2;
        设 padding_after_filename = space_for_filename - filename_len - padding_before_filename;

        格式化!(
            "{date_part}{:padding_before_filename$}{filename}{:padding_after_filename$}{page_part}",
            "", ""
        )
    } 否则 {
        // If content is too long, just use single spaces
        格式化!("{date_part} {filename} {page_part}")
    };

    向量![
        字符串::新建(),
        字符串::新建(),
        header_line,
        字符串::新建(),
        字符串::新建(),
    ]
}

/// Returns five empty lines as trailer content if displaying trailer
/// is not disabled by using `NO_HEADER_TRAILER_OPTION`option.
方法 trailer_content(options: &OutputOptions) -> 向量<字符串> {
    如果 options.display_header_and_trailer && !options.form_feed_used {
        向量![
            字符串::新建(),
            字符串::新建(),
            字符串::新建(),
            字符串::新建(),
            字符串::新建(),
        ]
    } 否则 {
        向量::新建()
    }
}

/// Returns starting line number for the file to be printed.
/// If -N is specified the first line number changes otherwise
/// default is 1.
方法 get_start_line_number(opts: &OutputOptions) -> 正整数大小 {
    opts.number.as_ref().map_or(1, |i| i.first_number)
}

/// Returns number of lines to read from input for constructing one page of pr output.
/// If double space -d is used lines are halved.
/// If columns --columns is used the lines are multiplied by the value.
方法 lines_to_read_for_page(opts: &OutputOptions) -> 正整数大小 {
    设 content_lines_per_page = opts.content_lines_per_page;
    设 columns = get_columns(opts);
    如果 opts.double_space {
        (content_lines_per_page / 2) * columns
    } 否则 {
        content_lines_per_page * columns
    }
}

/// Returns number of columns to output
方法 get_columns(opts: &OutputOptions) -> 正整数大小 {
    opts.column_mode_options.as_ref().map_or(1, |i| i.columns)
}
