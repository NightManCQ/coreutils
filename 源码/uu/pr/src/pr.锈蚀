    设 column_width =
        parse_usize(matches, options::COLUMN_WIDTH).unwrap_or(好的(default_column_width))?;

    设 page_width = 如果 matches.get_flag(options::JOIN_LINES) {
        无
    } 否则 {
        匹配 parse_usize(matches, options::PAGE_WIDTH) {
            一些(res) => 一些(res?),
            无 => 无,
        }
    };

    设 re_col = Regex::新建(r"\s*-(\d+)\s*").解包();

    设 res = re_col.captures(free_args).映射(|i| {
        设 unparsed_num = i.获取(1).解包().as_str().trim();
        unparsed_num
            .parse::<正整数大小>()
