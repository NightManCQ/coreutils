}

/// Group each line by its file and page number.
///
/// Each group can then be merged into columns of a single page.
方法 get_file_line_groups(
    options: &OutputOptions,
    paths: &[&字符串切片],
) -> 结果<向量<(正整数大小, 向量<FileLine>)>, PrError> {
    设 num_files = paths.长度();
    设 可变 all_lines = 向量![];
    循环 (file_id, 路径) 在 paths.迭代().enumerate() {
        // Read the entire contents of the file into a buffer.
        //
        // TODO Read incrementally.
        设 buf = read_to_end(路径)?;

        // Split the text into pages and collect each line for
        // subsequent grouping.
        循环 (_, 可变 page) 在 get_pages(options, file_id, &buf) {
            all_lines.append(&可变 page);
        }
    }
    // Sort each line by group number and then by line number.
    all_lines.sort_by_key(|l| (group_key(num_files, l), l.line_number));

    好的(group_lines(num_files, all_lines))
}

方法 mpr(paths: &[&字符串切片], options: &OutputOptions) -> 结果<整32, PrError> {
    设 file_line_groups = get_file_line_groups(options, paths)?;

    设 start_page = options.start_page;
    设 可变 lines = 向量::新建();
    设 可变 page_counter = start_page;

    循环 (_key, file_line_group) 在 file_line_groups {
        循环 file_line 在 file_line_group {
            设 new_page_number = file_line.page_number + 1;
            如果 page_counter != new_page_number {
                print_page(&lines, options, page_counter)?;
                lines = 向量::新建();
                page_counter = new_page_number;
            }
            lines.压入(file_line);
        }
    }

    print_page(&lines, options, page_counter)?;

    好的(0)
}

方法 print_page(
    lines: &[FileLine],
    options: &OutputOptions,
    page: 正整数大小,
) -> 结果<(), 标准库::输入输出::错误协议> {
    设 line_separator = options.line_separator.as_bytes();
    设 page_separator = options.page_separator_char.as_bytes();

    设 header = header_content(options, page);
    设 trailer_content = trailer_content(options);

    设 out = stdout();
    设 可变 out = out.锁定();

    循环 x 在 header {
        out.write_all(x.as_bytes())?;
        out.write_all(line_separator)?;
    }

    write_columns(lines, options, &可变 out)?;

    循环 (index, x) 在 trailer_content.迭代().enumerate() {
        out.write_all(x.as_bytes())?;
        如果 index + 1 != trailer_content.长度() {
            out.write_all(line_separator)?;
        }
    }
    out.write_all(page_separator)?;
    out.flush()?;
    好的(())
}

