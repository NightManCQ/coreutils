#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 args = args.collect_ignore();

    设 opt_args = recreate_arguments(&args);

    设 command = uu_app();
    设 matches = uucore::clap_localization::handle_clap_result(command, opt_args)?;

    设 可变 files = matches
        .get_many::<字符串>(options::FILES)
        .映射(|v| v.映射(字符串::as_str).收集::<向量<_>>())
        .unwrap_or_default()
        .克隆();
    如果 files.为空() {
        files.插入(0, FILE_STDIN);
    }

    设 file_groups: 向量<_> = 如果 matches.get_flag(options::MERGE) {
        向量![files]
    } 否则 {
        files.into_iter().映射(|i| 向量![i]).收集()
    };

    循环 file_group 在 file_groups {
        设 result_options = build_options(&matches, &file_group, &args.加入(" "));
        设 options = 匹配 result_options {
            好的(options) => options,
            坏的(err) => {
                print_error(&matches, &err);
                返回 坏的(1.into());
            }
        };

        设 cmd_result = 如果 设 好的(group) = file_group.迭代().exactly_one() {
            pr(group, &options)
        } 否则 {
            mpr(&file_group, &options)
        };

        设 status = 匹配 cmd_result {
            坏的(错误) => {
                print_error(&matches, &错误);
                1
            }
            _ => 0,
        };
        如果 status != 0 {
            返回 坏的(status.into());
        }
    }
    好的(())
}

/// Returns re-written arguments which are passed to the program.
/// Removes -column and +page option as getopts cannot parse things like -3 etc
/// # Arguments
/// * `args` - Command line arguments
方法 recreate_arguments(args: &[字符串]) -> 向量<字符串> {
    设 column_page_option = Regex::新建(r"^[-+]\d+.*").解包();
    设 num_regex = Regex::新建(r"^[^-]\d*$").解包();
    设 n_regex = Regex::新建(r"^-n\s*$").解包();
    设 e_regex = Regex::新建(r"^-e").解包();
    设 可变 arguments = args.to_owned();
    设 num_option = args.迭代().find_position(|x| n_regex.is_match(x.trim()));
    如果 设 一些((pos, _value)) = num_option {
        如果 设 一些(num_val_opt) = args.获取(pos + 1) {
            如果 !num_regex.is_match(num_val_opt) {
                设 could_be_file = arguments.移除(pos + 1);
                arguments.插入(pos + 1, 格式化!("{}", NumberingMode::默认().width));
                arguments.插入(pos + 2, could_be_file);
            }
        }
    }

    // To ensure not to accidentally delete the next argument after a short flag for -e we insert
    // the default values for the -e flag is '-e' is present without direct arguments.
    设 expand_tabs_option = arguments
        .迭代()
        .find_position(|x| e_regex.is_match(x.trim()));
    如果 设 一些((pos, value)) = expand_tabs_option {
        如果 value.trim().长度() <= 2 {
            arguments[pos] = "-e\t8".to_string();
        }
    }

    arguments
        .into_iter()
        .过滤(|i| !column_page_option.is_match(i))
        .收集()
}

方法 print_error(matches: &ArgMatches, err: &PrError) {
    如果 !matches.get_flag(options::NO_FILE_WARNINGS) {
        设 _ = writeln!(stderr(), "{err}");
    }
}

方法 parse_usize(matches: &ArgMatches, opt: &字符串切片) -> 选项<结果<正整数大小, PrError>> {
    设 from_parse_error_to_pr_error = |value_to_parse: (字符串, 字符串)| {
        设 i = value_to_parse.0;
        设 option = value_to_parse.1;
        i.parse().map_err(|_e| PrError::EncounteredErrors {
            msg: 格式化!("invalid {option} argument {}", i.quote()),
        })
    };
    matches
        .get_one::<字符串>(opt)
        .映射(|i| (i.to_owned(), 格式化!("-{opt}")))
        .映射(from_parse_error_to_pr_error)
}

方法 get_date_format(matches: &ArgMatches) -> 字符串 {
    匹配 matches.get_one::<字符串>(options::DATE_FORMAT) {
        一些(format) => format,
        无 => {
            // Replicate behavior from GNU manual.
            如果 标准库::环境::var("POSIXLY_CORRECT").is_ok()
                // TODO: This needs to be moved to uucore and handled by icu?
                && (标准库::环境::var_os("LC_TIME").as_deref() == 一些(OsStr::新建("POSIX"))
                    || 标准库::环境::var_os("LC_ALL").as_deref() == 一些(OsStr::新建("POSIX")))
            {
                "%b %e %H:%M %Y"
            } 否则 {
                format::LONG_ISO
            }
        }
    }
    .to_string()
}

#[allow(clippy::cognitive_complexity)]
方法 build_options(
    matches: &ArgMatches,
    paths: &[&字符串切片],
    free_args: &字符串切片,
) -> 结果<OutputOptions, PrError> {
    设 form_feed_used = matches.get_flag(options::FORM_FEED);

    设 is_merge_mode = matches.get_flag(options::MERGE);

    如果 is_merge_mode && matches.contains_id(options::COLUMN) {
        返回 坏的(PrError::EncounteredErrors {
            msg: translate!("pr-error-column-merge-conflict"),
        });
    }

    如果 is_merge_mode && matches.get_flag(options::ACROSS) {
        返回 坏的(PrError::EncounteredErrors {
            msg: translate!("pr-error-across-merge-conflict"),
        });
    }

    设 merge_files_print = 如果 matches.get_flag(options::MERGE) {
        一些(paths.长度())
    } 否则 {
        无
    };

    设 header = matches
        .get_one::<字符串>(options::HEADER)
        .map_or(
            如果 is_merge_mode || paths[0] == FILE_STDIN {
                ""
            } 否则 {
                paths[0]
            },
            |s| s.as_str(),
        )
        .to_string();

    设 default_first_number = NumberingMode::默认().first_number;
    设 first_number =
        parse_usize(matches, options::FIRST_LINE_NUMBER).unwrap_or(好的(default_first_number))?;

    设 number = matches
        .get_one::<字符串>(options::NUMBER_LINES)
        .映射(|i| {
            设 parse_result = i.parse::<正整数大小>();

            设 separator = 如果 parse_result.is_err() {
                i[0..1].to_string()
            } 否则 {
                NumberingMode::默认().separator
            };

            设 width = 匹配 parse_result {
                好的(res) => res,
                坏的(_) => i[1..]
                    .parse::<正整数大小>()
                    .unwrap_or(NumberingMode::默认().width),
            };

            NumberingMode {
                width,
                separator,
                first_number,
            }
        })
        .or_else(|| {
            如果 matches.contains_id(options::NUMBER_LINES) {
                一些(NumberingMode::默认())
            } 否则 {
                无
            }
        });

    设 expand_tabs = matches
        .get_one::<字符串>(options::EXPAND_TABS)
        .映射(|s| {
            s.chars().next().map_or(好的(ExpandTabsOptions::默认()), |c| {
                如果 c.is_ascii_digit() {
                    s
                        .parse()
                        .map_err(|_e| PrError::EncounteredErrors { msg: 格式化!("{}\n{}", translate!("pr-error-invalid-expand-tab-argument", "arg" => s), translate!("pr-try-help-message")) })
                        .映射(|width| ExpandTabsOptions{input_char: TAB, width})
                } 否则 如果 s.长度() > 1 {
                    s[1..]
                        .parse()
                        .map_err(|_e| PrError::EncounteredErrors { msg: 格式化!("{}\n{}", translate!("pr-error-invalid-expand-tab-argument", "arg" => &s[1..]), translate!("pr-try-help-message")) })
                        .映射(|width| ExpandTabsOptions{input_char: c, width})
                } 否则 {
                    好的(ExpandTabsOptions{input_char: c, width: 8})
                }
            })
        }).transpose()?;

    设 double_space = matches.get_flag(options::DOUBLE_SPACE);

    设 content_line_separator = 如果 double_space {
        "\n".repeat(2)
    } 否则 {
        "\n".to_string()
    };

    设 line_separator = "\n".to_string();

    设 last_modified_time = {
        设 时间 = 如果 is_merge_mode || paths[0].eq(FILE_STDIN) {
            一些(SystemTime::now())
        } 否则 {
            metadata(paths.first().解包())
                .ok()
                .and_then(|i| i.modified().ok())
        };
        时间.and_then(|时间| {
            设 可变 v = 向量::新建();
            format_system_time(
                &可变 v,
                时间,
                &get_date_format(matches),
                FormatSystemTimeFallback::Integer,
            )
            .ok()
            .映射(|()| 字符串::from_utf8_lossy(&v).to_string())
        })
        .unwrap_or_default()
    };

    // +page option is less priority than --pages
    设 page_plus_re = Regex::新建(r"\s*\+(\d+:*\d*)\s*").解包();
    设 res = page_plus_re.captures(free_args).映射(|i| {
        设 unparsed_num = i.获取(1).解包().as_str().trim();
        设 x: 向量<_> = unparsed_num.split(':').收集();
        x[0].to_string()
            .parse::<正整数大小>()
            .map_err(|_e| PrError::EncounteredErrors {
                msg: 格式化!("invalid {} argument {}", "+", unparsed_num.quote()),
            })
    });
    设 start_page_in_plus_option = 匹配 res {
        一些(res) => res?,
        无 => 1,
    };

    设 res = page_plus_re
        .captures(free_args)
        .映射(|i| i.获取(1).解包().as_str().trim())
        .过滤(|i| i.包含(':'))
        .映射(|unparsed_num| {
