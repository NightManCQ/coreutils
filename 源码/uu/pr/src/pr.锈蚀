    设 res = matches
        .get_one::<字符串>(options::PAGES)
        .映射(|i| {
            设 x: 向量<_> = i.split(':').收集();
            x[0].to_string()
        })
        .映射(invalid_pages_map);
    设 start_page = 匹配 res {
        一些(res) => res?,
        无 => start_page_in_plus_option,
    };

    设 res = matches
        .get_one::<字符串>(options::PAGES)
        .过滤(|i| i.包含(':'))
        .映射(|i| {
            设 x: 向量<_> = i.split(':').收集();
            x[1].to_string()
