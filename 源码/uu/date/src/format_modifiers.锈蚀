    #[test]
    方法 test_parse_format_spec() {
        // (input, expected: Some((flags, width, spec, len)) or None)
        类型 ParsedTuple = (&'静态 字符串切片, 选项<正整数大小>, &'静态 字符串切片, 正整数大小);
        设 cases: &[(&字符串切片, 选项<ParsedTuple>)] = &[
            // ---- plain single-letter specifiers ----
            ("%Y", 一些(("", 无, "Y", 2))),
            ("%a", 一些(("", 无, "a", 2))),
            ("%B", 一些(("", 无, "B", 2))),
            // ---- single flag, no width ----
            ("%-d", 一些(("-", 无, "d", 3))),
            ("%_m", 一些(("_", 无, "m", 3))),
            ("%0e", 一些(("0", 无, "e", 3))),
            ("%^B", 一些(("^", 无, "B", 3))),
            ("%#Z", 一些(("#", 无, "Z", 3))),
            ("%+Y", 一些(("+", 无, "Y", 3))),
            // ---- combined flags ----
            ("%_+Y", 一些(("_+", 无, "Y", 4))),
            ("%-^B", 一些(("-^", 无, "B", 4))),
            // ---- width only ----
            ("%10Y", 一些(("", 一些(10), "Y", 4))),
            ("%4C", 一些(("", 一些(4), "C", 3))),
            // `0` is a flag, then `5` is the width.
            ("%05d", 一些(("0", 一些(5), "d", 4))),
            // ---- flags + width ----
            ("%_10m", 一些(("_", 一些(10), "m", 5))),
            ("%+6Y", 一些(("+", 一些(6), "Y", 4))),
            ("%-5d", 一些(("-", 一些(5), "d", 4))),
            ("%+4C", 一些(("+", 一些(4), "C", 4))),
            // ---- colon-prefixed specifiers (numeric timezones) ----
            ("%:z", 一些(("", 无, ":z", 3))),
            ("%::z", 一些(("", 无, "::z", 4))),
            ("%:::z", 一些(("", 无, ":::z", 5))),
            ("%-3:z", 一些(("-", 一些(3), ":z", 5))),
            // ---- only the spec is consumed; trailing text is ignored ----
            ("%Y-%m-%d", 一些(("", 无, "Y", 2))),
            ("%10Yhello", 一些(("", 一些(10), "Y", 4))),
            // ---- invalid: should return None ----
            ("Y", 无),
            ("", 无),
            ("%", 无),
            ("%-", 无),
            ("%10", 无),
            ("%_+", 无),
            ("%:", 无),
            ("%::", 无),
            ("%%", 无), // %% is not a spec — caller handles it.
            ("%é", 无), // non-ASCII letter
        ];

        循环 (input, expected) 在 cases {
            设 actual = parse_format_spec(input).映射(|p| (p.flags, p.width, p.spec, p.长度));
            相等断言!(actual, *expected, "input = {input:?}");
        }
    }

    #[test]
    方法 test_has_gnu_modifiers() {
        // (input, expected)
        设 cases: &[(&字符串切片, 布尔)] = &[
            // ---- modifier present (flag and/or width) ----
            ("%10Y", 真),
            ("%^B", 真),
            ("%-d", 真),
            ("%_m", 真),
            ("%+Y", 真),
            ("today is %-d of %B", 真),
            ("%5:z", 真),
            // %% mixed with a real modifier is still detected.
            ("%%%-d", 真),
            ("%%%10Y", 真),
            // ---- no modifier: plain specs only ----
            ("%Y-%m-%d", 假),
            ("%H:%M:%S", 假),
            ("%a %b %e %T %Z %Y", 假),
            ("", 假),
            ("no percent here", 假),
            // ---- %% literals must never count as modifiers ----
            ("%%", 假),
            ("100%% done", 假),
            ("%%Y", 假),
            ("%%10", 假),
            // ---- colon specs without flags/width are not modifiers ----
            ("%:z", 假),
            ("%::z", 假),
        ];

        循环 (input, expected) 在 cases {
            相等断言!(has_gnu_modifiers(input), *expected, "input = {input:?}");
        }
    }
