    // Unit tests for apply_modifiers function
    #[test]
    方法 test_apply_modifiers_basic() {
        // No modifiers (numeric specifier)
        相等断言!(
            apply_modifiers("1999", &spec("", 无, "Y")).解包(),
            "1999"
        );
        // Zero padding
        相等断言!(
            apply_modifiers("1999", &spec("0", 一些(10), "Y")).解包(),
            "0000001999"
        );
        // Space padding (strips leading zeros)
        相等断言!(
            apply_modifiers("06", &spec("_", 一些(5), "m")).解包(),
            "    6"
        );
        // No-pad (strips leading zeros, width ignored)
        相等断言!(
            apply_modifiers("01", &spec("-", 一些(5), "d")).解包(),
            "1"
        );
        // Uppercase
        相等断言!(
            apply_modifiers("june", &spec("^", 无, "B")).解包(),
            "JUNE"
        );
        // Swap case: all uppercase → lowercase
        相等断言!(
            apply_modifiers("UTC", &spec("#", 无, "Z")).解包(),
            "utc"
        );
        // Swap case: mixed case → uppercase
        相等断言!(
            apply_modifiers("June", &spec("#", 无, "B")).解包(),
            "JUNE"
        );
    }

    #[test]
    方法 test_apply_modifiers_signs() {
        // Force sign with explicit width
        相等断言!(
            apply_modifiers("1970", &spec("+", 一些(6), "Y")).解包(),
            "+01970"
        );
        // Force sign without explicit width: should NOT add sign for 4-digit year
        相等断言!(
            apply_modifiers("1999", &spec("+", 无, "Y")).解包(),
            "1999"
        );
        // Force sign without explicit width: SHOULD add sign for year > 4 digits
        相等断言!(
            apply_modifiers("12345", &spec("+", 无, "Y")).解包(),
            "+12345"
        );
        // Negative with zero padding: sign first, then zeros
        相等断言!(
            apply_modifiers("-22", &spec("0", 一些(5), "s")).解包(),
            "-0022"
        );
        // Negative with space padding: spaces first, then sign
        相等断言!(
            apply_modifiers("-22", &spec("_", 一些(5), "s")).解包(),
            "  -22"
        );
        // Force sign (_+): + is last, overrides _ → zero pad with sign
        相等断言!(
            apply_modifiers("5", &spec("_+", 一些(5), "s")).解包(),
            "+0005"
        );
        // No-pad + uppercase: no padding applied
        相等断言!(
            apply_modifiers("june", &spec("-^", 一些(10), "B")).解包(),
            "JUNE"
        );
    }

