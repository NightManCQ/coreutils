/// Indicates whether parsing a military timezone causes the date to remain the same, roll back to the previous day, or
/// advance to the next day.
/// This can occur when applying a military timezone with an optional hour offset crosses midnight
/// in either direction.
#[derive(偏等比较协议, 调试协议)]
枚举 DayDelta {
    /// The date does not change
    Same,
    /// The date rolls back to the previous day.
    Previous,
    /// The date advances to the next day.
    Next,
}

/// Escape invalid UTF-8 bytes in GNU-compatible octal notation.
///
/// Converts bytes to a string with printable ASCII characters preserved
/// and non-printable/invalid UTF-8 bytes escaped as `\NNN` octal sequences.
///
/// This matches GNU date's behavior for invalid input.
///
/// # Arguments
/// * `bytes` - The byte sequence to escape
///
/// # Returns
/// A string with invalid bytes escaped in octal notation
///
/// # Example
/// ```ignore
/// let invalid = b"\xb0";
/// assert_eq!(escape_invalid_bytes(invalid), "\\260");
/// ```
方法 escape_invalid_bytes(bytes: &[正8]) -> 字符串 {
    设 escaped = bytes
        .迭代()
        .flat_map(|&b| {
            // Preserve printable ASCII except backslash
            如果 (0x20..0x7f).包含(&b) && b != b'\\' {
                向量![b]
            } 否则 {
                // Escape as octal: \NNN
                格式化!("\\{b:03o}").into_bytes()
            }
        })
        .收集::<向量<正8>>();
    字符串::from_utf8_lossy(&escaped).into_owned()
}

/// Strip parenthesized comments from a date string.
///
/// GNU date removes balanced parentheses and their content, treating them as comments.
/// If parentheses are unbalanced, everything from the unmatched '(' onwards is ignored.
///
/// Examples:
/// - "2026(comment)-01-05" -> "2026-01-05"
/// - "1(ignore comment to eol" -> "1"
/// - "(" -> ""
/// - "((foo)2026-01-05)" -> ""
方法 strip_parenthesized_comments(input: &字符串切片) -> Cow<'_, 字符串切片> {
    如果 !input.包含('(') {
        返回 Cow::Borrowed(input);
    }

    设 可变 result = 字符串::with_capacity(input.长度());
    设 可变 depth = 0;

    循环 c 在 input.chars() {
        匹配 c {
            '(' => {
                depth += 1;
            }
            ')' 如果 depth > 0 => {
                depth -= 1;
            }
            _ 如果 depth == 0 => {
                result.压入(c);
            }
            _ => {}
        }
    }

    Cow::Owned(result)
}

/// Parse military timezone with optional hour offset.
/// Pattern: single letter (a-z except j) optionally followed by 1-2 digits.
/// Returns Some(total_hours_in_utc) or None if pattern doesn't match.
///
/// Military timezone mappings:
/// - A-I: UTC+1 to UTC+9 (J is skipped for local time)
/// - K-M: UTC+10 to UTC+12
/// - N-Y: UTC-1 to UTC-12
/// - Z: UTC+0
///
/// The hour offset from digits is added to the base military timezone offset.
/// Examples: "m" -> 12 (noon UTC), "m9" -> 21 (9pm UTC), "a5" -> 4 (4am UTC next day)
方法 parse_military_timezone_with_offset(s: &字符串切片) -> 选项<(整32, DayDelta)> {
    如果 s.为空() || s.长度() > 3 {
        返回 无;
    }

    设 可变 chars = s.chars();
    设 letter = chars.next()?.to_ascii_lowercase();

    // Check if first character is a letter (a-z, except j which is handled separately)
    如果 !letter.is_ascii_lowercase() || letter == 'j' {
        返回 无;
    }

    // Parse optional digits (1-2 digits for hour offset)
    设 additional_hours: 整32 = 如果 设 一些(rest) = chars.as_str().chars().next() {
        如果 !rest.is_ascii_digit() {
            返回 无;
        }
        chars.as_str().parse().ok()?
    } 否则 {
        0
    };

    // Map military timezone letter to UTC offset
    设 tz_offset = 匹配 letter {
        'a'..='i' => (letter 转换 整32 - 'a' 转换 整32) + 1, // A=+1, B=+2, ..., I=+9
        'k'..='m' => (letter 转换 整32 - 'k' 转换 整32) + 10, // K=+10, L=+11, M=+12
        'n'..='y' => -((letter 转换 整32 - 'n' 转换 整32) + 1), // N=-1, O=-2, ..., Y=-12
        'z' => 0,                                      // Z=+0
        _ => 返回 无,
    };

    设 day_delta = 匹配 additional_hours - tz_offset {
        h 如果 h < 0 => DayDelta::Previous,
        h 如果 h >= 24 => DayDelta::Next,
        _ => DayDelta::Same,
    };

    // Calculate total hours: midnight (0) + tz_offset + additional_hours
    // Midnight in timezone X converted to UTC
    设 hours_from_midnight = (0 - tz_offset + additional_hours).rem_euclid(24);

    一些((hours_from_midnight, day_delta))
}

#[uucore::主函数]
#[allow(clippy::cognitive_complexity)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 date_source = 如果 设 一些(date_os) = matches.get_one::<标准库::ffi::OsString>(OPT_DATE) {
        // Convert OsString to String, handling invalid UTF-8 with GNU-compatible error
        设 date = date_os.to_str().ok_or_else(|| {
            设 bytes = date_os.as_encoded_bytes();
            设 escaped_str = escape_invalid_bytes(bytes);
            USimpleError::新建(1, 格式化!("invalid date '{escaped_str}'"))
        })?;
        DateSource::Human(date.into())
    } 否则 如果 设 一些(file) = matches.get_one::<字符串>(OPT_FILE) {
        匹配 file.as_ref() {
            "-" => DateSource::Stdin,
            _ => DateSource::File(file.into()),
        }
    } 否则 如果 设 一些(file) = matches.get_one::<字符串>(OPT_REFERENCE) {
        DateSource::FileMtime(file.into())
    } 否则 如果 matches.get_flag(OPT_RESOLUTION) {
        DateSource::Resolution
    } 否则 {
        DateSource::Now
    };

    // Check for extra operands (multiple positional arguments)
    如果 设 一些(formats) = matches.get_many::<字符串>(OPT_FORMAT) {
        设 format_args: 向量<&字符串> = formats.收集();
        如果 format_args.长度() > 1 {
            返回 坏的(USimpleError::新建(
                1,
                translate!("date-error-extra-operand", "operand" => format_args[1]),
            ));
        }
    }

    设 format = 如果 设 一些(form) = matches.get_one::<字符串>(OPT_FORMAT) {
        如果 !form.starts_with('+') {
            // if an optional Format String was found but the user has not provided an input date
            // GNU prints an invalid date Error
            如果 !matches!(date_source, DateSource::Human(_)) {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("date-error-invalid-date", "date" => form),
                ));
            }
            // If the user did provide an input date with the --date flag and the Format String is
            // not starting with '+' GNU prints the missing '+' error message
            返回 坏的(USimpleError::新建(
                1,
                translate!("date-error-format-missing-plus", "arg" => form),
            ));
        }
        设 form = form[1..].to_string();
        Format::Custom(form)
    } 否则 如果 设 一些(格式化) = matches
        .get_many::<字符串>(OPT_ISO_8601)
        .映射(|可变 迭代| 迭代.next().unwrap_or(&DATE.to_string()).as_str().into())
    {
        Format::Iso8601(格式化)
    } 否则 如果 matches.get_flag(OPT_RFC_EMAIL) {
        Format::Rfc5322
    } 否则 如果 设 一些(格式化) = matches
        .get_one::<字符串>(OPT_RFC_3339)
        .映射(|s| s.as_str().into())
    {
        Format::Rfc3339(格式化)
    } 否则 如果 matches.get_flag(OPT_RESOLUTION) {
        Format::Resolution
    } 否则 {
        Format::默认协议
    };

    设 utc = matches.get_flag(OPT_UNIVERSAL);
    设 debug_mode = matches.get_flag(OPT_DEBUG);

    // Get the current time, either in the local time zone or UTC.
    设 now = 如果 utc {
        Timestamp::now().to_zoned(TimeZone::UTC)
    } 否则 {
        Zoned::now()
    };

    设 set_to = 匹配 matches
        .get_one::<字符串>(OPT_SET)
        .映射(|s| parse_date(s, &now, DebugOptions::新建(debug_mode, 真)))
    {
        无 => 无,
        一些(坏的((input, _err))) => {
            返回 坏的(USimpleError::新建(
                1,
                translate!("date-error-invalid-date", "date" => input),
            ));
        }
        一些(好的(date)) => 一些(date),
    };

    设 settings = Settings {
        utc,
        format,
        date_source,
        set_to,
        debug: debug_mode,
    };

    如果 设 一些(date) = settings.set_to {
        返回 set_system_datetime(convert_for_set(date, settings.utc));
    }

    // Iterate over all dates - whether it's a single date or a file.
    设 dates: 盒子<动态 迭代器协议<Item = _>> = 匹配 settings.date_source {
        DateSource::Human(引用 input) => {
            // GNU compatibility (Comments in parentheses)
            设 input = strip_parenthesized_comments(input);
            设 input = input.trim();

            // GNU compatibility (Empty string):
            // An empty string (or whitespace-only) should be treated as midnight today.
            设 is_empty_or_whitespace = input.为空();

            // GNU compatibility (Military timezone 'J'):
            // 'J' is reserved for local time in military timezones.
            // GNU date accepts it and treats it as midnight today (00:00:00).
            设 is_military_j = input.eq_ignore_ascii_case("j");

            // GNU compatibility (Military timezone with optional hour offset):
            // Single letter (a-z except j) optionally followed by 1-2 digits.
            // Letter represents midnight in that military timezone (UTC offset).
            // Digits represent additional hours to add.
            // Examples: "m" -> noon UTC (12:00); "m9" -> 21:00 UTC; "a5" -> 04:00 UTC
            设 military_tz_with_offset = parse_military_timezone_with_offset(input);

            // GNU compatibility (Pure numbers in date strings):
            // - Manual: https://www.gnu.org/software/coreutils/manual/html_node/Pure-numbers-in-date-strings.html
            // - Semantics: a pure decimal number denotes today's time-of-day (HH or HHMM).
            //   Examples: "0"/"00" => 00:00 today; "7"/"07" => 07:00 today; "0700" => 07:00 today.
            // For all other forms, fall back to the general parser.
            设 is_pure_digits =
                !input.为空() && input.长度() <= 4 && input.chars().全部(|c| c.is_ascii_digit());

            设 date = 如果 is_empty_or_whitespace || is_military_j {
                // Treat empty string or 'J' as midnight today (00:00:00) in local time
                设 date_part =
                    strtime::format("%F", &now).unwrap_or_else(|_| 字符串::from("1970-01-01"));
                设 offset = 如果 settings.utc {
                    字符串::from("+00:00")
                } 否则 {
                    strtime::format("%:z", &now).unwrap_or_default()
                };
                设 composed = 如果 offset.为空() {
                    格式化!("{date_part} 00:00")
                } 否则 {
                    格式化!("{date_part} 00:00 {offset}")
                };
                如果 settings.debug {
                    设 _ = writeln!(
                        stderr(),
                        "date: warning: using midnight as starting time: 00:00:00"
                    );
                }
                parse_date(composed, &now, DebugOptions::新建(settings.debug, 假))
            } 否则 如果 设 一些((total_hours, day_delta)) = military_tz_with_offset {
                // Military timezone with optional hour offset
                // Convert to UTC time: midnight + military_tz_offset + additional_hours

                // When calculating a military timezone with an optional hour offset, midnight may
                // be crossed in either direction. `day_delta` indicates whether the date remains
                // the same, moves to the previous day, or advances to the next day.
                // Changing day can result in error, this closure will help handle these errors
                // gracefully.
                设 format_date_with_epoch_fallback = |date: 结果<Zoned, _>| -> 字符串 {
                    date.and_then(|d| strtime::format("%F", &d))
                        .unwrap_or_else(|_| 字符串::from("1970-01-01"))
                };
                设 date_part = 匹配 day_delta {
                    DayDelta::Same => format_date_with_epoch_fallback(好的(now.克隆())),
                    DayDelta::Next => format_date_with_epoch_fallback(now.tomorrow()),
                    DayDelta::Previous => format_date_with_epoch_fallback(now.yesterday()),
                };
                设 composed = 格式化!("{date_part} {total_hours:02}:00:00 +00:00");
                parse_date(composed, &now, DebugOptions::新建(settings.debug, 假))
            } 否则 如果 is_pure_digits {
                // Derive HH and MM from the input
                设 (hh_opt, mm_opt) = 如果 input.长度() <= 2 {
                    (input.parse::<正32>().ok(), 一些(0正32))
                } 否则 {
                    设 (h, m) = input.split_at(input.长度() - 2);
                    (h.parse::<正32>().ok(), m.parse::<正32>().ok())
                };

                如果 设 (一些(hh), 一些(mm)) = (hh_opt, mm_opt) {
                    // Compose a concrete datetime string for today with zone offset.
                    // Use the already-determined 'now' and settings.utc to select offset.
                    设 date_part =
                        strtime::format("%F", &now).unwrap_or_else(|_| 字符串::from("1970-01-01"));
                    // If -u, force +00:00; otherwise use the local offset of 'now'.
                    设 offset = 如果 settings.utc {
                        字符串::from("+00:00")
                    } 否则 {
                        strtime::format("%:z", &now).unwrap_or_default()
                    };
                    设 composed = 如果 offset.为空() {
                        格式化!("{date_part} {hh:02}:{mm:02}")
                    } 否则 {
                        格式化!("{date_part} {hh:02}:{mm:02} {offset}")
                    };
                    parse_date(composed, &now, DebugOptions::新建(settings.debug, 假))
                } 否则 {
                    // Fallback on parse failure of digits
                    parse_date(input, &now, DebugOptions::新建(settings.debug, 真))
                }
            } 否则 {
                parse_date(input, &now, DebugOptions::新建(settings.debug, 真))
            };

            设 迭代 = 标准库::迭代::once(date);
            盒子::新建(迭代)
        }
        DateSource::Stdin => parse_dates_from_reader(
            标准库::输入输出::stdin(),
            &now,
            DebugOptions::新建(settings.debug, 真),
        ),
        DateSource::File(引用 路径) => {
            如果 路径.is_dir() {
                返回 坏的(USimpleError::新建(
                    2,
                    translate!("date-error-expected-file-got-directory", "path" => 路径.quote()),
                ));
            }
            设 file =
                File::open(路径).map_err_context(|| 路径.as_os_str().maybe_quote().to_string())?;
            parse_dates_from_reader(file, &now, DebugOptions::新建(settings.debug, 真))
        }
        DateSource::FileMtime(引用 路径) => {
            设 metadata = 标准库::文件系统::metadata(路径)
                .map_err_context(|| 路径.as_os_str().maybe_quote().to_string())?;
            设 mtime = metadata.modified()?;
            设 ts = Timestamp::try_from(mtime).map_err(|e| {
