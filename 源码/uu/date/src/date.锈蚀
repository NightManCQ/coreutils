            设 date = ts.to_zoned(TimeZone::try_system().unwrap_or(TimeZone::UTC));
            设 迭代 = 标准库::迭代::once(好的(date));
            盒子::新建(迭代)
        }
        DateSource::Resolution => {
            设 resolution = get_clock_resolution();
            设 date = resolution.to_zoned(TimeZone::system());
            设 迭代 = 标准库::迭代::once(好的(date));
            盒子::新建(迭代)
        }
        DateSource::Now => {
            设 迭代 = 标准库::迭代::once(好的(now));
            盒子::新建(迭代)
        }
    };

    设 format_string = make_format_string(&settings);
    设 可变 stdout = BufWriter::新建(标准库::输入输出::stdout().锁定());

    // Format all the dates
    设 config = Config::新建().custom(PosixCustom::新建()).lenient(真);
    循环 date 在 dates {
        匹配 date {
            好的(date) => {
                设 date = 如果 settings.utc {
                    date.with_time_zone(TimeZone::UTC)
                } 否则 {
                    date
                };
                设 skip_localization =
                    matches!(settings.format, Format::Rfc5322 | Format::Rfc3339(_));
                匹配 format_date_with_locale_aware_months(
                    &date,
                    format_string,
                    &config,
