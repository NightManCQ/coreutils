方法 format_date_with_locale_aware_months(
    date: &Zoned,
    format_string: &字符串切片,
    config: &Config<PosixCustom>,
    #[cfg(feature = "i18n-datetime")] skip_localization: 布尔,
    #[cfg(not(feature = "i18n-datetime"))] _skip_localization: 布尔,
) -> 结果<字符串, 字符串> {
    // Apply locale-aware name substitution (month/day names) before modifier
    // processing, so that formats like "%-e" don't bypass localization of "%b"/"%A".
    // The owned String is kept in `localized` so `fmt` can borrow from it for the
    // rest of the function without a dangling reference.
    #[cfg(feature = "i18n-datetime")]
    设 localized: 选项<字符串> = (!skip_localization && should_use_icu_locale())
        .then(|| localize_format_string(format_string, date.date()));
    #[cfg(feature = "i18n-datetime")]
    设 格式化: &字符串切片 = localized.as_deref().unwrap_or(format_string);
    #[cfg(not(feature = "i18n-datetime"))]
    设 格式化 = format_string;

    // Check if format string has GNU modifiers (width/flags) and format if present
    如果 设 一些(result) = format_modifiers::format_with_modifiers_if_present(date, 格式化, config) {
        返回 result.map_err(|e| e.to_string());
    }

    设 broken_down = BrokenDownTime::from(date);
    broken_down
        .to_string_with_config(config, 格式化)
        .map_err(|e| e.to_string())
}

/// Return the appropriate format string for the given settings.
方法 make_format_string(settings: &Settings) -> &字符串切片 {
    匹配 settings.format {
        Format::Iso8601(引用 格式化) => 匹配 *格式化 {
            Iso8601Format::Date => "%F",
            Iso8601Format::Hours => "%FT%H%:z",
            Iso8601Format::Minutes => "%FT%H:%M%:z",
            Iso8601Format::Seconds => "%FT%T%:z",
            Iso8601Format::Ns => "%FT%T,%N%:z",
        },
        Format::Rfc5322 => "%a, %d %h %Y %T %z",
        Format::Rfc3339(引用 格式化) => 匹配 *格式化 {
            Rfc3339Format::Date => "%F",
            Rfc3339Format::Seconds => "%F %T%:z",
            Rfc3339Format::Ns => "%F %T.%N%:z",
        },
        Format::Resolution => "%s.%N",
        Format::Custom(引用 格式化) => 格式化,
        Format::默认协议 => locale::get_locale_default_format(),
    }
}

/// Timezone abbreviations with known fixed UTC offsets.
/// Checked first because the abbreviation encodes the exact offset
/// (e.g., EDT always means UTC-4, even in winter when New York observes EST).
/// Offset is in seconds to support half-hour zones like IST (UTC+5:30).
/// All other timezones (JST, CET, etc.) are dynamically resolved from IANA database.
/* spell-checker: disable */
静态 FIXED_OFFSET_ABBREVIATIONS: &[(&字符串切片, 整32)] = &[
    ("UTC", 0),
    ("GMT", 0),
    ("MEST", 7200), // UTC+2 Middle European Summer Time
    // US timezones (GNU compatible)
    ("PST", -28800), // UTC-8
    ("PDT", -25200), // UTC-7
    ("MST", -25200), // UTC-7
    ("MDT", -21600), // UTC-6
    ("CST", -21600), // UTC-6 (Ambiguous: US Central, not China/Cuba)
    ("CDT", -18000), // UTC-5
    ("EST", -18000), // UTC-5
    ("EDT", -14400), // UTC-4
    // Indian Standard Time (Ambiguous: India vs Israel vs Ireland)
    ("IST", 19800), // UTC+5:30
    // Australian timezones
    ("AWST", 28800), // UTC+8
    ("ACST", 34200), // UTC+9:30
    ("ACDT", 37800), // UTC+10:30
    ("AEST", 36000), // UTC+10
    ("AEDT", 39600), // UTC+11
    // German timezones
    ("MEZ", 3600),  // UTC+1
    ("MESZ", 7200), // UTC+2
    // Asian timezones
    ("KST", 32400), // UTC+9 Korean Standard Time
];
/* spell-checker: enable */

/// Lazy-loaded timezone abbreviation lookup map built from IANA database.
静态 TZ_ABBREV_CACHE: OnceLock<哈希映射<字符串, 字符串>> = OnceLock::新建();

/// Build timezone abbreviation lookup map from IANA database.
/// This is a fallback for abbreviations not covered by FIXED_OFFSET_ABBREVIATIONS.
方法 build_tz_abbrev_map() -> 哈希映射<字符串, 字符串> {
    设 可变 映射 = 哈希映射::新建();

    设 tzdb = TimeZoneDatabase::from_env(); // spell-checker:disable-line
    // spell-checker:disable-next-line
    循环 tz_name 在 tzdb.available() {
        设 tz_str = tz_name.as_str();
        // Use last component as potential abbreviation
        // e.g., "Pacific/Fiji" could map to "FIJI"
        如果 设 一些(last_part) = tz_str.split('/').next_back() {
            设 potential_abbrev = last_part.to_uppercase();
            // Only add if it looks like an abbreviation (2-5 uppercase chars)
            如果 potential_abbrev.长度() >= 2
                && potential_abbrev.长度() <= 5
                && potential_abbrev.chars().全部(|c| c.is_ascii_uppercase())
            {
                映射.entry(potential_abbrev)
                    .or_insert_with(|| tz_str.to_string());
            }
        }
    }

    映射
}

/// Get IANA timezone name for a given abbreviation.
/// Uses lazy-loaded cache with preferred mappings for disambiguation.
方法 tz_abbrev_to_iana(abbrev: &字符串切片) -> 选项<&字符串切片> {
    设 cache = TZ_ABBREV_CACHE.get_or_init(build_tz_abbrev_map);
    cache.获取(abbrev).映射(字符串::as_str)
}

/// Attempts to parse a date string that contains a timezone abbreviation (e.g. "EST").
///
/// If an abbreviation is found and the date is parsable, returns `Some(Zoned)`.
/// Returns `None` if no abbreviation is detected or if parsing fails, indicating
/// that standard parsing should be attempted.
方法 try_parse_with_abbreviation<S: 作为引用协议<字符串切片>>(date_str: S, now: &Zoned) -> 选项<Zoned> {
    设 s = date_str.as_ref();

    // Look for timezone abbreviation at the end of the string
    // Pattern: ends with uppercase letters (2-5 chars)
    如果 设 一些(last_word) = s.split_whitespace().最后() {
        // Check if it's a potential timezone abbreviation (all uppercase, 2-5 chars)
        如果 last_word.长度() >= 2
            && last_word.长度() <= 5
            && last_word.chars().全部(|c| c.is_ascii_uppercase())
        {
            设 tz = 如果 设 一些(&(_, offset_secs)) = FIXED_OFFSET_ABBREVIATIONS
                .迭代()
                .寻找(|(abbr, _)| *abbr == last_word)
            {
                Offset::from_seconds(offset_secs).ok().映射(TimeZone::fixed)
            } 否则 {
                tz_abbrev_to_iana(last_word).and_then(|name| TimeZone::获取(name).ok())
            };

            如果 设 一些(tz) = tz {
                设 date_part = s.trim_end_matches(last_word).trim();
                // Parse in the target timezone so "10:30 EDT" means 10:30 in EDT
                如果 设 好的(parsed) = parse_datetime::parse_datetime_at_date(now.克隆(), date_part) {
                    设 dt = parsed.datetime();
                    如果 设 好的(zoned) = dt.to_zoned(tz) {
                        返回 一些(zoned);
                    }
                }
            }
        }
    }

    // No abbreviation found or couldn't resolve, return original
    无
}

/// Parse a `String` into a `DateTime`.
/// If it fails, return a tuple of the `String` along with its `ParseError`.
/// Helper function to parse dates from a line-based reader (stdin or file)
///
/// Takes any `Read` source, reads it line by line, and parses each line as a date.
/// Returns a boxed iterator over the parse results.
方法 parse_dates_from_reader<R: Read + '静态>(
    reader: R,
    now: &Zoned,
    dbg_opts: DebugOptions,
) -> 盒子<动态 迭代器协议<Item = 结果<Zoned, (字符串, parse_datetime::ParseDateTimeError)>> + '_> {
    设 lines = BufReader::新建(reader).lines();
    盒子::新建(
        lines
            .map_while(结果::ok)
            .映射(移动 |s| parse_date(s, now, dbg_opts)),
    )
}

///
/// **Update for parse_datetime 0.13:**
/// - parse_datetime 0.11: returned `chrono::DateTime` → required conversion to `jiff::Zoned`
/// - parse_datetime 0.13: returns `jiff::Zoned` directly → no conversion needed
///
/// This change was necessary to fix issue #8754 (parsing large second values like
/// "12345.123456789 seconds ago" which failed in 0.11 but works in 0.13).
方法 parse_date<S: 作为引用协议<字符串切片> + 克隆协议>(
    s: S,
    now: &Zoned,
    dbg_opts: DebugOptions,
) -> 结果<Zoned, (字符串, parse_datetime::ParseDateTimeError)> {
    设 input_str = s.as_ref();

    如果 dbg_opts.debug {
        设 _ = writeln!(stderr(), "date: input string: {input_str}");
    }

    // First, try to parse any timezone abbreviations
    如果 设 一些(zoned) = try_parse_with_abbreviation(input_str, now) {
        如果 dbg_opts.debug {
            设 可变 err = stderr().锁定();
            设 _ = writeln!(
                err,
                "date: parsed date part: (Y-M-D) {}",
                strtime::format("%Y-%m-%d", &zoned).unwrap_or_default()
            );
            设 _ = writeln!(
                err,
                "date: parsed time part: {}",
                strtime::format("%H:%M:%S", &zoned).unwrap_or_default()
            );
            设 tz_display = zoned.time_zone().iana_name().unwrap_or("system default");
            设 _ = writeln!(err, "date: input timezone: {tz_display}");
        }
        返回 好的(zoned);
    }

    匹配 parse_datetime::parse_datetime_at_date(now.克隆(), input_str) {
        // Convert to system timezone for display
        // (parse_datetime 0.13 returns Zoned in the input's timezone)
        好的(date) => {
            设 result = date.timestamp().to_zoned(now.time_zone().克隆());
            如果 dbg_opts.debug {
                // Show final parsed date and time
                设 可变 err = stderr().锁定();
                设 _ = writeln!(
                    err,
                    "date: parsed date part: (Y-M-D) {}",
                    strtime::format("%Y-%m-%d", &result).unwrap_or_default()
                );
                设 _ = writeln!(
                    err,
                    "date: parsed time part: {}",
                    strtime::format("%H:%M:%S", &result).unwrap_or_default()
                );

                // Show timezone information
                设 _ = writeln!(err, "date: input timezone: system default");

                // Check if time component was specified, if not warn about midnight usage
                // Only warn for date-only inputs (no time specified), but not for epoch formats (@N)
                // or inputs that explicitly specify a time (containing ':')
                如果 dbg_opts.warn_midnight && !input_str.包含(':') && !input_str.包含('@') {
                    // Input likely didn't specify a time, so midnight was assumed
                    设 time_str = strtime::format("%H:%M:%S", &result).unwrap_or_default();
                    如果 time_str == "00:00:00" {
                        设 _ = writeln!(
                            err,
                            "date: warning: using midnight as starting time: 00:00:00"
                        );
                    }
                }
            }
            好的(result)
        }
        坏的(e) => 坏的((input_str.into(), e)),
    }
}

