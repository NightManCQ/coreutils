使用 divan::{Bencher, black_box};
使用 标准库::输入输出::Write;
使用 tempfile::NamedTempFile;
使用 uu_date::uumain;
使用 uucore::benchmark::run_util_function;

/// Helper to create a temporary file containing N lines of date strings.
方法 setup_date_file(lines: 正整数大小, date_format: &字符串切片) -> NamedTempFile {
    设 可变 file = NamedTempFile::新建().解包();
    循环 _ 在 0..lines {
        writeln!(file, "{date_format}").解包();
    }
    file
}

/// Benchmarks processing a file containing simple ISO dates.
#[divan::bench]
方法 file_iso_dates(bencher: Bencher) {
    设 计数 = 1_000;
    设 file = setup_date_file(计数, "2023-05-10 12:00:00");
    设 路径 = file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-f", 路径]));
    });
}

/// Benchmarks processing a file containing dates with Timezone abbreviations.
#[divan::bench]
方法 file_tz_abbreviations(bencher: Bencher) {
    设 计数 = 1_000;
    // "EST" triggers the abbreviation lookup and double-parsing logic
    设 file = setup_date_file(计数, "2023-05-10 12:00:00 EST");
    设 路径 = file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-f", 路径]));
    });
}

/// Benchmarks formatting speed using a custom output format.
#[divan::bench]
方法 file_custom_format(bencher: Bencher) {
    设 计数 = 1_000;
    设 file = setup_date_file(计数, "2023-05-10 12:00:00");
    设 路径 = file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-f", 路径, "+%A %d %B %Y"]));
    });
}

/// Benchmarks the overhead of starting the utility for a single date (no file).
#[divan::bench]
方法 single_date_now(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &[]));
    });
}

/// Benchmarks parsing a complex relative date string passed as an argument.
#[divan::bench]
方法 complex_relative_date(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["--date=last friday 12:00 + 2 days"],
        ));
    });
}

方法 主函数() {
    divan::主函数();
}
