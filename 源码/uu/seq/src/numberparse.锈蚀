//! Parsing numbers for use in `seq`.
//!
//! This module provides an implementation of [`FromStr`] for the
//! [`PreciseNumber`] struct.
使用 标准库::字符串切片::FromStr;

使用 uucore::parser::num_parser::{ExtendedParser, ExtendedParserError};

使用 箱::number::PreciseNumber;
使用 uucore::extendedbigdecimal::ExtendedBigDecimal;

/// An error returned when parsing a number fails.
#[derive(调试协议, 偏等比较协议, 相等比较协议)]
公有 枚举 ParseNumberError {
    Float,
    Nan,
}

/// Compute the number of integral and fractional digits in input string,
/// and wrap the result in a PreciseNumber.
/// We know that the string has already been parsed correctly, so we don't
/// need to be too careful.
方法 compute_num_digits(input: &字符串切片, ebd: ExtendedBigDecimal) -> PreciseNumber {
    设 input = input.to_lowercase();
    设 input = input.trim_start();

    // Leading + is ignored for this.
    设 input = input.strip_prefix('+').unwrap_or(input);

    // Integral digits for any hex number is ill-defined (0 is fine as an output)
    // Fractional digits for an floating hex number is ill-defined, return None
    // as we'll totally ignore that number for precision computations.
    // Still return 0 for hex integers though.
    如果 input.starts_with("0x") || input.starts_with("-0x") {
        返回 PreciseNumber {
            number: ebd,
            num_integral_digits: 0,
            num_fractional_digits: 如果 input.包含('.') || input.包含('p') {
                无
            } 否则 {
                一些(0)
            },
        };
    }

    // Split the exponent part, if any
    设 parts: 向量<&字符串切片> = input.split('e').收集();
    调试断言!(parts.长度() <= 2);

    // Count all the digits up to `.`, `-` sign is included.
    设 (可变 int_digits, 可变 frac_digits) = 匹配 parts[0].寻找('.') {
        一些(i) => {
            // Cover special case .X and -.X where we behave as if there was a leading 0:
            // 0.X, -0.X.
            设 int_digits = 匹配 i {
                0 => 1,
                1 如果 parts[0].starts_with('-') => 2,
                _ => i,
            };

            (int_digits, parts[0].长度() - i - 1)
        }
        无 => (parts[0].长度(), 0),
    };

    // If there is an exponent, reparse that (yes this is not optimal,
    // but we can't necessarily exactly recover that from the parsed number).
    如果 parts.长度() == 2 {
        设 exp = parts[1].parse::<整64>().unwrap_or(0);
        // For positive exponents, effectively expand the number. Ignore negative exponents.
        // Also ignore overflowed exponents (unwrap_or(0)).
        如果 exp > 0 {
            int_digits += exp.try_into().unwrap_or(0);
        }
        frac_digits = 如果 exp < frac_digits 转换 整64 {
            // Subtract from i128 to avoid any overflow
            (frac_digits 转换 整128 - exp 转换 整128).try_into().unwrap_or(0)
        } 否则 {
            0
        }
    }

    PreciseNumber {
        number: ebd,
        num_integral_digits: int_digits,
        num_fractional_digits: 一些(frac_digits),
    }
}

// Note: We could also have provided an `ExtendedParser` implementation for
// PreciseNumber, but we want a simpler custom error.
实现 FromStr 循环 PreciseNumber {
    类型 坏的 = ParseNumberError;
    方法 from_str(input: &字符串切片) -> 结果<自身类型, 自身类型::坏的> {
        设 ebd = 匹配 ExtendedBigDecimal::extended_parse(input) {
            好的(ebd) => 匹配 ebd {
                // Handle special values
                ExtendedBigDecimal::BigDecimal(_) | ExtendedBigDecimal::MinusZero => {
                    // TODO: GNU `seq` treats small numbers < 1e-4950 as 0, we could do the same
                    // to avoid printing senselessly small numbers.
                    ebd
                }
                ExtendedBigDecimal::Infinity | ExtendedBigDecimal::MinusInfinity => {
                    返回 好的(自身类型 {
                        number: ebd,
                        num_integral_digits: 0,
                        num_fractional_digits: 一些(0),
                    });
                }
                ExtendedBigDecimal::Nan | ExtendedBigDecimal::MinusNan => {
                    返回 坏的(ParseNumberError::Nan);
                }
            },
            坏的(ExtendedParserError::Underflow(ebd)) => ebd, // Treat underflow as 0
            坏的(_) => 返回 坏的(ParseNumberError::Float),
        };

        好的(compute_num_digits(input, ebd))
    }
}

#[cfg(test)]
模组 tests {
    使用 bigdecimal::BigDecimal;
    使用 uucore::extendedbigdecimal::ExtendedBigDecimal;

    使用 箱::number::PreciseNumber;
    使用 箱::numberparse::ParseNumberError;

    /// Convenience function for parsing a [`Number`] and unwrapping.
    方法 parse(s: &字符串切片) -> ExtendedBigDecimal {
        s.parse::<PreciseNumber>().解包().number
    }

    /// Convenience function for getting the number of integral digits.
    方法 num_integral_digits(s: &字符串切片) -> 正整数大小 {
        s.parse::<PreciseNumber>().解包().num_integral_digits
    }

    /// Convenience function for getting the number of fractional digits.
    方法 num_fractional_digits(s: &字符串切片) -> 正整数大小 {
        s.parse::<PreciseNumber>()
            .解包()
            .num_fractional_digits
            .解包()
    }

    /// Convenience function for making sure the number of fractional digits is "None"
    方法 num_fractional_digits_is_none(s: &字符串切片) -> 布尔 {
        s.parse::<PreciseNumber>()
            .解包()
            .num_fractional_digits
            .is_none()
    }

    #[test]
    方法 test_parse_minus_zero_int() {
        相等断言!(parse("-0e0"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0e-0"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0e1"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0e+1"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0.0e1"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0x0"), ExtendedBigDecimal::MinusZero);
    }

    #[test]
    方法 test_parse_minus_zero_float() {
        相等断言!(parse("-0.0"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0e-1"), ExtendedBigDecimal::MinusZero);
        相等断言!(parse("-0.0e-1"), ExtendedBigDecimal::MinusZero);
    }

    #[test]
    方法 test_parse_big_int() {
        相等断言!(parse("0"), ExtendedBigDecimal::zero());
        相等断言!(parse("0.1e1"), ExtendedBigDecimal::one());
        相等断言!(parse("0.1E1"), ExtendedBigDecimal::one());
        相等断言!(
            parse("1.0e1"),
            ExtendedBigDecimal::BigDecimal("10".parse::<BigDecimal>().解包())
        );
    }

    #[test]
    方法 test_parse_hexadecimal_big_int() {
        相等断言!(parse("0x0"), ExtendedBigDecimal::zero());
        相等断言!(
            parse("0x10"),
            ExtendedBigDecimal::BigDecimal("16".parse::<BigDecimal>().解包())
        );
    }

    #[test]
    方法 test_parse_big_decimal() {
        相等断言!(
            parse("0.0"),
            ExtendedBigDecimal::BigDecimal("0.0".parse::<BigDecimal>().解包())
        );
        相等断言!(
            parse(".0"),
            ExtendedBigDecimal::BigDecimal("0.0".parse::<BigDecimal>().解包())
        );
        相等断言!(
            parse("1.0"),
            ExtendedBigDecimal::BigDecimal("1.0".parse::<BigDecimal>().解包())
        );
        相等断言!(
            parse("10e-1"),
            ExtendedBigDecimal::BigDecimal("1.0".parse::<BigDecimal>().解包())
        );
        相等断言!(
            parse("-1e-3"),
            ExtendedBigDecimal::BigDecimal("-0.001".parse::<BigDecimal>().解包())
        );
    }

    #[test]
    方法 test_parse_inf() {
        相等断言!(parse("inf"), ExtendedBigDecimal::Infinity);
        相等断言!(parse("infinity"), ExtendedBigDecimal::Infinity);
        相等断言!(parse("+inf"), ExtendedBigDecimal::Infinity);
        相等断言!(parse("+infinity"), ExtendedBigDecimal::Infinity);
        相等断言!(parse("-inf"), ExtendedBigDecimal::MinusInfinity);
        相等断言!(parse("-infinity"), ExtendedBigDecimal::MinusInfinity);
    }

    #[test]
    方法 test_parse_invalid_float() {
        相等断言!(
            "1.2.3".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Float
        );
        相等断言!(
            "1e2e3".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Float
        );
        相等断言!(
            "1e2.3".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Float
        );
        相等断言!(
            "-+-1".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Float
        );
    }

    #[test]
    方法 test_parse_invalid_hex() {
        相等断言!(
            "0xg".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Float
        );
    }

    #[test]
    方法 test_parse_invalid_nan() {
        相等断言!(
            "nan".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Nan
        );
        相等断言!(
            "NAN".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Nan
        );
        相等断言!(
            "NaN".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Nan
        );
        相等断言!(
            "nAn".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Nan
        );
        相等断言!(
            "-nan".parse::<PreciseNumber>().unwrap_err(),
            ParseNumberError::Nan
        );
    }

    #[test]
    #[allow(clippy::cognitive_complexity)]
    方法 test_num_integral_digits() {
        // no decimal, no exponent
        相等断言!(num_integral_digits("123"), 3);
        // decimal, no exponent
        相等断言!(num_integral_digits("123.45"), 3);
        相等断言!(num_integral_digits("-0.1"), 2);
        相等断言!(num_integral_digits("-.1"), 2);
        // exponent, no decimal
        相等断言!(num_integral_digits("123e4"), 3 + 4);
        相等断言!(num_integral_digits("123e-4"), 3);
        相等断言!(num_integral_digits("-1e-3"), 2);
        // decimal and exponent
        相等断言!(num_integral_digits("123.45e6"), 3 + 6);
        相等断言!(num_integral_digits("123.45e-6"), 3);
        相等断言!(num_integral_digits("123.45e-1"), 3);
        相等断言!(num_integral_digits("-0.1e0"), 2);
        相等断言!(num_integral_digits("-0.1e2"), 4);
        相等断言!(num_integral_digits("-.1e0"), 2);
        相等断言!(num_integral_digits("-.1e2"), 4);
        相等断言!(num_integral_digits("-1.e-3"), 2);
        相等断言!(num_integral_digits("-1.0e-4"), 2);
        // minus zero int
        相等断言!(num_integral_digits("-0e0"), 2);
        相等断言!(num_integral_digits("-0e-0"), 2);
        相等断言!(num_integral_digits("-0e1"), 3);
        相等断言!(num_integral_digits("-0e+1"), 3);
        相等断言!(num_integral_digits("-0.0e1"), 3);
        // minus zero float
        相等断言!(num_integral_digits("-0.0"), 2);
        相等断言!(num_integral_digits("-0e-1"), 2);
        相等断言!(num_integral_digits("-0.0e-1"), 2);

        // TODO In GNU `seq`, the `-w` option does not seem to work with
        // hexadecimal arguments. In order to match that behavior, we
        // report the number of integral digits as zero for hexadecimal
        // inputs.
        相等断言!(num_integral_digits("0xff"), 0);
    }

    #[test]
    #[allow(clippy::cognitive_complexity)]
    方法 test_num_fractional_digits() {
        // no decimal, no exponent
        相等断言!(num_fractional_digits("123"), 0);
        相等断言!(num_fractional_digits("0xff"), 0);
        // decimal, no exponent
        相等断言!(num_fractional_digits("123.45"), 2);
        相等断言!(num_fractional_digits("-0.1"), 1);
        相等断言!(num_fractional_digits("-.1"), 1);
        // exponent, no decimal
        相等断言!(num_fractional_digits("123e4"), 0);
        相等断言!(num_fractional_digits("123e-4"), 4);
        相等断言!(num_fractional_digits("123e-1"), 1);
        相等断言!(num_fractional_digits("-1e-3"), 3);
        // decimal and exponent
        相等断言!(num_fractional_digits("123.45e6"), 0);
        相等断言!(num_fractional_digits("123.45e1"), 1);
        相等断言!(num_fractional_digits("123.45e-6"), 8);
        相等断言!(num_fractional_digits("123.45e-1"), 3);
        相等断言!(num_fractional_digits("-0.1e0"), 1);
        相等断言!(num_fractional_digits("-0.1e2"), 0);
        相等断言!(num_fractional_digits("-.1e0"), 1);
        相等断言!(num_fractional_digits("-.1e2"), 0);
        相等断言!(num_fractional_digits("-1.e-3"), 3);
        相等断言!(num_fractional_digits("-1.0e-4"), 5);
        // minus zero int
        相等断言!(num_fractional_digits("-0e0"), 0);
        相等断言!(num_fractional_digits("-0e-0"), 0);
        相等断言!(num_fractional_digits("-0e1"), 0);
        相等断言!(num_fractional_digits("-0e+1"), 0);
        相等断言!(num_fractional_digits("-0.0e1"), 0);
        // minus zero float
        相等断言!(num_fractional_digits("-0.0"), 1);
        相等断言!(num_fractional_digits("-0e-1"), 1);
        相等断言!(num_fractional_digits("-0.0e-1"), 2);
        // Hexadecimal numbers
        相等断言!(num_fractional_digits("0xff"), 0);
        断言!(num_fractional_digits_is_none("0xff.1"));
    }

    #[test]
    方法 test_parse_min_exponents() {
        // Make sure exponents < i64::MIN do not cause errors
        断言!("1e-9223372036854775807".parse::<PreciseNumber>().is_ok());
        断言!("1e-9223372036854775808".parse::<PreciseNumber>().is_ok());
        断言!("1e-92233720368547758080".parse::<PreciseNumber>().is_ok());
    }

    #[test]
    方法 test_parse_max_exponents() {
        // Make sure exponents much bigger than i64::MAX cause errors
        断言!("1e9223372036854775807".parse::<PreciseNumber>().is_ok());
        断言!("1e92233720368547758070".parse::<PreciseNumber>().is_err());
    }
}
