使用 divan::{Bencher, black_box};
使用 uu_seq::uumain;
使用 uucore::benchmark::run_util_function;

/// Benchmark simple integer sequence
#[divan::bench]
方法 seq_integers(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["1", "1000000"]));
    });
}

/// Benchmark large integer
#[divan::bench]
方法 seq_large_integers(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["4e10003", "4e10003"]));
    });
}

/// Benchmark sequence with custom separator
#[divan::bench]
方法 seq_custom_separator(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-s", ",", "1", "1000000"]));
    });
}

/// Benchmark sequence with step
#[divan::bench]
方法 seq_with_step(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["1", "2", "1000000"]));
    });
}

/// Benchmark formatted output
#[divan::bench]
方法 seq_formatted(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-f", "%.3f", "1", "0.1", "10000"],
        ));
    });
}

方法 主函数() {
    divan::主函数();
}
