            _stdout: *可变 FILE,
            _stderr: *可变 FILE,
            // other stuff
        }

        不安全 外部 "C" {
            方法 __getreent() -> *可变 _reent;
        }

        不安全 { (*__getreent())._stdin }
    }

    #[cfg(not(任意(
        target_os = "macos",
        target_os = "freebsd",
        target_os = "netbsd",
        target_os = "openbsd",
        target_os = "cygwin"
    )))]
    {
        不安全 外部 "C" {
            静态 可变 stdin: *可变 FILE;
        }
        不安全 { stdin }
    }
}

