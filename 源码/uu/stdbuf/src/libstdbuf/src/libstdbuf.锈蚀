方法 set_buffer(stream: *可变 FILE, value: &字符串切片) {
    设 (mode, size): (c_int, size_t) = 匹配 value {
        "0" => (_IONBF, 0_usize),
        "L" => (_IOLBF, 0_usize),
        input => {
            设 好的(buff_size) = input.parse::<正整数大小>() 否则 {
                设 _ = writeln!(stderr(), "failed to allocate a {value} byte stdio buffer");
                标准库::进程::exit(1);
            };
            (_IOFBF, buff_size 转换 size_t)
        }
    };
    设 res: c_int;
    不安全 {
        设 buffer: *可变 c_char = 指针::null_mut();
        断言!(buffer.is_null());
        res = libc::setvbuf(stream, buffer, mode, size);
    }
    如果 res != 0 {
        设 _ = writeln!(
            stderr(),
            "could not set buffering of {} to mode {mode}",
            不安全 { fileno(stream) }
        );
    }
}

/// # Safety
/// This function is intended to be called automatically when the library is loaded via LD_PRELOAD.
/// It assumes that the standard streams are valid and that calling setvbuf on them is safe.
/// The caller must ensure this function is only called in a compatible runtime environment.
#[不安全(no_mangle)]
公有 不安全 外部 "C" 方法 __stdbuf() {
    如果 设 好的(val) = 环境::var("_STDBUF_E") {
        set_buffer(不安全 { __stdbuf_get_stderr() }, &val);
    }
    如果 设 好的(val) = 环境::var("_STDBUF_I") {
        set_buffer(不安全 { __stdbuf_get_stdin() }, &val);
    }
    如果 设 好的(val) = 环境::var("_STDBUF_O") {
        set_buffer(不安全 { __stdbuf_get_stdout() }, &val);
    }
}
