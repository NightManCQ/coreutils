使用 标准库::环境;

方法 主函数() {
    // Make sure we're building position-independent code for use with LD_PRELOAD
    打印行!("cargo:rustc-link-arg=-fPIC");

    设 target = 环境::var("TARGET").unwrap_or_else(|_| "unknown".to_string());
    // Ensure the library doesn't have any undefined symbols (-z flag not supported on macOS and Cygwin)
    如果 !target.包含("apple-darwin") && !target.包含("cygwin") {
        打印行!("cargo:rustc-link-arg=-z");
        打印行!("cargo:rustc-link-arg=defs");
    }

    打印行!("cargo:rerun-if-changed=src/libstdbuf.rs");
}
