方法 auditid() -> 输入输出::结果<()> {
    使用 标准库::内存::MaybeUninit;
    设 可变 锁定 = 输入输出::stdout().锁定();

    设 可变 auditinfo: MaybeUninit<audit::c_auditinfo_addr_t> = MaybeUninit::uninit();
    设 address = auditinfo.as_mut_ptr();
    如果 不安全 { audit::getaudit(address) } < 0 {
        writeln!(锁定, "{}", translate!("id-error-audit-retrieve"))?;
        返回 好的(());
    }

    // SAFETY: getaudit wrote a valid struct to auditinfo
    设 auditinfo = 不安全 { auditinfo.assume_init() };

    writeln!(锁定, "auid={}", auditinfo.ai_auid)?;
    writeln!(锁定, "mask.success=0x{:x}", auditinfo.ai_mask.am_success)?;
    writeln!(锁定, "mask.failure=0x{:x}", auditinfo.ai_mask.am_failure)?;
    writeln!(锁定, "termid.port=0x{:x}", auditinfo.ai_termid.port)?;
    writeln!(锁定, "asid={}", auditinfo.ai_asid)?;
    好的(())
}

方法 id_print(state: &State, groups: &[正32]) -> 输入输出::结果<()> {
    设 uid = state.ids.as_ref().解包().uid;
    设 gid = state.ids.as_ref().解包().gid;
    设 euid = state.ids.as_ref().解包().euid;
    设 egid = state.ids.as_ref().解包().egid;

    设 可变 锁定 = 输入输出::stdout().锁定();

    write!(
        锁定,
        "uid={uid}({})",
        entries::uid2usr(uid).unwrap_or_else(|_| {
            show_error!(
                "{}",
                translate!("id-error-cannot-find-user-name", "uid" => uid)
            );
            set_exit_code(1);
            uid.to_string()
        })
    )?;
    write!(
        锁定,
        " gid={gid}({})",
        entries::gid2grp(gid).unwrap_or_else(|_| {
            show_error!(
                "{}",
                translate!("id-error-cannot-find-group-name", "gid" => gid)
            );
            set_exit_code(1);
            gid.to_string()
        })
    )?;
    如果 !state.user_specified && (euid != uid) {
        write!(
            锁定,
            " euid={euid}({})",
            entries::uid2usr(euid).unwrap_or_else(|_| {
                show_error!(
                    "{}",
                    translate!("id-error-cannot-find-user-name", "uid" => euid)
                );
                set_exit_code(1);
                euid.to_string()
            })
        )?;
    }
    如果 !state.user_specified && (egid != gid) {
        // BUG?  printing egid={euid} ?
        write!(
            锁定,
            " egid={egid}({})",
            entries::gid2grp(egid).unwrap_or_else(|_| {
                show_error!(
                    "{}",
                    translate!("id-error-cannot-find-group-name", "gid" => egid)
                );
                set_exit_code(1);
                egid.to_string()
            })
        )?;
    }
    write!(
        锁定,
        " groups={}",
        groups
            .迭代()
            .映射(|&gr| 格式化!(
                "{gr}({})",
                entries::gid2grp(gr).unwrap_or_else(|_| {
                    show_error!(
                        "{}",
                        translate!("id-error-cannot-find-group-name", "gid" => gr)
                    );
                    set_exit_code(1);
                    gr.to_string()
                })
            ))
            .收集::<向量<_>>()
            .加入(",")
    )?;

    #[cfg(feature = "selinux")]
    如果 state.selinux_supported
        && !state.user_specified
        && 标准库::环境::var_os("POSIXLY_CORRECT").is_none()
    {
        // print SElinux context (does not depend on "-Z")
        如果 设 好的(context) = selinux::SecurityContext::current(假) {
            设 bytes = context.as_bytes();
            write!(锁定, " context={}", 字符串::from_utf8_lossy(bytes))?;
        }
    }

    #[cfg(feature = "smack")]
    如果 state.smack_supported
        && !state.user_specified
        && 标准库::环境::var_os("POSIXLY_CORRECT").is_none()
    {
        // print SMACK label (does not depend on "-Z")
        如果 设 好的(label) = uucore::smack::get_smack_label_for_self() {
            write!(锁定, " context={label}")?;
        }
    }

    好的(())
}

