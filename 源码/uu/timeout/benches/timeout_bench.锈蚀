#[cfg(unix)]
使用 divan::{Bencher, black_box};
#[cfg(unix)]
使用 uu_timeout::uumain;
#[cfg(unix)]
使用 uucore::benchmark::run_util_function;

/// Benchmark the fast path where the command exits immediately.
#[cfg(unix)]
#[divan::bench]
方法 timeout_quick_exit(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["0.02", "true"]));
    });
}

/// Benchmark a command that runs longer than the threshold and receives the default signal.
#[cfg(unix)]
#[divan::bench]
方法 timeout_enforced(bencher: Bencher) {
    bencher.bench(|| {
        black_box(run_util_function(uumain, &["0.02", "sleep", "0.2"]));
    });
}

方法 主函数() {
    #[cfg(unix)]
    divan::主函数();
}
