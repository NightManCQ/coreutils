公有 模组 options {
    公有 静态 FOREGROUND: &字符串切片 = "foreground";
    公有 静态 KILL_AFTER: &字符串切片 = "kill-after";
    公有 静态 SIGNAL: &字符串切片 = "signal";
    公有 静态 PRESERVE_STATUS: &字符串切片 = "preserve-status";
    公有 静态 VERBOSE: &字符串切片 = "verbose";

