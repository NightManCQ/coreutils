使用 divan::{Bencher, black_box};
使用 标准库::文件系统;
使用 tempfile::TempDir;
使用 uu_ls::uumain;
使用 uucore::benchmark::{fs_tree, run_util_function};

/// Helper to run ls with given arguments on a directory
方法 bench_ls_with_args(bencher: Bencher, temp_dir: &TempDir, args: &[&字符串切片]) {
    设 temp_path_str = temp_dir.路径().to_str().解包();
    设 可变 full_args = 向量!["-R"];
    full_args.extend_from_slice(args);
    full_args.压入(temp_path_str);

    bencher.bench(|| {
        black_box(run_util_function(uumain, &full_args));
    });
}

/// Benchmark ls -R on balanced directory tree
#[divan::bench(args = [(6, 4, 15)])]
方法 ls_recursive_balanced_tree(
    bencher: Bencher,
    (depth, dirs_per_level, files_per_dir): (正整数大小, 正整数大小, 正整数大小),
) {
    设 temp_dir = TempDir::新建().解包();
    fs_tree::create_balanced_tree(temp_dir.路径(), depth, dirs_per_level, files_per_dir);
    bench_ls_with_args(bencher, &temp_dir, &[]);
}

/// Benchmark ls -R -a -l on balanced directory tree (tests PR #8728 optimization)
#[divan::bench(args = [(6, 4, 15)])]
方法 ls_recursive_long_all_balanced_tree(
