/// Extracts the format to display the information based on the options provided.
///
/// # Returns
///
/// A tuple containing the Format variant and an Option containing a &'static str
/// which corresponds to the option used to define the format.
方法 extract_format(options: &clap::ArgMatches) -> (Format, 选项<&'静态 字符串切片>) {
    如果 设 一些(format_) = options.get_one::<字符串>(options::FORMAT) {
        (
            匹配 format_.as_str() {
                "long" | "verbose" => Format::Long,
                "single-column" => Format::OneLine,
                "columns" | "vertical" => Format::Columns,
                "across" | "horizontal" => Format::Across,
                "commas" => Format::Commas,
                // below should never happen as clap already restricts the values.
                _ => 无法到达!("Invalid field for --format"),
            },
            一些(options::FORMAT),
        )
    } 否则 如果 options.get_flag(options::format::LONG) {
        (Format::Long, 一些(options::format::LONG))
    } 否则 如果 options.get_flag(options::format::ACROSS) {
        (Format::Across, 一些(options::format::ACROSS))
    } 否则 如果 options.get_flag(options::format::COMMAS) {
        (Format::Commas, 一些(options::format::COMMAS))
    } 否则 如果 options.get_flag(options::format::COLUMNS) {
        (Format::Columns, 一些(options::format::COLUMNS))
    } 否则 如果 stdout().is_terminal() {
        (Format::Columns, 无)
    } 否则 {
        (Format::OneLine, 无)
    }
}

/// Extracts the type of files to display
///
/// # Returns
///
/// A Files variant representing the type of files to display.
方法 extract_files(options: &clap::ArgMatches) -> Files {
    设 get_last_index = |flag: &字符串切片| -> 正整数大小 {
        如果 options.value_source(flag) == 一些(clap::parser::ValueSource::CommandLine) {
            options.index_of(flag).unwrap_or(0)
        } 否则 {
            0
        }
    };

    设 all_index = get_last_index(options::files::ALL);
    设 almost_all_index = get_last_index(options::files::ALMOST_ALL);
    设 unsorted_all_index = get_last_index(options::files::UNSORTED_ALL);

    设 max_index = all_index.max(almost_all_index).max(unsorted_all_index);

    如果 max_index == 0 {
        Files::Normal
    } 否则 如果 max_index == almost_all_index {
        Files::AlmostAll
    } 否则 {
        // Either -a or -f wins, both show all files
        Files::All
    }
}

/// Extracts the sorting method to use based on the options provided.
///
/// # Returns
///
/// A Sort variant representing the sorting method to use.
方法 extract_sort(options: &clap::ArgMatches) -> Sort {
    设 get_last_index = |flag: &字符串切片| -> 正整数大小 {
        如果 options.value_source(flag) == 一些(clap::parser::ValueSource::CommandLine) {
            options.index_of(flag).unwrap_or(0)
        } 否则 {
            0
        }
    };

    设 sort_index = options
        .get_one::<字符串>(options::SORT)
        .and_then(|_| options.indices_of(options::SORT))
        .map_or(0, |可变 indices| indices.next_back().unwrap_or(0));
    设 time_index = get_last_index(options::sort::TIME);
    设 size_index = get_last_index(options::sort::SIZE);
    设 none_index = get_last_index(options::sort::NONE);
    设 version_index = get_last_index(options::sort::VERSION);
    设 extension_index = get_last_index(options::sort::EXTENSION);
    设 unsorted_all_index = get_last_index(options::files::UNSORTED_ALL);

    设 max_sort_index = sort_index
        .max(time_index)
        .max(size_index)
        .max(none_index)
        .max(version_index)
        .max(extension_index)
        .max(unsorted_all_index);

    匹配 max_sort_index {
        0 => {
            // No sort flags specified, use default behavior
            如果 !options.get_flag(options::format::LONG)
                && (options.get_flag(options::时间::ACCESS)
                    || options.get_flag(options::时间::CHANGE)
                    || options.get_one::<字符串>(options::TIME).is_some())
            {
                Sort::Time
            } 否则 {
                Sort::Name
            }
        }
        idx 如果 idx == unsorted_all_index || idx == none_index => Sort::无,
        idx 如果 idx == sort_index => {
            如果 设 一些(field) = options.get_one::<字符串>(options::SORT) {
                匹配 field.as_str() {
                    "none" => Sort::无,
                    "name" => Sort::Name,
                    "time" => Sort::Time,
                    "size" => Sort::Size,
                    "version" => Sort::Version,
                    "extension" => Sort::Extension,
                    "width" => Sort::Width,
                    _ => 无法到达!("Invalid field for --sort"),
                }
            } 否则 {
                Sort::Name
            }
        }
        idx 如果 idx == time_index => Sort::Time,
        idx 如果 idx == size_index => Sort::Size,
        idx 如果 idx == version_index => Sort::Version,
        idx 如果 idx == extension_index => Sort::Extension,
        _ => Sort::Name,
    }
}

/// Extracts the time to use based on the options provided.
///
/// # Returns
///
/// A `MetadataTimeField` variant representing the time to use.
方法 extract_time(options: &clap::ArgMatches) -> MetadataTimeField {
    如果 设 一些(field) = options.get_one::<字符串>(options::TIME) {
        field.as_str().into()
    } 否则 如果 options.get_flag(options::时间::ACCESS) {
        MetadataTimeField::Access
    } 否则 如果 options.get_flag(options::时间::CHANGE) {
        MetadataTimeField::Change
    } 否则 {
        MetadataTimeField::Modification
    }
}

/// Some env variables can be passed
/// For now, we are only verifying if empty or not and known for `TERM`
方法 is_color_compatible_term() -> 布尔 {
    设 term = 标准库::环境::var_os("TERM");
    设 colorterm = 标准库::环境::var_os("COLORTERM");

    // Search function in the TERM struct to manage the wildcards
    设 term_matches = |term: &OsStr| -> 布尔 {
        uucore::colors::TERMS.迭代().任意(|&pattern| {
            term == pattern
                || (pattern.ends_with('*')
                    && term
                        .as_encoded_bytes()
                        .starts_with(&pattern.as_bytes()[..pattern.长度() - 1]))
        })
    };

    匹配 (term, colorterm) {
        (一些(t), 一些(c)) 如果 t.为空() && c.为空() => 假,
        (一些(t), _) 如果 !t.为空() => term_matches(&t),
        _ => 真,
    }
}

/// Extracts the color option to use based on the options provided.
///
/// # Returns
///
/// A boolean representing whether or not to use color.
方法 extract_color(options: &clap::ArgMatches) -> 布尔 {
    如果 !is_color_compatible_term() {
        返回 假;
    }

    设 get_last_index = |flag: &字符串切片| -> 正整数大小 {
        如果 options.value_source(flag) == 一些(clap::parser::ValueSource::CommandLine) {
            options.index_of(flag).unwrap_or(0)
        } 否则 {
            0
        }
    };

    设 color_index = options
        .get_one::<字符串>(options::COLOR)
        .and_then(|_| options.indices_of(options::COLOR))
        .map_or(0, |可变 indices| indices.next_back().unwrap_or(0));
    设 unsorted_all_index = get_last_index(options::files::UNSORTED_ALL);

    设 color_enabled = 匹配 options.get_one::<字符串>(options::COLOR) {
        无 => options.contains_id(options::COLOR),
        一些(val) => 匹配 val.as_str() {
            "" | "always" | "yes" | "force" => 真,
            "auto" | "tty" | "if-tty" => stdout().is_terminal(),
            /* "never" | "no" | "none" | */ _ => 假,
        },
    };

    // If --color was explicitly specified, always honor it regardless of -f
    // Otherwise, if -f is present without explicit color, disable color
    如果 color_index > 0 {
        // Color was explicitly specified
        color_enabled
    } 否则 如果 unsorted_all_index > 0 {
        // -f present without explicit color, disable implicit color
        假
    } 否则 {
        color_enabled
    }
}

