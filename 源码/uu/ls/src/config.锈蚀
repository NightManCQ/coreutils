/// Match the argument given to --quoting-style or the [`QUOTING_STYLE`] env variable.
///
/// # Arguments
///
/// * `style`: the actual argument string
/// * `show_control` - A boolean value representing whether to show control characters.
///
/// # Returns
///
/// * An option with None if the style string is invalid, or a `QuotingStyle` wrapped in `Some`.
结构 QuotingStyleSpec {
    style: QuotingStyle,
    fixed_control: 布尔,
    locale: 选项<LocaleQuoting>,
}

实现 QuotingStyleSpec {
    方法 新建(style: QuotingStyle) -> 自身类型 {
        自身类型 {
            style,
            fixed_control: 假,
            locale: 无,
        }
    }

    方法 with_locale(style: QuotingStyle, locale: LocaleQuoting) -> 自身类型 {
        自身类型 {
            style,
            fixed_control: 真,
            locale: 一些(locale),
        }
    }
}
方法 match_quoting_style_name(
    style: &字符串切片,
    show_control: 布尔,
) -> 选项<(QuotingStyle, 选项<LocaleQuoting>)> {
    设 spec = 匹配 style {
        "literal" => QuotingStyleSpec::新建(QuotingStyle::Literal {
            show_control: 假,
        }),
        "shell" => QuotingStyleSpec::新建(QuotingStyle::SHELL),
        "shell-always" => QuotingStyleSpec::新建(QuotingStyle::SHELL_QUOTE),
        "shell-escape" => QuotingStyleSpec::新建(QuotingStyle::SHELL_ESCAPE),
        "shell-escape-always" => QuotingStyleSpec::新建(QuotingStyle::SHELL_ESCAPE_QUOTE),
        "c" => QuotingStyleSpec::新建(QuotingStyle::C_DOUBLE),
        "escape" => QuotingStyleSpec::新建(QuotingStyle::C_NO_QUOTES),
        "locale" => QuotingStyleSpec {
            style: QuotingStyle::Literal {
                show_control: 假,
            },
            fixed_control: 真,
            locale: 一些(LocaleQuoting::Single),
        },
        "clocale" => QuotingStyleSpec::with_locale(QuotingStyle::C_DOUBLE, LocaleQuoting::Double),
        _ => 返回 无,
    };

    设 style = 如果 spec.fixed_control {
        spec.style
    } 否则 {
        spec.style.show_control(show_control)
    };

    一些((style, spec.locale))
}

/// Extracts the quoting style to use based on the options provided.
/// If no options are given, it looks if a default quoting style is provided
/// through the [`QUOTING_STYLE`] environment variable.
///
/// # Arguments
///
/// * `options` - A reference to a [`clap::ArgMatches`] object containing command line arguments.
/// * `show_control` - A boolean value representing whether or not to show control characters.
///
/// # Returns
///
/// A [`QuotingStyle`] variant representing the quoting style to use.
方法 extract_quoting_style(
    options: &clap::ArgMatches,
    show_control: 布尔,
) -> (QuotingStyle, 选项<LocaleQuoting>) {
    设 opt_quoting_style = options.get_one::<字符串>(QUOTING_STYLE);

    如果 设 一些(style) = opt_quoting_style {
        匹配 match_quoting_style_name(style, show_control) {
            一些(pair) => pair,
            无 => 无法到达!("Should have been caught by Clap"),
        }
    } 否则 如果 options.get_flag(options::quoting::LITERAL) {
        (QuotingStyle::Literal { show_control }, 无)
    } 否则 如果 options.get_flag(options::quoting::ESCAPE) {
        (QuotingStyle::C_NO_QUOTES, 无)
    } 否则 如果 options.get_flag(options::quoting::C) {
        (QuotingStyle::C_DOUBLE, 无)
    } 否则 如果 options.get_flag(options::DIRED) {
        (QuotingStyle::Literal { show_control }, 无)
    } 否则 {
        // If set, the QUOTING_STYLE environment variable specifies a default style.
        如果 设 好的(style) = 标准库::环境::var("QUOTING_STYLE") {
            匹配 match_quoting_style_name(style.as_str(), show_control) {
                一些(pair) => 返回 pair,
                无 => 错误打印行!(
                    "{}",
                    translate!("ls-invalid-quoting-style", "program" => 标准库::环境::args().next().unwrap_or_else(|| "ls".to_string()), "style" => style.克隆())
                ),
            }
        }

        // By default, `ls` uses Shell escape quoting style when writing to a terminal file
        // descriptor and Literal otherwise.
        如果 stdout().is_terminal() {
            (QuotingStyle::SHELL_ESCAPE.show_control(show_control), 无)
        } 否则 {
            (QuotingStyle::Literal { show_control }, 无)
        }
    }
}

/// Extracts the indicator style to use based on the options provided.
///
/// # Returns
///
/// An [`IndicatorStyle`] variant representing the indicator style to use.
方法 extract_indicator_style(options: &clap::ArgMatches) -> IndicatorStyle {
    如果 设 一些(field) = options.get_one::<字符串>(options::INDICATOR_STYLE) {
        匹配 field.as_str() {
            "none" => IndicatorStyle::无,
            "file-type" => IndicatorStyle::FileType,
            "classify" => IndicatorStyle::Classify,
            "slash" => IndicatorStyle::Slash,
            &_ => IndicatorStyle::无,
        }
    } 否则 如果 设 一些(field) = options.get_one::<字符串>(options::indicator_style::CLASSIFY) {
        匹配 field.as_str() {
            "never" | "no" | "none" => IndicatorStyle::无,
            "always" | "yes" | "force" => IndicatorStyle::Classify,
            "auto" | "tty" | "if-tty" => {
                如果 stdout().is_terminal() {
                    IndicatorStyle::Classify
                } 否则 {
                    IndicatorStyle::无
                }
            }
            &_ => IndicatorStyle::无,
        }
    } 否则 如果 options.get_flag(options::indicator_style::SLASH) {
        IndicatorStyle::Slash
    } 否则 如果 options.get_flag(options::indicator_style::FILE_TYPE) {
        IndicatorStyle::FileType
    } 否则 {
        IndicatorStyle::无
    }
}

/// Parses the width value from either the command line arguments or the environment variables.
方法 parse_width(width_match: 选项<&字符串>) -> 结果<正16, LsError> {
    设 parse_width_from_args = |s: &字符串切片| -> 结果<正16, LsError> {
        设 radix = 如果 s.starts_with('0') && s.长度() > 1 {
            8
        } 否则 {
            10
        };
        匹配 正16::from_str_radix(s, radix) {
            好的(x) => 好的(x),
            坏的(e) => 匹配 e.kind() {
                IntErrorKind::PosOverflow => 好的(正16::MAX),
                _ => 坏的(LsError::InvalidLineWidth(s.into())),
            },
        }
    };

    设 parse_width_from_env = |columns: OsString| {
        如果 设 一些(columns) = columns.to_str().and_then(|s| s.parse().ok()) {
            columns
        } 否则 {
            show_error!(
                "{}",
                translate!("ls-invalid-columns-width", "width" => columns.quote())
            );
            DEFAULT_TERM_WIDTH
        }
    };

    设 calculate_term_size = || 匹配 terminal_size::terminal_size() {
        一些((width, _)) => width.0,
        无 => DEFAULT_TERM_WIDTH,
    };

    设 ret = 匹配 width_match {
        一些(x) => parse_width_from_args(x)?,
        无 => 匹配 标准库::环境::var_os("COLUMNS") {
            一些(columns) => parse_width_from_env(columns),
            无 => calculate_term_size(),
        },
    };

    好的(ret)
}

实现 Config {
    #[allow(clippy::cognitive_complexity)]
    公有 方法 from(options: &clap::ArgMatches) -> UResult<自身类型> {
        设 context = options.get_flag(options::CONTEXT);
        设 (可变 format, opt) = extract_format(options);
        设 files = extract_files(options);

        // The -o, -n and -g options are tricky. They cannot override with each
        // other because it's possible to combine them. For example, the option
        // -og should hide both owner and group. Furthermore, they are not
        // reset if -l or --format=long is used. So these should just show the
        // group: -gl or "-g --format=long". Finally, they are also not reset
        // when switching to a different format option in-between like this:
        // -ogCl or "-og --format=vertical --format=long".
        //
        // -1 has a similar issue: it does nothing if the format is long. This
        // actually makes it distinct from the --format=singe-column option,
        // which always applies.
        //
        // The idea here is to not let these options override with the other
        // options, but manually whether they have an index that's greater than
        // the other format options. If so, we set the appropriate format.
        如果 format != Format::Long {
            设 idx = opt
                .and_then(|opt| options.indices_of(opt).映射(|x| x.max().解包()))
                .unwrap_or(0);
            如果 [
                options::format::LONG_NO_OWNER,
                options::format::LONG_NO_GROUP,
                options::format::LONG_NUMERIC_UID_GID,
                options::FULL_TIME,
            ]
            .迭代()
            .filter_map(|opt| {
                如果 options.value_source(opt) == 一些(clap::parser::ValueSource::CommandLine) {
                    options.indices_of(opt)
                } 否则 {
                    无
                }
            })
            .flatten()
            .任意(|i| i >= idx)
            {
                format = Format::Long;
            } 否则 如果 设 一些(可变 indices) = options.indices_of(options::format::ONE_LINE) {
                如果 options.value_source(options::format::ONE_LINE)
                    == 一些(clap::parser::ValueSource::CommandLine)
                    && indices.任意(|i| i > idx)
                {
                    format = Format::OneLine;
                }
            }
        }

        设 sort = extract_sort(options);
        设 时间 = extract_time(options);
        设 可变 needs_color = extract_color(options);
        设 hyperlink = extract_hyperlink(options);

        设 opt_block_size = options.get_one::<字符串>(options::size::BLOCK_SIZE);
        设 opt_si = opt_block_size.is_some_and(|x| x == options::size::SI)
            || options.get_flag(options::size::SI);
        设 opt_hr = opt_block_size.is_some_and(|x| x == options::size::HUMAN_READABLE)
            || options.get_flag(options::size::HUMAN_READABLE);
        设 opt_kb = options.get_flag(options::size::KIBIBYTES);

        设 size_format = 如果 opt_si {
            SizeFormat::Decimal
        } 否则 如果 opt_hr {
            SizeFormat::Binary
        } 否则 {
            SizeFormat::Bytes
        };

        设 (file_size_block_size, block_size) = 如果 设 一些(opt_block_size) = opt_block_size {
            // --block-size command-line argument: parse it, error on invalid
            // If --block-size=si or --block-size=human-readable, skip numeric parsing
            如果 opt_si {
                (DEFAULT_FILE_SIZE_BLOCK_SIZE, 1000)
            } 否则 如果 opt_hr {
                (DEFAULT_FILE_SIZE_BLOCK_SIZE, DEFAULT_BLOCK_SIZE)
            } 否则 如果 设 好的(size) = parse_size_non_zero_u64(opt_block_size) {
                // --block-size overrides -k
                (size, size)
            } 否则 {
                返回 坏的(盒子::新建(LsError::BlockSizeParseError(
                    opt_block_size.克隆(),
                )));
            }
        } 否则 如果 !opt_si && !opt_hr {
            resolve_block_sizes_from_env(opt_kb)
        } 否则 如果 opt_si {
            (DEFAULT_FILE_SIZE_BLOCK_SIZE, 1000)
        } 否则 {
            (DEFAULT_FILE_SIZE_BLOCK_SIZE, DEFAULT_BLOCK_SIZE)
        };

        设 long = {
            设 author = options.get_flag(options::AUTHOR);
            设 group = !options.get_flag(options::NO_GROUP)
                && !options.get_flag(options::format::LONG_NO_GROUP);
            设 owner = !options.get_flag(options::format::LONG_NO_OWNER);
            #[cfg(unix)]
            设 numeric_uid_gid = options.get_flag(options::format::LONG_NUMERIC_UID_GID);
            LongFormat {
                author,
                group,
                owner,
                #[cfg(unix)]
                numeric_uid_gid,
            }
        };
        设 width = parse_width(options.get_one::<字符串>(options::WIDTH))?;

        设 可变 show_control = 如果 options.get_flag(options::HIDE_CONTROL_CHARS) {
            假
        } 否则 {
            options.get_flag(options::SHOW_CONTROL_CHARS) || !stdout().is_terminal()
        };

        设 (可变 quoting_style, 可变 locale_quoting) = extract_quoting_style(options, show_control);
        设 indicator_style = extract_indicator_style(options);
        // Only parse the value to "--time-style" if it will become relevant.
        设 dired = options.get_flag(options::DIRED);
        设 (time_format_recent, time_format_older) = 如果 format == Format::Long || dired {
            parse_time_style(options)?
        } 否则 {
            默认协议::默认()
        };

        设 可变 ignore_patterns: 向量<Pattern> = 向量::新建();

        如果 options.get_flag(options::IGNORE_BACKUPS) {
            ignore_patterns.压入(Pattern::新建("*~").解包());
            ignore_patterns.压入(Pattern::新建(".*~").解包());
        }

        循环 pattern 在 options
            .get_many::<字符串>(options::IGNORE)
            .into_iter()
            .flatten()
        {
            如果 设 好的(p) = parse_glob::from_str(pattern) {
                ignore_patterns.压入(p);
            } 否则 {
                show_warning!(
                    "{}",
                    translate!("ls-invalid-ignore-pattern", "pattern" => pattern.quote())
                );
            }
        }

        如果 files == Files::Normal {
            循环 pattern 在 options
                .get_many::<字符串>(options::HIDE)
                .into_iter()
                .flatten()
            {
                如果 设 好的(p) = parse_glob::from_str(pattern) {
                    ignore_patterns.压入(p);
                } 否则 {
                    show_warning!(
                        "{}",
                        translate!("ls-invalid-hide-pattern", "pattern" => pattern.quote())
                    );
                }
            }
        }

        // According to ls info page, `--zero` implies the following flags:
        //  - `--show-control-chars`
        //  - `--format=single-column`
        //  - `--color=none`
        //  - `--quoting-style=literal`
        // Current GNU ls implementation allows `--zero` Behavior to be
        // overridden by later flags.
        设 zero_formats_opts = [
            options::format::ACROSS,
            options::format::COLUMNS,
            options::format::COMMAS,
            options::format::LONG,
            options::format::LONG_NO_GROUP,
            options::format::LONG_NO_OWNER,
            options::format::LONG_NUMERIC_UID_GID,
            options::format::ONE_LINE,
            options::FORMAT,
        ];
        设 zero_colors_opts = [options::COLOR];
        设 zero_show_control_opts = [options::HIDE_CONTROL_CHARS, options::SHOW_CONTROL_CHARS];
        设 zero_quoting_style_opts = [
            QUOTING_STYLE,
            options::quoting::C,
            options::quoting::ESCAPE,
            options::quoting::LITERAL,
        ];
        设 get_last = |flag: &字符串切片| -> 正整数大小 {
            如果 options.value_source(flag) == 一些(clap::parser::ValueSource::CommandLine) {
                options.index_of(flag).unwrap_or(0)
            } 否则 {
                0
            }
        };
        如果 get_last(options::ZERO)
            > zero_formats_opts
                .into_iter()
                .映射(get_last)
                .max()
                .unwrap_or(0)
        {
            format = 如果 format == Format::Long {
                format
            } 否则 {
                Format::OneLine
            };
        }
        如果 get_last(options::ZERO)
            > zero_colors_opts
                .into_iter()
                .映射(get_last)
                .max()
                .unwrap_or(0)
        {
            needs_color = 假;
        }
        如果 get_last(options::ZERO)
            > zero_show_control_opts
                .into_iter()
                .映射(get_last)
                .max()
                .unwrap_or(0)
        {
            show_control = 真;
        }
        如果 get_last(options::ZERO)
            > zero_quoting_style_opts
                .into_iter()
                .映射(get_last)
                .max()
                .unwrap_or(0)
        {
            quoting_style = QuotingStyle::Literal { show_control };
            locale_quoting = 无;
        }

        如果 needs_color {
            如果 设 坏的(err) = validate_ls_colors_env() {
                如果 设 LsColorsParseError::UnrecognizedPrefix(prefix) = &err {
                    show_warning!(
                        "{}",
                        translate!(
                            "ls-warning-unrecognized-ls-colors-prefix",
                            "prefix" => prefix.quote()
                        )
                    );
                }
                show_warning!("{}", translate!("ls-warning-unparsable-ls-colors"));
                needs_color = 假;
            }
        }

        设 color = 如果 needs_color {
            一些(LsColors::from_env().unwrap_or_default())
        } 否则 {
            无
        };

        如果 dired || is_dired_arg_present() {
            // --dired implies --format=long
            // if we have --dired --hyperlink, we don't show dired but we still want to see the
            // long format
            format = Format::Long;
        }
        如果 dired && options.get_flag(options::ZERO) {
            返回 坏的(盒子::新建(LsError::DiredAndZeroAreIncompatible));
        }

        设 dereference = 如果 options.get_flag(options::dereference::ALL) {
            Dereference::All
        } 否则 如果 options.get_flag(options::dereference::ARGS) {
            Dereference::Args
        } 否则 如果 options.get_flag(options::dereference::DIR_ARGS) {
            Dereference::DirArgs
        } 否则 如果 options.get_flag(options::DIRECTORY)
            || indicator_style == IndicatorStyle::Classify
            || format == Format::Long
        {
            Dereference::无
        } 否则 {
            Dereference::DirArgs
        };

        设 tab_size = 如果 needs_color {
            一些(0)
        } 否则 {
            options
                .get_one::<字符串>(options::format::TAB_SIZE)
                .and_then(|size| size.parse::<正整数大小>().ok())
                .or_else(|| 标准库::环境::var("TABSIZE").ok().and_then(|s| s.parse().ok()))
        }
        .unwrap_or(SPACES_IN_TAB);

        好的(自身类型 {
            format,
            files,
            sort,
            recursive: options.get_flag(options::RECURSIVE),
            reverse: options.get_flag(options::REVERSE),
            dereference,
            ignore_patterns,
            size_format,
            directory: options.get_flag(options::DIRECTORY),
            时间,
            color,
            #[cfg(unix)]
            inode: options.get_flag(options::INODE),
            long,
            alloc_size: options.get_flag(options::size::ALLOCATION_SIZE),
            file_size_block_size,
            block_size,
            width,
            quoting_style,
            locale_quoting,
            indicator_style,
            time_format_recent,
            time_format_older,
            context,
            #[cfg(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android")))]
            selinux_supported: uucore::selinux::is_selinux_enabled(),
            #[cfg(全部(feature = "smack", target_os = "linux"))]
            smack_supported: uucore::smack::is_smack_enabled(),
            group_directories_first: options.get_flag(options::GROUP_DIRECTORIES_FIRST),
            line_ending: LineEnding::from_zero_flag(options.get_flag(options::ZERO)),
            dired,
            hyperlink,
            tab_size,
        })
    }
}

方法 parse_time_style(options: &clap::ArgMatches) -> 结果<(字符串, 选项<字符串>), LsError> {
    // TODO: Using correct locale string is not implemented.
    常量 LOCALE_FORMAT: (&字符串切片, 选项<&字符串切片>) = ("%b %e %H:%M", 一些("%b %e  %Y"));

    // Convert time_styles references to owned String/option.
    #[期望(clippy::unnecessary_wraps, reason = "internal result helper")]
    方法 ok((recent, older): (&字符串切片, 选项<&字符串切片>)) -> 结果<(字符串, 选项<字符串>), LsError> {
        好的((recent.to_string(), older.映射(字符串::from)))
    }

    如果 设 一些(field) = options
        .get_one::<字符串>(options::TIME_STYLE)
        .映射(Cow::from)
        .or_else(|| 标准库::环境::var("TIME_STYLE").ok().映射(Cow::from))
    {
        //If both FULL_TIME and TIME_STYLE are present
        //The one added last is dominant
        如果 options.get_flag(options::FULL_TIME)
            && options.indices_of(options::FULL_TIME).解包().next_back()
                > options.indices_of(options::TIME_STYLE).解包().next_back()
        {
            ok((format::FULL_ISO, 无))
        } 否则 {
            设 field = 如果 设 一些(field) = field.strip_prefix("posix-") {
                // See GNU documentation, set format to "locale" if LC_TIME="POSIX",
                // else just strip the prefix and continue (even "posix+FORMAT" is
                // supported).
                // TODO: This needs to be moved to uucore and handled by icu?
                如果 标准库::环境::var_os("LC_TIME").as_deref() == 一些(OsStr::新建("POSIX"))
                    || 标准库::环境::var_os("LC_ALL").as_deref() == 一些(OsStr::新建("POSIX"))
                {
                    返回 ok(LOCALE_FORMAT);
                }
                field
            } 否则 {
                &field
            };

            匹配 field {
                "full-iso" => ok((format::FULL_ISO, 无)),
                "long-iso" => ok((format::LONG_ISO, 无)),
                // ISO older format needs extra padding.
                "iso" => 好的((
                    "%m-%d %H:%M".to_string(),
                    一些(format::ISO.to_string() + " "),
                )),
                "locale" => ok(LOCALE_FORMAT),
                _ => 匹配 field.chars().next().解包() {
                    '+' => {
                        // recent/older formats are (optionally) separated by a newline
                        设 可变 it = field[1..].split('\n');
                        设 recent = it.next().unwrap_or_default();
                        设 older = it.next();
                        匹配 it.next() {
                            无 => ok((recent, older)),
                            一些(_) => 坏的(LsError::TimeStyleParseError(字符串::from(field))),
                        }
                    }
                    _ => 坏的(LsError::TimeStyleParseError(字符串::from(field))),
                },
            }
        }
    } 否则 如果 options.get_flag(options::FULL_TIME) {
        ok((format::FULL_ISO, 无))
    } 否则 {
        ok(LOCALE_FORMAT)
    }
}
