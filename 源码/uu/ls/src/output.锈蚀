模组 tests {
    使用 超级::*;

    #[test]
    方法 test_entry_info_is_dir() {
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/dir"),
            display_name: OsString::from("dir"),
            file_type: 无,
            metadata: 无,
            security_context: 字符串::新建(),
            command_line: 假,
            must_dereference: 假,
        };
        断言!(!entry.is_dir());
    }

    #[test]
    方法 test_entry_info_size() {
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/file"),
            display_name: OsString::from("file"),
            file_type: 无,
            metadata: 无,
            security_context: 字符串::新建(),
            command_line: 假,
            must_dereference: 假,
        };
        相等断言!(entry.size(), 无);
    }

    #[test]
    方法 test_entry_info_file_name() {
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/file.txt"),
            display_name: OsString::from("file.txt"),
            file_type: 无,
