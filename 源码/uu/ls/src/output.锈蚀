    #[test]
    方法 test_streaming_output_new() {
        设 collector = StreamingOutput::新建();
        断言!(collector.entries().为空());
        断言!(collector.directories().为空());
        断言!(collector.totals().为空());
    }

    #[test]
    方法 test_streaming_output_write_entry() {
        设 可变 collector = StreamingOutput::新建();
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/file"),
            display_name: OsString::from("file"),
            file_type: 无,
            metadata: 无,
            security_context: 字符串::新建(),
            command_line: 假,
            must_dereference: 假,
        };
        collector.write_entry(&entry).解包();
        相等断言!(collector.entries().长度(), 1);
        相等断言!(collector.entries()[0].display_name, OsString::from("file"));
    }

    #[test]
    方法 test_streaming_output_clear() {
        设 可变 collector = StreamingOutput::新建();
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/file"),
            display_name: OsString::from("file"),
            file_type: 无,
            metadata: 无,
            security_context: 字符串::新建(),
            command_line: 假,
            must_dereference: 假,
        };
        collector.write_entry(&entry).解包();

        collector.clear();
        断言!(collector.entries().为空());
        断言!(collector.directories().为空());
        断言!(collector.totals().为空());
    }

    #[test]
    方法 test_streaming_output_into_entries() {
        设 可变 collector = StreamingOutput::新建();
        设 entry = EntryInfo {
            路径: PathBuf::from("/test/file"),
            display_name: OsString::from("file"),
            file_type: 无,
            metadata: 无,
            security_context: 字符串::新建(),
            command_line: 假,
            must_dereference: 假,
        };
        collector.write_entry(&entry).解包();

        设 entries = collector.into_entries();
        相等断言!(entries.长度(), 1);
        相等断言!(entries[0].display_name, OsString::from("file"));
    }

    #[test]
    方法 test_streaming_output_flush() {
        设 可变 collector = StreamingOutput::新建();
