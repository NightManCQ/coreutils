/// Lists files and directories, sending structured output to a custom sink.
///
/// This function provides programmatic access to ls functionality without
/// requiring text parsing. It enumerates files and directories according
/// to the provided configuration and sends each entry to the output sink.
///
/// # Arguments
///
/// * `locs` - Paths to list
/// * `config` - Configuration controlling listing behavior
/// * `output` - A sink implementing [`LsOutput`] to receive entries
///
/// # Example
///
/// ```ignore
/// use uu_ls::{Config, list_with_output, StreamingOutput};
/// use std::path::Path;
///
/// let config = Config::from(&matches)?;
/// let mut output = StreamingOutput::new();
/// list_with_output(vec![Path::new(".")], &config, &mut output)?;
///
/// for entry in output.entries() {
///     println!("{}: {:?}", entry.display_name.to_string_lossy(), entry.file_type);
/// }
/// ```
公有 方法 list_with_output<O: LsOutput>(
    locs: 向量<&Path>,
    config: &Config,
    output: &可变 O,
) -> UResult<()> {
    设 可变 files = 向量::with_capacity(locs.长度());
    设 可变 dirs = 向量::with_capacity(locs.长度());
    设 initial_locs_len = locs.长度();

    循环 loc 在 locs {
        设 path_data = PathData::新建(loc.into(), 无, 无, config, 真);

        // Getting metadata here is no big deal as it's just the CWD
        // and we really just want to know if the strings exist as files/dirs
        //
        // Proper GNU handling is don't show if dereferenced symlink DNE
        // but only for the base dir, for a child dir show, and print ?s
        // in long format
        如果 path_data.metadata().is_none() {
            继续;
        }

        设 show_dir_contents = 如果 设 一些(ft) = path_data.file_type() {
            !config.directory && ft.is_dir()
        } 否则 {
            set_exit_code(1);
            假
        };

        如果 show_dir_contents {
            dirs.压入(path_data);
        } 否则 {
            files.压入(path_data);
        }
    }

    sort_entries(&可变 files, config);
    sort_entries(&可变 dirs, config);

    output.initialize(config)?;

    // Write file entries.
    如果 matches!(output.stream_mode(), StreamMode::Streaming) {
        循环 file_entry 在 &files {
            output.write_entry(&file_entry.to_entry_info(config))?;
        }
    } 否则 {
        output.write_entries(&files, config)?;
    }

    设 可变 entries = 向量::<PathData>::with_capacity(2);

    循环 (pos, path_data) 在 dirs.迭代().enumerate() {
        // Do read_dir call here to match GNU semantics by printing
        // read_dir errors before directory headings, names and totals
        设 read_dir = 匹配 文件系统::read_dir(path_data.路径()) {
            坏的(err) => {
                // flush stdout buffer before the error to preserve formatting and order
                output.flush()?;
                show!(LsError::IOErrorContext(
                    path_data.路径().to_path_buf(),
                    err,
                    path_data.command_line
                ));
                继续;
            }
            好的(rd) => rd,
        };

        // Write dir heading for multiple arguments or recursive mode
        如果 initial_locs_len > 1 || config.recursive {
            设 is_first = pos == 0 && files.为空();
            output.write_dir_header(path_data, config, is_first)?;
        }

        设 可变 listed_ancestors = FxHashSet::默认();
        listed_ancestors.插入(FileInformation::from_path(
            path_data.路径(),
            path_data.must_dereference,
        )?);
        enter_directory(
            path_data,
            read_dir,
            config,
            &可变 listed_ancestors,
            output,
            &可变 entries,
        )?;
    }

    output.finalize(config)?;
    好的(())
}

方法 collect_directory_entries<O: LsOutput>(
    entries: &可变 向量<PathData>,
    path_data: &PathData,
    config: &Config,
    output: &可变 O,
    read_dir: &可变 ReadDir,
) -> UResult<()> {
    entries.clear();

    如果 config.files == Files::All {
        entries.压入(PathData::新建(
            path_data.路径().to_path_buf().into(),
            无,
            一些(OsStr::新建(".").into()),
            config,
            假,
        ));
        entries.压入(PathData::新建(
            path_data.路径().加入("..").into(),
            无,
            一些(OsStr::新建("..").into()),
            config,
            假,
        ));
    }

    循环 raw_entry 在 read_dir.by_ref() {
        设 dir_entry = 匹配 raw_entry {
            好的(路径) => 路径,
            坏的(err) => {
                output.flush()?;
                show!(LsError::IOError(err));
                继续;
            }
        };

        如果 should_display(&dir_entry, config) {
            entries.压入(PathData::新建(
                dir_entry.路径().into(),
                一些(dir_entry),
                无,
                config,
                假,
            ));
        }
    }

    sort_entries(entries, config);
    entries.shrink_to_fit();

    好的(())
}

方法 write_directory_entries<O: LsOutput>(
    entries: &[PathData],
    config: &Config,
    output: &可变 O,
) -> UResult<()> {
    如果 config.format == Format::Long || config.alloc_size {
        设 total_size: 正64 = entries
            .迭代()
            .映射(|item| {
                item.metadata()
                    .as_ref()
                    .map_or(0, |md| get_block_size(md, config))
            })
            .求和();
        output.write_total(total_size, config)?;
    }

    如果 matches!(output.stream_mode(), StreamMode::Streaming) {
        循环 entry 在 entries {
            output.write_entry(&entry.to_entry_info(config))?;
        }
        好的(())
    } 否则 {
        output.write_entries(entries, config)
    }
}

/// Recursively traverse directories using an explicit stack.
///
/// This avoids deep recursive call chains while preserving GNU-style
/// directory traversal order and ancestor detection.
方法 enter_directory<O: LsOutput>(
    path_data: &PathData,
    read_dir: ReadDir,
    config: &Config,
    listed_ancestors: &可变 FxHashSet<FileInformation>,
    output: &可变 O,
    entries: &可变 向量<PathData>,
) -> UResult<()> {
    结构 StackEntry {
        路径: PathBuf,
        command_line: 布尔,
        is_first: 布尔,
    }

    设 可变 stack = 向量::新建();
    设 可变 current = 一些(StackEntry {
        路径: path_data.路径().to_path_buf(),
        command_line: path_data.command_line,
        is_first: 真,
    });
    设 可变 initial_read_dir = 一些(read_dir);

    当 设 一些(entry) = current.take().or_else(|| stack.弹出()) {
        设 path_data = PathData::新建(
            entry.路径.as_path().into(),
            无,
            无,
            config,
            entry.command_line,
        );

        如果 !entry.is_first {
            output.write_dir_header(&path_data, config, 假)?;
        }

        设 可变 current_read_dir = 如果 entry.is_first {
            initial_read_dir
                .take()
                .期望("initial read_dir is present for first entry")
        } 否则 {
            匹配 文件系统::read_dir(&entry.路径) {
                坏的(err) => {
                    output.flush()?;
                    show!(LsError::IOErrorContext(
                        entry.路径.克隆(),
                        err,
                        entry.command_line,
                    ));
                    继续;
                }
                好的(rd) => rd,
            }
        };

        collect_directory_entries(entries, &path_data, config, output, &可变 current_read_dir)?;
        write_directory_entries(entries, config, output)?;

        如果 config.recursive {
            设 start = 如果 config.files == Files::All { 2 } 否则 { 0 };

            循环 child 在 entries
                .迭代()
                .skip(start)
                .过滤(|p| p.file_type().is_some_and(FileType::is_dir))
                .rev()
            {
                设 child_path = child.路径().to_path_buf();
                设 child_must_dereference = child.must_dereference;
                设 child_command_line = child.command_line;

                匹配 文件系统::read_dir(&child_path) {
                    坏的(err) => {
                        output.flush()?;
                        show!(LsError::IOErrorContext(
                            child_path.克隆(),
                            err,
                            child_command_line,
                        ));
                    }
                    好的(_) => {
                        如果 listed_ancestors.插入(FileInformation::from_path(
                            &child_path,
                            child_must_dereference,
                        )?) {
                            stack.压入(StackEntry {
                                路径: child_path,
                                command_line: child_command_line,
                                is_first: 假,
                            });
                        } 否则 {
                            output.flush()?;
                            show!(LsError::AlreadyListedError(child_path));
                        }
                    }
                }
            }
        }
    }

    好的(())
}

