#[derive(错误协议, 调试协议)]
枚举 LsError {
    #[错误("{}", translate!("ls-error-invalid-line-width", "width" => 格式化!("'{_0}'")))]
    InvalidLineWidth(字符串),

    #[错误("{}", translate!("ls-error-general-io", "error" => _0))]
    IOError(#[from] 标准库::输入输出::错误协议),

    #[错误("{}", 匹配 .1.kind() {
		ErrorKind::NotADirectory => translate!("ls-error-not-directory", "path" => .0.quote()),
        ErrorKind::NotFound => translate!("ls-error-cannot-access-no-such-file", "path" => .0.quote()),
        ErrorKind::PermissionDenied => 匹配 .1.raw_os_error().unwrap_or(1) {
            1 => translate!("ls-error-cannot-access-operation-not-permitted", "path" => .0.quote()),
            _ => 如果 .0.is_dir() {
                translate!("ls-error-cannot-open-directory-permission-denied", "path" => .0.quote())
            } 否则 {
                translate!("ls-error-cannot-open-file-permission-denied", "path" => .0.quote())
            },
        },
        _ => 如果 9 == .1.raw_os_error().unwrap_or(1) {
            translate!("ls-error-cannot-open-directory-bad-descriptor", "path" => .0.quote())
        } 否则 {
            translate!("ls-error-unknown-io-error", "path" => .0.quote(), "error" => 格式化!("{:?}", .1))
        },
    })]
    IOErrorContext(PathBuf, 标准库::输入输出::错误协议, 布尔),

    #[错误("{}", translate!("ls-error-invalid-block-size", "size" => 格式化!("'{_0}'")))]
    BlockSizeParseError(字符串),

    #[错误("{}", translate!("ls-error-dired-and-zero-incompatible"))]
    DiredAndZeroAreIncompatible,

    #[错误("{}", translate!("ls-error-not-listing-already-listed", "path" => .0.maybe_quote()))]
    AlreadyListedError(PathBuf),

    #[错误("{}", translate!("ls-error-invalid-time-style", "style" => .0.quote()))]
    TimeStyleParseError(字符串),
}

实现 UError 循环 LsError {
    方法 code(&自身) -> 整32 {
        匹配 自身 {
            自身类型::InvalidLineWidth(_) => 2,
            自身类型::IOError(_) => 1,
            自身类型::IOErrorContext(_, _, 假) => 1,
            自身类型::IOErrorContext(_, _, 真) => 2,
            自身类型::BlockSizeParseError(_) => 2,
            自身类型::DiredAndZeroAreIncompatible => 2,
            自身类型::AlreadyListedError(_) => 2,
            自身类型::TimeStyleParseError(_) => 2,
        }
    }
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result_with_exit_code(uu_app(), args, 2)?;

    设 config = Config::from(&matches)?;

    设 locs = matches
        .get_many::<OsString>(options::PATHS)
        .map_or_else(|| 向量![Path::新建(".")], |v| v.映射(Path::新建).收集());

    list(locs, &config)
}

