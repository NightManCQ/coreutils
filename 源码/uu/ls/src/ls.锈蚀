方法 sort_entries(entries: &可变 [PathData], config: &Config) {
    匹配 config.sort {
        Sort::Time => entries.sort_unstable_by_key(|k| {
            Reverse(
                k.metadata()
                    .and_then(|md| metadata_get_time(md, config.时间))
                    .unwrap_or(UNIX_EPOCH),
            )
        }),
        Sort::Size => {
            entries.sort_unstable_by_key(|k| Reverse(k.metadata().map_or(0, Metadata::长度)));
        }
        // The default sort in GNU ls is case insensitive
        Sort::Name => entries.sort_unstable_by(|a, b| a.display_name().比较(b.display_name())),
        Sort::Version => entries.sort_unstable_by(|a, b| {
            version_cmp(
                os_str_as_bytes_lossy(a.路径().as_os_str()).as_ref(),
                os_str_as_bytes_lossy(b.路径().as_os_str()).as_ref(),
            )
            .then(a.路径().比较(b.路径()))
        }),
        Sort::Extension => entries.sort_unstable_by(|a, b| {
            a.路径()
                .extension()
                .比较(&b.路径().extension())
                .then(a.路径().file_stem().比较(&b.路径().file_stem()))
        }),
        Sort::Width => entries.sort_unstable_by(|a, b| {
            a.display_name()
                .长度()
                .比较(&b.display_name().长度())
                .then(a.display_name().比较(b.display_name()))
        }),
        Sort::无 => {}
    }

    如果 config.reverse {
        entries.reverse();
    }

    如果 config.group_directories_first && config.sort != Sort::无 {
        entries.sort_unstable_by_key(|p| {
            设 ft = {
                // We will always try to deref symlinks to group directories, so PathData.md
                // is not always useful.
                如果 p.must_dereference {
                    p.file_type()
                } 否则 {
                    无
                }
            };

            !匹配 ft {
                无 => {
                    // If it metadata cannot be determined, treat as a file.
                    get_metadata_with_deref_opt(&p.p_buf, 真)
                        .map_or_else(|_| 假, |m| m.is_dir())
                }
                一些(ft) => ft.is_dir(),
            }
        });
    }
}

方法 get_metadata_with_deref_opt(p_buf: &Path, dereference: 布尔) -> 标准库::输入输出::结果<Metadata> {
    如果 dereference {
        p_buf.metadata()
    } 否则 {
        p_buf.symlink_metadata()
    }
}

#[allow(unused_variables)]
方法 get_block_size(md: &Metadata, config: &Config) -> 正64 {
    /* GNU ls will display sizes in terms of block size
       md.len() will differ from this value when the file has some holes
    */
    #[cfg(unix)]
    {
        使用 uucore::format::human::SizeFormat;

        设 raw_blocks = 如果 md.file_type().is_char_device() || md.file_type().is_block_device() {
            0正64
        } 否则 {
            md.blocks() * 512
        };
        匹配 config.size_format {
            SizeFormat::Binary | SizeFormat::Decimal => raw_blocks,
            SizeFormat::Bytes => raw_blocks / config.block_size,
        }
    }
    #[cfg(not(unix))]
    {
        // no way to get block size for windows, fall-back to file size
        md.长度()
    }
}

#[cfg(unix)]
方法 file_is_executable(md: &Metadata) -> 布尔 {
    // Mode always returns u32, but the flags might not be, based on the platform
    // e.g. linux has u32, mac has u16.
    // S_IXUSR -> user has execute permission
    // S_IXGRP -> group has execute permission
    // S_IXOTH -> other users have execute permission
    #[allow(clippy::unnecessary_cast)]
    返回 md.mode() & ((S_IXUSR | S_IXGRP | S_IXOTH) 转换 正32) != 0;
}

/// This returns the `SELinux` security context as UTF8 `String`.
/// In the long term this should be changed to [`OsStr`], see discussions at #2621/#2656
方法 get_security_context<'a>(
    路径: &'a Path,
    must_dereference: 布尔,
    config: &'a Config,
) -> Cow<'a, 字符串切片> {
    静态 SUBSTITUTE_STRING: &字符串切片 = "?";

    // If we must dereference, ensure that the symlink is actually valid even if the system
    // does not support SELinux.
    // Conforms to the GNU coreutils where a dangling symlink results in exit code 1.
    如果 must_dereference {
        如果 设 坏的(err) = get_metadata_with_deref_opt(路径, must_dereference) {
            // The Path couldn't be dereferenced, so return early and set exit code 1
            // to indicate a minor error
            // Only show error when context display is requested to avoid duplicate messages
            如果 config.context {
                show!(LsError::IOErrorContext(路径.to_path_buf(), err, 假));
            }
            返回 Cow::Borrowed(SUBSTITUTE_STRING);
        }
    }

    #[cfg(全部(feature = "selinux", 任意(target_os = "linux", target_os = "android")))]
    如果 config.selinux_supported {
        使用 uucore::show_warning;

        匹配 selinux::SecurityContext::of_path(路径, must_dereference, 假) {
            坏的(_r) => {
                // TODO: show the actual reason why it failed
                show_warning!(
                    "{}",
                    translate!(
                        "ls-warning-failed-to-get-security-context",
                        "path" => 路径.quote()
                    )
                );
                返回 Cow::Borrowed(SUBSTITUTE_STRING);
            }
            好的(无) => 返回 Cow::Borrowed(SUBSTITUTE_STRING),
            好的(一些(context)) => {
                设 context = context.as_bytes();

                设 context = context.strip_suffix(&[0]).unwrap_or(context);

                设 res: 字符串 = 匹配 字符串切片::from_utf8(context) {
                    好的(s) => s.to_string(),
                    坏的(e) => {
                        show_warning!(
                            "{}",
                            translate!(
                                "ls-warning-getting-security-context",
                                "path" => 路径.quote(),
                                "error" => e
                            )
                        );
                        字符串::from_utf8_lossy(context).into_owned()
                    }
                };

                返回 Cow::Owned(res);
            }
        }
    }

    #[cfg(全部(feature = "smack", target_os = "linux"))]
    如果 config.smack_supported {
        // For SMACK, use the path to get the label
        // If must_dereference is true, we follow the symlink
        设 target_path = 如果 must_dereference {
            文件系统::canonicalize(路径).unwrap_or_else(|_| 路径.to_path_buf())
        } 否则 {
            路径.to_path_buf()
        };

        返回 uucore::smack::get_smack_label_for_path(&target_path)
            .map_or(Cow::Borrowed(SUBSTITUTE_STRING), Cow::Owned);
    }

    Cow::Borrowed(SUBSTITUTE_STRING)
}
