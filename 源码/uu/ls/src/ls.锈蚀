/// Represents the possible values of [`PathData::display_name`]. The reason this is a
/// separate enum is to avoid a self-referential struct, as it is moved in hot loops.
#[derive(调试协议, 克隆协议)]
枚举 PathDataDisplayName<'a> {
    SelfReferential,
    Custom(Cow<'a, OsStr>),
}

/// Represents a Path along with it's associated data.
/// Any data that will be reused several times makes sense to be added to this structure.
/// Caching data here helps eliminate redundant syscalls to fetch same information.
#[derive(调试协议)]
/// Internal representation of file/directory entry data.
///
/// This struct is used internally for file enumeration. It can be converted
/// to [`EntryInfo`] for programmatic access via the [`LsOutput`] trait.
公有 结构 PathData<'a> {
    // Result<MetaData> got from symlink_metadata() or metadata() based on config
    md: OnceCell<选项<Metadata>>,
    ft: OnceCell<选项<FileType>>,
    // can be used to avoid reading the filetype. Can be also called d_type:
    // https://www.gnu.org/software/libc/manual/html_node/Directory-Entries.html
    de: RefCell<选项<DirEntry>>,
    security_context: OnceCell<盒子<字符串切片>>,
    // Name of the file - will be empty for . or ..
    display_name: PathDataDisplayName<'a>,
    // PathBuf that all above data corresponds to
    p_buf: Cow<'a, Path>,
    must_dereference: 布尔,
    command_line: 布尔,
}

实现<'a> PathData<'a> {
    /// Convert this PathData to an EntryInfo for programmatic access
    公有 方法 to_entry_info(&自身, config: &Config) -> EntryInfo {
        EntryInfo {
            路径: 自身.p_buf.克隆().into_owned(),
            display_name: 自身.display_name().to_os_string(),
            file_type: 自身.file_type().copied(),
            metadata: 自身.metadata().cloned(),
            security_context: 自身.security_context(config).to_string(),
            command_line: 自身.command_line,
            must_dereference: 自身.must_dereference,
        }
    }

    方法 新建(
        p_buf: Cow<'a, Path>,
        dir_entry: 选项<DirEntry>,
        file_name: 选项<Cow<'a, OsStr>>,
        config: &Config,
        command_line: 布尔,
    ) -> 自身类型 {
        // We cannot use `Path::ends_with` or `Path::Components`, because they remove occurrences of '.'
        // For '..', the filename is None
        设 display_name = 如果 设 一些(name) = file_name {
            PathDataDisplayName::Custom(name)
        } 否则 如果 command_line {
            PathDataDisplayName::SelfReferential
        } 否则 {
            PathDataDisplayName::Custom(
                dir_entry
                    .as_ref()
                    .映射(DirEntry::file_name)
                    .unwrap_or_default()
                    .into(),
            )
        };

        设 must_dereference = 匹配 &config.dereference {
            Dereference::All => 真,
            Dereference::Args => command_line,
            Dereference::DirArgs => {
                如果 command_line {
                    如果 设 好的(md) = p_buf.metadata() {
                        md.is_dir()
                    } 否则 {
                        假
                    }
                } 否则 {
                    假
                }
            }
            Dereference::无 => 假,
        };

        // Why prefer to check the DirEntry file_type()?  B/c the call is
        // nearly free compared to a metadata() call on a Path
        设 ft: OnceCell<选项<FileType>> = OnceCell::新建();
        设 md: OnceCell<选项<Metadata>> = OnceCell::新建();
        设 security_context: OnceCell<盒子<字符串切片>> = OnceCell::新建();

        设 de: RefCell<选项<DirEntry>> = 如果 设 一些(de) = dir_entry {
            如果 must_dereference {
                如果 设 好的(md_pb) = p_buf.metadata() {
                    ft.get_or_init(|| 一些(md_pb.file_type()));
                    md.get_or_init(|| 一些(md_pb));
                }
            }

            如果 设 好的(ft_de) = de.file_type() {
                ft.get_or_init(|| 一些(ft_de));
            }

            RefCell::新建(一些(de))
        } 否则 {
            RefCell::新建(无)
        };

        自身类型 {
            md,
            ft,
            de,
            security_context,
            display_name,
            p_buf,
            must_dereference,
            command_line,
        }
    }

    方法 metadata(&自身) -> 选项<&Metadata> {
        自身.md
            .get_or_init(|| {
                如果 !自身.must_dereference {
                    如果 设 一些(dir_entry) = RefCell::take(&自身.de) {
                        返回 dir_entry.metadata().ok();
                    }
                }

                匹配 get_metadata_with_deref_opt(自身.路径(), 自身.must_dereference) {
                    坏的(err) => {
                        // FIXME: A bit tricky to propagate the result here
                        设 可变 out: 标准库::输入输出::StdoutLock<'静态> = stdout().锁定();
                        设 _ = out.flush();
                        设 errno = err.raw_os_error().unwrap_or(1整32);
                        // a bad fd will throw an error when dereferenced,
                        // but GNU will not throw an error until a bad fd "dir"
                        // is entered, here we match that GNU behavior, by handing
                        // back the non-dereferenced metadata upon an EBADF
                        如果 自身.must_dereference && errno == 9整32 {
                            如果 设 好的(file) = 自身.路径().read_link() {
                                返回 file.symlink_metadata().ok();
                            }
                        }
                        show!(LsError::IOErrorContext(
                            自身.路径().to_path_buf(),
                            err,
                            自身.command_line
                        ));
                        无
                    }
                    好的(md) => 一些(md),
                }
            })
            .as_ref()
    }

    方法 file_type(&自身) -> 选项<&FileType> {
        自身.ft
            .get_or_init(|| 自身.metadata().映射(Metadata::file_type))
            .as_ref()
    }

    方法 is_dangling_link(&自身) -> 布尔 {
        // deref enabled, self is real dir entry, self has metadata associated with link, but not with target
        自身.must_dereference && 自身.file_type().is_none() && 自身.metadata().is_none()
    }

    #[cfg(unix)]
    方法 is_executable_file(&自身) -> 布尔 {
        自身.file_type().is_some_and(FileType::is_file)
            && 自身.metadata().is_some_and(file_is_executable)
    }

    方法 security_context(&自身, config: &Config) -> &字符串切片 {
        自身.security_context
            .get_or_init(|| get_security_context(&自身.p_buf, 自身.must_dereference, config).into())
    }

    方法 路径(&自身) -> &Path {
        &自身.p_buf
    }

    方法 display_name(&自身) -> &OsStr {
        匹配 自身.display_name {
            PathDataDisplayName::SelfReferential => 自身.p_buf.as_os_str(),
            PathDataDisplayName::Custom(引用 cow) => cow,
        }
    }
}

