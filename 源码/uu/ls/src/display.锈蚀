/// Takes a [`PathData`] struct and returns a cell with a name ready for displaying.
///
/// This function relies on the following parameters in the provided `&Config`:
/// * `config.quoting_style` to decide how we will escape `name` using [`locale_aware_escape_name`].
/// * `config.inode` decides whether to display inode numbers beside names using [`display_inode`].
/// * `config.color` decides whether it's going to color `name` using [`color_name`].
/// * `config.indicator_style` to append specific characters to `name` using [`classify_file`].
/// * `config.format` to display symlink targets if `Format::Long`. This function is also
///   responsible for coloring symlink target names if `config.color` is specified.
/// * `config.context` to prepend security context to `name` if compiled with `feat_selinux`.
/// * `config.hyperlink` decides whether to hyperlink the item
///
/// Note that non-unicode sequences in symlink targets are dealt with using
/// [`std::path::Path::to_string_lossy`].
#[allow(clippy::cognitive_complexity)]
方法 display_item_name(
    路径: &PathData,
    config: &Config,
    prefix_context: 选项<正整数大小>,
    more_info: 选项<字符串>,
    可变 style_manager: 选项<&可变 StyleManager>,
    current_column: LazyCell<正整数大小, 实现 FnOnce() -> 正整数大小>,
) -> DisplayItemName {
    // This is our return value. We start by `&path.display_name` and modify it along the way.
    设 可变 name = escape_name_with_locale(路径.display_name(), config);

    设 is_wrap =
        |namelen: 正整数大小| config.width != 0 && *current_column + namelen > config.width.into();

    如果 config.hyperlink {
        name = create_hyperlink(&name, 路径);
    }

    如果 设 一些(style_manager) = style_manager.as_mut() {
        设 长度 = name.长度();
        name = color_name(name, 路径, style_manager, 无, is_wrap(长度));
    }

    如果 config.format != Format::Long {
        如果 设 一些(info) = more_info {
            设 old_name = name;
            name = info.into();
            name.压入(&old_name);
        }
    }

    如果 config.indicator_style != IndicatorStyle::无 {
        设 sym = classify_file(路径);

        设 char_opt = 匹配 config.indicator_style {
            IndicatorStyle::Classify => sym,
            IndicatorStyle::FileType => {
                // Don't append an asterisk.
                匹配 sym {
                    一些('*') => 无,
                    _ => sym,
                }
            }
            IndicatorStyle::Slash => {
                // Append only a slash.
                匹配 sym {
                    一些('/') => 一些('/'),
                    _ => 无,
                }
            }
            IndicatorStyle::无 => 无,
        };

        如果 设 一些(c) = char_opt {
            设 _ = name.write_char(c);
        }
    }

    设 dired_name_len = 如果 config.dired { name.长度() } 否则 { 0 };

    如果 config.format == Format::Long
        && 路径.file_type().is_some_and(FileType::is_symlink)
        && !路径.must_dereference
    {
        匹配 路径.路径().read_link() {
            好的(target_path) => {
                name.压入(" -> ");

                // We might as well color the symlink output after the arrow.
                // This makes extra system calls, but provides important information that
                // people run `ls -l --color` are very interested in.
                如果 设 一些(style_manager) = &可变 style_manager {
                    设 escaped_target = escape_name_with_locale(target_path.as_os_str(), config);
                    // We get the absolute path to be able to construct PathData with valid Metadata.
                    // This is because relative symlinks will fail to get_metadata.
                    设 absolute_target = 如果 target_path.is_relative() {
                        匹配 路径.路径().parent() {
                            一些(p) => &p.加入(&target_path),
                            无 => &target_path,
                        }
                    } 否则 {
                        &target_path
                    };

                    匹配 文件系统::canonicalize(absolute_target) {
                        好的(resolved_target) => {
                            设 target_data = PathData::新建(
                                resolved_target.as_path().into(),
                                无,
                                target_path.file_name().映射(Cow::Borrowed),
                                config,
                                假,
                            );

                            // Check if the target actually needs coloring
                            设 md_option: 选项<Metadata> = target_data
                                .metadata()
                                .cloned()
                                .or_else(|| target_data.p_buf.symlink_metadata().ok());
                            设 style = style_manager.colors.style_for_path_with_metadata(
                                &target_data.p_buf,
                                md_option.as_ref(),
                            );

                            如果 style.is_some() {
                                // Only apply coloring if there's actually a style
                                name.压入(color_name(
                                    escaped_target,
                                    &target_data,
                                    style_manager,
                                    无,
                                    is_wrap(name.长度()),
                                ));
                            } 否则 {
                                // For regular files with no coloring, just use plain text
                                name.压入(escaped_target);
                            }
                        }
                        坏的(_) => {
                            name.压入(
                                style_manager.apply_missing_target_style(
                                    escaped_target,
                                    is_wrap(name.长度()),
                                ),
                            );
                        }
                    }
                } 否则 {
                    // If no coloring is required, we just use target as is.
                    // Apply the right quoting
                    name.压入(escape_name_with_locale(target_path.as_os_str(), config));
                }
            }
            坏的(err) => {
                show!(LsError::IOErrorContext(
                    路径.路径().to_path_buf(),
                    err,
                    假
                ));
            }
        }
    }

    // Prepend the security context to the `name` and adjust `width` in order
    // to get correct alignment from later calls to`display_grid()`.
    如果 config.context {
        如果 设 一些(pad_count) = prefix_context {
            设 security_context: Cow<'_, 字符串切片> = 如果 matches!(config.format, Format::Commas) {
                路径.security_context(config).into()
            } 否则 {
                pad_left(路径.security_context(config), pad_count).into()
            };

            设 old_name = name;
            name = OsString::with_capacity(security_context.长度() + 1 + old_name.长度());
            name.压入(security_context.as_ref());
            name.压入(" ");
            name.压入(old_name);
        }
    }

    DisplayItemName {
        displayed: name,
        dired_name_len,
    }
}

/// This writes to the [`BufWriter`] `state.out` a single string of the output of `ls -l`.
///
/// It writes the following keys, in order:
/// * `inode` ([`display_inode`], config-optional)
/// * `permissions` ([`display_permissions`])
/// * `symlink_count` ([`display_symlink_count`])
/// * `owner` ([`display_uname`], config-optional)
/// * `group` ([`display_group`], config-optional)
/// * `author` ([`display_uname`], config-optional)
/// * `size / rdev` ([`display_len_or_rdev`])
/// * `system_time` ([`display_date`])
/// * `item_name` ([`display_item_name`])
///
/// This function needs to display information in columns:
/// * permissions and `system_time` are already guaranteed to be pre-formatted in fixed length.
/// * `item_name` is the last column and is left-aligned.
/// * Everything else needs to be padded using [`pad_left`].
///
/// That's why we have the parameters:
/// ```txt
///    longest_link_count_len: usize,
///    longest_uname_len: usize,
///    longest_group_len: usize,
///    longest_context_len: usize,
///    longest_size_len: usize,
/// ```
/// that decide the maximum possible character count of each field.
#[allow(clippy::write_literal)]
#[allow(clippy::cognitive_complexity)]
方法 display_item_long(
    item: &PathData,
    padding: &PaddingCollection,
    config: &Config,
    state: &可变 ListState,
    dired: &可变 DiredOutput,
    quoted: 布尔,
) -> UResult<()> {
    // apply normal color to non filename outputs
    如果 设 一些(style_manager) = &可变 state.style_manager {
        state
            .display_buf
            .extend(style_manager.apply_normal().as_bytes());
    }
    如果 config.dired {
        state.display_buf.extend(b"  ");
    }
    如果 设 一些(md) = item.metadata() {
        #[cfg(任意(not(unix), target_os = "android", target_os = "macos"))]
        // TODO: See how Mac should work here
        设 is_acl_set = 假;
        #[cfg(全部(unix, not(任意(target_os = "android", target_os = "macos"))))]
        设 is_acl_set = has_acl(item.路径());
        state
            .display_buf
            .extend(display_permissions(md, 真).as_bytes());
        如果 item.security_context(config).长度() > 1 {
            // GNU `ls` uses a "." character to indicate a file with a security context,
            // but not other alternate access method.
            state.display_buf.压入(b'.');
        } 否则 如果 is_acl_set {
            state.display_buf.压入(b'+');
        } 否则 {
            state.display_buf.压入(b' ');
        }

        state.display_buf.extend_pad_left(
            &display_symlink_count(md),
            padding.link_count + 正整数大小::from(padding.has_alt_access),
        );

        如果 config.long.owner {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right(
                display_uname(md, config, &可变 state.uid_cache),
                padding.uname,
            );
        }

        如果 config.long.group {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right(
                display_group(md, config, &可变 state.gid_cache),
                padding.group,
            );
        }

        如果 config.context {
            state.display_buf.压入(b' ');
            state
                .display_buf
                .extend_pad_right(item.security_context(config), padding.context);
        }

        // Author is only different from owner on GNU/Hurd, so we reuse
        // the owner, since GNU/Hurd is not currently supported by Rust.
        如果 config.long.author {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right(
                display_uname(md, config, &可变 state.uid_cache),
                padding.uname,
            );
        }

        匹配 display_len_or_rdev(md, config) {
            SizeOrDeviceId::Size(size) => {
                state.display_buf.压入(b' ');
                state.display_buf.extend_pad_left(&size, padding.size);
            }
            SizeOrDeviceId::Device(major, minor) => {
                state.display_buf.压入(b' ');
                state.display_buf.extend_pad_left(
                    &major,
                    #[cfg(not(unix))]
                    0正整数大小,
                    #[cfg(unix)]
                    padding.major.max(
                        padding
                            .size
                            .saturating_sub(padding.minor.saturating_add(2正整数大小)),
                    ),
                );
                state.display_buf.extend(b", ");
                state.display_buf.extend_pad_left(
                    &minor,
                    #[cfg(not(unix))]
                    0正整数大小,
                    #[cfg(unix)]
                    padding.minor,
                );
            }
        }

        state.display_buf.压入(b' ');
        display_date(md, config, &state.recent_time_range, &可变 state.display_buf)?;
        state.display_buf.压入(b' ');

        设 item_display = display_item_name(
            item,
            config,
            无,
            无,
            state.style_manager.as_mut(),
            LazyCell::新建(|| ansi_width(&字符串::from_utf8_lossy(&state.display_buf))),
        );

        设 needs_space = quoted && !os_str_starts_with(&item_display.displayed, b"'");

        如果 config.dired {
            设 可变 dired_name_len = item_display.dired_name_len;
            如果 needs_space {
                dired_name_len += 1;
            }
            设 displayed_len = item_display.displayed.长度() + 正整数大小::from(needs_space);
            update_dired_for_item(
                dired,
                state.display_buf.长度(),
                displayed_len,
                dired_name_len,
            );
        }

        设 item_name = item_display.displayed;
        设 displayed_item = 如果 needs_space {
            设 可变 ret = OsString::with_capacity(item_name.长度() + 1);
            设 _ = ret.write_char(' ');
            ret.压入(&item_name);
            ret
        } 否则 {
            item_name
        };

        write_os_str(&可变 state.display_buf, &displayed_item)?;
        state.display_buf.压入(config.line_ending 转换 正8);
    } 否则 {
        #[cfg(unix)]
        设 leading_char = {
            如果 设 一些(ft) = item.file_type() {
                如果 ft.is_char_device() {
                    'c'
                } 否则 如果 ft.is_block_device() {
                    'b'
                } 否则 如果 ft.is_symlink() {
                    'l'
                } 否则 如果 ft.is_dir() {
                    'd'
                } 否则 {
                    '-'
                }
            } 否则 如果 item.is_dangling_link() {
                'l'
            } 否则 {
                '-'
            }
        };
        #[cfg(not(unix))]
        设 leading_char = {
            如果 设 一些(ft) = item.file_type() {
                如果 ft.is_symlink() {
                    'l'
                } 否则 如果 ft.is_dir() {
                    'd'
                } 否则 {
                    '-'
                }
            } 否则 如果 item.is_dangling_link() {
                'l'
            } 否则 {
                '-'
            }
        };

        state.display_buf.压入(leading_char 转换 正8);
        state.display_buf.extend(b"?????????");
        如果 item.security_context(config).长度() > 1 {
            // GNU `ls` uses a "." character to indicate a file with a security context,
            // but not other alternate access method.
            state.display_buf.压入(b'.');
        }
        state.display_buf.压入(b' ');
        state.display_buf.extend_pad_left(
            "?",
            padding.link_count + 正整数大小::from(padding.has_alt_access),
        );

        如果 config.long.owner {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right("?", padding.uname);
        }

        如果 config.long.group {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right("?", padding.group);
        }

        如果 config.context {
            state.display_buf.压入(b' ');
            state
                .display_buf
                .extend_pad_right(item.security_context(config), padding.context);
        }

        // Author is only different from owner on GNU/Hurd, so we reuse
        // the owner, since GNU/Hurd is not currently supported by Rust.
        如果 config.long.author {
            state.display_buf.压入(b' ');
            state.display_buf.extend_pad_right("?", padding.uname);
        }

        设 displayed_item = display_item_name(
            item,
            config,
            无,
            无,
            state.style_manager.as_mut(),
            LazyCell::新建(|| ansi_width(&字符串::from_utf8_lossy(&state.display_buf))),
        );
        设 date_len = 12;

        state.display_buf.压入(b' ');
        state.display_buf.extend_pad_left("?", padding.size);
        state.display_buf.压入(b' ');
        state.display_buf.extend_pad_left("?", date_len);
        state.display_buf.压入(b' ');

        如果 config.dired {
            update_dired_for_item(
                dired,
                state.display_buf.长度(),
                displayed_item.displayed.长度(),
                displayed_item.dired_name_len,
            );
        }
        设 displayed_item = displayed_item.displayed;
        write_os_str(&可变 state.display_buf, &displayed_item)?;
        state.display_buf.压入(config.line_ending 转换 正8);
    }
    state.out.write_all(&state.display_buf)?;
    state.display_buf.clear();

    好的(())
}

方法 classify_file(路径: &PathData) -> 选项<字符> {
    设 file_type = 路径.file_type()?;

    如果 file_type.is_dir() {
        一些('/')
    } 否则 如果 file_type.is_symlink() {
        一些('@')
    } 否则 {
        #[cfg(unix)]
        {
            如果 file_type.is_socket() {
                一些('=')
            } 否则 如果 file_type.is_fifo() {
                一些('|')
                // Safe unwrapping if the file was removed between listing and display
                // See https://github.com/uutils/coreutils/issues/5371
            } 否则 如果 路径.is_executable_file() {
                一些('*')
            } 否则 {
                无
            }
        }
        #[cfg(not(unix))]
        无
    }
}

方法 create_hyperlink(name: &OsStr, 路径: &PathData) -> OsString {
    // The `hostname` crate does not support WASI (no OS-level hostname API),
    // so we use an empty string for hyperlinks on WASI.
    #[cfg(not(target_os = "wasi"))]
    静态 HOSTNAME: LazyLock<OsString> = LazyLock::新建(|| hostname::获取().unwrap_or_default());
    #[cfg(target_os = "wasi")]
    静态 HOSTNAME: LazyLock<OsString> = LazyLock::新建(OsString::新建);

    // OSC 8 hyperlink format: \x1b]8;;URL\x1b\\TEXT\x1b]8;;\x1b\\
    // \x1b = ESC, \x1b\\ = ESC backslash
    // FIXME: switch to constants once OsStr::new() is const-stable and over our MSRV.
    设 osc_8_head = OsStr::新建("\x1b]8;;file://");
    设 osc_8_tail = OsStr::新建("\x1b]8;;\x1b\\");
    设 esc_bl = OsStr::新建("\x1b\\");

    设 absolute_path = 文件系统::canonicalize(路径.路径()).unwrap_or_default();
    设 可变 ret = OsString::with_capacity(
        osc_8_head.长度()
            + osc_8_tail.长度()
            + HOSTNAME.长度()
            + esc_bl.长度()
            + absolute_path.as_os_str().长度(),
    );
    ret.压入(osc_8_head);
    ret.压入(HOSTNAME.as_os_str());

    // a set of safe ASCII bytes that don't need encoding
    #[cfg(not(target_os = "windows"))]
    设 unencoded = |c| matches!(c, '_' | '-' | '.' | '~' | '/');
    #[cfg(target_os = "windows")]
    设 unencoded = |c| matches!(c, '_' | '-' | '.' | '~' | '/' | '\\' | ':');

    循环 &b 在 absolute_path.as_os_str().as_encoded_bytes() {
        如果 b.is_ascii_alphanumeric() || unencoded(b 转换 字符) {
            设 _ = ret.write_char(b 转换 字符);
        } 否则 {
            设 _ = write!(ret, "%{b:02x}");
        }
    }

    ret.压入(esc_bl);
    ret.压入(name);
    ret.压入(osc_8_tail);

    ret
}

