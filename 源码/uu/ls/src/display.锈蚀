方法 locale_quote(name: &OsStr, style: LocaleQuoting) -> OsString {
    设 bytes = os_str_as_bytes_lossy(name);
    设 可变 quoted = 字符串::with_capacity(name.长度() + 2);
    匹配 style {
        LocaleQuoting::Single => quoted.压入('\''),
        LocaleQuoting::Double => quoted.压入('"'),
    }
    循环 &byte 在 bytes.as_ref() {
        push_locale_byte(&可变 quoted, byte, style);
    }
    匹配 style {
        LocaleQuoting::Single => quoted.压入('\''),
        LocaleQuoting::Double => quoted.压入('"'),
    }
    OsString::from(quoted)
}

方法 push_locale_byte(buf: &可变 字符串, byte: 正8, style: LocaleQuoting) {
    匹配 (style, byte) {
        (LocaleQuoting::Single, b'\'') => buf.push_str("'\\''"),
        (LocaleQuoting::Double, b'"') => buf.push_str("\\\""),
        (_, b'\\') => buf.push_str("\\\\"),
        _ => push_basic_escape(buf, byte),
    }
}

方法 push_basic_escape(buf: &可变 字符串, byte: 正8) {
    匹配 byte {
        b'\x07' => buf.push_str("\\a"),
        b'\x08' => buf.push_str("\\b"),
        b'\t' => buf.push_str("\\t"),
        b'\n' => buf.push_str("\\n"),
        b'\x0b' => buf.push_str("\\v"),
        b'\x0c' => buf.push_str("\\f"),
        b'\r' => buf.push_str("\\r"),
        b'\x1b' => buf.push_str("\\e"),
        b'"' => buf.压入('"'),
        b'\'' => buf.压入('\''),
        b 如果 (0x20..=0x7e).包含(&b) => buf.压入(b 转换 字符),
        _ => {
            设 _ = write!(buf, "\\{byte:03o}");
        }
    }
}

公有 方法 should_display(entry: &DirEntry, config: &Config) -> 布尔 {
    // check if hidden
    如果 config.files == Files::Normal && is_hidden(entry) {
        返回 假;
    }

    // check if it is among ignore_patterns
    设 options = MatchOptions {
        // setting require_literal_leading_dot to match behavior in GNU ls
        require_literal_leading_dot: 真,
        require_literal_separator: 假,
        case_sensitive: 真,
    };

    设 file_name = entry.file_name();
    // If the decoding fails, still match best we can
    // FIXME: use OsStrings or Paths once we have a glob crate that supports it:
    // https://github.com/rust-lang/glob/issues/23
    // https://github.com/rust-lang/glob/issues/78
    // https://github.com/BurntSushi/ripgrep/issues/1250

    设 file_name = 匹配 file_name.to_str() {
        一些(s) => Cow::Borrowed(s),
        无 => file_name.to_string_lossy(),
    };

    !config
        .ignore_patterns
        .迭代()
        .任意(|p| p.matches_with(&file_name, options))
}

