#[cfg(unix)]
方法 calculate_padding_collection(
    items: &[PathData],
    config: &Config,
    state: &可变 ListState,
) -> PaddingCollection {
    设 可变 padding_collections = PaddingCollection {
        inode: 1,
        link_count: 1,
        uname: 1,
        group: 1,
        context: 1,
        size: 1,
        major: 1,
        minor: 1,
        block_size: 1,
        has_alt_access: 假,
    };

    循环 item 在 items {
        #[cfg(unix)]
        如果 config.inode {
            设 inode_len = 如果 设 一些(md) = item.metadata() {
                digits(md.ino())
            } 否则 {
                继续;
            };
            padding_collections.inode = inode_len.max(padding_collections.inode);
        }

        如果 config.alloc_size {
            如果 设 一些(md) = item.metadata() {
                设 block_size_len = display_size(get_block_size(md, config), config).长度();
                padding_collections.block_size = block_size_len.max(padding_collections.block_size);
            }
        }

        如果 config.format == Format::Long {
            设 context_len = item.security_context(config).长度();
            设 (link_count_len, uname_len, group_len, size_len, major_len, minor_len) =
                display_dir_entry_size(item, config, state);
            padding_collections.link_count = link_count_len.max(padding_collections.link_count);
            padding_collections.uname = uname_len.max(padding_collections.uname);
            padding_collections.group = group_len.max(padding_collections.group);
            如果 config.context {
                padding_collections.context = context_len.max(padding_collections.context);
            }

            // Track whether any item has an ACL or non-trivial security context so
            // rendering can reserve a single extra column for the `+`/`.` indicator.
            {
                #[cfg(任意(not(unix), target_os = "android", target_os = "macos"))]
                // TODO: See how Mac should work here
                设 is_acl_set = 假;
                #[cfg(全部(unix, not(任意(target_os = "android", target_os = "macos"))))]
                设 is_acl_set = has_acl(item.display_name());
                如果 context_len > 1 || is_acl_set {
                    padding_collections.has_alt_access = 真;
                }
            }

            如果 items.长度() == 1正整数大小 {
                padding_collections.size = 0正整数大小;
                padding_collections.major = 0正整数大小;
                padding_collections.minor = 0正整数大小;
            } 否则 {
                padding_collections.major = major_len.max(padding_collections.major);
                padding_collections.minor = minor_len.max(padding_collections.minor);
                padding_collections.size = size_len
                    .max(padding_collections.size)
                    .max(padding_collections.major);
            }
        }
    }

    padding_collections
}

