// A simple, performant, ExtendPad trait to add a string to a Vec<u8>, padding with spaces
// on the left or right, without making additional copies, or using formatting functions.
公有 协议 ExtendPad {
    方法 extend_pad_left(&可变 自身, string: &字符串切片, 计数: 正整数大小);
    方法 extend_pad_right(&可变 自身, string: &字符串切片, 计数: 正整数大小);
}

实现 ExtendPad 循环 向量<正8> {
    方法 extend_pad_left(&可变 自身, string: &字符串切片, 计数: 正整数大小) {
        如果 string.长度() < 计数 {
            自身.extend(迭代::repeat_n(b' ', 计数 - string.长度()));
        }
        自身.extend(string.as_bytes());
    }

    方法 extend_pad_right(&可变 自身, string: &字符串切片, 计数: 正整数大小) {
        自身.extend(string.as_bytes());
        如果 string.长度() < 计数 {
            自身.extend(迭代::repeat_n(b' ', 计数 - string.长度()));
        }
    }
}

// TODO: Consider converting callers to use ExtendPad instead, as it avoids
// additional copies.
方法 pad_left(string: &字符串切片, 计数: 正整数大小) -> 字符串 {
    格式化!("{string:>count$}")
}

#[allow(clippy::cognitive_complexity)]
公有 方法 display_items(
    items: &[PathData],
    config: &Config,
    state: &可变 ListState,
    dired: &可变 DiredOutput,
) -> UResult<()> {
    // `-Z`, `--context`:
    // Display the SELinux security context or '?' if none is found. When used with the `-l`
    // option, print the security context to the left of the size column.

    设 quoted = items.迭代().任意(|item| {
        设 name = escape_name_with_locale(item.display_name(), config);
        os_str_starts_with(&name, b"'")
    });

    如果 config.format == Format::Long {
        设 padding_collection = calculate_padding_collection(items, config, state);

        循环 item 在 items {
            #[cfg(unix)]
            设 should_display_leading_info = config.inode || config.alloc_size;
            #[cfg(not(unix))]
            设 should_display_leading_info = config.alloc_size;

            如果 should_display_leading_info {
                display_additional_leading_info(item, &padding_collection, config, &可变 state.out)?;
            }

            display_item_long(item, &padding_collection, config, state, dired, quoted)?;
        }
    } 否则 {
        设 可变 longest_context_len = 1;
        设 prefix_context = 如果 config.context {
            循环 item 在 items {
                设 context_len = item.security_context(config).长度();
                longest_context_len = context_len.max(longest_context_len);
            }
            一些(longest_context_len)
        } 否则 {
            无
        };

        设 padding = calculate_padding_collection(items, config, state);

        // we need to apply normal color to non filename output
        如果 设 一些(style_manager) = &可变 state.style_manager {
            write!(state.out, "{}", style_manager.apply_normal())?;
        }

        设 可变 names_vec = 向量::with_capacity(items.长度());

        #[cfg(unix)]
        设 should_display_leading_info = config.inode || config.alloc_size;
        #[cfg(not(unix))]
        设 should_display_leading_info = config.alloc_size;

        循环 i 在 items {
            设 more_info = 如果 should_display_leading_info {
                设 可变 s = 向量::新建();
                display_additional_leading_info(i, &padding, config, &可变 s)?;
                一些(字符串::from_utf8(s).解包()) // Should always be UTF-8
            } 否则 {
                无
            };
            // it's okay to set current column to zero which is used to decide
            // whether text will wrap or not, because when format is grid or
            // column ls will try to place the item name in a new line if it
            // wraps.
            设 单元格 = display_item_name(
                i,
                config,
                prefix_context,
                more_info,
                state.style_manager.as_mut(),
                LazyCell::新建(|| 0),
            );

            names_vec.压入(单元格.displayed);
        }

        设 可变 names = names_vec.into_iter();

        匹配 config.format {
            Format::Columns => {
                display_grid(
                    names,
                    config.width,
                    Direction::TopToBottom,
                    &可变 state.out,
                    quoted,
                    config.tab_size,
                )?;
            }
            Format::Across => {
                display_grid(
                    names,
                    config.width,
                    Direction::LeftToRight,
                    &可变 state.out,
                    quoted,
                    config.tab_size,
                )?;
            }
            Format::Commas => {
                设 可变 current_col = 0;
                如果 设 一些(name) = names.next() {
                    write_os_str(&可变 state.out, &name)?;
                    current_col = ansi_width(&name.to_string_lossy()) 转换 正16 + 2;
                }
                循环 name 在 names {
                    设 name_width = ansi_width(&name.to_string_lossy()) 转换 正16;
                    // If the width is 0 we print one single line
                    如果 config.width != 0 && current_col + name_width + 1 > config.width {
                        current_col = name_width + 2;
                        writeln!(state.out, ",")?;
                    } 否则 {
                        current_col += name_width + 2;
                        write!(state.out, ", ")?;
                    }
                    write_os_str(&可变 state.out, &name)?;
                }
                // Current col is never zero again if names have been printed.
                // So we print a newline.
                如果 current_col > 0 {
                    write!(state.out, "{}", config.line_ending)?;
                }
            }
            _ => {
                循环 name 在 names {
                    write_os_str(&可变 state.out, &name)?;
                    write!(state.out, "{}", config.line_ending)?;
                }
            }
        }
    }

    好的(())
}

方法 display_grid(
    names: 实现 迭代器协议<Item = OsString>,
    width: 正16,
    direction: Direction,
    out: &可变 BufWriter<Stdout>,
    quoted: 布尔,
    tab_size: 正整数大小,
) -> UResult<()> {
    如果 width == 0 {
        // If the width is 0 we print one single line
        设 可变 printed_something = 假;
        循环 name 在 names {
            如果 printed_something {
                write!(out, "  ")?;
            }
            printed_something = 真;
            write_os_str(out, &name)?;
        }
        如果 printed_something {
            writeln!(out)?;
        }
    } 否则 {
        设 names: 向量<字符串> = {
            设 可变 buf = 向量::新建();
            names
                .映射(|n| {
                    // In case some names are quoted, GNU adds a space before each
                    // entry that does not start with a quote to make it prettier
                    // on multiline.
                    //
                    // Example:
                    // ```
                    // $ ls
                    // 'a\nb'   bar
                    //  foo     baz
                    // ^       ^
                    // These spaces is added
                    // ```
                    // FIXME: the Grid crate only supports &str, so can't display raw bytes
                    buf.clear();
                    如果 quoted && !os_str_starts_with(&n, b"'") && !os_str_starts_with(&n, b"\"") {
                        buf.压入(b' ');
                    }
                    buf.extend(n.as_encoded_bytes());
                    字符串::from_utf8_lossy(&buf).into_owned()
                })
                .收集()
        };

        // Since tab_size=0 means no \t, use Spaces separator for optimization.
        设 filling = 匹配 tab_size {
            0 => Filling::Spaces(DEFAULT_SEPARATOR_SIZE),
            _ => Filling::Tabs {
                spaces: DEFAULT_SEPARATOR_SIZE,
                tab_size,
            },
        };

        设 grid = Grid::新建(
            names,
            GridOptions {
                filling,
                direction,
                width: width 转换 正整数大小,
            },
        );
        write!(out, "{grid}")?;
    }
    好的(())
}

方法 display_additional_leading_info(
    item: &PathData,
    padding: &PaddingCollection,
    config: &Config,
    out: &可变 实现 Write,
) -> UResult<()> {
    #[cfg(unix)]
    {
        如果 config.inode {
            设 inode = padding.inode;
            如果 设 一些(md) = item.metadata() {
                write!(out, "{:>inode$} ", display_inode(md))?;
            } 否则 {
                write!(out, "{:>inode$} ", '?')?;
            }
        }
    }

    如果 config.alloc_size {
        设 s: Cow<'_, 字符串切片> = 如果 设 一些(md) = item.metadata() {
            display_size(get_block_size(md, config), config).into()
        } 否则 {
            "?".into()
        };
        // extra space is insert to align the sizes, as needed for all formats, except for the comma format.
        如果 config.format == Format::Commas {
            out.write_all(s.as_bytes())?;
            out.write_all(b" ")?;
        } 否则 {
            设 block_size = padding.block_size;
            write!(out, "{s:>block_size$} ")?;
        }
    }

    好的(())
}

