方法 display_len_or_rdev(metadata: &Metadata, config: &Config) -> SizeOrDeviceId {
    #[cfg(任意(
        target_os = "linux",
        target_os = "macos",
        target_os = "android",
        target_os = "ios",
        target_os = "freebsd",
        target_os = "dragonfly",
        target_os = "netbsd",
        target_os = "openbsd",
        target_os = "illumos",
        target_os = "solaris"
    ))]
    {
        设 ft = metadata.file_type();
        如果 ft.is_char_device() || ft.is_block_device() {
            // A type cast is needed here as the `dev_t` type varies across OSes.
            设 dev = metadata.rdev() 转换 dev_t;
            设 major = major(dev);
            设 minor = minor(dev);
            返回 SizeOrDeviceId::Device(major.to_string(), minor.to_string());
        }
    }
    设 len_adjusted = {
        设 d = metadata.长度() / config.file_size_block_size;
        设 r = metadata.长度() % config.file_size_block_size;
        如果 r == 0 { d } 否则 { d + 1 }
    };
    SizeOrDeviceId::Size(display_size(len_adjusted, config))
}

