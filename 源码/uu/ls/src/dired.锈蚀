/// `dired` Module Documentation
///
/// This module handles the --dired output format, representing file and
/// directory listings.
///
/// Key Mechanisms:
/// 1. **Position Tracking**:
///    - The module tracks byte positions for each file or directory entry.
///    - `BytePosition`: Represents a byte range with start and end positions.
///    - `DiredOutput`: Contains positions for DIRED and SUBDIRED outputs and
///      maintains a padding value.
///
/// 2. **Padding**:
///    - Padding is used when dealing with directory names or the "total" line.
///    - The module adjusts byte positions by adding padding for these cases.
///    - This ensures correct offset for subsequent files or directories.
///
/// 3. **Position Calculation**:
///    - Functions like `calculate_dired`, `calculate_subdired`, and
///      `calculate_and_update_positions` compute byte positions based on output
///      length, previous positions, and padding.
///
/// 4. **Output**:
///    - The module provides functions to print the DIRED output
///      (`print_dired_output`) based on calculated positions and configuration.
///    - Helpers like `print_positions` print positions with specific prefixes.
///
/// Overall, the module ensures each entry in the DIRED output has the correct
/// byte position, considering additional lines or padding affecting positions.
///
使用 箱::Config;
使用 标准库::格式化;
使用 标准库::输入输出::{BufWriter, Stdout, Write};
使用 uucore::错误::UResult;

#[derive(调试协议, 克隆协议, 偏等比较协议)]
公有 结构 BytePosition {
    公有 start: 正整数大小,
    公有 end: 正整数大小,
}

/// Represents the output structure for DIRED, containing positions for both DIRED and SUBDIRED.
#[derive(调试协议, 克隆协议, 默认协议, 偏等比较协议)]
公有 结构 DiredOutput {
    公有 dired_positions: 向量<BytePosition>,
    公有 subdired_positions: 向量<BytePosition>,
    公有 padding: 正整数大小,
    公有 line_offset: 正整数大小,
}

实现 格式化::显示协议 循环 BytePosition {
    方法 格式化(&自身, f: &可变 格式化::Formatter<'_>) -> 格式化::结果 {
        write!(f, "{} {}", 自身.start, 自身.end)
    }
}

// When --dired is used, all lines starts with 2 spaces
静态 DIRED_TRAILING_OFFSET: 正整数大小 = 2;

/// Calculates the byte positions for DIRED
公有 方法 calculate_dired(
    dired: &DiredOutput,
    output_display_len: 正整数大小,
    dfn_len: 正整数大小,
) -> (正整数大小, 正整数大小) {
    设 offset_from_previous_line = dired.line_offset;

    设 start = output_display_len + offset_from_previous_line;
    设 end = start + dfn_len;
    (start, end)
}

公有 方法 indent(out: &可变 BufWriter<Stdout>) -> UResult<()> {
    write!(out, "  ")?;
    好的(())
}

公有 方法 calculate_subdired(dired: &可变 DiredOutput, path_len: 正整数大小) {
    设 offset_from_previous_line = dired.line_offset + dired.padding;
    设 start = offset_from_previous_line + DIRED_TRAILING_OFFSET;
    设 end = start + path_len;
    dired.subdired_positions.压入(BytePosition { start, end });
}

/// Prints the dired output based on the given configuration and dired structure.
公有 方法 print_dired_output(
    config: &Config,
    dired: &DiredOutput,
    out: &可变 BufWriter<Stdout>,
) -> UResult<()> {
    out.flush()?;
    如果 !dired.dired_positions.为空() {
        print_positions("//DIRED//", &dired.dired_positions);
    }
    // SUBDIRED is needed whenever directory headings are printed (multiple args or -R),
    // so don't gate it on config.recursive.
    如果 !dired.subdired_positions.为空() {
        print_positions("//SUBDIRED//", &dired.subdired_positions);
    }
    打印行!("//DIRED-OPTIONS// --quoting-style={}", config.quoting_style);
    好的(())
}

/// Helper function to print positions with a given prefix.
方法 print_positions(prefix: &字符串切片, positions: &[BytePosition]) {
    打印!("{prefix}");
    循环 c 在 positions {
        打印!(" {c}");
    }
    打印行!();
}

公有 方法 add_total(dired: &可变 DiredOutput, total_len: 正整数大小) {
    dired.padding += total_len + DIRED_TRAILING_OFFSET;
}

// when using -R, we have the dirname. we need to add it to the padding
公有 方法 add_dir_name(dired: &可变 DiredOutput, dir_len: 正整数大小) {
    // "  dirname:\n"
    dired.padding += dir_len + DIRED_TRAILING_OFFSET + 2;
}

/// Calculates byte positions and updates the dired structure.
公有 方法 calculate_and_update_positions(
    dired: &可变 DiredOutput,
    output_display_len: 正整数大小,
    dfn_len: 正整数大小,
    line_len: 正整数大小,
) {
    设 (start, end) = calculate_dired(dired, output_display_len, dfn_len);
    update_positions(dired, start, end, line_len);
}

/// Updates the dired positions based on the given start and end positions.
/// update when it is the first element in the list (to manage "total X")
/// insert when it isn't the about total
公有 方法 update_positions(dired: &可变 DiredOutput, start: 正整数大小, end: 正整数大小, line_len: 正整数大小) {
    // padding can be 0 but as it doesn't matter
    设 padding = dired.padding;
    dired.dired_positions.压入(BytePosition {
        start: start + padding,
        end: end + padding,
    });
    dired.line_offset += padding + line_len;
    // Remove the previous padding
    dired.padding = 0;
}

/// Checks if the "--dired" or "-D" argument is present in the command line arguments.
/// we don't use clap here because we need to know if the argument is present
/// as it can be overridden by --hyperlink
公有 方法 is_dired_arg_present() -> 布尔 {
    标准库::环境::args_os().任意(|x| x == "--dired" || x == "-D")
}

#[cfg(test)]
模组 tests {
    使用 超级::*;

    #[test]
    方法 test_calculate_dired() {
        设 output_display = "sample_output".to_string();
        设 dfn = "sample_file".to_string();
        设 dired = DiredOutput {
            dired_positions: 向量![BytePosition { start: 5, end: 10 }],
            subdired_positions: 向量![],
            padding: 0,
            line_offset: 11,
        };
        设 (start, end) = calculate_dired(&dired, output_display.长度(), dfn.长度());

        相等断言!(start, 24);
        相等断言!(end, 35);
    }

    #[test]
    方法 test_calculate_subdired() {
        设 可变 dired = DiredOutput {
            dired_positions: 向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
            ],
            subdired_positions: 向量![],
            padding: 0,
            line_offset: 12,
        };
        设 path_len = 5;
        calculate_subdired(&可变 dired, path_len);
        相等断言!(
            dired.subdired_positions,
            向量![BytePosition { start: 14, end: 19 }],
        );
    }

    #[test]
    方法 test_add_dir_name() {
        设 可变 dired = DiredOutput {
            dired_positions: 向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
            ],
            subdired_positions: 向量![],
            padding: 0,
            line_offset: 0,
        };
        设 dir_len = 5;
        add_dir_name(&可变 dired, dir_len);
        相等断言!(
            dired,
            DiredOutput {
                dired_positions: 向量![
                    BytePosition { start: 0, end: 3 },
                    BytePosition { start: 4, end: 7 },
                    BytePosition { start: 8, end: 11 },
                ],
                subdired_positions: 向量![],
                // 9 = 5 for dir_len + 2 for "  " + 1 for : + 1 for \n
                padding: 9,
                line_offset: 0,
            }
        );
    }

    #[test]
    方法 test_add_total() {
        设 可变 dired = DiredOutput {
            dired_positions: 向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
            ],
            subdired_positions: 向量![],
            padding: 0,
            line_offset: 12,
        };
        // if we have "total: 2"
        设 total_len = 8;
        add_total(&可变 dired, total_len);
        // 10 = 8 (len) + 2 ("  ")
        相等断言!(dired.padding, 10);
    }

    #[test]
    方法 test_add_dir_name_and_total() {
        // test when we have
        //   dirname:
        //   total 0
        //   -rw-r--r-- 1 sylvestre sylvestre 0 Sep 30 09:41 ab

        设 可变 dired = DiredOutput {
            dired_positions: 向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
            ],
            subdired_positions: 向量![],
            padding: 0,
            line_offset: 12,
        };
        设 dir_len = 5;
        add_dir_name(&可变 dired, dir_len);
        // 9 = 2 ("  ") + 1 (\n) + 5 + 1 (: of dirname)
        相等断言!(dired.padding, 9);

        设 total_len = 8;
        add_total(&可变 dired, total_len);
        相等断言!(dired.padding, 19);
    }

    #[test]
    方法 test_dired_update_positions() {
        设 可变 dired = DiredOutput {
            dired_positions: 向量![BytePosition { start: 5, end: 10 }],
            subdired_positions: 向量![],
            padding: 10,
            line_offset: 0,
        };

        // Test with adjust = true
        update_positions(&可变 dired, 15, 20, 1);
        设 last_position = dired.dired_positions.最后().解包();
        相等断言!(last_position.start, 25); // 15 + 10 (end of the previous position)
        相等断言!(last_position.end, 30); // 20 + 10 (end of the previous position)

        // Test with adjust = false
        update_positions(&可变 dired, 30, 35, 1);
        设 last_position = dired.dired_positions.最后().解包();
        相等断言!(last_position.start, 30);
        相等断言!(last_position.end, 35);
    }

    #[test]
    方法 test_calculate_and_update_positions() {
        设 可变 dired = DiredOutput {
            dired_positions: 向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
            ],
            subdired_positions: 向量![],
            padding: 5,
            line_offset: 12,
        };
        设 output_display_len = 15;
        设 dfn_len = 5;
        calculate_and_update_positions(&可变 dired, output_display_len, dfn_len, 20);
        相等断言!(
            dired.dired_positions,
            向量![
                BytePosition { start: 0, end: 3 },
                BytePosition { start: 4, end: 7 },
                BytePosition { start: 8, end: 11 },
                BytePosition { start: 32, end: 37 },
            ]
        );
        相等断言!(dired.padding, 0);
    }
}
