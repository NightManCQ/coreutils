/// Benchmark cutting fields with tab delimiter
#[divan::bench]
方法 cut_fields_tab(bencher: Bencher) {
    设 可变 data = 向量::新建();
    循环 i 在 0..100_000 {
        设 line = 格式化!("field1\tfield2_{i}\tfield3\tfield4\tfield5\n");
        data.extend_from_slice(line.as_bytes());
    }
    设 file_path = setup_test_file(&data);

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-f", "2,4", file_path.to_str().解包()],
        ));
    });
}

