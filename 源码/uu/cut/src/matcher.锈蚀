使用 memchr::{memchr, memchr2};

// Find the next matching byte sequence positions
// Return (first, last) where haystack[first..last] corresponds to the matched pattern
公有 协议 Matcher {
    方法 next_match(&自身, haystack: &[正8]) -> 选项<(正整数大小, 正整数大小)>;
}

// Matches for the exact byte sequence pattern
公有 结构 ExactMatcher<'a> {
    needle: &'a [正8],
}

实现<'a> ExactMatcher<'a> {
    公有 方法 新建(needle: &'a [正8]) -> 自身类型 {
        断言!(!needle.为空());
        自身类型 { needle }
    }
}

实现 Matcher 循环 ExactMatcher<'_> {
    方法 next_match(&自身, haystack: &[正8]) -> 选项<(正整数大小, 正整数大小)> {
        设 可变 pos = 0正整数大小;
        无限循环 {
            设 match_idx = memchr(自身.needle[0], &haystack[pos..])?;
            设 match_idx = match_idx + pos; // account for starting from pos

            如果 自身.needle.长度() == 1 || haystack[match_idx + 1..].starts_with(&自身.needle[1..]) {
                返回 一些((match_idx, match_idx + 自身.needle.长度()));
            }

            pos = match_idx + 1;
        }
    }
}

// Matches for any number of SPACE or TAB
公有 结构 WhitespaceMatcher {}

实现 Matcher 循环 WhitespaceMatcher {
    方法 next_match(&自身, haystack: &[正8]) -> 选项<(正整数大小, 正整数大小)> {
        设 match_idx = memchr2(b' ', b'\t', haystack)?;
        设 可变 skip = match_idx + 1;

        当 skip < haystack.长度() {
            匹配 haystack[skip] {
                b' ' | b'\t' => skip += 1,
                _ => 中断,
            }
        }

        一些((match_idx, skip))
    }
}

#[cfg(test)]
模组 matcher_tests {

    使用 超级::*;

    #[test]
    方法 test_exact_matcher_single_byte() {
        设 matcher = ExactMatcher::新建(":".as_bytes());
        // spell-checker:disable
        相等断言!(matcher.next_match("".as_bytes()), 无);
        相等断言!(matcher.next_match(":".as_bytes()), 一些((0, 1)));
        相等断言!(matcher.next_match(":abcxyz".as_bytes()), 一些((0, 1)));
        相等断言!(matcher.next_match("abc:xyz".as_bytes()), 一些((3, 4)));
        相等断言!(matcher.next_match("abcxyz:".as_bytes()), 一些((6, 7)));
        相等断言!(matcher.next_match("abcxyz".as_bytes()), 无);
        // spell-checker:enable
    }

    #[test]
    方法 test_exact_matcher_multi_bytes() {
        设 matcher = ExactMatcher::新建("<>".as_bytes());
        // spell-checker:disable
        相等断言!(matcher.next_match("".as_bytes()), 无);
        相等断言!(matcher.next_match("<>".as_bytes()), 一些((0, 2)));
        相等断言!(matcher.next_match("<>abcxyz".as_bytes()), 一些((0, 2)));
        相等断言!(matcher.next_match("abc<>xyz".as_bytes()), 一些((3, 5)));
        相等断言!(matcher.next_match("abcxyz<>".as_bytes()), 一些((6, 8)));
        相等断言!(matcher.next_match("abcxyz".as_bytes()), 无);
        // spell-checker:enable
    }

    #[test]
    方法 test_whitespace_matcher_single_space() {
        设 matcher = WhitespaceMatcher {};
        // spell-checker:disable
        相等断言!(matcher.next_match("".as_bytes()), 无);
        相等断言!(matcher.next_match(" ".as_bytes()), 一些((0, 1)));
        相等断言!(matcher.next_match("\tabcxyz".as_bytes()), 一些((0, 1)));
        相等断言!(matcher.next_match("abc\txyz".as_bytes()), 一些((3, 4)));
        相等断言!(matcher.next_match("abcxyz ".as_bytes()), 一些((6, 7)));
        相等断言!(matcher.next_match("abcxyz".as_bytes()), 无);
        // spell-checker:enable
    }

    #[test]
    方法 test_whitespace_matcher_multi_spaces() {
        设 matcher = WhitespaceMatcher {};
        // spell-checker:disable
        相等断言!(matcher.next_match("".as_bytes()), 无);
        相等断言!(matcher.next_match(" \t ".as_bytes()), 一些((0, 3)));
        相等断言!(matcher.next_match("\t\tabcxyz".as_bytes()), 一些((0, 2)));
        相等断言!(matcher.next_match("abc \txyz".as_bytes()), 一些((3, 5)));
        相等断言!(matcher.next_match("abcxyz  ".as_bytes()), 一些((6, 8)));
        相等断言!(matcher.next_match("abcxyz".as_bytes()), 无);
        // spell-checker:enable
    }
}
