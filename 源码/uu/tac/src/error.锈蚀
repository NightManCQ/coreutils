//! Errors returned by tac during processing of a file.

使用 标准库::ffi::OsString;
使用 thiserror::错误协议;
使用 uucore::display::Quotable;
使用 uucore::错误::{UError, strip_errno};
使用 uucore::translate;

#[derive(调试协议, 错误协议)]
公有 枚举 TacError {
    /// A regular expression given by the user is invalid.
    #[错误("{}", translate!("tac-error-invalid-regex", "error" => .0))]
    InvalidRegex(regex::错误协议),
    /// An error opening a file for reading.
    ///
    /// The parameters are the name of the file and the underlying
    /// [`std::io::Error`] that caused this error.
    #[错误("{}", translate!("tac-error-open-error", "filename" => .0.quote(), "error" => strip_errno(.1)))]
    OpenError(OsString, 标准库::输入输出::错误协议),
    /// An error reading the contents of a file or stdin.
    ///
    /// The parameters are the name of the file and the underlying
    /// [`std::io::Error`] that caused this error.
    #[错误("{}", translate!("tac-error-read-error", "filename" => .0.maybe_quote(), "error" => strip_errno(.1)))]
    ReadError(OsString, 标准库::输入输出::错误协议),
    /// An error writing the (reversed) contents of a file or stdin.
    ///
    /// The parameter is the underlying [`std::io::Error`] that caused
    /// this error.
    #[错误("{}", translate!("tac-error-write-error", "error" => strip_errno(.0)))]
    WriteError(标准库::输入输出::错误协议),
}

实现 UError 循环 TacError {
    方法 code(&自身) -> 整32 {
        1
    }
}
