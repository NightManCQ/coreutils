#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 before = matches.get_flag(options::BEFORE);
    设 regex = matches.get_flag(options::REGEX);
    设 raw_separator = matches
        .get_one::<OsString>(options::SEPARATOR)
        .map_or(OsStr::新建("\n"), |s| s.as_os_str());

    设 separator = 如果 raw_separator.为空() {
        OsStr::新建("\0")
    } 否则 {
        raw_separator
    };

    设 files: 向量<OsString> = 匹配 matches.get_many::<OsString>(options::FILE) {
        一些(v) => v.cloned().收集(),
        无 => 向量![OsString::from("-")],
    };

    tac(&files, before, regex, separator)
}

公有 方法 uu_app() -> Command {
    Command::新建("tac")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("tac"))
        .override_usage(format_usage(&translate!("tac-usage")))
        .about(translate!("tac-about"))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::BEFORE)
                .short('b')
                .long(options::BEFORE)
                .help(translate!("tac-help-before"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::REGEX)
                .short('r')
                .long(options::REGEX)
                .help(translate!("tac-help-regex"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::SEPARATOR)
                .short('s')
                .long(options::SEPARATOR)
                .help(translate!("tac-help-separator"))
                .value_parser(clap::value_parser!(OsString))
                .value_name("STRING"),
        )
        .arg(
            Arg::新建(options::FILE)
                .hide(真)
                .action(ArgAction::Append)
                .value_parser(clap::value_parser!(OsString))
                .value_hint(clap::ValueHint::FilePath),
        )
}

/// Print lines of a buffer in reverse, with line separator given as a regex.
///
/// `data` contains the bytes of the file.
///
/// `pattern` is the regular expression given as a
/// [`regex::bytes::Regex`] (not a [`regex::Regex`], since the input is
/// given as a slice of bytes). If `before` is `true`, then each match
/// of this pattern in `data` is interpreted as the start of a line. If
/// `before` is `false`, then each match of this pattern is interpreted
/// as the end of a line.
///
/// This function writes each line in `data` to [`std::io::Stdout`] in
/// reverse.
///
/// # Errors
///
/// If there is a problem writing to `stdout`, then this function
/// returns [`std::io::Error`].
方法 buffer_tac_regex(
    data: &[正8],
    pattern: &regex::bytes::Regex,
    before: 布尔,
) -> 标准库::输入输出::结果<()> {
    设 out = stdout();
    设 可变 out = BufWriter::新建(out.锁定());

    // The index of the line separator for the current line.
    //
    // As we scan through the `data` from right to left, we update this
    // variable each time we find a new line separator. We restrict our
    // regular expression search to only those bytes up to the line
    // separator.
    设 可变 this_line_end = data.长度();

    // The index of the start of the next line in the `data`.
    //
    // As we scan through the `data` from right to left, we update this
    // variable each time we find a new line.
    //
    // If `before` is `true`, then each line starts immediately before
    // the line separator. Otherwise, each line starts immediately after
    // the line separator.
    设 可变 following_line_start = data.长度();

    // Iterate over each byte in the buffer in reverse. When we find a
    // line separator, write the line to stdout.
    //
    // The `before` flag controls whether the line separator appears at
    // the end of the line (as in "abc\ndef\n") or at the beginning of
    // the line (as in "/abc/def").
    循环 i 在 (0..data.长度()).rev() {
        // Determine if there is a match for `pattern` starting at index
        // `i` in `data`. Only search up to the line ending that was
        // found previously.
        如果 设 一些(match_) = pattern.find_at(&data[..this_line_end], i)
            && match_.start() == i
        {
            // Record this index as the ending of the current line.
            this_line_end = i;

            // The length of the match (that is, the line separator), in bytes.
            设 slen = match_.end() - match_.start();

            如果 before {
                out.write_all(&data[i..following_line_start])?;
                following_line_start = i;
            } 否则 {
                out.write_all(&data[i + slen..following_line_start])?;
                following_line_start = i + slen;
            }
        }
    }

    // After the loop terminates, write whatever bytes are remaining at
    // the beginning of the buffer.
    out.write_all(&data[0..following_line_start])?;
    out.flush()?;
    好的(())
}

/// Write lines from `data` to stdout in reverse.
///
/// This function writes to [`stdout`] each line appearing in `data`,
/// starting with the last line and ending with the first line. The
/// `separator` parameter defines what characters to use as a line
/// separator.
///
/// If `before` is `false`, then this function assumes that the
/// `separator` appears at the end of each line, as in `"abc\ndef\n"`.
/// If `before` is `true`, then this function assumes that the
/// `separator` appears at the beginning of each line, as in
/// `"/abc/def"`.
方法 buffer_tac(data: &[正8], before: 布尔, separator: &OsStr) -> 标准库::输入输出::结果<()> {
    设 out = stdout();
    设 可变 out = BufWriter::新建(out.锁定());

    // The number of bytes in the line separator.
    设 slen = separator.长度();

    // The index of the start of the next line in the `data`.
    //
    // As we scan through the `data` from right to left, we update this
    // variable each time we find a new line.
    //
    // If `before` is `true`, then each line starts immediately before
    // the line separator. Otherwise, each line starts immediately after
    // the line separator.
    设 可变 following_line_start = data.长度();

    // Iterate over each byte in the buffer in reverse. When we find a
    // line separator, write the line to stdout.
    //
    // The `before` flag controls whether the line separator appears at
    // the end of the line (as in "abc\ndef\n") or at the beginning of
    // the line (as in "/abc/def").
    循环 i 在 memmem::rfind_iter(data, separator.as_encoded_bytes()) {
        如果 before {
            out.write_all(&data[i..following_line_start])?;
            following_line_start = i;
        } 否则 {
            out.write_all(&data[i + slen..following_line_start])?;
            following_line_start = i + slen;
        }
    }

    // After the loop terminates, write whatever bytes are remaining at
    // the beginning of the buffer.
    out.write_all(&data[0..following_line_start])?;
    out.flush()?;
    好的(())
}

/// Make the regex flavor compatible with `regex` crate
///
/// Concretely:
/// - Toggle escaping of (), |, {}
/// - Escape ^ and $ when not at edges
/// - Leave only ASCII bytes inside []
/// - Escape non-ASCII bytes as `(?-u:\xFF)` outside []
方法 translate_regex_flavor(bytes: &[正8]) -> 字符串 {
    设 可变 result = 向量::新建();
    设 可变 i = 0;
    设 可变 inside_brackets = 假;
    设 可变 prev_was_backslash = 假;
    设 可变 last_byte: 选项<正8> = 无;

    当 设 一些(b) = bytes.获取(i) {
        设 is_escaped = prev_was_backslash;
        prev_was_backslash = 假;

        匹配 b {
            _ 如果 inside_brackets && !b.is_ascii() => {
                i += 1;
                继续;
            }
            // Unescape escaped (), |, {} when not inside brackets
            b'\\' 如果 !inside_brackets && !is_escaped => {
                如果 设 一些(next) = bytes.获取(i + 1) {
                    如果 matches!(next, b'(' | b')' | b'|' | b'{' | b'}') {
                        result.压入(*next);
                        last_byte = 一些(*next);
                        i += 2;
                        继续;
                    }
                }

                result.压入(b'\\');
                last_byte = 一些(b'\\');
                prev_was_backslash = 真;
            }
            // Bracket tracking
            b'[' => {
                inside_brackets = 真;
                result.压入(*b);
                last_byte = 一些(*b);
            }
            b']' => {
                inside_brackets = 假;
                result.压入(*b);
                last_byte = 一些(*b);
            }
            // Escape (), |, {} when not escaped and outside brackets
            b'(' | b')' | b'|' | b'{' | b'}' 如果 !inside_brackets && !is_escaped => {
                result.压入(b'\\');
                result.压入(*b);
                last_byte = 一些(*b);
            }
            b'^' 如果 !inside_brackets && !is_escaped => {
                设 is_anchor_position =
                    result.为空() || matches!(last_byte, 一些(b'(' | b'|'));
                如果 !is_anchor_position {
                    result.压入(b'\\');
                }
                result.压入(*b);
                last_byte = 一些(*b);
            }
            b'$' 如果 !inside_brackets && !is_escaped => {
                设 next_is_anchor_position = 匹配 bytes.获取(i + 1) {
                    无 => 真,
                    一些(b')' | b'|') => 真,
                    一些(b'\\') => {
                        // Peek two ahead to see if it's \) or \|
                        matches!(bytes.获取(i + 2), 一些(b')' | b'|'))
                    }
                    _ => 假,
                };
                如果 !next_is_anchor_position {
                    result.压入(b'\\');
                }
                result.压入(*b);
                last_byte = 一些(*b);
            }
            _ 如果 !b.is_ascii() => {
                设 _ = write!(result, r"(?-u:\x{b:02x})");
                last_byte = 无;
            }
            _ => {
                result.压入(*b);
                last_byte = 一些(*b);
            }
        }

        i += 1;
    }

    字符串::from_utf8(result).期望("produces ASCII bytes")
}

#[allow(clippy::cognitive_complexity)]
方法 tac(filenames: &[OsString], before: 布尔, regex: 布尔, separator: &OsStr) -> UResult<()> {
    // Compile the regular expression pattern if it is provided.
    设 maybe_pattern = 如果 regex {
        匹配 regex::bytes::RegexBuilder::新建(&translate_regex_flavor(separator.as_encoded_bytes()))
            .multi_line(真)
            .build()
        {
            好的(p) => 一些(p),
            坏的(e) => 返回 坏的(TacError::InvalidRegex(e).into()),
        }
    } 否则 {
        无
    };

    循环 filename 在 filenames {
        设 mmap;
        设 buf;

        设 data: &[正8] = 如果 filename == "-" {
            #[cfg(unix)]
            如果 uucore::signals::stdin_was_closed() {
                设 e: 盒子<动态 UError> = TacError::ReadError(
                    OsString::from("-"),
                    标准库::输入输出::错误协议::from_raw_os_error(libc::EBADF),
                )
                .into();
                show!(e);
                set_exit_code(1);
                继续;
            }
            如果 设 一些(mmap1) = try_mmap_stdin() {
                mmap = mmap1;
                &mmap
            } 否则 {
                // Copy stdin to a temp file (respects TMPDIR), then mmap it.
                // Falls back to Vec buffer if temp file creation fails (e.g., bad TMPDIR).
                匹配 buffer_stdin() {
                    好的(StdinData::Mmap(mmap1)) => {
                        mmap = mmap1;
                        &mmap
                    }
                    好的(StdinData::向量(buf1)) => {
                        buf = buf1;
                        &buf
                    }
                    坏的(e) => {
                        show!(TacError::ReadError(OsString::from("stdin"), e));
                        继续;
                    }
                }
            }
        } 否则 {
            设 路径 = Path::新建(filename);
            设 可变 file = 匹配 File::open(路径) {
                好的(f) => f,
                坏的(e) => {
                    show!(TacError::OpenError(filename.克隆(), e));
                    继续;
                }
            };

            如果 设 一些(mmap1) = try_mmap_file(&file) {
                mmap = mmap1;
                &mmap
            } 否则 {
                设 可变 contents = 向量::新建();
                匹配 file.read_to_end(&可变 contents) {
                    好的(_) => {
                        buf = contents;
                        &buf
                    }
                    坏的(e) => {
                        show!(TacError::ReadError(filename.克隆(), e));
                        继续;
                    }
                }
            }
        };

        // Select the appropriate `tac` algorithm based on whether the
        // separator is given as a regular expression or a fixed string.
        设 result = 匹配 maybe_pattern {
            一些(引用 pattern) => buffer_tac_regex(data, pattern, before),
            无 => buffer_tac(data, before, separator),
        };

        // If there is any error in writing the output, terminate immediately.
        如果 设 坏的(e) = result {
            返回 坏的(TacError::WriteError(e).into());
        }
    }
    好的(())
}

方法 try_mmap_stdin() -> 选项<Mmap> {
    // SAFETY: If the file is truncated while we map it, SIGBUS will be raised
    // and our process will be terminated, thus preventing access of invalid memory.
    设 mmap = 不安全 { Mmap::映射(&stdin()).ok()? };
    // On Windows, mmap on a pipe handle can "succeed" but return 0 bytes
    // (the file size of a pipe is reported as 0). When that happens, return
    // None so we fall through to buffer_stdin() which reads the pipe properly.
    如果 mmap.为空() { 无 } 否则 { 一些(mmap) }
}

枚举 StdinData {
    Mmap(Mmap),
    向量(向量<正8>),
}

/// Copy stdin to a temp file, then memory-map it.
/// Falls back to reading directly into memory if temp file creation fails.
方法 buffer_stdin() -> 标准库::输入输出::结果<StdinData> {
    // Try to create a temp file (respects TMPDIR)
    如果 设 好的(可变 tmp) = tempfile::tempfile() {
        // Temp file created - copy stdin to it, then read back
        copy(&可变 stdin(), &可变 tmp)?;
        // SAFETY: If the file is truncated while we map it, SIGBUS will be raised
        // and our process will be terminated, thus preventing access of invalid memory.
        设 mmap = 不安全 { Mmap::映射(&tmp)? };
        好的(StdinData::Mmap(mmap))
    } 否则 {
        // Fall back to reading directly into memory (e.g., bad TMPDIR)
        设 可变 buf = 向量::新建();
        stdin().read_to_end(&可变 buf)?;
        好的(StdinData::向量(buf))
    }
}

方法 try_mmap_file(file: &File) -> 选项<Mmap> {
    // SAFETY: If the file is truncated while we map it, SIGBUS will be raised
    // and our process will be terminated, thus preventing access of invalid memory.
    不安全 { Mmap::映射(file).ok() }
}

#[cfg(test)]
模组 tests_hybrid_flavor {
    使用 超级::translate_regex_flavor;

    #[test]
    方法 test_grouping_and_alternation() {
        相等断言!(translate_regex_flavor(br"\(abc\)"), r"(abc)");

        相等断言!(translate_regex_flavor(br"(abc)"), r"\(abc\)");

        相等断言!(translate_regex_flavor(br"a\|b"), r"a|b");

        相等断言!(translate_regex_flavor(br"a|b"), r"a\|b");
    }

    #[test]
    方法 test_quantifiers() {
        相等断言!(translate_regex_flavor(b"a+"), "a+");

        相等断言!(translate_regex_flavor(b"a*"), "a*");

        相等断言!(translate_regex_flavor(b"a?"), "a?");

        相等断言!(translate_regex_flavor(br"a\+"), r"a\+");

        相等断言!(translate_regex_flavor(br"a\*"), r"a\*");

        相等断言!(translate_regex_flavor(br"a\?"), r"a\?");
    }

    #[test]
    方法 test_intervals() {
        相等断言!(translate_regex_flavor(br"a\{1,3\}"), r"a{1,3}");

        相等断言!(translate_regex_flavor(br"a{1,3}"), r"a\{1,3\}");
    }

    #[test]
    方法 test_anchors_context() {
        相等断言!(translate_regex_flavor(br"^abc$"), r"^abc$");

        相等断言!(translate_regex_flavor(br"a^b"), r"a\^b");
        相等断言!(translate_regex_flavor(br"a$b"), r"a\$b");

        // Anchors inside groups (reset by \(...\) regardless of position)
        相等断言!(translate_regex_flavor(br"\(^abc\)"), r"(^abc)");
        相等断言!(translate_regex_flavor(br"z\(^abc\)"), r"z(^abc)");
        相等断言!(translate_regex_flavor(br"\(abc$\)"), r"(abc$)");
        相等断言!(translate_regex_flavor(br"\(abc$\)z"), r"(abc$)z");

        // Anchors inside alternation (reset by \| regardless of position)
        相等断言!(translate_regex_flavor(br"^a\|^b"), r"^a|^b");
        相等断言!(translate_regex_flavor(br"x\|^b"), r"x|^b");
        相等断言!(translate_regex_flavor(br"a$\|b$"), r"a$|b$");
    }

    #[test]
    方法 test_character_classes() {
        相等断言!(translate_regex_flavor(br"[a-z]"), r"[a-z]");

        相等断言!(translate_regex_flavor(br"[.]"), r"[.]");
        相等断言!(translate_regex_flavor(br"[+]"), r"[+]");

        相等断言!(translate_regex_flavor(br"[]abc]"), r"[]abc]");

        相等断言!(translate_regex_flavor(br"[^]abc]"), r"[^]abc]");
    }

    #[test]
    方法 test_complex_strings() {
        相等断言!(translate_regex_flavor(br"(\d+)[+*]"), r"\(\d+\)[+*]");

        相等断言!(translate_regex_flavor(br"\(\d+\)\{2\}"), r"(\d+){2}");
    }

    #[test]
    方法 test_edge_cases() {
        相等断言!(translate_regex_flavor(br"abc\"), r"abc\");

        assert_eq!(translate_regex_flavor(br"\\"), r"\\");

        assert_eq!(translate_regex_flavor(br"\^"), r"\^");
    }
}
