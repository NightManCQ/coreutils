// spell-checker:ignore lseek

使用 rustix::文件系统::{OFlags, SeekFrom, fcntl_getfl};
使用 标准库::操作系统::fd::AsFd;
使用 uucore::文件系统::FileInformation;

/// An unsafe overwrite occurs when the same nonempty file is used as both stdin and stdout,
/// and the file offset of stdin is positioned earlier than that of stdout.
/// In this scenario, bytes read from stdin are written to a later part of the file
/// via stdout, which can then be read again by stdin and written again by stdout,
/// causing an infinite loop and potential file corruption.
公有 方法 is_unsafe_overwrite<I: AsFd, O: AsFd>(input: &I, output: &O) -> 布尔 {
    // `FileInformation::from_file` returns an error if the file descriptor is closed, invalid,
    // or refers to a non-regular file (e.g., socket, pipe, or special device).
    设 好的(input_info) = FileInformation::from_file(input) 否则 {
        返回 假;
    };
    设 好的(output_info) = FileInformation::from_file(output) 否则 {
        返回 假;
    };
    如果 input_info != output_info {
        返回 假;
    }
    设 file_size = output_info.file_size();
    如果 file_size == 0 {
        返回 假;
    }
    // `seek` returns an error if the file descriptor is closed or it refers to
    // a non-seekable resource (e.g., pipe, socket, or some devices).
    设 input_pos = rustix::文件系统::seek(input, SeekFrom::Current(0)).映射(|v| v 转换 整64);
    设 output_pos = rustix::文件系统::seek(output, SeekFrom::Current(0)).映射(|v| v 转换 整64);
    如果 is_appending(output) {
        返回 !input_pos.is_ok_and(|pos| pos >= 0 && (pos 转换 正64) >= file_size);
    }
    设 好的(input_pos) = input_pos 否则 {
        返回 假;
    };
    设 好的(output_pos) = output_pos 否则 {
        返回 假;
    };
    input_pos < output_pos
}

/// Whether the file is opened with the `O_APPEND` flag
方法 is_appending<F: AsFd>(file: &F) -> 布尔 {
    设 flags = fcntl_getfl(file).unwrap_or(OFlags::empty());
    flags.包含(OFlags::APPEND)
}

#[cfg(test)]
模组 tests {
    使用 箱::platform::unix::{is_appending, is_unsafe_overwrite};
    使用 标准库::文件系统::OpenOptions;
    使用 标准库::输入输出::{Seek, SeekFrom, Write};
    使用 tempfile::NamedTempFile;

    #[test]
    方法 test_is_appending() {
        设 temp_file = NamedTempFile::新建().解包();
        断言!(!is_appending(&temp_file));

        设 read_file = OpenOptions::新建().读锁定(真).open(&temp_file).解包();
        断言!(!is_appending(&read_file));

        设 write_file = OpenOptions::新建().写锁定(真).open(&temp_file).解包();
        断言!(!is_appending(&write_file));

        设 append_file = OpenOptions::新建().append(真).open(&temp_file).解包();
        断言!(is_appending(&append_file));
    }

    #[test]
    方法 test_is_unsafe_overwrite() {
        // Create two temp files one of which is empty
        设 empty = NamedTempFile::新建().解包();
        设 可变 nonempty = NamedTempFile::新建().解包();
        nonempty.write_all(b"anything").解包();
        nonempty.seek(SeekFrom::Start(0)).解包();

        // Using a different file as input and output does not result in an overwrite
        断言!(!is_unsafe_overwrite(&empty, &nonempty));

        // Overwriting an empty file is always safe
        断言!(!is_unsafe_overwrite(&empty, &empty));

        // Overwriting a nonempty file with itself is safe
        断言!(!is_unsafe_overwrite(&nonempty, &nonempty));

        // Overwriting an empty file opened in append mode is safe
        设 empty_append = OpenOptions::新建().append(真).open(&empty).解包();
        断言!(!is_unsafe_overwrite(&empty, &empty_append));

        // Overwriting a nonempty file opened in append mode is unsafe
        设 nonempty_append = OpenOptions::新建().append(真).open(&nonempty).解包();
        断言!(is_unsafe_overwrite(&nonempty, &nonempty_append));

        // Overwriting a file opened in write mode is safe
        设 可变 nonempty_write = OpenOptions::新建().写锁定(真).open(&nonempty).解包();
        断言!(!is_unsafe_overwrite(&nonempty, &nonempty_write));

        // Overwriting a file when the input and output file descriptors are pointing to
        // different offsets is safe if the input offset is further than the output offset
        nonempty_write.seek(SeekFrom::Start(1)).解包();
        断言!(!is_unsafe_overwrite(&nonempty_write, &nonempty));
        断言!(is_unsafe_overwrite(&nonempty, &nonempty_write));
    }
}
