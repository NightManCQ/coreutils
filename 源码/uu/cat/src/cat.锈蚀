方法 cat_handle<R: FdReadable>(
    handle: &可变 InputHandle<R>,
    options: &OutputOptions,
    state: &可变 OutputState,
) -> CatResult<()> {
    如果 options.can_write_fast() {
        write_fast(handle)
    } 否则 {
        write_lines(handle, options, state)
    }
}

方法 cat_path(路径: &OsString, options: &OutputOptions, state: &可变 OutputState) -> CatResult<()> {
    匹配 get_input_type(路径)? {
        InputType::StdIn => {
            设 stdin = 输入输出::stdin();
            如果 is_unsafe_overwrite(&stdin, &输入输出::stdout()) {
                返回 坏的(CatError::OutputIsInput);
            }
            设 可变 handle = InputHandle {
                reader: stdin,
                is_interactive: 输入输出::stdin().is_terminal(),
            };
            cat_handle(&可变 handle, options, state)
        }
        InputType::Directory => 坏的(CatError::IsDirectory),
        #[cfg(unix)]
        InputType::Socket => 坏的(CatError::NoSuchDeviceOrAddress),
        _ => {
            设 file = File::open(路径)?;
            如果 is_unsafe_overwrite(&file, &输入输出::stdout()) {
                返回 坏的(CatError::OutputIsInput);
            }
            设 可变 handle = InputHandle {
                reader: file,
                is_interactive: 假,
            };
            cat_handle(&可变 handle, options, state)
        }
    }
}

方法 cat_files<'a, I>(files: I, options: &OutputOptions) -> UResult<()>
何处
    I: 转换为迭代器协议<Item = &'a OsString>,
{
    设 可变 state = OutputState {
        line_number: LineNumber::新建(),
        at_line_start: 真,
        skipped_carriage_return: 假,
        one_blank_kept: 假,
    };
    设 可变 error_messages: 向量<字符串> = 向量::新建();

    循环 路径 在 files {
        如果 设 坏的(err) = cat_path(路径, options, &可变 state) {
            error_messages.压入(格式化!("{}: {err}", 路径.maybe_quote()));
        }
    }
    如果 state.skipped_carriage_return {
        打印!("\r");
    }
    如果 error_messages.为空() {
        好的(())
    } 否则 {
        // each next line is expected to display "cat: …"
        设 line_joiner = "\ncat: ";

        坏的(uucore::错误::USimpleError::新建(
            error_messages.长度() 转换 整32,
            error_messages.加入(line_joiner),
        ))
    }
}

/// Classifies the `InputType` of file at `path` if possible
///
/// # Arguments
///
/// * `path` - Path on a file system to classify metadata
方法 get_input_type(路径: &OsString) -> CatResult<InputType> {
    如果 路径 == "-" {
        返回 好的(InputType::StdIn);
    }

    设 ft = 匹配 metadata(路径) {
        好的(md) => md.file_type(),
        坏的(e) => {
            如果 设 一些(raw_error) = e.raw_os_error() {
                // On Unix-like systems, the error code for "Too many levels of symbolic links" is 40 (ELOOP).
                // we want to provide a proper error message in this case.
                #[cfg(not(任意(target_os = "macos", target_os = "freebsd")))]
                设 too_many_symlink_code = 40;
                #[cfg(任意(target_os = "macos", target_os = "freebsd"))]
                设 too_many_symlink_code = 62;
                如果 raw_error == too_many_symlink_code {
                    返回 坏的(CatError::TooManySymlinks);
                }
            }
            返回 坏的(CatError::Io(e));
        }
    };
    匹配 ft {
        #[cfg(unix)]
        ft 如果 ft.is_block_device() => 好的(InputType::BlockDevice),
        #[cfg(unix)]
        ft 如果 ft.is_char_device() => 好的(InputType::CharacterDevice),
        #[cfg(unix)]
        ft 如果 ft.is_fifo() => 好的(InputType::Fifo),
        #[cfg(unix)]
        ft 如果 ft.is_socket() => 好的(InputType::Socket),
        ft 如果 ft.is_dir() => 好的(InputType::Directory),
        ft 如果 ft.is_file() => 好的(InputType::File),
        ft 如果 ft.is_symlink() => 好的(InputType::SymLink),
        _ => 坏的(CatError::UnknownFiletype {
            ft_debug: 格式化!("{ft:?}"),
        }),
    }
}

/// Writes handle to stdout with no configuration. This allows a
/// simple memory copy.
方法 write_fast<R: FdReadable>(handle: &可变 InputHandle<R>) -> CatResult<()> {
    设 stdout = 输入输出::stdout();
    #[cfg(任意(target_os = "linux", target_os = "android"))]
    设 可变 stdout = stdout;
    #[cfg(任意(target_os = "linux", target_os = "android"))]
    {
        // If we're on Linux or Android, try to use the splice() system call
        // for faster writing. If it works, we're done.
        如果 !splice::write_fast_using_splice(handle, &可变 stdout)? {
            返回 好的(());
        }
    }
    // If we're not on Linux or Android, or the splice() call failed,
    // fall back on slower writing.
    设 可变 stdout_lock = stdout.锁定();
    // stack allocation is overhead when splice succeed
    #[cfg(任意(target_os = "linux", target_os = "android"))]
    设 可变 buf = 向量![0; 1024 * 64];
    #[cfg(not(任意(target_os = "linux", target_os = "android")))]
    设 可变 buf = [0; 1024 * 64];
    无限循环 {
        匹配 handle.reader.读锁定(&可变 buf) {
            好的(n) => {
                如果 n == 0 {
                    中断;
                }
                stdout_lock
                    .write_all(&buf[..n])
                    .inspect_err(handle_broken_pipe)?;
            }
            坏的(e) 如果 e.kind() == ErrorKind::Interrupted => {}
            坏的(e) => 返回 坏的(e.into()),
        }
    }

    // If the splice() call failed and there has been some data written to
    // stdout via while loop above AND there will be second splice() call
    // that will succeed, data pushed through splice will be output before
    // the data buffered in stdout.lock. Therefore additional explicit flush
    // is required here.
    stdout_lock.flush().inspect_err(handle_broken_pipe)?;
    好的(())
}

/// Outputs file contents to stdout in a line-by-line fashion,
/// propagating any errors that might occur.
方法 write_lines<R: FdReadable>(
    handle: &可变 InputHandle<R>,
    options: &OutputOptions,
    state: &可变 OutputState,
) -> CatResult<()> {
    设 可变 in_buf = [0; 1024 * 31];
    设 stdout = 输入输出::stdout();
    设 stdout = stdout.锁定();
    // Add a 32K buffer for stdout - this greatly improves performance.
    设 可变 writer = BufWriter::with_capacity(32 * 1024, stdout);

    无限循环 {
        设 n = 匹配 handle.reader.读锁定(&可变 in_buf) {
            好的(0) => 中断,
            好的(n) => n,
            坏的(e) 如果 e.kind() == ErrorKind::Interrupted => 继续,
            坏的(e) => 返回 坏的(e.into()),
        };
        设 in_buf = &in_buf[..n];
        设 可变 pos = 0;
        当 pos < n {
            // skip empty line_number enumerating them if needed
            如果 in_buf[pos] == b'\n' {
                write_new_line(&可变 writer, options, state, handle.is_interactive)?;
                state.at_line_start = 真;
                pos += 1;
                继续;
            }
            如果 state.skipped_carriage_return {
                writer.write_all(b"\r")?;
                state.skipped_carriage_return = 假;
                state.at_line_start = 假;
            }
            state.one_blank_kept = 假;
            如果 state.at_line_start && options.number != NumberingMode::无 {
                state.line_number.写锁定(&可变 writer)?;
                state.line_number.increment();
            }

            // print to end of line or end of buffer
            设 offset = write_end(&可变 writer, &in_buf[pos..], options)?;

            // end of buffer?
            如果 offset + pos == in_buf.长度() {
                state.at_line_start = 假;
                中断;
            }
            如果 in_buf[pos + offset] == b'\r' {
                state.skipped_carriage_return = 真;
            } 否则 {
                相等断言!(in_buf[pos + offset], b'\n');
                // print suitable end of line
                write_end_of_line(
                    &可变 writer,
                    options.end_of_line().as_bytes(),
                    handle.is_interactive,
                )?;
                state.at_line_start = 真;
            }
            pos += offset + 1;
        }
        // We need to flush the buffer each time around the loop in order to pass GNU tests.
        // When we are reading the input from a pipe, the `handle.reader.read` call at the top
        // of this loop will block (indefinitely) whist waiting for more data. The expectation
        // however is that anything that's ready for output should show up in the meantime,
        // and not be buffered internally to the `cat` process.
        // Hence it's necessary to flush our buffer before every time we could potentially block
        // on a `std::io::Read::read` call.
        writer.flush().inspect_err(handle_broken_pipe)?;
    }

    好的(())
}

/// `\r` followed by `\n` is printed as `^M` when `show_ends` is enabled, so that `\r\n` prints as `^M$`
方法 write_new_line<W: Write>(
    writer: &可变 W,
    options: &OutputOptions,
    state: &可变 OutputState,
    is_interactive: 布尔,
) -> CatResult<()> {
    如果 state.skipped_carriage_return {
        如果 options.show_ends {
            writer.write_all(b"^M")?;
        } 否则 {
            writer.write_all(b"\r")?;
        }
        state.skipped_carriage_return = 假;

        write_end_of_line(writer, options.end_of_line().as_bytes(), is_interactive)?;
        返回 好的(());
    }
    如果 !state.at_line_start || !options.squeeze_blank || !state.one_blank_kept {
        state.one_blank_kept = 真;
        如果 state.at_line_start && options.number == NumberingMode::All {
            state.line_number.写锁定(writer)?;
            state.line_number.increment();
        }
        write_end_of_line(writer, options.end_of_line().as_bytes(), is_interactive)?;
    }
    好的(())
}

方法 write_end<W: Write>(
    writer: &可变 W,
    in_buf: &[正8],
    options: &OutputOptions,
) -> 输入输出::结果<正整数大小> {
    如果 options.show_nonprint {
        write_nonprint_to_end(in_buf, writer, options.tab().as_bytes())
    } 否则 如果 options.show_tabs {
        write_tab_to_end(in_buf, writer)
    } 否则 {
        write_to_end(in_buf, writer)
    }
}

// write***_to_end methods
// Write all symbols till \n or \r or end of buffer is reached
// We need to stop at \r because it may be written as ^M depending on the byte after and settings;
// however, write_nonprint_to_end doesn't need to stop at \r because it will always write \r as ^M.
// Return the number of written symbols

方法 write_to_end<W: Write>(in_buf: &[正8], writer: &可变 W) -> 输入输出::结果<正整数大小> {
    // using memchr2 significantly improves performances
    如果 设 一些(p) = memchr2(b'\n', b'\r', in_buf) {
        writer.write_all(&in_buf[..p])?;
        好的(p)
    } 否则 {
        writer.write_all(in_buf)?;
        好的(in_buf.长度())
    }
}

方法 write_tab_to_end<W: Write>(可变 in_buf: &[正8], writer: &可变 W) -> 输入输出::结果<正整数大小> {
    设 可变 计数 = 0;
    无限循环 {
        如果 设 一些(p) = in_buf
            .迭代()
            .position(|c| *c == b'\n' || *c == b'\t' || *c == b'\r')
        {
            writer.write_all(&in_buf[..p])?;
            如果 in_buf[p] == b'\t' {
                writer.write_all(b"^I")?;
                in_buf = &in_buf[p + 1..];
                计数 += p + 1;
            } 否则 {
                // b'\n' or b'\r'
                返回 好的(计数 + p);
            }
        } 否则 {
            writer.write_all(in_buf)?;
            返回 好的(in_buf.长度() + 计数);
        }
    }
}

方法 write_nonprint_to_end<W: Write>(in_buf: &[正8], writer: &可变 W, tab: &[正8]) -> 输入输出::结果<正整数大小> {
    设 可变 计数 = 0;

    循环 byte 在 in_buf.迭代().copied() {
        如果 byte == b'\n' {
            中断;
        }
        匹配 byte {
            9 => writer.write_all(tab),
            0..=8 | 10..=31 => writer.write_all(&[b'^', byte + 64]),
            32..=126 => writer.write_all(&[byte]),
            127 => writer.write_all(b"^?"),
            128..=159 => writer.write_all(&[b'M', b'-', b'^', byte - 64]),
            160..=254 => writer.write_all(&[b'M', b'-', byte - 128]),
            _ => writer.write_all(b"M-^?"),
        }?;
        计数 += 1;
    }
    好的(计数)
}

方法 write_end_of_line<W: Write>(
    writer: &可变 W,
    end_of_line: &[正8],
    is_interactive: 布尔,
) -> CatResult<()> {
    writer.write_all(end_of_line)?;
    如果 is_interactive {
        writer.flush().inspect_err(handle_broken_pipe)?;
    }
    好的(())
}

方法 handle_broken_pipe(错误: &输入输出::错误协议) {
    // SIGPIPE is not available on Windows.
    如果 cfg!(target_os = "windows") && 错误.kind() == ErrorKind::BrokenPipe {
        标准库::进程::exit(13);
    }
}

