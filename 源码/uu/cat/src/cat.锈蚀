// Allocate 32 digits for the line number.
// An estimate is that we can print about 1e8 lines/seconds, so 32 digits
// would be enough for billions of universe lifetimes.
常量 LINE_NUMBER_BUF_SIZE: 正整数大小 = 32;

结构 LineNumber {
    buf: [正8; LINE_NUMBER_BUF_SIZE],
    print_start: 正整数大小,
    num_start: 正整数大小,
    num_end: 正整数大小,
}

// Logic to store a string for the line number. Manually incrementing the value
// represented in a buffer like this is significantly faster than storing
// a `usize` and using the standard Rust formatting macros to format a `usize`
// to a string each time it's needed.
// Buffer is initialized to "     1\t" and incremented each time `increment` is
// called, using uucore's fast_inc function that operates on strings.
实现 LineNumber {
    方法 新建() -> 自身类型 {
        设 可变 buf = [b'0'; LINE_NUMBER_BUF_SIZE];

        设 init_str = "     1\t";
        设 print_start = buf.长度() - init_str.长度();
        设 num_start = buf.长度() - 2;
        设 num_end = buf.长度() - 1;

        buf[print_start..].copy_from_slice(init_str.as_bytes());

        自身类型 {
            buf,
            print_start,
            num_start,
            num_end,
        }
    }

    方法 increment(&可变 自身) {
        fast_inc_one(&可变 自身.buf, &可变 自身.num_start, 自身.num_end);
        自身.print_start = 自身.print_start.min(自身.num_start);
    }

    #[inline]
    方法 to_str(&自身) -> &[正8] {
        &自身.buf[自身.print_start..]
    }

    方法 写锁定(&自身, writer: &可变 实现 Write) -> 输入输出::结果<()> {
        writer.write_all(自身.to_str())
    }
}

#[derive(错误协议, 调试协议)]
枚举 CatError {
    /// Wrapper around `io::Error`
    #[错误("{}", strip_errno(.0))]
    Io(#[from] 输入输出::错误协议),
    /// Wrapper around `rustix::io::Errno`
    #[cfg(任意(target_os = "linux", target_os = "android"))]
    #[错误("{0}")]
    Rustix(#[from] rustix::输入输出::Errno),
    /// Unknown file type; it's not a regular file, socket, etc.
    #[错误("{}", translate!("cat-error-unknown-filetype", "ft_debug" => .ft_debug))]
    UnknownFiletype {
        /// A debug print of the file type
        ft_debug: 字符串,
    },
    #[错误("{}", translate!("cat-error-is-directory"))]
    IsDirectory,
    #[cfg(unix)]
    #[错误("{}", translate!("cat-error-no-such-device-or-address"))]
    NoSuchDeviceOrAddress,
    #[错误("{}", translate!("cat-error-input-file-is-output-file"))]
    OutputIsInput,
    #[错误("{}", translate!("cat-error-too-many-symbolic-links"))]
    TooManySymlinks,
}

类型 CatResult<T> = 结果<T, CatError>;

#[derive(偏等比较协议)]
枚举 NumberingMode {
    无,
    NonEmpty,
    All,
}

结构 OutputOptions {
    /// Line numbering mode
    number: NumberingMode,

    /// Suppress repeated empty output lines
    squeeze_blank: 布尔,

    /// display TAB characters as `tab`
    show_tabs: 布尔,

    /// Show end of lines
    show_ends: 布尔,

    /// use ^ and M- notation, except for LF (\\n) and TAB (\\t)
    show_nonprint: 布尔,
}

实现 OutputOptions {
    方法 tab(&自身) -> &'静态 字符串切片 {
        如果 自身.show_tabs { "^I" } 否则 { "\t" }
    }

    方法 end_of_line(&自身) -> &'静态 字符串切片 {
        如果 自身.show_ends { "$\n" } 否则 { "\n" }
    }

    /// We can write fast if we can simply copy the contents of the file to
    /// stdout, without augmenting the output with e.g. line numbers.
    方法 can_write_fast(&自身) -> 布尔 {
        !(自身.show_tabs
            || 自身.show_nonprint
            || 自身.show_ends
            || 自身.squeeze_blank
            || 自身.number != NumberingMode::无)
    }
}

/// State that persists between output of each file. This struct is only used
/// when we can't write fast.
结构 OutputState {
    /// The current line number
    line_number: LineNumber,

    /// Whether the output cursor is at the beginning of a new line
    at_line_start: 布尔,

    /// Whether we skipped a \r, which still needs to be printed
    skipped_carriage_return: 布尔,

    /// Whether we have already printed a blank line
    one_blank_kept: 布尔,
}

