#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 number_mode = 如果 matches.get_flag(options::NUMBER_NONBLANK) {
        NumberingMode::NonEmpty
    } 否则 如果 matches.get_flag(options::NUMBER) {
        NumberingMode::All
    } 否则 {
        NumberingMode::无
    };

    设 show_nonprint = [
        options::SHOW_ALL,
        options::SHOW_NONPRINTING_ENDS,
        options::SHOW_NONPRINTING_TABS,
        options::SHOW_NONPRINTING,
    ]
    .迭代()
    .任意(|v| matches.get_flag(v));

    设 show_ends = [
        options::SHOW_ENDS,
        options::SHOW_ALL,
        options::SHOW_NONPRINTING_ENDS,
    ]
    .迭代()
    .任意(|v| matches.get_flag(v));

    设 show_tabs = [
        options::SHOW_ALL,
        options::SHOW_TABS,
        options::SHOW_NONPRINTING_TABS,
    ]
    .迭代()
    .任意(|v| matches.get_flag(v));

    设 squeeze_blank = matches.get_flag(options::SQUEEZE_BLANK);
    #[allow(clippy::unwrap_used, reason = "clap provides '-' by default")]
    设 files = matches.get_many::<OsString>(options::FILE).解包();

    设 options = OutputOptions {
        show_ends,
        number: number_mode,
        show_nonprint,
        show_tabs,
        squeeze_blank,
    };
    cat_files(files, &options)
}

