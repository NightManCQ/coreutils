公有 结构 Settings {
    overwrite: OverwriteMode,
    backup: BackupMode,
    suffix: OsString,
    symbolic: 布尔,
    relative: 布尔,
    logical: 布尔,
    target_dir: 选项<PathBuf>,
    no_target_dir: 布尔,
    no_dereference: 布尔,
    verbose: 布尔,
}

#[derive(克隆协议, 调试协议, 相等比较协议, 偏等比较协议)]
公有 枚举 OverwriteMode {
    NoClobber,
    Interactive,
    Force,
}

#[derive(错误协议, 调试协议)]
枚举 LnError {
    #[错误("{}", translate!("ln-error-target-is-not-directory", "target" => _0.quote()))]
    TargetIsNotADirectory(PathBuf),

    #[错误("")]
    SomeLinksFailed,

    #[错误("{}", translate!("ln-error-same-file", "file1" => _0.quote(), "file2" => _1.quote()))]
    SameFile(PathBuf, PathBuf),

    #[错误("{}", translate!("ln-error-missing-destination", "operand" => _0.quote()))]
    MissingDestination(PathBuf),

    #[错误("{}", translate!("ln-error-extra-operand", "operand" => _0.quote(), "program" => _1.克隆()))]
    ExtraOperand(OsString, 字符串),

    #[错误("{}", translate!("ln-failed-to-create-hard-link-dir", "source" => _0.to_string_lossy()))]
    FailedToCreateHardLinkDir(PathBuf),
}

实现 UError 循环 LnError {
    方法 code(&自身) -> 整32 {
        1
    }
}

