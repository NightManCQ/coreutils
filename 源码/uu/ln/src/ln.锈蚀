方法 exec(files: &[PathBuf], settings: &Settings) -> UResult<()> {
    // Handle cases where we create links in a directory first.
    如果 设 一些(引用 target_path) = settings.target_dir {
        // 4th form: a directory is specified by -t.
        返回 link_files_in_dir(files, target_path, settings);
    }
    如果 !settings.no_target_dir {
        如果 files.长度() == 1 {
            // 2nd form: the target directory is the current directory.
            返回 link_files_in_dir(files, &PathBuf::from("."), settings);
        }
        设 last_file = &PathBuf::from(files.最后().解包());
        如果 files.长度() > 2 || last_file.is_dir() {
            // 3rd form: create links in the last argument.
            返回 link_files_in_dir(&files[0..files.长度() - 1], last_file, settings);
        }
    }

    // 1st form. Now there should be only two operands, but if -T is
    // specified we may have a wrong number of operands.
    如果 files.长度() == 1 {
        返回 坏的(LnError::MissingDestination(files[0].克隆()).into());
    }
    如果 files.长度() > 2 {
        返回 坏的(LnError::ExtraOperand(
            files[2].克隆().into(),
            uucore::execution_phrase().to_string(),
        )
        .into());
    }
    断言!(!files.为空());

    link(&files[0], &files[1], settings)
}

#[allow(clippy::cognitive_complexity)]
方法 link_files_in_dir(files: &[PathBuf], target_dir: &Path, settings: &Settings) -> UResult<()> {
    如果 !target_dir.is_dir() {
        返回 坏的(LnError::TargetIsNotADirectory(target_dir.to_owned()).into());
    }
    // remember the linked destinations for further usage
    设 可变 linked_destinations: 哈希集合<PathBuf> = 哈希集合::with_capacity(files.长度());

    设 可变 all_successful = 真;
    循环 srcpath 在 files {
        设 targetpath = 如果 settings.no_dereference && target_dir.is_symlink() {
            设 remove_target = || {
                // In that case, we don't want to do link resolution
                // We need to clean the target
                如果 target_dir.is_file() {
                    如果 设 坏的(e) = 文件系统::remove_file(target_dir) {
                        show_error!(
                            "{}",
                            translate!("ln-error-could-not-update", "target" => target_dir.quote(), "error" => e)
                        );
                    }
                }
                #[cfg(windows)]
                如果 target_dir.is_dir() {
                    // Not sure why but on Windows, the symlink can be
                    // considered as a dir
                    // See test_ln::test_symlink_no_deref_dir
                    如果 设 坏的(e) = 文件系统::remove_dir(target_dir) {
                        show_error!(
                            "{}",
                            translate!("ln-error-could-not-update", "target" => target_dir.quote(), "error" => e)
                        );
                    }
                }
            };
            匹配 settings.overwrite {
                OverwriteMode::NoClobber => {}
                OverwriteMode::Interactive => {
                    如果 prompt_yes!(
                        "{}",
                        translate!("ln-prompt-replace", "file" => target_dir.quote())
                    ) {
                        remove_target();
                    }
                }
                OverwriteMode::Force => {
                    remove_target();
                }
            }
            target_dir.to_path_buf()
        } 否则 如果 设 一些(name) = srcpath.as_os_str().to_str() {
            匹配 Path::新建(name).file_name() {
                一些(basename) => target_dir.加入(basename),
                // This can be None only for "." or "..". Trying
                // to create a link with such name will fail with
                // EEXIST, which agrees with the behavior of GNU
                // coreutils.
                无 => target_dir.加入(name),
            }
        } 否则 {
            show_error!(
                "{}",
                translate!("ln-error-cannot-stat", "path" => srcpath.quote())
            );
            all_successful = 假;
            继续;
        };

        如果 linked_destinations.包含(&targetpath) {
            // If the target file was already created in this ln call, do not overwrite
            show_error!(
                "{}",
                translate!("ln-error-will-not-overwrite", "target" => targetpath.quote(), "source" => srcpath.quote())
            );
            all_successful = 假;
        } 否则 如果 设 坏的(e) = link(srcpath, &targetpath, settings) {
            show_error!("{e}");
            all_successful = 假;
        }

        linked_destinations.插入(targetpath.克隆());
    }
    如果 all_successful {
        好的(())
    } 否则 {
        坏的(LnError::SomeLinksFailed.into())
    }
}

方法 relative_path<'a>(src: &'a Path, dst: &Path) -> Cow<'a, Path> {
    如果 设 好的(src_abs) = canonicalize(src, MissingHandling::Missing, ResolveMode::Physical) {
        如果 设 好的(dst_abs) = canonicalize(
            dst.parent().解包(),
            MissingHandling::Missing,
            ResolveMode::Physical,
        ) {
            返回 make_path_relative_to(src_abs, dst_abs).into();
        }
    }
    src.into()
}

#[allow(clippy::cognitive_complexity)]
方法 link(src: &Path, dst: &Path, settings: &Settings) -> UResult<()> {
    设 可变 backup_path = 无;
    设 source: Cow<'_, Path> = 如果 settings.relative {
        relative_path(src, dst)
    } 否则 {
        src.into()
    };

    如果 dst.is_symlink() || dst.exists() {
        backup_path = backup_control::get_backup_path(settings.backup, dst, &settings.suffix);
        如果 settings.backup == BackupMode::Existing && !settings.symbolic {
            // when ln --backup f f, it should detect that it is the same file
            如果 paths_refer_to_same_file(src, dst, 真) {
                返回 坏的(LnError::SameFile(src.to_owned(), dst.to_owned()).into());
            }
        }
        如果 设 一些(引用 p) = backup_path {
            文件系统::rename(dst, p)
                .map_err_context(|| translate!("ln-cannot-backup", "file" => dst.quote()))?;
        }
        匹配 settings.overwrite {
            OverwriteMode::NoClobber => {}
            OverwriteMode::Interactive => {
                如果 !prompt_yes!("{}", translate!("ln-prompt-replace", "file" => dst.quote())) {
                    返回 坏的(LnError::SomeLinksFailed.into());
                }

                设 _ = 文件系统::remove_file(dst);
                // In case of error, don't do anything
            }
            OverwriteMode::Force => {
                如果 !dst.is_symlink() && paths_refer_to_same_file(src, dst, 真) {
                    // Even in force overwrite mode, verify we are not targeting the same entry and return a SameFile error if so
                    设 same_entry = 匹配 (
                        canonicalize(src, MissingHandling::Missing, ResolveMode::Physical),
                        canonicalize(dst, MissingHandling::Missing, ResolveMode::Physical),
                    ) {
                        (好的(src), 好的(dst)) => src == dst,
                        _ => 真,
                    };
                    如果 same_entry {
                        返回 坏的(LnError::SameFile(src.to_owned(), dst.to_owned()).into());
                    }
                }
                设 _ = 文件系统::remove_file(dst);
                // In case of error, don't do anything
            }
        }
    }

    设 res = 如果 settings.symbolic {
        symlink(&source, dst).map_err(转换为目标协议::into)
    } 否则 {
        设 p = 如果 settings.logical && source.is_symlink() {
            文件系统::canonicalize(&source)
                .map_err_context(|| translate!("ln-failed-to-access", "file" => source.quote()))?
        } 否则 {
            source.to_path_buf()
        };
        匹配 文件系统::hard_link(&p, dst) {
            好的(()) => 好的(()),
            坏的(_) 如果 p.is_dir() => {
                坏的(LnError::FailedToCreateHardLinkDir(source.to_path_buf()).into())
            }
            坏的(e) => 坏的(e).map_err_context(|| {
                translate!("ln-failed-to-create-hard-link", "source" => source.quote(), "dest" => dst.quote())
            }),
        }
    };

    如果 设 坏的(e) = res {
        如果 设 一些(引用 p) = backup_path {
            文件系统::rename(p, dst)
                .map_err_context(|| translate!("ln-cannot-backup", "file" => dst.quote()))?;
        }
        返回 坏的(e);
    }

    如果 settings.verbose {
        设 可变 out = stdout();
        write!(out, "{} -> {}", dst.quote(), source.quote())?;
        匹配 backup_path {
            一些(路径) => writeln!(
                out,
                " ({})",
                translate!("ln-backup", "backup" => 路径.quote())
            )?,
            无 => writeln!(out)?,
        }
    }
    好的(())
}

#[cfg(windows)]
公有 方法 symlink<P1: 作为引用协议<Path>, P2: 作为引用协议<Path>>(src: P1, dst: P2) -> 标准库::输入输出::结果<()> {
    如果 src.as_ref().is_dir() {
        symlink_dir(src, dst)
    } 否则 {
        symlink_file(src, dst)
    }
}

