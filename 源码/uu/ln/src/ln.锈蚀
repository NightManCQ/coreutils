静态 ARG_FILES: &字符串切片 = "files";

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    /* the list of files */

    设 paths: 向量<PathBuf> = matches
        .get_many::<OsString>(ARG_FILES)
        .解包()
        .映射(PathBuf::from)
        .收集();

    设 symbolic = matches.get_flag(options::SYMBOLIC);

    设 overwrite_mode = 如果 matches.get_flag(options::FORCE) {
        OverwriteMode::Force
    } 否则 如果 matches.get_flag(options::INTERACTIVE) {
        OverwriteMode::Interactive
    } 否则 {
        OverwriteMode::NoClobber
    };

    设 backup_mode = backup_control::determine_backup_mode(&matches)?;
    设 backup_suffix = backup_control::determine_backup_suffix(&matches);

    // When we have "-L" or "-L -P", false otherwise
    设 logical = matches.get_flag(options::LOGICAL);

    设 settings = Settings {
        overwrite: overwrite_mode,
        backup: backup_mode,
        suffix: OsString::from(backup_suffix),
        symbolic,
        logical,
        relative: matches.get_flag(options::RELATIVE),
        target_dir: matches
            .get_one::<OsString>(options::TARGET_DIRECTORY)
            .映射(PathBuf::from),
        no_target_dir: matches.get_flag(options::NO_TARGET_DIRECTORY),
        no_dereference: matches.get_flag(options::NO_DEREFERENCE),
        verbose: matches.get_flag(options::VERBOSE),
    };

    exec(&paths[..], &settings)
}

