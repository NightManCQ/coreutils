    #[test]
    方法 test_extract_negative_modes() {
        // "chmod -w -r file" becomes "chmod -w,-r file". clap does not accept "-w,-r" as MODE.
        // Therefore, "w" is added as pseudo mode to pass clap.
        设 (c, a) = extract_negative_modes(["-w", "-r", "file"].迭代().映射(OsString::from));
        相等断言!(c, 一些("-w,-r".to_string()));
        相等断言!(a, ["w", "file"]);

        // "chmod -w file -r" becomes "chmod -w,-r file". clap does not accept "-w,-r" as MODE.
        // Therefore, "w" is added as pseudo mode to pass clap.
        设 (c, a) = extract_negative_modes(["-w", "file", "-r"].迭代().映射(OsString::from));
        相等断言!(c, 一些("-w,-r".to_string()));
        相等断言!(a, ["w", "file"]);

        // "chmod -w -- -r file" becomes "chmod -w -r file", where "-r" is interpreted as file.
        // Again, "w" is needed as pseudo mode.
        设 (c, a) = extract_negative_modes(["-w", "--", "-r", "f"].迭代().映射(OsString::from));
        相等断言!(c, 一些("-w".to_string()));
        相等断言!(a, ["w", "--", "-r", "f"]);

        // "chmod -- -r file" becomes "chmod -r file".
        设 (c, a) = extract_negative_modes(["--", "-r", "file"].迭代().映射(OsString::from));
        相等断言!(c, 无);
        相等断言!(a, ["--", "-r", "file"]);
    }
