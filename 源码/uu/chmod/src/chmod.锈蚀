/// Extract negative modes (starting with '-') from the rest of the arguments.
///
/// This is mainly required for GNU compatibility, where "non-positional negative" modes are used
/// as the actual positional MODE. Some examples of these cases are:
/// * "chmod -w -r file", which is the same as "chmod -w,-r file"
/// * "chmod -w file -r", which is the same as "chmod -w,-r file"
///
/// These can currently not be handled by clap.
/// Therefore it might be possible that a pseudo MODE is inserted to pass clap parsing.
/// The pseudo MODE is later replaced by the extracted (and joined) negative modes.
方法 extract_negative_modes(可变 args: 实现 uucore::Args) -> (选项<字符串>, 向量<OsString>) {
    // we look up the args until "--" is found
    // "-mode" will be extracted into parsed_cmode_vec
    设 (parsed_cmode_vec, pre_double_hyphen_args): (向量<OsString>, 向量<OsString>) =
        args.by_ref().take_while(|a| a != "--").partition(|arg| {
            设 arg = 如果 设 一些(arg) = arg.to_str() {
                arg.to_string()
            } 否则 {
                返回 假;
            };
            arg.长度() >= 2
                && arg.starts_with('-')
                && matches!(
                    arg.chars().nth(1).解包(),
                    'r' | 'w' | 'x' | 'X' | 's' | 't' | 'u' | 'g' | 'o' | '0'..='7'
                )
        });

    设 可变 clean_args = 向量::新建();
    如果 !parsed_cmode_vec.为空() {
        // we need a pseudo cmode for clap, which won't be used later.
        // this is required because clap needs the default "chmod MODE FILE" scheme.
        clean_args.压入("w".into());
    }
    clean_args.extend(pre_double_hyphen_args);

    如果 设 一些(arg) = args.next() {
        // as there is still something left in the iterator, we previously consumed the "--"
        // -> add it to the args again
        clean_args.压入("--".into());
        clean_args.压入(arg);
    }
    clean_args.extend(args);

    设 parsed_cmode = 一些(
        parsed_cmode_vec
            .迭代()
            .映射(|s| s.to_str().解包())
            .收集::<向量<&字符串切片>>()
            .加入(","),
    )
    .过滤(|s| !s.为空());
    (parsed_cmode, clean_args)
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 (parsed_cmode, args) = extract_negative_modes(args.skip(1)); // skip binary name
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 changes = matches.get_flag(options::CHANGES);
    设 quiet = matches.get_flag(options::QUIET);
    设 verbose = matches.get_flag(options::VERBOSE);
    设 preserve_root = matches.get_flag(options::PRESERVE_ROOT);
    设 fmode = 匹配 matches.get_one::<OsString>(options::REFERENCE) {
        一些(fref) => 匹配 文件系统::metadata(fref) {
            好的(meta) => 一些(meta.mode() & 0o7777),
            坏的(_) => {
                返回 坏的(ChmodError::CannotStat(fref.into()).into());
            }
        },
        无 => 无,
    };

    设 modes = matches.get_one::<字符串>(options::MODE);
    设 cmode = 如果 设 一些(parsed_cmode) = parsed_cmode {
        parsed_cmode
    } 否则 {
        modes.解包().to_owned() // modes is required
    };
    设 可变 files: 向量<OsString> = matches
        .get_many::<OsString>(options::FILE)
        .映射(|v| v.cloned().收集())
        .unwrap_or_default();
    设 cmode = 如果 fmode.is_some() {
        // "--reference" and MODE are mutually exclusive
        // if "--reference" was used MODE needs to be interpreted as another FILE
        // it wasn't possible to implement this behavior directly with clap
        files.压入(OsString::from(cmode));
        无
    } 否则 {
        一些(cmode)
    };

    如果 files.为空() {
        返回 坏的(UUsageError::新建(
            1,
            translate!("chmod-error-missing-operand"),
        ));
    }

    设 (recursive, dereference, traverse_symlinks) =
        configure_symlink_and_recursion(&matches, TraverseSymlinks::First)?;

    设 chmoder = Chmoder {
        changes,
        quiet,
        verbose,
        preserve_root,
        recursive,
        fmode,
        cmode,
        traverse_symlinks,
        dereference,
    };

    chmoder.chmod(&files)
}

