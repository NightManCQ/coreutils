结构 Chmoder {
    changes: 布尔,
    quiet: 布尔,
    verbose: 布尔,
    preserve_root: 布尔,
    recursive: 布尔,
    fmode: 选项<正32>,
    cmode: 选项<字符串>,
    traverse_symlinks: TraverseSymlinks,
    dereference: 布尔,
}

实现 Chmoder {
    /// Calculate the new mode based on the current mode and the chmod specification.
    /// Returns (`new_mode`, `naively_expected_new_mode`) for symbolic modes, or (`new_mode`, `new_mode`) for numeric/reference modes.
    方法 calculate_new_mode(&自身, current_mode: 正32, is_dir: 布尔) -> UResult<(正32, 正32)> {
        如果 设 一些(mode) = 自身.fmode {
            好的((mode, mode))
        } 否则 {
            设 cmode_unwrapped = 自身.cmode.克隆().解包();
            设 可变 new_mode = current_mode;
            设 可变 naively_expected_new_mode = current_mode;

            循环 mode 在 cmode_unwrapped.split(',') {
                设 result = 如果 mode.chars().任意(|c| c.is_ascii_digit()) {
                    mode::parse_numeric(new_mode, mode, is_dir).映射(|v| (v, v))
                } 否则 {
                    mode::parse_symbolic(new_mode, mode, mode::get_umask(), is_dir).映射(|m| {
                        // calculate the new mode as if umask was 0
                        设 naive_mode =
                            mode::parse_symbolic(naively_expected_new_mode, mode, 0, is_dir)
                                .解包(); // we know that mode must be valid, so this cannot fail
                        (m, naive_mode)
                    })
                };

                匹配 result {
                    好的((mode, naive_mode)) => {
                        new_mode = mode;
                        naively_expected_new_mode = naive_mode;
                    }
                    坏的(f) => {
                        返回 如果 自身.quiet {
                            坏的(ExitCode::新建(1))
                        } 否则 {
                            坏的(USimpleError::新建(1, f))
                        };
                    }
                }
            }
            好的((new_mode, naively_expected_new_mode))
        }
    }

    /// Report permission changes based on verbose and changes flags
    方法 report_permission_change(&自身, file_path: &Path, old_mode: 正32, new_mode: 正32) {
        如果 自身.verbose || 自身.changes {
            设 current_permissions = display_permissions_unix(old_mode, 假);
            设 new_permissions = display_permissions_unix(new_mode, 假);

            如果 new_mode != old_mode {
                打印行!(
                    "mode of {} changed from {old_mode:04o} ({current_permissions}) to {new_mode:04o} ({new_permissions})",
                    file_path.quote(),
                );
            } 否则 如果 自身.verbose {
                打印行!(
                    "mode of {} retained as {old_mode:04o} ({current_permissions})",
                    file_path.quote(),
                );
            }
        }
    }

    /// Handle symlinks during directory traversal based on traversal mode
    #[cfg(not(unix))]
    方法 handle_symlink_during_traversal(
        &自身,
        路径: &Path,
        is_command_line_arg: 布尔,
    ) -> UResult<()> {
        设 should_follow_symlink = 匹配 自身.traverse_symlinks {
            TraverseSymlinks::All => 真,
            TraverseSymlinks::First => is_command_line_arg,
            TraverseSymlinks::无 => 假,
        };

        如果 !should_follow_symlink {
            返回 自身.chmod_file_internal(路径, 假);
        }

        匹配 文件系统::metadata(路径) {
            好的(meta) 如果 meta.is_dir() => 自身.walk_dir_with_context(路径, 假),
            好的(_) => {
                // It's a file symlink, chmod it
                自身.chmod_file(路径)
            }
            坏的(_) => {
                // Dangling symlink, chmod it without dereferencing
                自身.chmod_file_internal(路径, 假)
            }
        }
    }

    方法 chmod(&自身, files: &[OsString]) -> UResult<()> {
        设 可变 r = 好的(());

        循环 filename 在 files {
            设 file = Path::新建(filename);
            如果 !file.exists() {
                如果 file.is_symlink() {
                    如果 !自身.dereference && !自身.recursive {
                        // The file is a symlink and we should not follow it
                        // Don't try to change the mode of the symlink itself
                        继续;
                    }
                    如果 自身.recursive && 自身.traverse_symlinks == TraverseSymlinks::无 {
                        继续;
                    }

                    如果 !自身.quiet {
                        show!(ChmodError::DanglingSymlink(filename.into()));
                        set_exit_code(1);
                    }

                    如果 自身.verbose {
                        打印行!(
                            "{}",
                            translate!("chmod-verbose-failed-dangling", "file" => filename.quote())
                        );
                    }
                } 否则 如果 !自身.quiet {
                    show!(ChmodError::NoSuchFile(filename.into()));
                }
                // GNU exits with exit code 1 even if -q or --quiet are passed
                // So we set the exit code, because it hasn't been set yet if `self.quiet` is true.
                set_exit_code(1);
                继续;
            } 否则 如果 !自身.dereference && file.is_symlink() {
                // The file is a symlink and we should not follow it
                // chmod 755 --no-dereference a/link
                // should not change the permissions in this case
                继续;
            }
            如果 自身.recursive && 自身.preserve_root && 自身类型::is_root(file) {
                返回 坏的(ChmodError::PreserveRoot("/".into()).into());
            }
            如果 自身.recursive {
                r = 自身.walk_dir_with_context(file, 真).and(r);
            } 否则 {
                r = 自身.chmod_file(file).and(r);
            }
        }
        r
    }

    方法 is_root(file: 实现 作为引用协议<Path>) -> 布尔 {
        matches!(文件系统::canonicalize(&file), 好的(p) 如果 p == Path::新建("/"))
    }

    // Non-safe traversal implementation for platforms without safe_traversal support
    #[cfg(任意(not(unix), target_os = "redox"))]
    方法 walk_dir_with_context(&自身, file_path: &Path, is_command_line_arg: 布尔) -> UResult<()> {
        设 可变 r = 自身.chmod_file(file_path);

        // Determine whether to traverse symlinks based on context and traversal mode
        设 should_follow_symlink = 匹配 自身.traverse_symlinks {
            TraverseSymlinks::All => 真,
            TraverseSymlinks::First => is_command_line_arg, // Only follow symlinks that are command line args
            TraverseSymlinks::无 => 假,
        };

        // If the path is a directory (or we should follow symlinks), recurse into it
        如果 (!file_path.is_symlink() || should_follow_symlink) && file_path.is_dir() {
            // We buffer all paths in this dir to not keep too many fd's open during recursion
            设 可变 paths_in_this_dir = 向量::新建();

            循环 dir_entry 在 file_path.read_dir()? {
                匹配 dir_entry {
                    好的(entry) => paths_in_this_dir.压入(entry.路径()),
                    坏的(err) => {
                        r = r.and(坏的(err.into()));
                        继续;
                    }
                }
            }
            循环 路径 在 paths_in_this_dir {
                #[cfg(not(unix))]
                {
                    如果 路径.is_symlink() {
                        r = 自身.handle_symlink_during_recursion(&路径).and(r);
                    } 否则 {
                        r = 自身.walk_dir_with_context(路径.as_path(), 假).and(r);
                    }
                }
                #[cfg(target_os = "redox")]
                {
                    r = 自身.walk_dir_with_context(路径.as_path(), 假).and(r);
                }
            }
        }
        r
    }

    #[cfg(全部(unix, not(target_os = "redox")))]
    方法 walk_dir_with_context(&自身, file_path: &Path, is_command_line_arg: 布尔) -> UResult<()> {
        设 可变 r = 自身.chmod_file(file_path);

        // Determine whether to traverse symlinks based on context and traversal mode
        设 should_follow_symlink = 匹配 自身.traverse_symlinks {
            TraverseSymlinks::All => 真,
            TraverseSymlinks::First => is_command_line_arg, // Only follow symlinks that are command line args
            TraverseSymlinks::无 => 假,
        };

        // If the path is a directory (or we should follow symlinks), recurse into it using safe traversal
        如果 (!file_path.is_symlink() || should_follow_symlink) && file_path.is_dir() {
            匹配 DirFd::open(file_path, SymlinkBehavior::Follow) {
                好的(dir_fd) => {
                    r = 自身.safe_traverse_dir(&dir_fd, file_path).and(r);
                }
                坏的(err) => {
                    // Handle permission denied errors with proper file path context
                    如果 err.kind() == 标准库::输入输出::ErrorKind::PermissionDenied {
                        r = r.and(坏的(ChmodError::PermissionDenied(file_path.into()).into()));
                    } 否则 {
                        r = r.and(坏的(err.into()));
                    }
                }
            }
        }
        r
    }

    #[cfg(全部(unix, not(target_os = "redox")))]
    方法 safe_traverse_dir(&自身, dir_fd: &DirFd, dir_path: &Path) -> UResult<()> {
        设 可变 r = 好的(());

        设 entries = dir_fd.read_dir()?;

        // Determine if we should follow symlinks (doesn't depend on entry_name)
        设 should_follow_symlink = 自身.traverse_symlinks == TraverseSymlinks::All;

        循环 entry_name 在 entries {
            设 entry_path = dir_path.加入(&entry_name);

            设 dir_meta = dir_fd.metadata_at(&entry_name, should_follow_symlink.into());
            设 好的(meta) = dir_meta 否则 {
                // Handle permission denied with proper file path context
                设 e = dir_meta.unwrap_err();
                设 错误 = 如果 e.kind() == 标准库::输入输出::ErrorKind::PermissionDenied {
                    ChmodError::PermissionDenied(entry_path).into()
                } 否则 {
                    e.into()
                };
                r = r.and(坏的(错误));
                继续;
            };

            如果 entry_path.is_symlink() {
                r = 自身
                    .handle_symlink_during_safe_recursion(&entry_path, dir_fd, &entry_name)
                    .and(r);
            } 否则 {
                // For regular files and directories, chmod them
                r = 自身
                    .safe_chmod_file(&entry_path, dir_fd, &entry_name, meta.mode() & 0o7777)
                    .and(r);

                // Recurse into subdirectories using the existing directory fd
                如果 meta.is_dir() {
                    匹配 dir_fd.open_subdir(&entry_name, SymlinkBehavior::Follow) {
                        好的(child_dir_fd) => {
                            r = 自身.safe_traverse_dir(&child_dir_fd, &entry_path).and(r);
                        }
                        坏的(err) => {
                            设 错误 = 如果 err.kind() == 标准库::输入输出::ErrorKind::PermissionDenied {
                                ChmodError::PermissionDenied(entry_path).into()
                            } 否则 {
                                err.into()
                            };
                            r = r.and(坏的(错误));
                        }
                    }
                }
            }
        }
        r
    }

    #[cfg(全部(unix, not(target_os = "redox")))]
    方法 handle_symlink_during_safe_recursion(
        &自身,
        路径: &Path,
        dir_fd: &DirFd,
        entry_name: &标准库::ffi::OsStr,
    ) -> UResult<()> {
        // During recursion, determine behavior based on traversal mode
        匹配 自身.traverse_symlinks {
            TraverseSymlinks::All => {
                // Follow all symlinks during recursion
                // Check if the symlink target is a directory, but handle dangling symlinks gracefully
                匹配 文件系统::metadata(路径) {
                    好的(meta) 如果 meta.is_dir() => 自身.walk_dir_with_context(路径, 假),
                    好的(meta) => {
                        // It's a file symlink, chmod it using safe traversal
                        自身.safe_chmod_file(路径, dir_fd, entry_name, meta.mode() & 0o7777)
                    }
                    坏的(_) => {
                        // Dangling symlink, chmod it without dereferencing
                        自身.chmod_file_internal(路径, 假)
                    }
                }
            }
            TraverseSymlinks::First | TraverseSymlinks::无 => {
                // Don't follow symlinks encountered during recursion
                // For these symlinks, don't dereference them even if dereference is normally true
                自身.chmod_file_internal(路径, 假)
            }
        }
    }

    #[cfg(全部(unix, not(target_os = "redox")))]
    方法 safe_chmod_file(
        &自身,
        file_path: &Path,
        dir_fd: &DirFd,
        entry_name: &标准库::ffi::OsStr,
        current_mode: 正32,
    ) -> UResult<()> {
        // Calculate the new mode using the helper method
        设 (new_mode, _) = 自身.calculate_new_mode(current_mode, file_path.is_dir())?;

        // Use safe traversal to change the mode
        设 follow_symlinks = 自身.dereference;
        如果 设 坏的(_e) = dir_fd.chmod_at(entry_name, new_mode, follow_symlinks.into()) {
            如果 自身.verbose {
                打印行!(
                    "failed to change mode of {} to {new_mode:o}",
                    file_path.quote(),
                );
            }
            返回 坏的(ChmodError::PermissionDenied(file_path.into()).into());
        }

        // Report the change using the helper method
        自身.report_permission_change(file_path, current_mode, new_mode);

        好的(())
    }

    #[cfg(not(unix))]
    方法 handle_symlink_during_recursion(&自身, 路径: &Path) -> UResult<()> {
        // Use the common symlink handling logic
        自身.handle_symlink_during_traversal(路径, 假)
    }

    方法 chmod_file(&自身, file: &Path) -> UResult<()> {
        自身.chmod_file_internal(file, 自身.dereference)
    }

    方法 chmod_file_internal(&自身, file: &Path, dereference: 布尔) -> UResult<()> {
        使用 uucore::perms::get_metadata;

        设 metadata = get_metadata(file, dereference);

        设 fperm = 匹配 metadata {
            好的(meta) => meta.mode() & 0o7777,
            坏的(err) => {
                // Handle dangling symlinks or other errors
                返回 如果 file.is_symlink() && !dereference {
                    如果 自身.verbose {
                        打印行!(
                            "neither symbolic link {} nor referent has been changed",
                            file.quote()
                        );
                    }
                    好的(()) // Skip dangling symlinks
                } 否则 如果 err.kind() == 标准库::输入输出::ErrorKind::PermissionDenied {
                    坏的(ChmodError::PermissionDenied(file.into()).into())
                } 否则 {
                    坏的(ChmodError::CannotStat(file.into()).into())
                };
            }
        };

        // Calculate the new mode using the helper method
        设 (new_mode, naively_expected_new_mode) =
            自身.calculate_new_mode(fperm, file.is_dir())?;

        // Determine how to apply the permissions
        如果 设 一些(mode) = 自身.fmode {
            自身.change_file(fperm, mode, file)?;
        } 否则 {
            // Special handling for symlinks when not dereferencing
            如果 file.is_symlink() && !dereference {
                // TODO: On most Unix systems, symlink permissions are ignored by the kernel,
                // so changing them has no effect. We skip this operation for compatibility.
                // Note that "chmod without dereferencing" effectively does nothing on symlinks.
                如果 自身.verbose {
                    打印行!(
                        "neither symbolic link {} nor referent has been changed",
                        file.quote()
                    );
                }
            } 否则 {
                自身.change_file(fperm, new_mode, file)?;
            }
            // if a permission would have been removed if umask was 0, but it wasn't because umask was not 0, print an error and fail
            如果 (new_mode & !naively_expected_new_mode) != 0 {
                返回 坏的(ChmodError::NewPermissions(
                    file.into(),
                    display_permissions_unix(new_mode, 假),
                    display_permissions_unix(naively_expected_new_mode, 假),
                )
                .into());
            }
        }

        好的(())
    }

    方法 change_file(&自身, fperm: 正32, mode: 正32, file: &Path) -> 结果<(), 整32> {
        如果 fperm == mode {
            // Use the helper method for consistent reporting
            自身.report_permission_change(file, fperm, mode);
            好的(())
        } 否则 如果 设 坏的(err) = 文件系统::set_permissions(file, 文件系统::Permissions::from_mode(mode)) {
            如果 !自身.quiet {
                show_error!("{err}");
            }
            如果 自身.verbose {
                打印行!(
                    "failed to change mode of file {} from {fperm:04o} ({}) to {mode:04o} ({})",
                    file.quote(),
                    display_permissions_unix(fperm, 假),
                    display_permissions_unix(mode, 假)
                );
            }
            坏的(1)
        } 否则 {
            // Use the helper method for consistent reporting
            自身.report_permission_change(file, fperm, mode);
            好的(())
        }
    }
}

