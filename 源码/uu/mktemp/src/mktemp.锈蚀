    ) -> 结果<自身类型::Value, clap::错误协议> {
        如果 value.为空() {
            好的(无)
        } 否则 {
            好的(一些(PathBuf::from(value)))
        }
    }
}

实现 ValueParserFactory 循环 OptionalPathBufParser {
