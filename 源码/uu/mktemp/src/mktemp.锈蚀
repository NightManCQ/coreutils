}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 args: 向量<_> = args.收集();
    设 matches = 匹配 uu_app().try_get_matches_from(&args) {
        好的(m) => m,
        坏的(e) => {
            使用 uucore::clap_localization::handle_clap_error_with_exit_code;
            如果 e.kind() == clap::错误::ErrorKind::UnknownArgument {
                handle_clap_error_with_exit_code(e, 1);
            }
            如果 e.kind() == clap::错误::ErrorKind::TooManyValues
                && e.context().任意(|(kind, val)| {
                    kind == clap::错误::ContextKind::InvalidArg
                        && val == &clap::错误::ContextValue::字符串("[template]".into())
                })
            {
                返回 坏的(UUsageError::新建(
                    1,
                    translate!("mktemp-error-too-many-templates"),
                ));
            }
            返回 坏的(e.into());
        }
    };

    // Parse command-line options into a format suitable for the
    // application logic.
    设 options = Options::from(&matches);

    如果 环境::var_os("POSIXLY_CORRECT").is_some() {
        // If POSIXLY_CORRECT was set, template MUST be the last argument.
        如果 matches.contains_id(ARG_TEMPLATE) {
            // Template argument was provided, check if was the last one.
            如果 args.最后().解包() != &options.template {
                返回 坏的(盒子::新建(MkTempError::TooManyTemplates));
            }
        }
    }

    设 dry_run = options.dry_run;
    设 suppress_file_err = options.quiet;
    设 make_dir = options.directory;

    // Parse file path parameters from the command-line options.
    设 Params {
        directory: tmpdir,
        prefix,
        num_rand_chars: rand,
        suffix,
    } = Params::from(options)?;

    // Create the temporary file or directory, or simulate creating it.
    设 res = 如果 dry_run {
        好的(dry_exec(&tmpdir, &prefix, rand, &suffix))
    } 否则 {
        exec(&tmpdir, &prefix, rand, &suffix, make_dir)
    };

    设 res = 如果 suppress_file_err {
        // Mapping all UErrors to ExitCodes prevents the errors from being printed
        res.map_err(|e| e.code().into())
    } 否则 {
        res
    };
    println_verbatim(res?).map_err_context(|| translate!("mktemp-error-failed-print"))
}

