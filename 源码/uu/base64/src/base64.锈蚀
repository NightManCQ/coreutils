#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 config = base_common::parse_base_cmd_args(args, uu_app())?;
    设 可变 input = base_common::get_input(&config)?;
    base_common::handle_input(&可变 input, Format::Base64, config)
}

公有 方法 uu_app() -> Command {
    base_common::base_app(translate!("base64-about"), translate!("base64-usage")).name("base64")
}
