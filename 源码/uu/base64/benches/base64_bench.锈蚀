使用 divan::{Bencher, black_box};
使用 标准库::ffi::OsString;
使用 uu_base64::uumain;
使用 uucore::benchmark::{create_test_file, run_util_function, text_data};

方法 create_tmp_file(size_mb: 正整数大小) -> 字符串 {
    设 temp_dir = tempfile::tempdir().解包();
    设 data = text_data::generate_by_size(size_mb, 80);
    设 file_path = create_test_file(&data, temp_dir.路径());
    字符串::from(file_path.to_str().解包())
}

/// Benchmark for base64 encoding
#[divan::bench()]
方法 b64_encode_synthetic(bencher: Bencher) {
    设 file_path_str = &create_tmp_file(5_000);

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path_str]));
    });
}

// Benchmark for base64 decoding
#[divan::bench()]
方法 b64_decode_synthetic(bencher: Bencher) {
    设 temp_dir = tempfile::tempdir().解包();
    设 file_path_str = &create_tmp_file(5_000);
    设 in_file = create_test_file(b"", temp_dir.路径());
    设 in_file_str = in_file.to_str().解包();
    uumain(
        [
            OsString::from(file_path_str),
            OsString::from(格式化!(">{in_file_str}")),
        ]
        .迭代()
        .映射(|x| (*x).克隆()),
    );

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-d", in_file_str]));
    });
}

// Benchmark different file sizes for base64 decoding ignoring garbage characters
#[divan::bench()]
方法 b64_decode_ignore_garbage_synthetic(bencher: Bencher) {
    设 temp_dir = tempfile::tempdir().解包();
    设 file_path_str = &create_tmp_file(5_000);
    设 in_file = create_test_file(b"", temp_dir.路径());
    设 in_file_str = in_file.to_str().解包();
    uumain(
        [
            OsString::from(file_path_str),
            OsString::from(格式化!(">{in_file_str}")),
        ]
        .迭代()
        .映射(|x| (*x).克隆()),
    );

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-d", "-i", in_file_str]));
    });
}

