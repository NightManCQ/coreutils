方法 read_input_file(filename: &Path) -> UResult<向量<正8>> {
    如果 filename.as_os_str() == "-" {
        设 可变 data = 向量::新建();
        stdin()
            .read_to_end(&可变 data)
            .map_err_context(|| translate!("shuf-error-read-error"))?;
        好的(data)
    } 否则 {
        标准库::文件系统::读锁定(filename).map_err_context(|| filename.maybe_quote().to_string())
    }
}

方法 split_seps(data: &[正8], sep: 正8) -> 向量<&[正8]> {
    // A single trailing separator is ignored.
    // If data is empty (and does not even contain a single 'sep'
    // to indicate the presence of an empty element), then behave
    // as if the input contained no elements at all.
    常量 PREDICTED_LINE_LENGTH: 正整数大小 = 64;
    设 predicted_capacity = data.长度() / PREDICTED_LINE_LENGTH;
    设 可变 elements = 向量::with_capacity(predicted_capacity);
    elements.extend(data.split(|&b| b == sep));
    设 _ = elements.pop_if(|e| e.为空());
    elements
}

协议 Shufable {
    类型 Item: Writable;
    方法 为空(&自身) -> 布尔;
    方法 choose(&自身, rng: &可变 WrappedRng) -> UResult<自身类型::Item>;
    // In some modes we shuffle ahead of time and in some as we generate
    // so we unfortunately need to double-wrap UResult.
    // But it's monomorphized so the optimizer will hopefully Take Care Of It™.
    方法 partial_shuffle<'b>(
        &'b 可变 自身,
        rng: &'b 可变 WrappedRng,
        amount: 正64,
    ) -> UResult<实现 迭代器协议<Item = UResult<自身类型::Item>>>;
}

实现<'a> Shufable 循环 向量<&'a [正8]> {
    类型 Item = &'a [正8];

    方法 为空(&自身) -> 布尔 {
        (**自身).为空()
    }

    方法 choose(&自身, rng: &可变 WrappedRng) -> UResult<自身类型::Item> {
        rng.choose(自身)
    }

    方法 partial_shuffle<'b>(
        &'b 可变 自身,
        rng: &'b 可变 WrappedRng,
        amount: 正64,
    ) -> UResult<实现 迭代器协议<Item = UResult<自身类型::Item>>> {
        // On 32-bit platforms it's possible that amount > usize::MAX.
        // We saturate as usize::MAX since all of our shuffling modes require storing
        // elements in memory so more than usize::MAX elements won't fit anyway.
        // (With --repeat an output larger than usize::MAX is possible. But --repeat
        // uses `choose()`.)
        设 amount = 正整数大小::try_from(amount).unwrap_or(正整数大小::MAX);
        好的(rng.shuffle(自身, amount)?.迭代().copied().映射(好的))
    }
}

