#[cold]
#[inline(never)]
方法 handle_write_error(e: 输入输出::错误协议) -> 盒子<动态 uucore::错误::UError> {
    使用 uucore::错误::FromIo;
    设 ctx = translate!("shuf-error-write-failed");
    e.map_err_context(移动 || ctx)
}

方法 shuf_exec(
    input: &可变 实现 Shufable,
    opts: &Options,
    rng: &可变 WrappedRng,
    output: &可变 BufWriter<盒子<动态 OsWrite>>,
) -> UResult<()> {
    设 sep = [opts.sep];
    如果 opts.repeat {
        如果 input.为空() {
            返回 坏的(USimpleError::新建(
                1,
                translate!("shuf-error-no-lines-to-repeat"),
            ));
        }
        循环 _ 在 0..opts.head_count {
            设 r = input.choose(rng)?;
            r.write_all_to(output).map_err(handle_write_error)?;
            output.write_all(&sep).map_err(handle_write_error)?;
        }
    } 否则 {
        设 shuffled = input.partial_shuffle(rng, opts.head_count)?;

        循环 r 在 shuffled {
            设 r = r?;
            r.write_all_to(output).map_err(handle_write_error)?;
            output.write_all(&sep).map_err(handle_write_error)?;
        }
    }
    output.flush().map_err(handle_write_error)?;

    好的(())
}

方法 parse_range(input_range: &字符串切片) -> 结果<RangeInclusive<正64>, 字符串> {
    如果 设 一些((from, to)) = input_range.split_once('-') {
        设 begin = from.parse::<正64>().map_err(|e| e.to_string())?;
        设 end = to.parse::<正64>().map_err(|e| e.to_string())?;
        如果 begin <= end || begin == end + 1 {
            好的(begin..=end)
        } 否则 {
            坏的(translate!("shuf-error-start-exceeds-end"))
        }
    } 否则 {
        坏的(translate!("shuf-error-missing-dash"))
    }
}

枚举 WrappedRng {
    默认协议(ThreadRng),
    Seed(SeededRng),
    File(RandomSourceAdapter<BufReader<File>>),
}

实现 WrappedRng {
    方法 choose<T: 复制协议>(&可变 自身, vals: &[T]) -> UResult<T> {
        匹配 自身 {
            自身类型::默认协议(rng) => 好的(*vals.choose(rng).解包()),
            自身类型::Seed(rng) => 好的(rng.choose_from_slice(vals)),
            自身类型::File(rng) => rng.choose_from_slice(vals),
        }
    }

    方法 shuffle<'a, T>(&可变 自身, vals: &'a 可变 [T], amount: 正整数大小) -> UResult<&'a 可变 [T]> {
        匹配 自身 {
            自身类型::默认协议(rng) => 好的(vals.partial_shuffle(rng, amount).0),
            自身类型::Seed(rng) => 好的(rng.shuffle(vals, amount)),
            自身类型::File(rng) => rng.shuffle(vals, amount),
        }
    }

    方法 choose_from_range(&可变 自身, range: RangeInclusive<正64>) -> UResult<正64> {
        匹配 自身 {
            自身类型::默认协议(rng) => 好的(rng.random_range(range)),
            自身类型::Seed(rng) => 好的(rng.choose_from_range(range)),
            自身类型::File(rng) => rng.choose_from_range(range),
        }
    }
}

#[cfg(test)]
模组 test_split_seps {
    使用 超级::split_seps;

    #[test]
    方法 test_empty_input() {
        断言!(split_seps(b"", b'\n').为空());
    }

    #[test]
