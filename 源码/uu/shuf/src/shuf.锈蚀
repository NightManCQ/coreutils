#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 mode = 如果 matches.get_flag(options::ECHO) {
        Mode::Echo(
            matches
                .get_many(options::FILE_OR_ARGS)
                .unwrap_or_default()
                .cloned()
                .收集(),
        )
    } 否则 如果 设 一些(range) = matches.get_one(options::INPUT_RANGE).cloned() {
        Mode::InputRange(range)
    } 否则 {
        设 可变 operands = matches
            .get_many::<OsString>(options::FILE_OR_ARGS)
            .unwrap_or_default();
        设 file = operands.next().cloned().unwrap_or("-".into());
        如果 设 一些(second_file) = operands.next() {
            返回 坏的(UUsageError::新建(
                1,
                translate!("shuf-error-unexpected-argument", "arg" => second_file.quote()),
            ));
        }
        Mode::默认协议(file.into())
    };

    设 random_source = 如果 设 一些(filename) = matches.get_one(options::RANDOM_SOURCE).cloned() {
        RandomSource::File(filename)
    } 否则 如果 设 一些(seed) = matches.get_one(options::RANDOM_SEED).cloned() {
        RandomSource::Seed(seed)
    } 否则 {
        RandomSource::无
    };

    设 options = Options {
        // GNU shuf takes the lowest value passed, so we imitate that.
        // It's probably a bug or an implementation artifact though.
        // Busybox takes the final value which is more typical: later
        // options override earlier options.
        head_count: matches
            .get_many::<正64>(options::HEAD_COUNT)
            .unwrap_or_default()
            .copied()
            .min()
            .unwrap_or(正64::MAX),
        output: matches.get_one(options::OUTPUT).cloned(),
        random_source,
        repeat: matches.get_flag(options::REPEAT),
        sep: 如果 matches.get_flag(options::ZERO_TERMINATED) {
            b'\0'
        } 否则 {
            b'\n'
        },
    };

    设 可变 output = BufWriter::with_capacity(
        BUF_SIZE,
        匹配 options.output {
            无 => 盒子::新建(stdout()) 转换 盒子<动态 OsWrite>,
            一些(引用 s) => {
                设 file = File::create(s).map_err_context(
                    || translate!("shuf-error-failed-to-open-for-writing", "file" => s.quote()),
                )?;
                盒子::新建(file) 转换 盒子<动态 OsWrite>
            }
        },
    );

    如果 options.head_count == 0 {
        // In this case we do want to touch the output file but we can quit immediately.
        返回 好的(());
    }

    设 可变 rng = 匹配 options.random_source {
        RandomSource::无 => WrappedRng::默认协议(rand::rng()),
        RandomSource::Seed(引用 seed) => WrappedRng::Seed(SeededRng::新建(seed)),
        RandomSource::File(引用 r) => {
            设 file = File::open(r).map_err_context(
                || translate!("shuf-error-failed-to-open-random-source", "file" => r.quote()),
            )?;
            设 file = BufReader::新建(file);
            WrappedRng::File(RandomSourceAdapter::新建(file))
        }
    };

    匹配 mode {
        Mode::Echo(args) => {
            设 可变 evec: 向量<&OsStr> = args.迭代().映射(作为引用协议::as_ref).收集();
            shuf_exec(&可变 evec, &options, &可变 rng, &可变 output)?;
        }
        Mode::InputRange(可变 range) => {
            shuf_exec(&可变 range, &options, &可变 rng, &可变 output)?;
        }
        Mode::默认协议(filename) => {
            设 fdata = read_input_file(&filename)?;
            设 可变 items = split_seps(&fdata, options.sep);
            shuf_exec(&可变 items, &options, &可变 rng, &可变 output)?;
        }
    }

    好的(())
}

