使用 divan::{Bencher, black_box};
使用 uu_shuf::uumain;
使用 uucore::benchmark::{run_util_function, setup_test_file, text_data};

/// Benchmark shuffling lines from a file
/// Tests the default mode with a large number of lines
#[divan::bench(args = [100_000])]
方法 shuf_lines(bencher: Bencher, num_lines: 正整数大小) {
    设 data = text_data::generate_by_lines(num_lines, 80);
    设 file_path = setup_test_file(&data);
    设 file_path_str = file_path.to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(uumain, &[file_path_str]));
    });
}

/// Benchmark shuffling a numeric range with -i
/// Tests the input-range mode which uses a different algorithm
#[divan::bench(args = [1_000_000])]
方法 shuf_input_range(bencher: Bencher, range_size: 正整数大小) {
    设 range_arg = 格式化!("1-{range_size}");

    bencher.bench(|| {
        black_box(run_util_function(uumain, &["-i", &range_arg]));
    });
}

/// Benchmark shuffling with repeat (sampling with replacement)
/// Tests the -r flag combined with -n to output a specific count
#[divan::bench(args = [50_000])]
方法 shuf_repeat_sampling(bencher: Bencher, num_lines: 正整数大小) {
    设 data = text_data::generate_by_lines(10_000, 80);
    设 file_path = setup_test_file(&data);
    设 file_path_str = file_path.to_str().解包();
    设 计数 = 格式化!("{num_lines}");

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-r", "-n", &计数, file_path_str],
        ));
    });
}

方法 主函数() {
    divan::主函数();
}
