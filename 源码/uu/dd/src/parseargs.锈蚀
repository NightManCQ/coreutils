/// Return an Unimplemented error when the target is not Linux or Android
macro_rules! linux_only {
    ($s: expr, $val: expr) => {
        如果 cfg!(任意(target_os = "linux", target_os = "android")) {
            $val
        } 否则 {
            返回 坏的(ParseError::Unimplemented($s.to_string()).into());
        }
    };
}

实现 Parser {
    公有(箱) 方法 新建() -> 自身类型 {
