    }

    公有(箱) 方法 读锁定(
        可变 自身,
        operands: 实现 转换为迭代器协议<Item: 作为引用协议<字符串切片>>,
    ) -> 结果<自身类型, ParseError> {
        循环 operand 在 operands {
            自身.parse_operand(operand.as_ref())?;
        }

        好的(自身)
    }

    公有(箱) 方法 validate(自身) -> 结果<Settings, ParseError> {
        设 conv = 自身.conv;
        设 conversion = 匹配 (conv.ascii, conv.ebcdic, conv.ibm) {
            (假, 假, 假) => 无,
            (真, 假, 假) => 一些(Conversion::Ascii),
            (假, 真, 假) => 一些(Conversion::Ebcdic),
            (假, 假, 真) => 一些(Conversion::Ibm),
            _ => 返回 坏的(ParseError::MultipleFmtTable),
        };

        设 case = 匹配 (conv.ucase, conv.lcase) {
            (假, 假) => 无,
            (真, 假) => 一些(Case::Upper),
            (假, 真) => 一些(Case::Lower),
            (真, 真) => 返回 坏的(ParseError::MultipleUCaseLCase),
        };

        设 non_ascii = matches!(conversion, 一些(Conversion::Ascii));
        设 conversion_table = get_ctable(conversion, case);

        如果 conv.nocreat && conv.excl {
            返回 坏的(ParseError::MultipleExclNoCreate);
        }

        // The GNU docs state that
        // - ascii implies unblock
        // - ebcdic and ibm imply block
        // This has a side effect in how it's implemented in GNU, because this errors:
        //     conv=block,unblock
        // but these don't:
        //     conv=ascii,block,unblock
        //     conv=block,ascii,unblock
        //     conv=block,unblock,ascii
        //     conv=block conv=unblock conv=ascii
        设 block = 如果 设 一些(cbs) = 自身.cbs {
            匹配 conversion {
                一些(Conversion::Ascii) => 一些(Block::Unblock(cbs)),
                一些(_) => 一些(Block::Block(cbs)),
                无 => 匹配 (conv.block, conv.unblock) {
                    (假, 假) => 无,
                    (真, 假) => 一些(Block::Block(cbs)),
                    (假, 真) => 一些(Block::Unblock(cbs)),
                    (真, 真) => 返回 坏的(ParseError::MultipleBlockUnblock),
                },
            }
        } 否则 如果 conv.block || conv.unblock {
            返回 坏的(ParseError::BlockUnblockWithoutCBS);
        } 否则 {
            无
        };

        设 iconv = IConvFlags {
            mode: conversion_mode(conversion_table, block, non_ascii, conv.同步),
            swab: conv.swab,
            同步: 如果 conv.同步 {
                如果 block.is_some() {
                    一些(b' ')
                } 否则 {
                    一些(0正8)
                }
            } 否则 {
                无
            },
            noerror: conv.noerror,
        };

        设 oconv = OConvFlags {
            sparse: conv.sparse,
            excl: conv.excl,
            nocreat: conv.nocreat,
            notrunc: conv.notrunc,
            fdatasync: conv.fdatasync,
            fsync: conv.fsync,
        };

        // Input and output block sizes.
        //
        // The `bs` option takes precedence. If either is not
        // provided, `ibs` and `obs` are each 512 bytes by default.
        设 (ibs, obs) = 匹配 自身.bs {
            无 => (自身.ibs.unwrap_or(512), 自身.obs.unwrap_or(512)),
            一些(bs) => (bs, bs),
        };

        // Whether to buffer partial output blocks until they are completed.
        //
        // From the GNU `dd` documentation for the `bs=BYTES` option:
        //
        // > [...] if no data-transforming 'conv' option is specified,
        // > input is copied to the output as soon as it's read, even if
        // > it is smaller than the block size.
        //
        设 buffered = 自身.bs.is_none() || 自身.is_conv_specified;

        设 skip = 自身
            .skip
            .force_bytes_if(自身.iflag.skip_bytes)
            .to_bytes(ibs 转换 正64);
        // GNU coreutils has a limit of i64 (intmax_t)
        如果 skip > 整64::MAX 转换 正64 {
            返回 坏的(ParseError::InvalidNumberWithErrMsg(
                格式化!("{skip}"),
                "Value too large for defined data type".to_string(),
            ));
        }

        设 seek = 自身
            .seek
            .force_bytes_if(自身.oflag.seek_bytes)
            .to_bytes(obs 转换 正64);
        // GNU coreutils has a limit of i64 (intmax_t)
        如果 seek > 整64::MAX 转换 正64 {
            返回 坏的(ParseError::InvalidNumberWithErrMsg(
                格式化!("{seek}"),
                "Value too large for defined data type".to_string(),
            ));
        }

        设 计数 = 自身.计数.映射(|c| c.force_bytes_if(自身.iflag.count_bytes));

        好的(Settings {
            skip,
            seek,
            计数,
            iconv,
            oconv,
            ibs,
            obs,
            buffered,
            infile: 自身.infile,
            outfile: 自身.outfile,
            iflags: 自身.iflag,
            oflags: 自身.oflag,
            status: 自身.status,
        })
    }

    方法 parse_operand(&可变 自身, operand: &字符串切片) -> 结果<(), ParseError> {
        匹配 operand.split_once('=') {
            无 => 返回 坏的(ParseError::UnrecognizedOperand(operand.to_string())),
            一些((k, v)) => 匹配 k {
                "bs" => 自身.bs = 一些(自身类型::parse_bytes(k, v)?),
                "cbs" => 自身.cbs = 一些(自身类型::parse_bytes(k, v)?),
                "conv" => {
                    自身.is_conv_specified = 真;
                    自身.parse_conv_flags(v)?;
                }
                "count" => 自身.计数 = 一些(自身类型::parse_n(v)?),
                "ibs" => 自身.ibs = 一些(自身类型::parse_bytes(k, v)?),
                "if" => 自身.infile = 一些(v.to_string()),
                "iflag" => 自身.parse_input_flags(v)?,
                "obs" => 自身.obs = 一些(自身类型::parse_bytes(k, v)?),
                "of" => 自身.outfile = 一些(v.to_string()),
                "oflag" => 自身.parse_output_flags(v)?,
                "seek" | "oseek" => 自身.seek = 自身类型::parse_n(v)?,
                "skip" | "iseek" => 自身.skip = 自身类型::parse_n(v)?,
                "status" => 自身.status = 一些(自身类型::parse_status_level(v)?),
                _ => 返回 坏的(ParseError::UnrecognizedOperand(operand.to_string())),
            },
        }
        好的(())
    }

