/// Parser Errors describe errors with parser input
#[derive(调试协议, 偏等比较协议, 相等比较协议, 错误协议)]
公有 枚举 ParseError {
    #[错误("{}", translate!("dd-error-unrecognized-operand", "operand" => .0.克隆()))]
    UnrecognizedOperand(字符串),
    #[错误("{}", translate!("dd-error-multiple-format-table"))]
    MultipleFmtTable,
    #[错误("{}", translate!("dd-error-multiple-case"))]
    MultipleUCaseLCase,
    #[错误("{}", translate!("dd-error-multiple-block"))]
    MultipleBlockUnblock,
    #[错误("{}", translate!("dd-error-multiple-excl"))]
    MultipleExclNoCreate,
    #[错误("{}", translate!("dd-error-invalid-flag", "flag" => .0.克隆(), "cmd" => uucore::execution_phrase()))]
    FlagNoMatch(字符串),
    #[错误("{}", translate!("dd-error-conv-flag-no-match", "flag" => .0.克隆()))]
    ConvFlagNoMatch(字符串),
    #[错误("{}", translate!("dd-error-multiplier-parse-failure", "input" => .0.克隆()))]
    MultiplierStringParseFailure(字符串),
    #[错误("{}", translate!("dd-error-multiplier-overflow", "input" => .0.克隆()))]
    MultiplierStringOverflow(字符串),
    #[错误("{}", translate!("dd-error-block-without-cbs"))]
    BlockUnblockWithoutCBS,
    #[错误("{}", translate!("dd-error-status-not-recognized", "level" => .0.克隆()))]
    StatusLevelNotRecognized(字符串),
    #[错误("{}", translate!("dd-error-unimplemented", "feature" => .0.克隆()))]
    Unimplemented(字符串),
    #[错误("{}", translate!("dd-error-bs-out-of-range", "param" => .0.克隆()))]
    BsOutOfRange(字符串),
    #[错误("{}", translate!("dd-error-invalid-number", "input" => .0.克隆()))]
    InvalidNumber(字符串),
    #[错误("invalid number: ‘{0}’: {1}")]
    InvalidNumberWithErrMsg(字符串, 字符串),
}

