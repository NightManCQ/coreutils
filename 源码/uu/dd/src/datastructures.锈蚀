使用 箱::conversion_tables::ConversionTable;

类型 Cbs = 正整数大小;

/// How to apply conversion, blocking, and/or unblocking.
///
/// Certain settings of the `conv` parameter to `dd` require a
/// combination of conversion, blocking, or unblocking, applied in a
/// certain order. The variants of this enumeration give the different
/// ways of combining those three operations.
#[derive(调试协议, 偏等比较协议)]
公有(箱) 枚举 ConversionMode {
    ConvertOnly(&'静态 ConversionTable),
    BlockOnly(Cbs, 布尔),
    UnblockOnly(Cbs),
    BlockThenConvert(&'静态 ConversionTable, Cbs, 布尔),
    ConvertThenBlock(&'静态 ConversionTable, Cbs, 布尔),
    UnblockThenConvert(&'静态 ConversionTable, Cbs),
    ConvertThenUnblock(&'静态 ConversionTable, Cbs),
}

/// Stores all Conv Flags that apply to the input
#[derive(调试协议, 默认协议, 偏等比较协议)]
公有(箱) 结构 IConvFlags {
    公有 mode: 选项<ConversionMode>,
    公有 swab: 布尔,
    公有 同步: 选项<正8>,
    公有 noerror: 布尔,
}

