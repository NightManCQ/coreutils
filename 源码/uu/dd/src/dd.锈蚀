}

实现 Dest {
    方法 fsync(&可变 自身) -> 输入输出::结果<()> {
        匹配 自身 {
            自身类型::Stdout(stdout) => stdout.flush(),
            自身类型::File(f, _) => {
                f.flush()?;
                f.sync_all()
            }
            #[cfg(unix)]
            自身类型::Fifo(f) => {
                f.flush()?;
                f.sync_all()
            }
            #[cfg(unix)]
            自身类型::Sink => 好的(()),
        }
    }

    方法 fdatasync(&可变 自身) -> 输入输出::结果<()> {
        匹配 自身 {
            自身类型::Stdout(stdout) => stdout.flush(),
            自身类型::File(f, _) => {
                f.flush()?;
                f.sync_data()
            }
            #[cfg(unix)]
            自身类型::Fifo(f) => {
                f.flush()?;
                f.sync_data()
            }
            #[cfg(unix)]
            自身类型::Sink => 好的(()),
        }
    }

    #[cfg_attr(not(unix), allow(unused_variables))]
    方法 seek(&可变 自身, n: 正64, obs: 正整数大小) -> 输入输出::结果<正64> {
