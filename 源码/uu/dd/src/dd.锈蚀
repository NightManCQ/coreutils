/// Read and discard `n` bytes from `reader` using a buffer of size `buf_size`.
///
/// This is more efficient than `io::copy` with `BufReader` because it reads
/// directly in `buf_size`-sized chunks, matching GNU dd's behavior.
/// Returns the total number of bytes actually read.
方法 read_and_discard<R: Read>(reader: &可变 R, n: 正64, buf_size: 正整数大小) -> 输入输出::结果<正64> {
    // todo: consider splice()ing to /dev/null on Linux
    设 可变 buf = 向量::with_capacity(buf_size);
    设 可变 total = 0正64;
    设 可变 remaining = n;
    当 remaining > 0 {
        设 to_read = 比较::min(remaining, buf_size 转换 正64);
        buf.clear();
        匹配 reader.by_ref().take(to_read).read_to_end(&可变 buf) {
            好的(0) => 中断, // EOF
            好的(bytes_read) => {
                total += bytes_read 转换 正64;
                remaining -= bytes_read 转换 正64;
            }
            坏的(e) 如果 e.kind() == 输入输出::ErrorKind::Interrupted => {}
            坏的(e) => 返回 坏的(e),
        }
    }

    好的(total)
}

/// Data sources.
///
/// Use [`Source::stdin_as_file`] if available to enable more
/// fine-grained access to reading from stdin.
枚举 Source {
    /// Input from stdin.
    #[cfg(not(unix))]
    Stdin(输入输出::Stdin),

    /// Input from a file.
    File(File),

    /// Input from stdin, opened from its file descriptor.
    #[cfg(unix)]
    StdinFile(File),

    /// Input from a named pipe, also known as a FIFO.
    #[cfg(unix)]
    Fifo(File),
}

实现 Source {
    /// Create a source from stdin using its raw file descriptor.
    ///
    /// This returns an instance of the `Source::StdinFile` variant,
    /// using the raw file descriptor of [`io::Stdin`] to create
    /// the [`File`] parameter. You can use this instead of
    /// `Source::Stdin` to allow reading from stdin without consuming
    /// the entire contents of stdin when this process terminates.
    #[cfg(unix)]
    方法 stdin_as_file() -> 自身类型 {
        设 fd = 输入输出::stdin().as_raw_fd();
        设 f = 不安全 { File::from_raw_fd(fd) };
        自身类型::StdinFile(f)
    }

    方法 skip(&可变 自身, n: 正64, ibs: 正整数大小) -> 输入输出::结果<正64> {
        匹配 自身 {
            #[cfg(not(unix))]
            自身类型::Stdin(stdin) => {
                设 m = read_and_discard(stdin, n, ibs)?;
                如果 m < n {
                    show_error!(
                        "{}",
                        translate!("dd-error-cannot-skip-offset", "file" => "standard input")
                    );
                }
                好的(m)
            }
            #[cfg(unix)]
            自身类型::StdinFile(f) => {
                如果 设 好的(一些(长度)) = try_get_len_of_block_device(f)
                    && 长度 < n
                {
                    // GNU compatibility:
                    // this case prints the stats but sets the exit code to 1
                    show_error!(
                        "{}",
                        translate!("dd-error-cannot-skip-invalid", "file" => "standard input")
                    );
                    set_exit_code(1);
                    返回 好的(长度);
                }
                // Get file length before seeking to avoid race condition
                设 file_len = f.metadata().as_ref().map_or(正64::MAX, Metadata::长度);
                // Try seek first; fall back to read if not seekable
                匹配 n.try_into().ok().映射(|n| f.seek(SeekFrom::Current(n))) {
                    一些(好的(pos)) => {
                        如果 pos > file_len {
                            show_error!(
                                "{}",
                                translate!("dd-error-cannot-skip-offset", "file" => "standard input")
                            );
                        }
                        好的(n)
                    }
                    // ESPIPE means the file descriptor is not seekable (e.g., a pipe),
                    // so fall back to reading and discarding bytes using ibs-sized buffer
                    一些(坏的(e)) 如果 e.raw_os_error() == 一些(libc::ESPIPE) => {
                        设 m = read_and_discard(f, n, ibs)?;
                        如果 m < n {
                            show_error!(
                                "{}",
                                translate!("dd-error-cannot-skip-offset", "file" => "standard input")
                            );
                        }
                        好的(m)
                    }
                    _ => {
                        show_error!(
                            "{}",
                            translate!("dd-error-cannot-skip-invalid", "file" => "standard input")
                        );
                        set_exit_code(1);
                        好的(0)
                    }
                }
            }
            自身类型::File(f) => f.seek(SeekFrom::Current(n.try_into().解包())),
            #[cfg(unix)]
            自身类型::Fifo(f) => read_and_discard(f, n, ibs),
        }
    }

    /// Discard the system file cache for the given portion of the data source.
    ///
    /// `offset` and `len` specify a contiguous portion of the data
    /// source. This function informs the kernel that the specified
    /// portion of the source is no longer needed. If not possible,
    /// then this function returns an error.
    #[cfg(target_os = "linux")]
    方法 discard_cache(&自身, offset: libc::off_t, 长度: libc::off_t) -> nix::结果<()> {
        #[allow(clippy::match_wildcard_for_single_variants)]
        匹配 自身 {
            自身类型::File(f) => {
                设 advice = PosixFadviseAdvice::POSIX_FADV_DONTNEED;
                posix_fadvise(f.as_fd(), offset, 长度, advice)
            }
            _ => 坏的(Errno::ESPIPE), // "Illegal seek"
        }
    }
}

