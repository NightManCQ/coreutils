                设 prog_update = ProgUpdate::新建(rstat, wstat, start.elapsed(), tp);
                prog_tx.发送(prog_update).unwrap_or(());
            }
            _ => {}
        }
    }

    finalize(o, rstat, wstat, start, &prog_tx, output_thread, truncate)
}

