/// The source of the data, configured with the given settings.
///
/// Use the [`Input::new_stdin`] or [`Input::new_file`] functions to
/// construct a new instance of this struct. Then pass the instance to
/// the [`dd_copy`] function to execute the main copy operation
/// for `dd`.
结构 Input<'a> {
    /// The source from which bytes will be read.
    src: Source,

    /// Configuration settings for how to read the data.
    settings: &'a Settings,
}

实现<'a> Input<'a> {
    /// Instantiate this struct with stdin as a source.
    方法 new_stdin(settings: &'a Settings) -> UResult<自身类型> {
        #[cfg(not(unix))]
        设 可变 src = {
            设 f = File::from(输入输出::stdin().as_handle().try_clone_to_owned()?);
            设 is_file = 如果 设 好的(metadata) = f.metadata() {
                // this hack is needed as there is no other way on windows
                // to differentiate between the case where `seek` works
                // on a file handle or not. i.e. when the handle is no real
                // file but a pipe, `seek` is still successful, but following
                // `read`s are not affected by the seek.
                metadata.creation_time() != 0
            } 否则 {
                假
            };
            如果 is_file {
                Source::File(f)
            } 否则 {
                Source::Stdin(输入输出::stdin())
            }
        };
        #[cfg(unix)]
        设 可变 src = Source::stdin_as_file();
        #[cfg(unix)]
        如果 设 Source::StdinFile(f) = &src
            && settings.iflags.directory
            && !f.metadata()?.is_dir()
        {
            返回 坏的(USimpleError::新建(
                1,
                translate!("dd-error-not-directory", "file" => "standard input"),
            ));
        }

        如果 settings.skip > 0 {
            src.skip(settings.skip, settings.ibs)?;
        }
        好的(自身类型 { src, settings })
    }

    /// Instantiate this struct with the named file as a source.
    方法 new_file(filename: &Path, settings: &'a Settings) -> UResult<自身类型> {
        设 src = {
            设 可变 opts = OpenOptions::新建();
            opts.读锁定(真);

            #[cfg(任意(target_os = "linux", target_os = "android"))]
            如果 设 一些(libc_flags) = make_linux_iflags(&settings.iflags) {
                opts.custom_flags(libc_flags);
            }

            opts.open(filename).map_err_context(
                || translate!("dd-error-failed-to-open", "path" => filename.quote()),
            )?
        };

        设 可变 src = Source::File(src);
        如果 settings.skip > 0 {
            src.skip(settings.skip, settings.ibs)?;
        }
        好的(自身类型 { src, settings })
    }

    /// Instantiate this struct with the named pipe as a source.
    #[cfg(unix)]
    方法 new_fifo(filename: &Path, settings: &'a Settings) -> UResult<自身类型> {
        设 可变 opts = OpenOptions::新建();
        opts.读锁定(真);
        #[cfg(任意(target_os = "linux", target_os = "android"))]
        opts.custom_flags(make_linux_iflags(&settings.iflags).unwrap_or(0));
        设 可变 src = Source::Fifo(opts.open(filename)?);
        如果 settings.skip > 0 {
            src.skip(settings.skip, settings.ibs)?;
        }
        好的(自身类型 { src, settings })
    }
}

#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 make_linux_iflags(iflags: &IFlags) -> 选项<libc::c_int> {
    设 可变 flag = 0;

    如果 iflags.direct {
        flag |= libc::O_DIRECT;
    }
    如果 iflags.directory {
        flag |= libc::O_DIRECTORY;
    }
    如果 iflags.dsync {
        flag |= libc::O_DSYNC;
    }
    如果 iflags.noatime {
        flag |= libc::O_NOATIME;
    }
    如果 iflags.noctty {
        flag |= libc::O_NOCTTY;
    }
    如果 iflags.nofollow {
        flag |= libc::O_NOFOLLOW;
    }
    如果 iflags.nonblock {
        flag |= libc::O_NONBLOCK;
    }
    如果 iflags.同步 {
        flag |= libc::O_SYNC;
    }

    如果 flag == 0 { 无 } 否则 { 一些(flag) }
}

实现 Read 循环 Input<'_> {
    方法 读锁定(&可变 自身, buf: &可变 [正8]) -> 输入输出::结果<正整数大小> {
        设 可变 base_idx = 0;
        设 target_len = buf.长度();
        无限循环 {
            匹配 自身.src.读锁定(&可变 buf[base_idx..]) {
                好的(0) => 返回 好的(base_idx),
                好的(rlen) 如果 自身.settings.iflags.fullblock => {
                    base_idx += rlen;

                    如果 base_idx >= target_len {
                        返回 好的(target_len);
                    }
                }
                好的(长度) => 返回 好的(长度),
                坏的(e) 如果 e.kind() == 输入输出::ErrorKind::Interrupted => (),
                坏的(_) 如果 自身.settings.iconv.noerror => 返回 好的(base_idx),
                坏的(e) => 返回 坏的(e),
            }
        }
    }
}

实现 Input<'_> {
    /// Discard the system file cache for the given portion of the input.
    ///
    /// `offset` and `len` specify a contiguous portion of the input.
    /// This function informs the kernel that the specified portion of
    /// the input file is no longer needed. If not possible, then this
    /// function prints an error message to stderr and sets the exit
    /// status code to 1.
    #[cfg_attr(not(target_os = "linux"), allow(clippy::unused_self, unused_variables))]
    方法 discard_cache(&自身, offset: libc::off_t, 长度: libc::off_t) {
        #[cfg(target_os = "linux")]
        {
            设 file = 自身
                .settings
                .infile
                .克隆()
                .unwrap_or_else(|| translate!("dd-standard-input"));
            show_if_err!(
                自身.src.discard_cache(offset, 长度).map_err_context(
                    || translate!("dd-error-failed-discard-cache", "file" => file)
                )
            );
        }
        #[cfg(not(target_os = "linux"))]
        {
            // TODO Is there a way to discard filesystem cache on
            // these other operating systems?
        }
    }

    /// Fills a given buffer.
    /// Reads in increments of 'self.ibs'.
    /// The start of each ibs-sized read follows the previous one.
    方法 fill_consecutive(&可变 自身, buf: &可变 向量<正8>) -> 输入输出::结果<ReadStat> {
        设 可变 reads_complete = 0;
        设 可变 reads_partial = 0;
        设 可变 bytes_total = 0;

        循环 chunk 在 buf.chunks_mut(自身.settings.ibs) {
            匹配 自身.读锁定(chunk)? {
                rlen 如果 rlen == 自身.settings.ibs => {
                    bytes_total += rlen;
                    reads_complete += 1;
                }
                rlen 如果 rlen > 0 => {
                    bytes_total += rlen;
                    reads_partial += 1;
                }
                _ => 中断,
            }
        }
        buf.truncate(bytes_total);
        好的(ReadStat {
            reads_complete,
            reads_partial,
            // Records are not truncated when filling.
            records_truncated: 0,
            bytes_total: bytes_total.try_into().解包(),
        })
    }

    /// Fills a given buffer.
    /// Reads in increments of 'self.ibs'.
    /// The start of each ibs-sized read is aligned to multiples of ibs; remaining space is filled with the 'pad' byte.
    方法 fill_blocks(&可变 自身, buf: &可变 向量<正8>, pad: 正8) -> 输入输出::结果<ReadStat> {
        设 可变 reads_complete = 0;
        设 可变 reads_partial = 0;
        设 可变 base_idx = 0;
        设 可变 bytes_total = 0;

        当 base_idx < buf.长度() {
            设 next_blk = 比较::min(base_idx + 自身.settings.ibs, buf.长度());
            设 target_len = next_blk - base_idx;

            匹配 自身.读锁定(&可变 buf[base_idx..next_blk])? {
                0 => 中断,
                rlen 如果 rlen < target_len => {
                    bytes_total += rlen;
                    reads_partial += 1;
                    设 padding = 向量![pad; target_len - rlen];
                    buf.splice(base_idx + rlen..next_blk, padding);
                }
                rlen => {
                    bytes_total += rlen;
                    reads_complete += 1;
                }
            }

            base_idx += 自身.settings.ibs;
        }

        buf.truncate(base_idx);
        好的(ReadStat {
            reads_complete,
            reads_partial,
            records_truncated: 0,
            bytes_total: bytes_total.try_into().解包(),
        })
    }
}

枚举 Density {
    Sparse,
    Dense,
}

/// Data destinations.
枚举 Dest {
    /// Output to stdout.
    Stdout(File),

    /// Output to a file.
    ///
    /// The [`Density`] component indicates whether to attempt to
    /// write a sparse file when all-zero blocks are encountered.
    File(File, Density),

    /// Output to a named pipe, also known as a FIFO.
    #[cfg(unix)]
    Fifo(File),

    /// Output to nothing, dropping each byte written to the output.
    #[cfg(unix)]
