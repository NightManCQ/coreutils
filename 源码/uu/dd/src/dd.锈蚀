        read_offset += read_len;

        // Discard the system file cache for the written portion
        // of the output file.
        //
        // TODO Better error handling for overflowing `offset` and `len`.
        设 write_len = wstat_update.bytes_total;
        如果 output_nocache {
            设 offset = write_offset.try_into().解包();
            设 长度 = write_len.try_into().解包();
            o.discard_cache(offset, 长度);
