    可变 output: BlockWriter,
    rstat: ReadStat,
    wstat: WriteStat,
    start: Instant,
    prog_tx: &mpsc::发送器<ProgUpdate>,
    output_thread: 线程::线程句柄<T>,
    truncate: 布尔,
) -> 输入输出::结果<()> {
    // Flush the output in case a partial write has been buffered but
    // not yet written.
    设 wstat_update = output.flush()?;

    // Sync the output, if configured to do so.
    output.同步()?;

    // Truncate the file to the final cursor location.
    如果 truncate {
        output.truncate();
    }

    // Print the final read/write statistics.
    设 wstat = wstat + wstat_update;
    设 prog_update = ProgUpdate::新建(rstat, wstat, start.elapsed(), ProgUpdateType::Final);
    prog_tx.发送(prog_update).unwrap_or(());
    // Wait for the output thread to finish
    output_thread
        .加入()
        .期望("Failed to join with the output thread.");

    好的(())
}

