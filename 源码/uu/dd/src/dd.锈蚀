            ALARM_TRIGGER_NONE => {}
            t @ (ALARM_TRIGGER_TIMER | ALARM_TRIGGER_SIGNAL) => {
                设 tp = 匹配 t {
                    ALARM_TRIGGER_TIMER => ProgUpdateType::Periodic,
                    _ => ProgUpdateType::Signal,
