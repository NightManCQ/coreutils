#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 settings: Settings = Parser::新建().parse(
        matches
            .get_many::<字符串>(options::OPERANDS)
            .unwrap_or_default(),
    )?;

    #[cfg(unix)]
    如果 uucore::signals::stderr_was_closed() && settings.status != 一些(StatusLevel::无) {
        返回 坏的(USimpleError::新建(1, "write error"));
    }

    设 i = 匹配 settings.infile {
        #[cfg(unix)]
        一些(引用 infile) 如果 is_fifo(infile) => Input::new_fifo(Path::新建(&infile), &settings)?,
        一些(引用 infile) => Input::new_file(Path::新建(&infile), &settings)?,
        无 => Input::new_stdin(&settings)?,
    };
    设 o = 匹配 settings.outfile {
        #[cfg(unix)]
        一些(引用 outfile) 如果 is_fifo(outfile) => Output::new_fifo(Path::新建(&outfile), &settings)?,
        一些(引用 outfile) => Output::new_file(Path::新建(&outfile), &settings)?,
        无 如果 is_stdout_redirected_to_seekable_file() => Output::new_file_from_stdout(&settings)?,
        无 => Output::new_stdout(&settings)?,
    };
    dd_copy(i, o).map_err_context(|| translate!("dd-error-io-error"))
}

