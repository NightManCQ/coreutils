        设 wstat = output.write_blocks(b"ab").解包();
        相等断言!(wstat.writes_complete, 0);
        相等断言!(wstat.writes_partial, 0);
        相等断言!(wstat.bytes_total, 0);
        相等断言!(output.buf, b"ab");
    }

    #[test]
    方法 test_buffered_output_write_blocks_complete() {
        设 settings = Settings {
            obs: 3,
            ..默认协议::默认()
        };
        设 inner = Output {
            dst: Dest::Sink,
            settings: &settings,
        };
        设 可变 output = BufferedOutput::新建(inner);
        设 wstat = output.write_blocks(b"abcd").解包();
        相等断言!(wstat.writes_complete, 1);
        相等断言!(wstat.writes_partial, 0);
        相等断言!(wstat.bytes_total, 3);
        相等断言!(output.buf, b"d");
    }

    #[test]
    方法 test_buffered_output_write_blocks_append() {
        设 settings = Settings {
            obs: 3,
            ..默认协议::默认()
        };
        设 inner = Output {
            dst: Dest::Sink,
            settings: &settings,
        };
        设 可变 output = BufferedOutput {
            inner,
            buf: b"ab".to_vec(),
        };
        设 wstat = output.write_blocks(b"cdefg").解包();
        相等断言!(wstat.writes_complete, 2);
        相等断言!(wstat.writes_partial, 0);
        相等断言!(wstat.bytes_total, 6);
        相等断言!(output.buf, b"g");
    }

    #[test]
    方法 test_buffered_output_flush() {
        设 settings = Settings {
            obs: 10,
            ..默认协议::默认()
        };
        设 inner = Output {
            dst: Dest::Sink,
            settings: &settings,
        };
        设 可变 output = BufferedOutput {
            inner,
