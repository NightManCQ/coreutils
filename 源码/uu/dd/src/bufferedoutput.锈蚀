        };
        设 wstat = output.flush().解包();
        相等断言!(wstat.writes_complete, 0);
        相等断言!(wstat.writes_partial, 1);
        相等断言!(wstat.bytes_total, 3);
        相等断言!(output.buf, 向量![]);
    }
