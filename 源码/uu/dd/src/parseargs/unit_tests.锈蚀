#[test]
#[allow(clippy::cognitive_complexity)]
方法 test_all_top_level_args_no_leading_dashes() {
    设 args = [
        "if=foo.file",
        "of=bar.file",
        "ibs=10",
        "obs=10",
        "cbs=1",
        "bs=100",
        "count=2",
        "skip=2",
        "seek=2",
        "iseek=2",
        "oseek=2",
        "status=progress",
        "conv=ascii,ucase",
        "iflag=count_bytes,skip_bytes",
        "oflag=append,seek_bytes",
    ];

    设 settings = Parser::新建().parse(args).解包();

    // ibs=10 and obs=10 are overwritten by bs=100
    相等断言!(settings.ibs, 100);
    相等断言!(settings.obs, 100);

    // count=2 iflag=count_bytes
    相等断言!(settings.计数, 一些(Num::Bytes(2)));

    // seek=2 oflag=seek_bytes
    相等断言!(settings.seek, 2);

    // skip=2 iflag=skip_bytes
    相等断言!(settings.skip, 2);

    // status=progress
    相等断言!(settings.status, 一些(StatusLevel::Progress));

    // conv=ascii,ucase
    相等断言!(
        settings.iconv,
        IConvFlags {
            // ascii implies unblock
            mode: 一些(ConversionMode::ConvertThenUnblock(
                &EBCDIC_TO_ASCII_LCASE_TO_UCASE,
                1
            )),
            ..IConvFlags::默认()
        },
    );

    // no conv flags apply to output
    相等断言!(settings.oconv, OConvFlags::默认());

    // iconv=count_bytes,skip_bytes
    相等断言!(
        settings.iflags,
        IFlags {
            count_bytes: 真,
            skip_bytes: 真,
            ..IFlags::默认()
        },
    );

    // oconv=append,seek_bytes
    相等断言!(
        settings.oflags,
        OFlags {
            append: 真,
            seek_bytes: 真,
            ..OFlags::默认()
        },
    );
}

