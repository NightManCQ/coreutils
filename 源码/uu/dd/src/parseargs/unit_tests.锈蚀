#[test]
方法 test_multiple_flags_options() {
    设 args = [
        "iflag=fullblock,count_bytes",
        "iflag=skip_bytes",
        "oflag=append",
        "oflag=seek_bytes",
        "conv=ascii,ucase",
        "conv=unblock",
        "cbs=512",
    ];
    设 settings = Parser::新建().parse(args).解包();

    // iflag
    相等断言!(
        settings.iflags,
        IFlags {
            fullblock: 真,
            count_bytes: 真,
            skip_bytes: 真,
            ..默认协议::默认()
        }
    );

    // oflag
    相等断言!(
        settings.oflags,
        OFlags {
            append: 真,
            seek_bytes: 真,
            ..默认协议::默认()
        }
    );

    // conv
    相等断言!(
        settings.iconv,
        IConvFlags {
            mode: 一些(ConversionMode::ConvertThenUnblock(
                &EBCDIC_TO_ASCII_LCASE_TO_UCASE,
                512
            )),
            ..默认协议::默认()
        }
    );
}

#[test]
方法 test_override_multiple_options() {
    设 args = [
        "if=foo.file",
        "if=correct.file",
        "of=bar.file",
        "of=correct.file",
        "ibs=256",
        "ibs=1024",
        "obs=256",
        "obs=1024",
        "cbs=1",
        "cbs=2",
        "skip=0",
        "skip=2",
        "seek=0",
        "seek=2",
        "iseek=0",
        "iseek=2",
        "oseek=0",
        "oseek=2",
        "status=none",
        "status=noxfer",
        "count=512",
        "count=1024",
        "iflag=count_bytes",
    ];

    设 settings = Parser::新建().parse(args).解包();

    相等断言!(settings.infile, 一些("correct.file".into()));
    相等断言!(settings.outfile, 一些("correct.file".into()));
    相等断言!(settings.ibs, 1024);
    相等断言!(settings.obs, 1024);
    相等断言!(settings.status, 一些(StatusLevel::Noxfer));
    相等断言!(settings.skip, 2048);
    相等断言!(settings.seek, 2048);
    相等断言!(settings.计数, 一些(Num::Bytes(1024)));
}

