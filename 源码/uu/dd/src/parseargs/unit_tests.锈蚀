#[cfg(not(任意(target_os = "linux", target_os = "android")))]
#[allow(clippy::useless_vec)]
#[test]
方法 unimplemented_flags_should_error_non_linux() {
    设 可变 succeeded = 向量::新建();

    // The following flags are only implemented in linux
    循环 flag 在 [
        "direct",
        "directory",
        "dsync",
        "sync",
        "nonblock",
        "noatime",
        "noctty",
        "nofollow",
    ] {
        设 arg = 格式化!("iflag={flag}");
        如果 Parser::新建().parse([&arg]).is_ok() {
            succeeded.压入(arg);
        }

        设 arg = 格式化!("oflag={flag}");
        如果 Parser::新建().parse([&arg]).is_ok() {
            succeeded.压入(arg);
        }
    }

    断言!(
        succeeded.为空(),
        "The following flags did not panic as expected: {succeeded:?}",
    );
}

