使用 divan::{Bencher, black_box};
使用 tempfile::TempDir;
使用 uu_dd::uumain;
使用 uucore::benchmark::{binary_data, fs_utils, run_util_function};

/// Benchmark basic dd copy with default settings
#[divan::bench]
方法 dd_copy_default(bencher: Bencher) {
    设 size_mb = 32;
    设 temp_dir = TempDir::新建().解包();
    设 input = temp_dir.路径().加入("input.bin");
    设 output = temp_dir.路径().加入("output.bin");

    binary_data::create_file(&input, size_mb, b'x');

    设 input_str = input.to_str().解包();
    设 output_str = output.to_str().解包();

    bencher.bench(|| {
        fs_utils::remove_path(&output);
        black_box(run_util_function(
            uumain,
            &[
                &格式化!("if={input_str}"),
                &格式化!("of={output_str}"),
                "status=none",
            ],
        ));
    });
}

