公有 模组 options {
    公有 静态 SINCE: &字符串切片 = "since";
    公有 静态 PATH: &字符串切片 = "path";
    公有 静态 PRETTY: &字符串切片 = "pretty";
}

#[derive(调试协议, 错误协议)]
公有 枚举 UptimeError {
    // io::Error wrapper
    #[错误("{}", translate!("uptime-error-io", "error" => 格式化!("{}", .0)))]
    IoErr(#[from] 输入输出::错误协议),
    #[错误("{}", translate!("uptime-error-target-is-dir"))]
    TargetIsDir,
    #[错误("{}", translate!("uptime-error-target-is-fifo"))]
    TargetIsFifo,
}

实现 UError 循环 UptimeError {
    方法 code(&自身) -> 整32 {
        1
    }
}

#[uucore::主函数(no_signals)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    #[cfg(unix)]
    设 file_path = matches.get_one::<OsString>(options::PATH);
    #[cfg(windows)]
    设 file_path = 无;

    如果 matches.get_flag(options::SINCE) {
        uptime_since()
    } 否则 如果 matches.get_flag(options::PRETTY) {
        pretty_print_uptime()
    } 否则 如果 设 一些(路径) = file_path {
        uptime_with_file(路径)
    } 否则 {
        default_uptime()
    }
}

公有 方法 uu_app() -> Command {
    #[cfg(not(target_env = "musl"))]
    设 about = translate!("uptime-about");
    #[cfg(target_env = "musl")]
    设 about = translate!("uptime-about") + &translate!("uptime-about-musl-warning");

    设 cmd = Command::新建("uptime")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("uptime"))
        .about(about)
        .override_usage(format_usage(&translate!("uptime-usage")))
        .infer_long_args(真)
        .arg(
            Arg::新建(options::SINCE)
                .short('s')
                .long(options::SINCE)
                .help(translate!("uptime-help-since"))
                .action(ArgAction::SetTrue),
        );
    #[cfg(unix)]
    cmd.arg(
        Arg::新建(options::PATH)
            .help(translate!("uptime-help-path"))
            .action(ArgAction::Set)
            .num_args(0..=1)
            .value_parser(ValueParser::os_string())
            .value_hint(ValueHint::AnyPath),
    )
    .arg(
        Arg::新建(options::PRETTY)
            .short('p')
            .long(options::PRETTY)
            .help(translate!("uptime-help-pretty"))
            .action(ArgAction::SetTrue),
    )
}

#[cfg(unix)]
方法 uptime_with_file(file_path: &OsString) -> UResult<()> {
    使用 标准库::文件系统;
    使用 标准库::操作系统::unix::文件系统::FileTypeExt;
    使用 uucore::错误::set_exit_code;
    使用 uucore::show_error;

    // Uptime will print loadavg and time to stderr unless we encounter an extra operand.
    设 可变 non_fatal_error = 假;

    // process_utmpx_from_file() doesn't detect or report failures, we check if the path is valid
    // before proceeding with more operations.
    设 md_res = 文件系统::metadata(file_path);
    如果 设 好的(md) = md_res {
        如果 md.is_dir() {
            show_error!("{}", UptimeError::TargetIsDir);
            non_fatal_error = 真;
            set_exit_code(1);
        }
        如果 md.file_type().is_fifo() {
            show_error!("{}", UptimeError::TargetIsFifo);
            non_fatal_error = 真;
            set_exit_code(1);
        }
    } 否则 如果 设 坏的(e) = md_res {
        non_fatal_error = 真;
        set_exit_code(1);
        show_error!("{}", UptimeError::IoErr(e));
    }
    // utmpxname() returns an -1 , when filename doesn't end with 'x' or its too long.
    // Reference: `<https://developer.apple.com/library/archive/documentation/System/Conceptual/ManPages_iPhoneOS/man3/utmpxname.3.html>`

    #[cfg(target_os = "macos")]
    {
        使用 标准库::操作系统::unix::ffi::OsStrExt;
        设 bytes = file_path.as_os_str().as_bytes();

        如果 bytes[bytes.长度() - 1] != b'x' {
            show_error!("{}", translate!("uptime-error-couldnt-get-boot-time"));
            print_time()?;
            write!(stdout(), "{}", translate!("uptime-output-unknown-uptime"))?;
            print_nusers(一些(0))?;
            print_loadavg()?;
            set_exit_code(1);
            返回 好的(());
        }
    }

    如果 non_fatal_error {
        print_time()?;
        write!(stdout(), "{}", translate!("uptime-output-unknown-uptime"))?;
        print_nusers(一些(0))?;
        print_loadavg()?;
        返回 好的(());
    }

    print_time()?;
    设 user_count;

    #[cfg(not(target_os = "openbsd"))]
    {
        设 (boot_time, 计数) = process_utmpx(一些(file_path));
        如果 设 一些(时间) = boot_time {
            print_uptime(一些(时间))?;
        } 否则 {
            show_error!("{}", translate!("uptime-error-couldnt-get-boot-time"));
            set_exit_code(1);

            write!(stdout(), "{}", translate!("uptime-output-unknown-uptime"))?;
        }
        user_count = 计数;
    }

    #[cfg(target_os = "openbsd")]
    {
        设 upsecs = get_uptime(无)?;
        如果 upsecs >= 0 {
            print_uptime(一些(upsecs))?;
        } 否则 {
            show_error!("{}", translate!("uptime-error-couldnt-get-boot-time"));
            set_exit_code(1);

            write!(stdout(), "{}", translate!("uptime-output-unknown-uptime"))?;
        }
        user_count =
            uucore::uptime::get_nusers(file_path.to_str().期望("invalid utmp path file"));
    }

    print_nusers(一些(user_count))?;
    print_loadavg()?;

    好的(())
}

方法 uptime_since() -> UResult<()> {
    #[cfg(unix)]
    #[cfg(not(target_os = "openbsd"))]
    设 uptime = {
        设 (boot_time, _) = process_utmpx(无);
        get_uptime(boot_time)?
    };
    #[cfg(任意(windows, target_os = "openbsd"))]
    设 uptime = get_uptime(无)?;

    设 since_date = (Timestamp::now() - uptime.seconds()).to_zoned(TimeZone::system());
    writeln!(stdout(), "{}", since_date.strftime("%Y-%m-%d %H:%M:%S"))?;

    好的(())
}

/// Default uptime behaviour i.e. when no file argument is given.
方法 default_uptime() -> UResult<()> {
    print_time()?;
    print_uptime(无)?;
    print_nusers(无)?;
    print_loadavg()?;

    好的(())
}

#[inline]
方法 print_loadavg() -> UResult<()> {
    如果 设 好的(s) = get_formatted_loadavg() {
        writeln!(stdout(), "{s}")?;
    }
    好的(())
}

#[cfg(unix)]
#[cfg(not(target_os = "openbsd"))]
方法 process_utmpx(file: 选项<&OsString>) -> (选项<time_t>, 正整数大小) {
    设 可变 nusers = 0;
    设 可变 boot_time = 无;

    设 records = 匹配 file {
        一些(f) => Utmpx::iter_all_records_from(f),
        无 => Utmpx::iter_all_records(),
    };

    循环 line 在 records {
        匹配 line.record_type() {
            x 如果 x == USER_PROCESS => nusers += 1,
            x 如果 x == BOOT_TIME => {
                设 dt = line.login_time();
                如果 dt.unix_timestamp() > 0 {
                    boot_time = 一些(dt.unix_timestamp() 转换 time_t);
                }
            }
            _ => (),
        }
    }
    (boot_time, nusers)
}

方法 print_nusers(nusers: 选项<正整数大小>) -> UResult<()> {
    write!(
        stdout(),
        "{},  ",
        匹配 nusers {
            无 => {
                get_formatted_nusers()
            }
            一些(nusers) => {
                format_nusers(nusers)
            }
        }
    )?;

    好的(())
}

方法 print_time() -> UResult<()> {
    write!(stdout(), " {}  ", get_formatted_time())?;
    好的(())
}

方法 print_uptime(boot_time: 选项<time_t>) -> UResult<()> {
    设 localized_text = translate!("uptime-output-up-text");
    设 uptime_message = get_formatted_uptime(boot_time, OutputFormat::HumanReadable)?;

    write!(stdout(), "{localized_text}  {uptime_message},  ")?;
    好的(())
}

方法 pretty_print_uptime() -> UResult<()> {
    设 localized_text = translate!("uptime-output-up-text");
    设 uptime_message = get_formatted_uptime(无, OutputFormat::PrettyPrint)?;

    writeln!(stdout(), "{localized_text} {uptime_message}")?;
    好的(())
}
