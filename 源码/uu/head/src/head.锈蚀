方法 arg_iterate<'a>(
    可变 args: 实现 uucore::Args + 'a,
) -> HeadResult<盒子<动态 迭代器协议<Item = OsString> + 'a>> {
    // argv[0] is always present
    设 first = args.next().解包();
    如果 设 一些(second) = args.next() {
        如果 设 一些(s) = second.to_str() {
            如果 设 一些(v) = parse::parse_obsolete(s) {
                匹配 v {
                    好的(迭代) => 好的(盒子::新建(向量![first].into_iter().chain(迭代).chain(args))),
                    坏的(parse::ParseError) => 坏的(HeadError::ParseError(
                        translate!("head-error-bad-argument-format", "arg" => s.quote()),
                    )),
                }
            } 否则 {
                // The second argument contains non-UTF-8 sequences, so it can't be an obsolete option
                // like "-5". Treat it as a regular file argument.
                好的(盒子::新建(向量![first, second].into_iter().chain(args)))
            }
        } 否则 {
            // The second argument contains non-UTF-8 sequences, so it can't be an obsolete option
            // like "-5". Treat it as a regular file argument.
            好的(盒子::新建(向量![first, second].into_iter().chain(args)))
        }
    } 否则 {
        好的(盒子::新建(向量![first].into_iter()))
    }
}

