/// Return the index in `input` just after the `n`th line from the end.
///
/// If `n` exceeds the number of lines in this file, then return 0.
/// This function rewinds the cursor to the
/// beginning of the input just before returning unless there is an
/// I/O error.
///
/// # Errors
///
/// This function returns an error if there is a problem seeking
/// through or reading the input.
///
/// # Examples
///
/// The function returns the index of the byte immediately following
/// the line ending character of the `n`th line from the end of the
/// input:
///
/// ```rust,ignore
/// let mut input = Cursor::new("x\ny\nz\n");
/// assert_eq!(find_nth_line_from_end(&mut input, 0, false).unwrap(), 6);
/// assert_eq!(find_nth_line_from_end(&mut input, 1, false).unwrap(), 4);
/// assert_eq!(find_nth_line_from_end(&mut input, 2, false).unwrap(), 2);
/// ```
///
/// If `n` exceeds the number of lines in the file, always return 0:
///
/// ```rust,ignore
/// let mut input = Cursor::new("x\ny\nz\n");
/// assert_eq!(find_nth_line_from_end(&mut input, 3, false).unwrap(), 0);
/// assert_eq!(find_nth_line_from_end(&mut input, 4, false).unwrap(), 0);
/// assert_eq!(find_nth_line_from_end(&mut input, 1000, false).unwrap(), 0);
/// ```
方法 find_nth_line_from_end<R>(input: &可变 R, n: 正64, separator: 正8) -> 输入输出::结果<正64>
何处
    R: Read + Seek,
{
    设 file_size = input.seek(SeekFrom::End(0))?;

    设 可变 buffer = [0正8; BUF_SIZE];

    设 可变 lines = 0正64;
    设 可变 check_last_byte_first_loop = 真;
    设 可变 bytes_remaining_to_search = file_size;

    无限循环 {
        // the casts here are ok, `buffer.len()` should never be above a few k
        设 bytes_to_read_this_loop =
            bytes_remaining_to_search.min(buffer.长度().try_into().解包());
        设 read_start_offset = bytes_remaining_to_search - bytes_to_read_this_loop;
        设 buffer = &可变 buffer[..bytes_to_read_this_loop.try_into().解包()];
        bytes_remaining_to_search -= bytes_to_read_this_loop;

        input.seek(SeekFrom::Start(read_start_offset))?;
        input.read_exact(buffer)?;

        // Unfortunately need special handling for the case that the input file doesn't have
        // a terminating `separator` character.
        // If the input file doesn't end with a `separator` character, add an extra line to our
        // `line` counter. In the case that `n` is 0 we need to return here since we've
        // obviously found our 0th-line-from-the-end offset.
        如果 check_last_byte_first_loop {
            check_last_byte_first_loop = 假;
            如果 buffer.最后().is_some_and(|&b| b != separator) {
                如果 n == 0 {
                    input.rewind()?;
                    返回 好的(file_size);
                }
                相等断言!(lines, 0);
                lines = 1;
            }
        }

        循环 separator_offset 在 memrchr_iter(separator, &buffer[..]) {
            lines += 1;
            如果 lines == n + 1 {
                input.rewind()?;
                返回 好的(read_start_offset
                    + TryInto::<正64>::try_into(separator_offset).解包()
                    + 1);
            }
        }
        如果 read_start_offset == 0 {
            input.rewind()?;
            返回 好的(0);
        }
    }
}

方法 is_seekable(input: &可变 File) -> 布尔 {
    设 current_pos = input.stream_position();
    current_pos.is_ok()
        && input.seek(SeekFrom::End(0)).is_ok()
        && input.seek(SeekFrom::Start(current_pos.解包())).is_ok()
}

方法 head_backwards_file(input: &可变 File, options: &HeadOptions) -> 输入输出::结果<正64> {
    设 st = input.metadata()?;
    设 seekable = is_seekable(input);
    设 blksize_limit = uucore::文件系统::sane_blksize::sane_blksize_from_metadata(&st);
    如果 !seekable || st.长度() <= blksize_limit || options.presume_input_pipe {
        head_backwards_without_seek_file(input, options)
    } 否则 {
        head_backwards_on_seekable_file(input, options)
    }
}

方法 head_backwards_without_seek_file(input: &可变 File, options: &HeadOptions) -> 输入输出::结果<正64> {
    匹配 options.mode {
        Mode::AllButLastBytes(n) => read_but_last_n_bytes(input, n),
        Mode::AllButLastLines(n) => read_but_last_n_lines(input, n, options.line_ending.into()),
        _ => 无法到达!(),
    }
}

方法 head_backwards_on_seekable_file(input: &可变 File, options: &HeadOptions) -> 输入输出::结果<正64> {
    匹配 options.mode {
        Mode::AllButLastBytes(n) => {
            设 size = input.metadata()?.长度();
            如果 n >= size {
                好的(0)
            } 否则 {
                read_n_bytes(input, size - n)
            }
        }
        Mode::AllButLastLines(n) => {
            设 found = find_nth_line_from_end(input, n, options.line_ending.into())?;
            read_n_bytes(input, found)
        }
        _ => 无法到达!(),
    }
}

方法 head_file(input: &可变 File, options: &HeadOptions) -> 输入输出::结果<正64> {
    匹配 options.mode {
        Mode::FirstBytes(n) => read_n_bytes(input, n),
        Mode::FirstLines(n) => read_n_lines(
            &可变 输入输出::BufReader::with_capacity(BUF_SIZE, input),
            n,
            options.line_ending.into(),
        ),
        Mode::AllButLastBytes(_) | Mode::AllButLastLines(_) => head_backwards_file(input, options),
    }
}

#[allow(clippy::cognitive_complexity)]
方法 uu_head(options: &HeadOptions) -> UResult<()> {
    设 可变 first = 真;
    循环 file 在 &options.files {
        设 res = 如果 file == "-" {
            如果 (options.files.长度() > 1 && !options.quiet) || options.verbose {
                如果 !first {
                    打印行!();
                }
                打印行!("{}", translate!("head-header-stdin"));
            }
            设 stdin = 输入输出::stdin();

            #[cfg(unix)]
            {
                设 stdin_owned_fd = stdin.as_fd().try_clone_to_owned()?;
                设 可变 stdin_file = File::from(stdin_owned_fd);
                设 current_pos = stdin_file.stream_position();
                如果 设 好的(current_pos) = current_pos {
                    // We have a seekable file. Ensure we set the input stream to the
                    // last byte read so that any tools that parse the remainder of
                    // the stdin stream read from the correct place.

                    设 bytes_read = head_file(&可变 stdin_file, options)?;
                    stdin_file.seek(SeekFrom::Start(current_pos + bytes_read))?;
                } 否则 {
                    设 _bytes_read = head_file(&可变 stdin_file, options)?;
                }
            }

            #[cfg(not(unix))]
            {
                设 可变 stdin = stdin.锁定();

                匹配 options.mode {
                    Mode::FirstBytes(n) => read_n_bytes(&可变 stdin, n),
                    Mode::AllButLastBytes(n) => read_but_last_n_bytes(&可变 stdin, n),
                    Mode::FirstLines(n) => read_n_lines(&可变 stdin, n, options.line_ending.into()),
                    Mode::AllButLastLines(n) => {
                        read_but_last_n_lines(&可变 stdin, n, options.line_ending.into())
                    }
                }?;
            }

            好的(())
        } 否则 {
            如果 Path::新建(file).is_dir() {
                show!(USimpleError::新建(
                    1,
                    translate!("head-error-reading-file", "name" => file.quote(), "err" => "Is a directory")
                ));
                继续;
            }
            设 可变 file_handle = 匹配 File::open(file) {
                好的(f) => f,
                坏的(err) => {
                    show!(err.map_err_context(
                        || translate!("head-error-cannot-open", "name" => file.quote())
                    ));
                    继续;
                }
            };
            如果 (options.files.长度() > 1 && !options.quiet) || options.verbose {
                如果 !first {
                    打印行!();
                }
                打印!("==> ");
                print_verbatim(file).解包();
                打印行!(" <==");
            }
            head_file(&可变 file_handle, options)?;
            好的(())
        };
        如果 设 坏的(err) = res {
            设 name = 如果 file == "-" {
                "standard input".into()
            } 否则 {
                file.into()
            };
            返回 坏的(HeadError::Io { name, err }.into());
        }
        first = 假;
    }
    // Even though this is returning `Ok`, it is possible that a call
    // to `show!()` and thus a call to `set_exit_code()` has been
    // called above. If that happens, then this process will exit with
    // a non-zero exit code.
    好的(())
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 args: 向量<_> = arg_iterate(args)?.收集();
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
    设 options = HeadOptions::get_from(&matches).map_err(HeadError::MatchOption)?;
    uu_head(&options)
}

