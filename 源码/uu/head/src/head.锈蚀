        设 input_file = "a\nb";
        设 可变 input = Cursor::新建(input_file);
        相等断言!(find_nth_line_from_end(&可变 input, 0, b'\n').解包(), 3);
        相等断言!(find_nth_line_from_end(&可变 input, 1, b'\n').解包(), 2);
    }

