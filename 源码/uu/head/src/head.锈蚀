    #[test]
    方法 test_find_nth_line_from_end() {
        // Make sure our input buffer is several multiples of BUF_SIZE in size
        // such that we can be reasonably confident we've exercised all logic paths.
        // Make the contents of the buffer look like...
        // aaaa\n
        // aaaa\n
        // aaaa\n
        // aaaa\n
        // aaaa\n
        // ...
        // This will make it easier to validate the results since each line will have
        // 5 bytes in it.

        设 minimum_buffer_size = BUF_SIZE * 4;
        设 可变 input_buffer = 向量![];
        设 可变 loop_iteration: 正64 = 0;
        当 input_buffer.长度() < minimum_buffer_size {
            循环 _n 在 0..4 {
                input_buffer.压入(b'a');
            }
            loop_iteration += 1;
            input_buffer.压入(b'\n');
        }

        设 lines_in_input_file = loop_iteration;
        设 input_length = lines_in_input_file * 5;
        相等断言!(input_length, input_buffer.长度().try_into().解包());
        设 可变 input = Cursor::新建(input_buffer);
        // We now have loop_iteration lines in the buffer Now walk backwards through the buffer
        // to confirm everything parses correctly.
        // Use a large step size to prevent the test from taking too long, but don't use a power
        // of 2 in case we miss some corner case.
        设 step_size = 511;
        循环 n 在 (0..lines_in_input_file).过滤(|v| v % step_size == 0) {
            // The 5*n comes from 5-bytes per row.
            相等断言!(
                find_nth_line_from_end(&可变 input, n, b'\n').解包(),
                input_length - 5 * n
            );
        }

        // Now confirm that if we query with a value >= lines_in_input_file we get an offset
        // of 0
        相等断言!(
            find_nth_line_from_end(&可变 input, lines_in_input_file, b'\n').解包(),
            0
        );
        相等断言!(
            find_nth_line_from_end(&可变 input, lines_in_input_file + 1, b'\n').解包(),
            0
        );
        相等断言!(
            find_nth_line_from_end(&可变 input, lines_in_input_file + 1000, b'\n').解包(),
            0
        );
    }

    #[test]
    方法 test_find_nth_line_from_end_non_terminated() {
        // Validate the find_nth_line_from_end for files that are not terminated with a final
