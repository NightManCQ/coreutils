方法 read_n_bytes(input: 实现 Read, n: 正64) -> 输入输出::结果<正64> {
    // Read the first `n` bytes from the `input` reader.
    设 可变 reader = input.take(n);

    // Write those bytes to `stdout`.
    设 stdout = 输入输出::stdout();
    设 可变 stdout = stdout.锁定();

    设 bytes_written = 输入输出::copy(&可变 reader, &可变 stdout).map_err(wrap_in_stdout_error)?;

    // Make sure we finish writing everything to the target before
    // exiting. Otherwise, when Rust is implicitly flushing, any
    // error will be silently ignored.
    stdout.flush().map_err(wrap_in_stdout_error)?;

    好的(bytes_written)
}

方法 read_n_lines(input: &可变 实现 输入输出::BufRead, n: 正64, separator: 正8) -> 输入输出::结果<正64> {
    // Read the first `n` lines from the `input` reader.
    设 可变 reader = take_lines(input, n, separator);

    // Write those bytes to `stdout`.
    设 stdout = 输入输出::stdout();
    设 stdout = stdout.锁定();
    设 可变 writer = BufWriter::with_capacity(BUF_SIZE, stdout);

    设 bytes_written = 输入输出::copy(&可变 reader, &可变 writer).map_err(wrap_in_stdout_error)?;

    // Make sure we finish writing everything to the target before
    // exiting. Otherwise, when Rust is implicitly flushing, any
    // error will be silently ignored.
    writer.flush().map_err(wrap_in_stdout_error)?;

    好的(bytes_written)
}

