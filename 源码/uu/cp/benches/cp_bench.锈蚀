使用 divan::{Bencher, black_box};
使用 标准库::文件系统;
使用 标准库::路径::Path;
使用 tempfile::TempDir;
使用 uu_cp::uumain;
使用 uucore::benchmark::{binary_data, fs_tree, fs_utils, run_util_function};

方法 bench_cp_directory<F>(bencher: Bencher, args: &[&字符串切片], setup_source: F)
何处
    F: Fn(&Path),
{
    设 temp_dir = TempDir::新建().解包();
    设 source = temp_dir.路径().加入("source");
    设 dest = temp_dir.路径().加入("dest");

    文件系统::create_dir(&source).解包();
    setup_source(&source);

    设 source_str = source.to_str().解包();
    设 dest_str = dest.to_str().解包();

    bencher.bench(|| {
        fs_utils::remove_path(&dest);

        设 可变 full_args = 向量::with_capacity(args.长度() + 2);
        full_args.extend_from_slice(args);
        full_args.压入(source_str);
        full_args.压入(dest_str);

        black_box(run_util_function(uumain, &full_args));
    });
}

#[divan::bench(args = [(5, 4, 10)])]
方法 cp_recursive_balanced_tree(
    bencher: Bencher,
    (depth, dirs_per_level, files_per_dir): (正整数大小, 正整数大小, 正整数大小),
) {
    bench_cp_directory(bencher, &["-R"], |source| {
        fs_tree::create_balanced_tree(source, depth, dirs_per_level, files_per_dir);
    });
}

