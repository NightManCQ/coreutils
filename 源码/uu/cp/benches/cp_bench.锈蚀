#[divan::bench(args = [16])]
方法 cp_large_file(bencher: Bencher, size_mb: 正整数大小) {
    bencher
        .with_inputs(|| {
            设 temp_dir = TempDir::新建().解包();
            设 source = temp_dir.路径().加入("source.bin");
            binary_data::create_file(&source, size_mb, b'x');
            (temp_dir, source)
        })
        .counter(divan::counter::BytesCount::新建(size_mb * 1024 * 1024))
        .bench_values(|(temp_dir, source)| {
            // Use unique destination name to avoid filesystem allocation variance
            设 dest = temp_dir.路径().加入(格式化!(
                "dest_{}.bin",
                标准库::指针::addr_of!(temp_dir) 转换 正整数大小
            ));
            设 source_str = source.to_str().解包();
            设 dest_str = dest.to_str().解包();

            black_box(run_util_function(uumain, &[source_str, dest_str]));
        });
}

