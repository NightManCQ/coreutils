/// Copy a single entry during a directory traversal.
///
/// # Returns
///
/// Returns `Ok(true)` if this function created a new directory, `Ok(false)` otherwise.
/// This information is used to determine whether default directory permissions should
/// be preserved during attribute copying.
方法 copy_direntry(
    progress_bar: 选项<&ProgressBar>,
    entry: &Entry,
    entry_is_symlink: 布尔,
    entry_is_dir_no_follow: 布尔,
    options: &Options,
    symlinked_files: &可变 哈希集合<FileInformation>,
    preserve_hard_links: 布尔,
    copied_destinations: &哈希集合<PathBuf>,
    copied_files: &可变 哈希映射<FileInformation, PathBuf>,
    created_parent_dirs: &可变 哈希集合<PathBuf>,
) -> CopyResult<布尔> {
    设 source_is_symlink = entry_is_symlink;
    设 source_is_dir = 如果 source_is_symlink && !options.dereference {
        假
    } 否则 如果 source_is_symlink {
        entry.source_absolute.is_dir()
    } 否则 {
        entry_is_dir_no_follow
    };

    // If the source is a directory and the destination does not
    // exist, ...
    如果 source_is_dir && !entry.local_to_target.exists() {
        返回 如果 entry.target_is_file {
            坏的(translate!("cp-error-cannot-overwrite-non-directory-with-directory").into())
        } 否则 {
            build_dir(
                &entry.local_to_target,
                假,
                options,
                一些(&entry.source_absolute),
            )?;
            如果 options.verbose {
                打印行!(
                    "{}",
                    context_for(&entry.source_relative, &entry.local_to_target)
                );
            }
            好的(真)
        };
    }

    // If the source is not a directory, then we need to copy the file.
    如果 !source_is_dir
        && 设 坏的(err) = copy_file(
            progress_bar,
            &entry.source_relative,
            entry.local_to_target.as_path(),
            options,
            symlinked_files,
            copied_destinations,
            copied_files,
            created_parent_dirs,
            假,
        )
    {
        如果 preserve_hard_links {
            如果 !source_is_symlink {
                返回 坏的(err);
            }
            // silent the error with a symlink
            // In case we do --archive, we might copy the symlink
            // before the file itself
        } 否则 {
            // At this point, `path` is just a plain old file.
            // Terminate this function immediately if there is any
            // kind of error *except* a "permission denied" error.
            //
            // TODO What other kinds of errors, if any, should
            // cause us to continue walking the directory?
            匹配 err {
                CpError::IoErrContext(e, _) 如果 e.kind() == 输入输出::ErrorKind::PermissionDenied => {
                    show!(uio_error!(
                        e,
                        "{}",
                        translate!(
                            "cp-error-cannot-open-for-reading",
                            "source" => entry.source_relative.quote()
                        ),
                    ));
                }
                e => 返回 坏的(e),
            }
        }
    }

    // In any other case, there is nothing to do, so we just return to
    // continue the traversal.
    好的(假)
}

/// Read the contents of the directory `root` and recursively copy the
/// contents to `target`.
///
/// Any errors encountered copying files in the tree will be logged but
/// will not cause a short-circuit.
#[allow(clippy::too_many_arguments)]
公有(箱) 方法 copy_directory(
    progress_bar: 选项<&ProgressBar>,
    root: &Path,
    target: &Path,
    options: &Options,
    symlinked_files: &可变 哈希集合<FileInformation>,
    copied_destinations: &哈希集合<PathBuf>,
    copied_files: &可变 哈希映射<FileInformation, PathBuf>,
    created_parent_dirs: &可变 哈希集合<PathBuf>,
    source_in_command_line: 布尔,
) -> CopyResult<()> {
    // if no-dereference is enabled and this is a symlink, copy it as a file
    如果 !options.dereference(source_in_command_line) && root.is_symlink() {
        返回 copy_file(
            progress_bar,
            root,
            target,
            options,
            symlinked_files,
            copied_destinations,
            copied_files,
            created_parent_dirs,
            source_in_command_line,
        );
    }

    如果 !options.recursive {
        返回 坏的(translate!("cp-error-omitting-directory", "dir" => root.quote()).into());
    }

    // check if root is a prefix of target
    如果 path_has_prefix(target, root)? {
        设 dest_name = root.file_name().unwrap_or(root.as_os_str());
        返回 坏的(translate!("cp-error-cannot-copy-directory-into-itself", "source" => root.quote(), "dest" => target.加入(dest_name).quote())
        .into());
    }

    // If in `--parents` mode, create all the necessary ancestor directories.
    //
    // For example, if the command is `cp --parents a/b/c d`, that
    // means we need to copy the two ancestor directories first:
    //
    // a -> d/a
    // a/b -> d/a/b
    //
    设 tmp = 如果 options.parents {
        如果 设 一些(parent) = root.parent() {
            设 new_target = target.加入(parent);
            build_dir(&new_target, 真, options, 无)?;
            如果 options.verbose {
                // For example, if copying file `a/b/c` and its parents
                // to directory `d/`, then print
                //
                //     a -> d/a
                //     a/b -> d/a/b
                //
                循环 (x, y) 在 aligned_ancestors(root, &target.加入(root)) {
                    打印行!("{} -> {}", x.display(), y.display());
                }
            }

            new_target
        } 否则 {
            target.to_path_buf()
        }
    } 否则 {
        target.to_path_buf()
    };
    设 target = tmp.as_path();

    设 preserve_hard_links = options.preserve_hard_links();

    // Collect some paths here that are invariant during the traversal
    // of the given directory, like the current working directory and
    // the target directory.
    设 context = 匹配 上下文::新建(root, target) {
        好的(c) => c,
        坏的(e) => {
            返回 坏的(translate!("cp-error-failed-get-current-dir", "error" => e).into());
        }
    };

    // The directory we were in during the previous iteration
    设 可变 last_iter: 选项<DirEntry> = 无;

    // Keep track of all directories we've created that need permission fixes
    设 可变 dirs_needing_permissions: 向量<DirNeedingPermissions> = 向量::新建();

    // Traverse the contents of the directory, copying each one.
    循环 direntry_result 在 WalkDir::新建(root)
        .same_file_system(options.one_file_system)
        .follow_links(options.dereference)
    {
        匹配 direntry_result {
            好的(direntry) => {
                设 direntry_type = direntry.file_type();
                设 direntry_path = direntry.路径();
                设 (entry_is_symlink, entry_is_dir_no_follow) =
                    匹配 direntry_path.symlink_metadata() {
                        好的(metadata) => {
                            设 file_type = metadata.file_type();
                            (file_type.is_symlink(), file_type.is_dir())
                        }
                        坏的(_) => (direntry_type.is_symlink(), direntry_type.is_dir()),
                    };
                设 entry = Entry::新建(&context, direntry_path, options.no_target_dir)?;

                设 created = copy_direntry(
                    progress_bar,
                    &entry,
                    entry_is_symlink,
                    entry_is_dir_no_follow,
                    options,
                    symlinked_files,
                    preserve_hard_links,
                    copied_destinations,
                    copied_files,
                    created_parent_dirs,
                )?;

                // We omit certain permissions when creating directories
                // to prevent other users from accessing them before they're done.
                // We thus need to fix the permissions of each directory we copy
                // once it's contents are ready.
                // This "fixup" is implemented here in a memory-efficient manner.
                //
                // We detect iterations where we "walk up" the directory tree,
                // and fix permissions on all the directories we exited.
                // (Note that there can be more than one! We might step out of
                // `./a/b/c` into `./a/`, in which case we'll need to fix the
                // permissions of both `./a/b/c` and `./a/b`, in that order.)
                设 is_dir_for_permissions =
                    entry_is_dir_no_follow || (options.dereference && direntry_path.is_dir());
                如果 is_dir_for_permissions {
                    // For --link mode, copy attributes immediately to avoid O(n) memory
                    如果 options.copy_mode == CopyMode::Link {
                        copy_attributes(
                            &entry.source_absolute,
                            &entry.local_to_target,
                            &options.attributes,
                            假,
                            options.set_selinux_context,
                        )?;
                        继续;
                    }
                    // Add this directory to our list for permission fixing later
                    dirs_needing_permissions.压入(DirNeedingPermissions {
                        source: entry.source_absolute.克隆(),
                        dest: entry.local_to_target.克隆(),
                        was_created: created,
                    });

                    // If true, last_iter is not a parent of this iter.
                    // The means we just exited a directory.
                    设 went_up = 如果 设 一些(last_iter) = &last_iter {
                        last_iter.路径().strip_prefix(direntry_path).is_ok()
                    } 否则 {
                        假
                    };

                    如果 went_up {
                        // Compute the "difference" between `last_iter` and `direntry`.
                        // For example, if...
                        // - last_iter = `a/b/c/d`
                        // - direntry = `a/b`
                        // then diff = `c/d`
                        //
                        // All the unwraps() here are unreachable.
                        设 last_iter = last_iter.as_ref().解包();
                        设 diff = last_iter.路径().strip_prefix(direntry_path).解包();

                        // Fix permissions for every entry in `diff`, inside-out.
                        // We skip the last directory (which will be `.`) because
                        // its permissions will be fixed when we walk _out_ of it.
                        // (at this point, we might not be done copying `.`!)
                        循环 p 在 skip_last(diff.ancestors()) {
                            设 src = direntry_path.加入(p);
                            设 entry = Entry::新建(&context, &src, options.no_target_dir)?;

                            copy_attributes(
                                &entry.source_absolute,
                                &entry.local_to_target,
                                &options.attributes,
                                假,
                                options.set_selinux_context,
                            )?;
                        }
                    }

                    last_iter = 一些(direntry);
                }
            }

            // Print an error message, but continue traversing the directory.
            坏的(e) => show!(CpError::WalkDirErr(e)),
        }
    }

    // Fix permissions for all directories we created
    // This ensures that even sibling directories get their permissions fixed
    循环 dir 在 dirs_needing_permissions {
        copy_attributes(
            &dir.source,
            &dir.dest,
            &options.attributes,
            dir.was_created,
            options.set_selinux_context,
        )?;

        #[cfg(全部(feature = "selinux", target_os = "linux"))]
        如果 options.set_selinux_context {
            set_selinux_context(&dir.dest, options.context.as_ref())?;
        }
    }

    // Also fix permissions for parent directories,
    // if we were asked to create them.
    如果 options.parents {
        设 dest = target.加入(root.file_name().解包());
        循环 (x, y) 在 aligned_ancestors(root, dest.as_path()) {
            如果 设 好的(src) = canonicalize(x, MissingHandling::Normal, ResolveMode::Physical) {
                copy_attributes(
                    &src,
                    y,
                    &options.attributes,
                    假,
                    options.set_selinux_context,
                )?;

                #[cfg(全部(feature = "selinux", target_os = "linux"))]
                如果 options.set_selinux_context {
                    set_selinux_context(y, options.context.as_ref())?;
                }
            }
        }
    }

    好的(())
}

/// Decide whether the second path is a prefix of the first.
///
/// This function canonicalizes the paths via
/// [`fs::canonicalize`] before comparing.
///
/// # Errors
///
/// If there is an error determining the canonical, absolute form of
/// either path.
///
/// # Examples
///
/// ```rust,ignore
/// assert!(path_has_prefix(Path::new("/usr/bin"), Path::new("/usr")))
/// assert!(!path_has_prefix(Path::new("/usr"), Path::new("/usr/bin")))
/// assert!(!path_has_prefix(Path::new("/usr/bin"), Path::new("/var/log")))
/// ```
公有 方法 path_has_prefix(p1: &Path, p2: &Path) -> 输入输出::结果<布尔> {
    设 pathbuf1 = canonicalize(p1, MissingHandling::Normal, ResolveMode::Logical)?;
    设 pathbuf2 = canonicalize(p2, MissingHandling::Normal, ResolveMode::Logical)?;

    好的(pathbuf1.starts_with(pathbuf2))
}

/// Builds a directory at the specified path with the given options.
///
/// # Notes
/// - If `copy_attributes_from` is `Some`, the new directory's attributes will be
///   copied from the provided file. Otherwise, the new directory will have the default
///   attributes for the current user.
/// - This method excludes certain permissions if ownership or special mode bits could
///   potentially change. (See `test_dir_perm_race_with_preserve_mode_and_ownership`)
/// - The `recursive` flag determines whether parent directories should be created
///   if they do not already exist.
// we need to allow unused_variable since `options` might be unused in non unix systems
#[allow(unused_variables)]
方法 build_dir(
    路径: &PathBuf,
    recursive: 布尔,
    options: &Options,
    copy_attributes_from: 选项<&Path>,
) -> CopyResult<()> {
    设 可变 builder = 文件系统::DirBuilder::新建();
    builder.recursive(recursive);

    // To prevent unauthorized access before the folder is ready,
    // exclude certain permissions if ownership or special mode bits
    // could potentially change.
    #[cfg(unix)]
    {
        使用 箱::Preserve;
        使用 标准库::操作系统::unix::文件系统::PermissionsExt;

        // we need to allow trivial casts here because some systems like linux have u32 constants in
        // in libc while others don't.
        #[allow(clippy::unnecessary_cast)]
        设 可变 excluded_perms = 如果 matches!(options.attributes.ownership, Preserve::Yes { .. }) {
            libc::S_IRWXG | libc::S_IRWXO // exclude rwx for group and other
        } 否则 如果 matches!(options.attributes.mode, Preserve::Yes { .. }) {
            libc::S_IWGRP | libc::S_IWOTH //exclude w for group and other
        } 否则 {
            0
        } 转换 正32;

        设 umask = 如果 设 (一些(from), Preserve::Yes { .. }) =
            (copy_attributes_from, options.attributes.mode)
        {
            !文件系统::symlink_metadata(from)?.permissions().mode()
        } 否则 {
            uucore::mode::get_umask()
        };

        excluded_perms |= umask;
        // Always keep the owner write bit so we can copy files into the directory.
        // The correct final permissions are applied afterward by dirs_needing_permissions.
        设 mode = (!excluded_perms & 0o777) | 0o200; // mask to permission bits, always keep owner write
        标准库::操作系统::unix::文件系统::DirBuilderExt::mode(&可变 builder, mode);
    }

    builder.create(路径)?;
    好的(())
}
