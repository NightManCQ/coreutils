    公有 方法 parse_iter<T>(values: 实现 迭代器协议<Item = T>) -> CopyResult<自身类型>
    何处
        T: 作为引用协议<字符串切片>,
    {
        设 可变 新建 = 自身类型::NONE;
        循环 value 在 values {
            新建 = 新建.union(&自身类型::parse_single_string(value.as_ref())?);
        }
        好的(新建)
    }

    /// Tries to match string containing a parameter to preserve with the corresponding entry in the
    /// Attributes struct.
    方法 parse_single_string(value: &字符串切片) -> CopyResult<自身类型> {
        设 value = value.to_lowercase();

        如果 value == "all" {
            返回 好的(自身类型::ALL);
        }

        设 可变 新建 = 自身类型::NONE;
        设 attribute = 匹配 value.as_ref() {
            "mode" => &可变 新建.mode,
            #[cfg(unix)]
            "ownership" => &可变 新建.ownership,
            "timestamps" => &可变 新建.timestamps,
            "context" => &可变 新建.context,
            "link" | "links" => &可变 新建.links,
            "xattr" => &可变 新建.xattr,
            _ => {
                返回 坏的(CpError::InvalidArgument(
                    translate!("cp-error-invalid-attribute", "value" => value.quote()),
                ));
            }
        };

        *attribute = Preserve::Yes { required: 真 };

        好的(新建)
    }
