#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 options = Options::from_matches(&matches)?;

    如果 options.overwrite == OverwriteMode::NoClobber && options.backup != BackupMode::无 {
        返回 坏的(UUsageError::新建(
            EXIT_ERR,
            translate!("cp-error-backup-mutually-exclusive"),
        ));
    }

    设 paths: 向量<PathBuf> = matches
        .get_many::<OsString>(options::PATHS)
        .映射(|v| v.映射(PathBuf::from).收集())
        .unwrap_or_default();

    设 (sources, target) = parse_path_args(paths, &options)?;

    如果 设 坏的(错误) = copy(&sources, &target, &options) {
        如果 设 CpError::NotAllFilesCopied = 错误 {
            // Error::NotAllFilesCopied is non-fatal, but the error
            // code should still be EXIT_ERR as does GNU cp
        } 否则 {
            // Else we caught a fatal bubbled-up error, log it to stderr
            show_error!("{error}");
        }
        set_exit_code(EXIT_ERR);
    }

    好的(())
}

