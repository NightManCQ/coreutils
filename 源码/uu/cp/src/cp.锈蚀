/// Handles the copy mode for a file copy operation.
///
/// This function determines how to copy a file based on the provided options.
/// It supports different copy modes, including hard linking, copying, symbolic linking, updating, and attribute-only copying.
/// It also handles file backups, overwriting, and dereferencing based on the provided options.
///
/// # Returns
///
/// * `Ok(())` - The file was copied successfully.
/// * `Err(CopyError)` - An error occurred while copying the file.
#[allow(clippy::too_many_arguments)]
方法 handle_copy_mode(
    source: &Path,
    dest: &Path,
    options: &Options,
    context: &字符串切片,
    source_metadata: &Metadata,
    symlinked_files: &可变 哈希集合<FileInformation>,
    source_in_command_line: 布尔,
    created_parent_dirs: &可变 哈希集合<PathBuf>,
) -> CopyResult<PerformedAction> {
    匹配 options.copy_mode {
        CopyMode::Link => {
            如果 dest.exists() {
                设 backup_path =
                    backup_control::get_backup_path(options.backup, dest, &options.backup_suffix);
                如果 设 一些(backup_path) = backup_path {
                    backup_dest(dest, &backup_path, dest.is_symlink())?;
                    文件系统::remove_file(dest)?;
                }
                如果 options.overwrite == OverwriteMode::Clobber(ClobberMode::Force) {
                    文件系统::remove_file(dest)?;
                }
            }
            如果 options.dereference(source_in_command_line) && source.is_symlink() {
                设 resolved =
                    canonicalize(source, MissingHandling::Missing, ResolveMode::Physical).解包();
                文件系统::hard_link(resolved, dest)
            } 否则 {
                文件系统::hard_link(source, dest)
            }
            .map_err(|e| {
                CpError::IoErrContext(
                    e,
                    translate!("cp-error-cannot-create-hard-link", "dest" => get_filename(dest).unwrap_or("?").quote(), "source" => get_filename(source).unwrap_or("?").quote())
                )
            })?;
        }
        CopyMode::复制协议 => {
            copy_helper(
                source,
                dest,
                options,
                context,
                source_metadata,
                symlinked_files,
                created_parent_dirs,
            )?;
        }
        CopyMode::SymLink => {
            如果 dest.exists() && options.overwrite == OverwriteMode::Clobber(ClobberMode::Force) {
                文件系统::remove_file(dest)?;
            }
            symlink_file(source, dest, symlinked_files)?;
        }
        CopyMode::Update => {
            如果 dest.exists() {
                匹配 options.update {
                    UpdateMode::All => {
                        copy_helper(
                            source,
                            dest,
                            options,
                            context,
                            source_metadata,
                            symlinked_files,
                            created_parent_dirs,
                        )?;
                    }
                    UpdateMode::无 => {
                        如果 options.debug {
                            打印行!("skipped {}", dest.quote());
                        }

                        返回 好的(PerformedAction::Skipped);
                    }
                    UpdateMode::NoneFail => {
                        返回 坏的(CpError::错误协议(
                            translate!("cp-error-not-replacing", "file" => dest.quote()),
                        ));
                    }
                    UpdateMode::IfOlder => {
                        设 dest_metadata = 文件系统::symlink_metadata(dest)?;

                        设 src_time = source_metadata.modified()?;
                        设 dest_time = dest_metadata.modified()?;
                        如果 src_time <= dest_time {
                            返回 好的(PerformedAction::Skipped);
                        }

                        options.overwrite.verify(dest, options.debug)?;

                        copy_helper(
                            source,
                            dest,
                            options,
                            context,
                            source_metadata,
                            symlinked_files,
                            created_parent_dirs,
                        )?;
                    }
                }
            } 否则 {
                copy_helper(
                    source,
                    dest,
                    options,
                    context,
                    source_metadata,
                    symlinked_files,
                    created_parent_dirs,
                )?;
            }
        }
        CopyMode::AttrOnly => {
            OpenOptions::新建()
                .写锁定(真)
                .truncate(假)
                .create(真)
                .open(dest)
                .解包();
        }
    }

    好的(PerformedAction::Copied)
}

/// Calculates the permissions for the destination file in a copy operation.
