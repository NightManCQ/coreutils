        file_type.is_fifo() || file_type.is_char_device() || file_type.is_block_device()
    }
    #[cfg(not(unix))]
    {
        设 _ = metadata;
        假
    }
}

#[cfg(unix)]
方法 handle_no_preserve_mode(options: &Options, org_mode: 正32) -> 正32 {
    设 (is_preserve_mode, is_explicit_no_preserve_mode) = options.preserve_mode();
    如果 !is_preserve_mode {
        使用 libc::{
            S_IRGRP, S_IROTH, S_IRUSR, S_IRWXG, S_IRWXO, S_IRWXU, S_IWGRP, S_IWOTH, S_IWUSR,
        };

        #[cfg(not(任意(
            target_os = "android",
            target_os = "macos",
            target_os = "freebsd",
            target_os = "redox",
        )))]
        {
            常量 MODE_RW_UGO: 正32 = S_IRUSR | S_IWUSR | S_IRGRP | S_IWGRP | S_IROTH | S_IWOTH;
            常量 S_IRWXUGO: 正32 = S_IRWXU | S_IRWXG | S_IRWXO;
            返回 如果 is_explicit_no_preserve_mode {
                MODE_RW_UGO
            } 否则 {
                org_mode & S_IRWXUGO
            };
        }

        #[cfg(任意(
            target_os = "android",
            target_os = "macos",
            target_os = "freebsd",
            target_os = "redox",
        ))]
        {
            #[allow(clippy::unnecessary_cast)]
            常量 MODE_RW_UGO: 正32 =
                (S_IRUSR | S_IWUSR | S_IRGRP | S_IWGRP | S_IROTH | S_IWOTH) 转换 正32;
            #[allow(clippy::unnecessary_cast)]
            常量 S_IRWXUGO: 正32 = (S_IRWXU | S_IRWXG | S_IRWXO) 转换 正32;
            返回 如果 is_explicit_no_preserve_mode {
                MODE_RW_UGO
            } 否则 {
                org_mode & S_IRWXUGO
            };
        }
    }

    org_mode
}

/// Copy the file from `source` to `dest` either using the normal `fs::copy` or a
/// copy-on-write scheme if --reflink is specified and the filesystem supports it.
方法 copy_helper(
    source: &Path,
    dest: &Path,
    options: &Options,
    context: &字符串切片,
    source_metadata: &Metadata,
    symlinked_files: &可变 哈希集合<FileInformation>,
    created_parent_dirs: &可变 哈希集合<PathBuf>,
) -> CopyResult<()> {
    如果 options.parents {
        设 parent = dest.parent().unwrap_or(dest);
        如果 created_parent_dirs.插入(parent.to_path_buf()) {
            文件系统::create_dir_all(parent)?;
        }
    }

    如果 path_ends_with_terminator(dest) && !dest.is_dir() {
        返回 坏的(CpError::NotADirectory(dest.to_path_buf()));
    }

    #[cfg(unix)]
    如果 options.recursive && !options.copy_contents {
        设 ft = source_metadata.file_type();
        如果 ft.is_socket() {
            返回 copy_socket(dest, options.overwrite, options.debug);
        }
        如果 ft.is_fifo() {
            返回 copy_fifo(dest, options.overwrite, options.debug);
        }
        如果 ft.is_char_device() || ft.is_block_device() {
            返回 copy_node(dest, source_metadata, options.overwrite, options.debug);
        }
    }

    如果 source_metadata.is_symlink() {
        copy_link(source, dest, symlinked_files, options)?;
    } 否则 {
        设 copy_debug = copy_on_write(
            source,
            dest,
            options.reflink_mode,
            options.sparse_mode,
            context,
            #[cfg(unix)]
            is_stream(source_metadata),
        )?;

        如果 !options.attributes_only && options.debug {
            show_debug(&copy_debug);
        }
    }

    好的(())
}

// "Copies" a FIFO by creating a new one. This workaround is because Rust's
// built-in fs::copy does not handle FIFOs (see rust-lang/rust/issues/79390).
#[cfg(unix)]
方法 copy_fifo(dest: &Path, overwrite: OverwriteMode, debug: 布尔) -> CopyResult<()> {
    如果 dest.exists() {
        overwrite.verify(dest, debug)?;
        文件系统::remove_file(dest)?;
    }

    make_fifo(dest)
        .map_err(|_| translate!("cp-error-cannot-create-fifo", "path" => dest.quote()).into())
}

#[cfg(unix)]
方法 copy_socket(dest: &Path, overwrite: OverwriteMode, debug: 布尔) -> CopyResult<()> {
    如果 dest.exists() {
        overwrite.verify(dest, debug)?;
        文件系统::remove_file(dest)?;
    }

    UnixListener::bind(dest)?;
    好的(())
}

#[cfg(unix)]
方法 copy_node(
    dest: &Path,
    source_metadata: &Metadata,
    overwrite: OverwriteMode,
    debug: 布尔,
) -> CopyResult<()> {
    如果 dest.exists() {
        overwrite.verify(dest, debug)?;
        文件系统::remove_file(dest)?;
    }
    设 sflag = 如果 source_metadata.file_type().is_char_device() {
        SFlag::S_IFCHR
    } 否则 {
        SFlag::S_IFBLK
    };
    设 mode = Mode::from_bits_truncate(source_metadata.mode() 转换 mode_t);
    nix_mknod(dest, sflag, mode, source_metadata.rdev() 转换 dev_t)
        .map_err(|e| translate!("cp-error-cannot-create-special-file", "path" => dest.quote(), "error" => e.desc()).into())
}

方法 copy_link(
    source: &Path,
    dest: &Path,
    symlinked_files: &可变 哈希集合<FileInformation>,
    options: &Options,
) -> CopyResult<()> {
    // Here, we will copy the symlink itself (actually, just recreate it)
    设 link = 文件系统::read_link(source)?;
    // we always need to remove the file to be able to create a symlink,
    // even if it is writeable.
    如果 dest.is_symlink() || dest.is_file() {
        delete_path(dest, options)?;
    }
    symlink_file(&link, dest, symlinked_files)?;
    copy_attributes(
        source,
        dest,
        &options.attributes,
        假,
        options.set_selinux_context,
    )
}

/// Generate an error message if `target` is not the correct `target_type`
公有 方法 verify_target_type(target: &Path, target_type: TargetType) -> CopyResult<()> {
    匹配 (target_type, target.is_dir()) {
        (TargetType::Directory, 假) => 坏的(translate!("cp-error-target-not-directory", "target" => target.quote())
        .into()),
        (TargetType::File, 真) => 坏的(translate!("cp-error-cannot-overwrite-directory-with-non-directory", "dir" => target.quote())
        .into()),
