            ownership: update_preserve_field(自身.ownership, other.ownership),
            mode: update_preserve_field(自身.mode, other.mode),
            timestamps: update_preserve_field(自身.timestamps, other.timestamps),
            context: update_preserve_field(自身.context, other.context),
            links: update_preserve_field(自身.links, other.links),
