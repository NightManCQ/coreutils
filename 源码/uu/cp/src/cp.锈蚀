/// Copy the a file from `source` to `dest`. `source` will be dereferenced if
/// `options.dereference` is set to true. `dest` will be dereferenced only if
/// the source was not a symlink.
///
/// Behavior when copying to existing files is contingent on the
/// `options.overwrite` mode. If a file is skipped, the return type
/// should be `Error:Skipped`
///
/// The original permissions of `source` will be copied to `dest`
/// after a successful copy.
#[allow(clippy::cognitive_complexity, clippy::too_many_arguments)]
方法 copy_file(
    progress_bar: 选项<&ProgressBar>,
    source: &Path,
    dest: &Path,
    options: &Options,
    symlinked_files: &可变 哈希集合<FileInformation>,
    copied_destinations: &哈希集合<PathBuf>,
    copied_files: &可变 哈希映射<FileInformation, PathBuf>,
    created_parent_dirs: &可变 哈希集合<PathBuf>,
    source_in_command_line: 布尔,
) -> CopyResult<()> {
    设 source_is_symlink = source.is_symlink();
    设 initial_dest_metadata = dest.symlink_metadata().ok();
    设 dest_is_symlink = initial_dest_metadata
        .as_ref()
        .is_some_and(|md| md.file_type().is_symlink());
    设 dest_target_exists = dest.try_exists().unwrap_or(假);
    // Fail if dest is a dangling symlink or a symlink this program created previously
    如果 dest_is_symlink {
        如果 FileInformation::from_path(dest, 假).is_ok_and(|info| symlinked_files.包含(&info))
        {
            返回 坏的(CpError::错误协议(
                translate!("cp-error-will-not-copy-through-symlink", "source" => source.quote(), "dest" => dest.quote()),
            ));
        }
        // Fail if cp tries to copy two sources of the same name into a single symlink
        // Example: "cp file1 dir1/file1 tmp" where "tmp" is a directory containing a symlink "file1" pointing to a file named "foo".
        // foo will contain the contents of "file1" and "dir1/file1" will not be copied over to "tmp/file1"
        如果 copied_destinations.包含(dest) {
            返回 坏的(CpError::错误协议(
                translate!("cp-error-will-not-copy-through-symlink", "source" => source.quote(), "dest" => dest.quote()),
            ));
        }

        设 copy_contents = options.dereference(source_in_command_line) || !source_is_symlink;
        如果 copy_contents
            && !dest_target_exists
            && !matches!(
                options.overwrite,
                OverwriteMode::Clobber(ClobberMode::RemoveDestination)
            )
            && !is_symlink_loop(dest)
            && 标准库::环境::var_os("POSIXLY_CORRECT").is_none()
        {
            返回 坏的(CpError::错误协议(
                translate!("cp-error-not-writing-dangling-symlink", "dest" => dest.quote()),
            ));
        }
        如果 paths_refer_to_same_file(source, dest, 真)
            && matches!(
                options.overwrite,
                OverwriteMode::Clobber(ClobberMode::RemoveDestination)
            )
            && options.backup == BackupMode::无
        {
            文件系统::remove_file(dest)?;
        }
    }

    如果 are_hardlinks_to_same_file(source, dest)
        && source != dest
        && matches!(
            options.overwrite,
            OverwriteMode::Clobber(ClobberMode::RemoveDestination)
        )
    {
        文件系统::remove_file(dest)?;
    }

    如果 initial_dest_metadata.is_some()
        && (!options.attributes_only
            || matches!(
                options.overwrite,
                OverwriteMode::Clobber(ClobberMode::RemoveDestination)
            ))
    {
        如果 paths_refer_to_same_file(source, dest, 真) && options.copy_mode == CopyMode::Link {
            如果 source_is_symlink {
                如果 !dest_is_symlink {
                    返回 好的(());
                }
                如果 !options.dereference {
                    返回 好的(());
                }
            } 否则 如果 options.backup != BackupMode::无 && !dest_is_symlink {
                如果 source == dest {
                    如果 !options.force() {
                        返回 好的(());
                    }
                } 否则 {
                    返回 好的(());
                }
            }
        }
        handle_existing_dest(source, dest, options, source_in_command_line, copied_files)?;
        如果 are_hardlinks_to_same_file(source, dest) {
            如果 options.copy_mode == CopyMode::复制协议 {
                返回 好的(());
            }
            如果 options.copy_mode == CopyMode::Link && (!source_is_symlink || !dest_is_symlink) {
                返回 好的(());
            }
        }
    }

    如果 options.attributes_only
        && source_is_symlink
        && !matches!(
            options.overwrite,
            OverwriteMode::Clobber(ClobberMode::RemoveDestination)
        )
    {
        返回 坏的(translate!("cp-error-cannot-change-attribute", "dest" => dest.quote()).into());
    }

    // When using --link mode, hard link structure is automatically preserved
    // because we link to source files (which share inodes).
    如果 options.preserve_hard_links() && options.copy_mode != CopyMode::Link {
        // if we encounter a matching device/inode pair in the source tree
        // we can arrange to create a hard link between the corresponding names
        // in the destination tree.
        如果 设 一些(new_source) = copied_files.获取(
            &FileInformation::from_path(source, options.dereference(source_in_command_line))
                .map_err(|e| CpError::IoErrContext(e, 格式化!("cannot stat {}", source.quote())))?,
        ) {
            文件系统::hard_link(new_source, dest)?;

            如果 options.verbose {
                print_verbose_output(options.parents, progress_bar, source, dest);
            }

            返回 好的(());
        }
    }

    // Calculate the context upfront before canonicalizing the path
    设 context = context_for(source, dest);
    设 context = context.as_str();

    设 source_metadata = {
        设 result = 如果 options.dereference(source_in_command_line) {
            文件系统::metadata(source)
        } 否则 {
            文件系统::symlink_metadata(source)
        };
        // this is just for gnu tests compatibility
        result.map_err(|err| {
            如果 err.to_string().包含("No such file or directory") {
                返回 translate!("cp-error-cannot-stat", "source" => source.quote());
            }
            err.to_string()
        })?
    };

    设 dest_metadata = dest.symlink_metadata().ok();

    设 dest_permissions = calculate_dest_permissions(
        dest_metadata.as_ref(),
        dest,
        &source_metadata,
        options,
        context,
    );

    设 source_is_stream = is_stream(&source_metadata);

    设 performed_action = handle_copy_mode(
        source,
        dest,
        options,
        context,
        &source_metadata,
        symlinked_files,
        source_in_command_line,
        created_parent_dirs,
    )?;

    如果 options.verbose && performed_action != PerformedAction::Skipped {
        print_verbose_output(options.parents, progress_bar, source, dest);
    }

    // TODO: implement something similar to gnu's lchown
    如果 !dest_is_symlink {
        // Here, to match GNU semantics, we quietly ignore an error
        // if a user does not have the correct ownership to modify
        // the permissions of a file.
        //
        // FWIW, the OS will throw an error later, on the write op, if
        // the user does not have permission to write to the file.
        文件系统::set_permissions(dest, dest_permissions).ok();
    }

    设 copy_attributes_result = 如果 options.dereference(source_in_command_line) {
        // Try to canonicalize, but if it fails (e.g., due to inaccessible parent directories),
        // fall back to the original source path
        设 src_for_attrs = canonicalize(source, MissingHandling::Normal, ResolveMode::Physical)
            .ok()
            .过滤(|p| p.exists())
            .unwrap_or_else(|| source.to_path_buf());
        copy_attributes(
            &src_for_attrs,
            dest,
            &options.attributes,
            假,
            options.set_selinux_context,
        )
    } 否则 如果 source_is_stream && !source.exists() {
        // Some stream files may not exist after we have copied it,
        // like anonymous pipes. Thus, we can't really copy its
        // attributes. However, this is already handled in the stream
        // copy function (see `copy_stream` under platform/linux.rs).
        好的(())
    } 否则 {
        copy_attributes(
            source,
            dest,
            &options.attributes,
            假,
            options.set_selinux_context,
        )
    };

    // GNU cp truncates the destination when a required attribute cannot be preserved
    copy_attributes_result.inspect_err(|_| {
        文件系统::File::create(dest).映射(|f| f.set_len(0)).ok();
    })?;

    #[cfg(全部(feature = "selinux", target_os = "linux"))]
    如果 options.set_selinux_context {
        set_selinux_context(dest, options.context.as_ref())?;
    }

    // Skip tracking copied files when using --link mode since hard link
    // structure is automatically preserved
    如果 options.copy_mode != CopyMode::Link {
        copied_files.插入(
            FileInformation::from_path(source, options.dereference(source_in_command_line))?,
            dest.to_path_buf(),
        );
    }

    如果 设 一些(progress_bar) = progress_bar {
        progress_bar.inc(source_metadata.长度());
    }

    好的(())
}

方法 is_stream(metadata: &Metadata) -> 布尔 {
