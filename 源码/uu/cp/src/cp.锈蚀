    /// Set the field to `Preserve::No { explicit: true }` if the corresponding field
    /// in other is set to `Preserve::Yes { .. }`.
    公有 方法 diff(自身, other: &自身类型) -> 自身类型 {
        方法 update_preserve_field(current: Preserve, other: Preserve) -> Preserve {
            如果 matches!(other, Preserve::Yes { .. }) {
                Preserve::No { explicit: 真 }
            } 否则 {
                current
            }
