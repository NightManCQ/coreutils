/// Checks whether an existing destination is a fifo
方法 check_dest_is_fifo(dest: &Path) -> 布尔 {
    // If our destination file exists and its a fifo , we do a standard copy .
    设 file_type = 标准库::文件系统::metadata(dest);
    匹配 file_type {
        好的(f) => f.file_type().is_fifo(),

        _ => 假,
    }
}

/// Copy the contents of a stream from `source` to `dest`.
方法 copy_stream<P>(source: P, dest: P) -> 标准库::输入输出::结果<正64>
何处
    P: 作为引用协议<Path>,
{
    // For some reason,
    //
    //     cp --preserve=ownership --copy-contents fifo fifo2
    //
    // causes `fifo2` to be created with limited permissions (mode 622
    // or maybe 600 it seems), and then after `fifo` is closed, the
    // permissions get updated to match those of `fifo`. This doesn't
    // make much sense to me but the behavior appears in
    // `tests/cp/file-perm-race.sh`.
    //
    // So it seems that if `--preserve=ownership` is true then what we
    // need to do is create the destination file with limited
    // permissions, copy the contents, then update the permissions. If
    // `--preserve=ownership` is not true, however, then we can just
    // match the mode of the source file.
    //
    // TODO Update the code below to respect the case where
    // `--preserve=ownership` is not true.
    设 可变 src_file = File::open(&source)?;
    设 mode = 0o622 & !get_umask();
    设 可变 dst_file = OpenOptions::新建()
        .create(真)
        .写锁定(真)
        .mode(mode)
        .open(&dest)?;

    设 dest_is_stream = is_stream(&dst_file.metadata()?);
    如果 !dest_is_stream {
        // `copy_stream` doesn't clear the dest file, if dest is not a stream, we should clear it manually.
        dst_file.set_len(0)?;
    }

    设 num_bytes_copied = buf_copy::copy_stream(&可变 src_file, &可变 dst_file)
        .map_err(|e| 标准库::输入输出::错误协议::other(格式化!("{e}")))?;

    好的(num_bytes_copied)
}

/// Copies `source` to `dest` using copy-on-write if possible.
公有(箱) 方法 copy_on_write(
    source: &Path,
    dest: &Path,
    reflink_mode: ReflinkMode,
    sparse_mode: SparseMode,
    context: &字符串切片,
    source_is_stream: 布尔,
) -> CopyResult<CopyDebug> {
    设 可变 copy_debug = CopyDebug {
        offload: OffloadReflinkDebug::Unknown,
        reflink: OffloadReflinkDebug::Unsupported,
        sparse_detection: SparseDebug::No,
    };
    设 result = 匹配 (reflink_mode, sparse_mode) {
        (ReflinkMode::Never, SparseMode::Always) => {
            copy_debug.sparse_detection = SparseDebug::Zeros;
            // Default SparseDebug val for SparseMode::Always
            copy_debug.reflink = OffloadReflinkDebug::No;
            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Avoided;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 可变 copy_method = CopyMethod::默认协议;
                设 result = handle_reflink_never_sparse_always(source, dest);
                如果 设 好的((debug, method)) = result {
                    copy_debug = debug;
                    copy_method = method;
                }

                匹配 copy_method {
                    CopyMethod::FSCopy => 标准库::文件系统::copy(source, dest).映射(|_| ()),
                    _ => sparse_copy(source, dest),
                }
            }
        }
        (ReflinkMode::Never, SparseMode::Never) => {
            copy_debug.reflink = OffloadReflinkDebug::No;

            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Avoided;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 result = handle_reflink_never_sparse_never(source);
                如果 设 好的(debug) = result {
                    copy_debug = debug;
                }
                标准库::文件系统::copy(source, dest).映射(|_| ())
            }
        }
        (ReflinkMode::Never, SparseMode::Auto) => {
            copy_debug.reflink = OffloadReflinkDebug::No;

            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Avoided;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 可变 copy_method = CopyMethod::默认协议;
                设 result = handle_reflink_never_sparse_auto(source, dest);
                如果 设 好的((debug, method)) = result {
                    copy_debug = debug;
                    copy_method = method;
                }

                匹配 copy_method {
                    CopyMethod::SparseCopyWithoutHole => sparse_copy_without_hole(source, dest),
                    _ => 标准库::文件系统::copy(source, dest).映射(|_| ()),
                }
            }
        }
        (ReflinkMode::Auto, SparseMode::Always) => {
            copy_debug.sparse_detection = SparseDebug::Zeros; // Default SparseDebug val for
            // SparseMode::Always
            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Avoided;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 可变 copy_method = CopyMethod::默认协议;
                设 result = handle_reflink_auto_sparse_always(source, dest);
                如果 设 好的((debug, method)) = result {
                    copy_debug = debug;
                    copy_method = method;
                }

                匹配 copy_method {
                    CopyMethod::FSCopy => 克隆(source, dest, CloneFallback::FSCopy),
                    _ => 克隆(source, dest, CloneFallback::SparseCopy),
                }
            }
        }

        (ReflinkMode::Auto, SparseMode::Never) => {
            copy_debug.reflink = OffloadReflinkDebug::No;
            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Avoided;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 result = handle_reflink_auto_sparse_never(source);
                如果 设 好的(debug) = result {
                    copy_debug = debug;
                }

                克隆(source, dest, CloneFallback::FSCopy)
            }
        }
        (ReflinkMode::Auto, SparseMode::Auto) => {
            如果 source_is_stream {
                copy_debug.offload = OffloadReflinkDebug::Unsupported;
                copy_stream(source, dest).映射(|_| ())
            } 否则 {
                设 可变 copy_method = CopyMethod::默认协议;
                设 result = handle_reflink_auto_sparse_auto(source, dest);
                如果 设 好的((debug, method)) = result {
                    copy_debug = debug;
                    copy_method = method;
                }

                匹配 copy_method {
                    CopyMethod::SparseCopyWithoutHole => {
                        克隆(source, dest, CloneFallback::SparseCopyWithoutHole)
                    }
                    _ => 克隆(source, dest, CloneFallback::FSCopy),
                }
            }
        }

        (ReflinkMode::Always, SparseMode::Auto) => {
            copy_debug.sparse_detection = SparseDebug::No;
            copy_debug.reflink = OffloadReflinkDebug::Yes;

            克隆(source, dest, CloneFallback::错误协议)
        }
        (ReflinkMode::Always, _) => {
            返回 坏的(translate!("cp-error-reflink-always-sparse-auto").into());
        }
    };
    result.map_err(|e| CpError::IoErrContext(e, context.to_owned()))?;
    好的(copy_debug)
}

/// Handles debug results when flags are "--reflink=auto" and "--sparse=always" and specifies what
/// type of copy should be used
方法 handle_reflink_auto_sparse_always(
    source: &Path,
    dest: &Path,
) -> 结果<(CopyDebug, CopyMethod), 标准库::输入输出::错误协议> {
    设 可变 copy_debug = CopyDebug {
        offload: OffloadReflinkDebug::Unknown,
        reflink: OffloadReflinkDebug::Unsupported,
        sparse_detection: SparseDebug::Zeros,
    };
    设 可变 copy_method = CopyMethod::默认协议;
    设 (data_flag, size, blocks) = check_for_data(source)?;
    设 sparse_flag = check_sparse_detection(source)?;

    如果 data_flag || size < 512 {
        copy_debug.offload = OffloadReflinkDebug::Avoided;
    }
    匹配 (sparse_flag, data_flag, blocks) {
        (真, 真, 0) => {
            // Handling funny files with 0 block allocation but has data
            // in it
            copy_method = CopyMethod::FSCopy;
            copy_debug.sparse_detection = SparseDebug::SeekHoleZeros;
        }
        (假, 真, 0) => copy_method = CopyMethod::FSCopy,

        (真, 假, 0) => copy_debug.sparse_detection = SparseDebug::SeekHole,
        (真, 真, _) => copy_debug.sparse_detection = SparseDebug::SeekHoleZeros,

        (真, 假, _) => copy_debug.sparse_detection = SparseDebug::SeekHole,

        (_, _, _) => (),
    }
    如果 check_dest_is_fifo(dest) {
        copy_method = CopyMethod::FSCopy;
    }
    好的((copy_debug, copy_method))
}

/// Handles debug results when flags are "--reflink=auto" and "--sparse=auto" and specifies what
/// type of copy should be used
方法 handle_reflink_never_sparse_never(source: &Path) -> 结果<CopyDebug, 标准库::输入输出::错误协议> {
    设 可变 copy_debug = CopyDebug {
        offload: OffloadReflinkDebug::Unknown,
        reflink: OffloadReflinkDebug::No,
        sparse_detection: SparseDebug::No,
    };
    设 (data_flag, size, _blocks) = check_for_data(source)?;
    设 sparse_flag = check_sparse_detection(source)?;

    如果 sparse_flag {
        copy_debug.sparse_detection = SparseDebug::SeekHole;
    }

    如果 data_flag || size < 512 {
        copy_debug.offload = OffloadReflinkDebug::Avoided;
    }
    好的(copy_debug)
}

/// Handles debug results when flags are "--reflink=auto" and "--sparse=never", files will be copied
