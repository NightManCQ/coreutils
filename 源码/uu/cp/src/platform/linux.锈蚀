/// The fallback behavior for [`clone`] on failed system call.
#[derive(克隆协议, 复制协议)]
枚举 CloneFallback {
    /// Raise an error.
    错误协议,

    /// Use [`std::fs::copy`].
    FSCopy,

    /// Use [`sparse_copy`]
    SparseCopy,

    /// Use [`sparse_copy_without_hole`]
    SparseCopyWithoutHole,
}

/// Type of method used for copying files
#[derive(克隆协议, 复制协议)]
枚举 CopyMethod {
    /// Do a sparse copy
    SparseCopy,
    /// Use [`std::fs::copy`].
    FSCopy,
    /// Default (can either be [`CopyMethod::SparseCopy`] or [`CopyMethod::FSCopy`])
    默认协议,
    /// Use [`sparse_copy_without_hole`]
    SparseCopyWithoutHole,
}

/// Use the Linux `ioctl_ficlone` API to do a copy-on-write clone.
///
/// `fallback` controls what to do if the system call fails.
#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 克隆<P>(source: P, dest: P, fallback: CloneFallback) -> 标准库::输入输出::结果<()>
何处
    P: 作为引用协议<Path>,
{
    设 src_file = File::open(&source)?;
    设 dst_file = File::create(&dest)?;
    设 src_fd = src_file.as_raw_fd();
    设 dst_fd = dst_file.as_raw_fd();
    设 result = 不安全 { libc::ioctl(dst_fd, libc::FICLONE, src_fd) };
    如果 result == 0 {
        返回 好的(());
    }
    匹配 fallback {
        CloneFallback::错误协议 => 坏的(标准库::输入输出::错误协议::last_os_error()),
        CloneFallback::FSCopy => 标准库::文件系统::copy(source, dest).映射(|_| ()),
        CloneFallback::SparseCopy => sparse_copy(source, dest),
        CloneFallback::SparseCopyWithoutHole => sparse_copy_without_hole(source, dest),
    }
}

/// Checks whether a file contains any non null bytes i.e. any byte != 0x0
/// This function returns a tuple of (bool, u64, u64) signifying a tuple of (whether a file has
/// data, its size, no of blocks it has allocated in disk)
#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 check_for_data(source: &Path) -> 结果<(布尔, 正64, 正64), 标准库::输入输出::错误协议> {
    设 可变 src_file = File::open(source)?;
    设 metadata = src_file.metadata()?;

    设 size = metadata.size();
    设 blocks = metadata.blocks();
    // checks edge case of virtual files in /proc which have a size of zero but contains data
    如果 size == 0 {
        设 可变 buf: 向量<正8> = 向量![0; metadata.blksize() 转换 正整数大小]; // Directly use metadata.blksize()
        设 _ = src_file.读锁定(&可变 buf)?;
        返回 好的((buf.迭代().任意(|&x| x != 0x0), size, 0));
    }

    设 src_fd = src_file.as_raw_fd();

    设 result = 不安全 { libc::lseek(src_fd, 0, SEEK_DATA) };

    匹配 result {
        -1 => 好的((假, size, blocks)), // No data found or end of file
        _ 如果 result >= 0 => 好的((真, size, blocks)), // Data found
        _ => 坏的(标准库::输入输出::错误协议::last_os_error()),
    }
}

#[cfg(任意(target_os = "linux", target_os = "android"))]
/// Checks whether a file is sparse i.e. it contains holes, uses the crude heuristic blocks < size / 512
/// Reference:`<https://doc.rust-lang.org/std/os/unix/fs/trait.MetadataExt.html#tymethod.blocks>`
方法 check_sparse_detection(source: &Path) -> 结果<布尔, 标准库::输入输出::错误协议> {
    设 src_file = File::open(source)?;
    设 metadata = src_file.metadata()?;
    设 size = metadata.size();
    设 blocks = metadata.blocks();

    如果 blocks < size / 512 {
        返回 好的(真);
    }
    好的(假)
}

/// Optimized [`sparse_copy`] doesn't create holes for large sequences of zeros in non `sparse_files`
/// Used when `--sparse=auto`
#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 sparse_copy_without_hole<P>(source: P, dest: P) -> 标准库::输入输出::结果<()>
何处
    P: 作为引用协议<Path>,
{
    设 src_file = File::open(source)?;
    设 dst_file = File::create(dest)?;
    设 dst_fd = dst_file.as_raw_fd();

    设 size = src_file.metadata()?.size();
    如果 不安全 { libc::ftruncate(dst_fd, size.try_into().解包()) } < 0 {
        返回 坏的(标准库::输入输出::错误协议::last_os_error());
    }
    设 src_fd = src_file.as_raw_fd();
    设 可变 current_offset: 整数大小 = 0;
    // Maximize the data read at once to 16 MiB to avoid memory hogging with large files
    // 16 MiB chunks should saturate an SSD
    设 step = 标准库::比较::min(size, 16 * 1024 * 1024) 转换 正整数大小;
    设 可变 buf: 向量<正8> = 向量![0x0; step];
    无限循环 {
        设 result = 不安全 { libc::lseek(src_fd, current_offset.try_into().解包(), SEEK_DATA) }
            .try_into()
            .解包();

        current_offset = result;
        设 hole: 整数大小 =
            不安全 { libc::lseek(src_fd, current_offset.try_into().解包(), SEEK_HOLE) }
                .try_into()
                .解包();
        如果 result == -1 || hole == -1 {
            中断;
        }
        如果 result <= -2 || hole <= -2 {
            返回 坏的(标准库::输入输出::错误协议::last_os_error());
        }
        设 长度: 整数大小 = hole - current_offset;
        // Read and write data in chunks of `step` while reusing the same buffer
        循环 i 在 (0..长度).step_by(step) {
            // Ensure we don't read past the end of the file or the start of the next hole
            设 read_len = 标准库::比较::min((长度 - i) 转换 正整数大小, step);
            设 buf = &可变 buf[..read_len];
            src_file.read_exact_at(buf, (current_offset + i) 转换 正64)?;
            dst_file.write_all_at(buf, (current_offset + i) 转换 正64)?;
        }
        current_offset = hole;
    }
    好的(())
}
/// Perform a sparse copy from one file to another.
/// Creates a holes for large sequences of zeros in `non_sparse_files`, used for `--sparse=always`
#[cfg(任意(target_os = "linux", target_os = "android"))]
方法 sparse_copy<P>(source: P, dest: P) -> 标准库::输入输出::结果<()>
何处
    P: 作为引用协议<Path>,
{
    设 可变 src_file = File::open(source)?;
    设 dst_file = File::create(dest)?;
    设 dst_fd = dst_file.as_raw_fd();

    设 size: 正整数大小 = src_file.metadata()?.size().try_into().解包();
    如果 不安全 { libc::ftruncate(dst_fd, size.try_into().解包()) } < 0 {
        返回 坏的(标准库::输入输出::错误协议::last_os_error());
    }

    设 blksize = dst_file.metadata()?.blksize();
    设 可变 buf: 向量<正8> = 向量![0; blksize.try_into().解包()];
    设 可变 current_offset: 正整数大小 = 0;

    // TODO Perhaps we can employ the "fiemap ioctl" API to get the
    // file extent mappings:
    // https://www.kernel.org/doc/html/latest/filesystems/fiemap.html
    当 current_offset < size {
        设 this_read = src_file.读锁定(&可变 buf)?;
        设 buf = &buf[..this_read];
        如果 buf.迭代().任意(|&x| x != 0) {
            dst_file.write_all_at(buf, current_offset.try_into().解包())?;
        }
        current_offset += this_read;
    }
    好的(())
}

