方法 handle_reflink_auto_sparse_never(source: &Path) -> 结果<CopyDebug, 标准库::输入输出::错误协议> {
    设 可变 copy_debug = CopyDebug {
        offload: OffloadReflinkDebug::Unknown,
        reflink: OffloadReflinkDebug::No,
        sparse_detection: SparseDebug::No,
    };

    设 (data_flag, size, _blocks) = check_for_data(source)?;
    设 sparse_flag = check_sparse_detection(source)?;

    如果 sparse_flag {
        copy_debug.sparse_detection = SparseDebug::SeekHole;
    }

    如果 data_flag || size < 512 {
        copy_debug.offload = OffloadReflinkDebug::Avoided;
    }
