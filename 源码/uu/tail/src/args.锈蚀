    #[case::follow_short_with_retry(向量!["-f", "--retry"], 一些(FollowMode::Descriptor), 真)]
    #[case::follow_overwrites_previous_selection_1(向量!["--follow=name", "--follow=descriptor"], 一些(FollowMode::Descriptor), 假)]
    #[case::follow_overwrites_previous_selection_2(向量!["--follow=descriptor", "--follow=name"], 一些(FollowMode::Name), 假)]
