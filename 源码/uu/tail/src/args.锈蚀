    Negative(正64),
    Positive(正64),
    PlusZero,
    MinusZero,
}

#[derive(调试协议, 偏等比较协议, 相等比较协议)]
公有 枚举 FilterMode {
    Bytes(Signum),

    /// Mode for lines delimited by delimiter as u8
    Lines(Signum, 正8),
}

实现 FilterMode {
    方法 from_obsolete_args(args: &parse::ObsoleteArgs) -> 自身类型 {
        设 signum = 如果 args.plus {
            Signum::Positive(args.数字)
        } 否则 {
            Signum::Negative(args.数字)
        };
        如果 args.lines {
            自身类型::Lines(signum, b'\n')
        } 否则 {
            自身类型::Bytes(signum)
        }
    }

    方法 from(matches: &ArgMatches) -> UResult<自身类型> {
        设 zero_term = matches.get_flag(options::ZERO_TERM);
        设 mode = 如果 设 一些(arg) = matches.get_one::<字符串>(options::BYTES) {
            匹配 parse_num(arg) {
                好的(signum) => 自身类型::Bytes(signum),
                坏的(e) => {
                    返回 坏的(USimpleError::新建(
                        1,
                        translate!("tail-error-invalid-number-of-bytes", "arg" => e.to_string()),
                    ));
                }
            }
        } 否则 如果 设 一些(arg) = matches.get_one::<字符串>(options::LINES) {
            匹配 parse_num(arg) {
                好的(signum) => {
                    设 delimiter = 如果 zero_term { 0 } 否则 { b'\n' };
                    自身类型::Lines(signum, delimiter)
                }
                坏的(_) => {
                    返回 坏的(USimpleError::新建(
                        1,
                        translate!("tail-error-invalid-number-of-lines", "arg" => arg.quote()),
                    ));
                }
            }
        } 否则 如果 zero_term {
            自身类型::default_zero()
        } 否则 {
            自身类型::默认()
        };

        好的(mode)
    }

    方法 default_zero() -> 自身类型 {
        自身类型::Lines(Signum::Negative(10), 0)
    }
}

实现 默认协议 循环 FilterMode {
    方法 默认() -> 自身类型 {
        自身类型::Lines(Signum::Negative(10), b'\n')
