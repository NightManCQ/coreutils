    #[case::multiple_big_f(向量!["-F", "-F"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_retry_then_does_not_change(向量!["-F", "--retry"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_follow_descriptor_then_change(向量!["-F", "--follow=descriptor"], 一些(FollowMode::Descriptor), 真)]
    #[case::multiple_big_f_with_follow_descriptor_then_no_change(向量!["-F", "--follow=descriptor", "-F"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_follow_short_then_change(向量!["-F", "-f"], 一些(FollowMode::Descriptor), 真)]
    #[case::follow_descriptor_with_big_f_then_change(向量!["--follow=descriptor", "-F"], 一些(FollowMode::Name), 真)]
    #[case::follow_short_with_big_f_then_change(向量!["-f", "-F"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_follow_name_then_not_change(向量!["-F", "--follow=name"], 一些(FollowMode::Name), 真)]
    #[case::follow_name_with_big_f_then_not_change(向量!["--follow=name", "-F"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_multiple_long_follow(向量!["--follow=name", "-F", "--follow=descriptor"], 一些(FollowMode::Descriptor), 真)]
    #[case::big_f_with_multiple_long_follow_name(向量!["--follow=name", "-F", "--follow=name"], 一些(FollowMode::Name), 真)]
    #[case::big_f_with_multiple_short_follow(向量!["-f", "-F", "-f"], 一些(FollowMode::Descriptor), 真)]
    #[case::multiple_big_f_with_multiple_short_follow(向量!["-f", "-F", "-f", "-F"], 一些(FollowMode::Name), 真)]
    方法 test_parse_settings_follow_mode_and_retry(
        #[case] args: 向量<&字符串切片>,
