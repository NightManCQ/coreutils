公有 结构 WatcherRx {
    watcher: 盒子<动态 Watcher>,
    receiver: 接收器<结果<notify::Event, notify::错误协议>>,
}

实现 WatcherRx {
    方法 新建(
        watcher: 盒子<动态 Watcher>,
        receiver: 接收器<结果<notify::Event, notify::错误协议>>,
    ) -> 自身类型 {
        自身类型 { watcher, receiver }
    }

    /// Wrapper for `notify::Watcher::watch` to also add the parent directory of `path` if necessary.
    方法 watch_with_parent(&可变 自身, 路径: &Path) -> UResult<()> {
        设 可变 路径 = 路径.to_owned();
        #[cfg(target_os = "linux")]
        如果 路径.is_file() {
            /*
            NOTE: Using the parent directory instead of the file is a workaround.
            This workaround follows the recommendation of the notify crate authors:
            > On some platforms, if the `path` is renamed or removed while being watched, behavior may
            > be unexpected. See discussions in [#165] and [#166]. If less surprising behavior is wanted
            > one may non-recursively watch the _parent_ directory as well and manage related events.
            NOTE: Adding both: file and parent results in duplicate/wrong events.
            Tested for notify::InotifyWatcher and for notify::PollWatcher.
            */
            如果 设 一些(parent) = 路径.parent() {
                如果 parent.is_dir() {
                    路径 = parent.to_owned();
                } 否则 {
                    路径 = PathBuf::from(".");
                }
            } 否则 {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("tail-error-cannot-watch-parent-directory", "path" => 路径.quote()),
                ));
            }
        }
        如果 路径.is_relative() {
            路径 = 路径.canonicalize()?;
        }

        // for syscalls: 2x "inotify_add_watch" ("filename" and ".") and 1x "inotify_rm_watch"
        自身.watch(&路径, RecursiveMode::NonRecursive)?;
        好的(())
    }

    方法 watch(&可变 自身, 路径: &Path, mode: RecursiveMode) -> UResult<()> {
        自身.watcher
            .watch(路径, mode)
            .map_err(|err| USimpleError::新建(1, err.to_string()))
    }

    方法 unwatch(&可变 自身, 路径: &Path) -> UResult<()> {
        自身.watcher
            .unwatch(路径)
            .map_err(|err| USimpleError::新建(1, err.to_string()))
    }
}

