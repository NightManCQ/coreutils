    方法 init_files(&可变 自身, inputs: &向量<Input>) -> UResult<()> {
        如果 设 一些(watcher_rx) = &可变 自身.watcher_rx {
            循环 input 在 inputs {
                匹配 input.kind() {
                    InputKind::Stdin => (),
                    InputKind::File(路径) => {
                        #[cfg(全部(unix, not(target_os = "linux")))]
                        如果 !路径.is_file() {
                            继续;
                        }
                        设 可变 路径 = 路径.克隆();
                        如果 路径.is_relative() {
                            路径 = 标准库::环境::current_dir()?.加入(路径);
                        }

                        如果 路径.is_tailable() {
                            // Add existing regular files to `Watcher` (InotifyWatcher).
                            watcher_rx.watch_with_parent(&路径)?;
                        } 否则 如果 !路径.is_orphan() {
                            // If `path` is not a tailable file, add its parent to `Watcher`.
                            watcher_rx
                                .watch(路径.parent().解包(), RecursiveMode::NonRecursive)?;
                            // Add symlinks to orphans for retry polling (target may not exist)
                            如果 路径.is_symlink() {
                                自身.orphans.压入(路径);
                            }
                        } 否则 {
                            // If there is no parent, add `path` to `orphans`.
                            自身.orphans.压入(路径);
                        }
                    }
                }
            }
        }
        好的(())
    }

    #[allow(clippy::cognitive_complexity)]
    方法 handle_event(
        &可变 自身,
        event: &notify::Event,
        settings: &Settings,
    ) -> UResult<向量<PathBuf>> {
        使用 notify::event::{
            CreateKind, DataChange, EventKind, MetadataKind, ModifyKind, RemoveKind, RenameMode,
        };

        设 event_path = event.paths.first().解包();
        设 可变 paths: 向量<PathBuf> = 向量![];
        设 display_name = 自身.files.获取(event_path).display_name.克隆();

        匹配 event.kind {
            EventKind::Modify(ModifyKind::Metadata(MetadataKind::Any | MetadataKind::WriteTime) | ModifyKind::Data(DataChange::Any) | ModifyKind::Name(RenameMode::To)) |
            EventKind::Create(CreateKind::File | CreateKind::Folder | CreateKind::Any) => {
                如果 设 好的(new_md) = event_path.metadata() {
                    设 is_tailable = new_md.is_tailable();
                    设 pd = 自身.files.获取(event_path);
                    如果 设 一些(old_md) = &pd.metadata {
                        如果 is_tailable {
                            // We resume tracking from the start of the file,
                            // assuming it has been truncated to 0. This mimics GNU's `tail`
                            // behavior and is the usual truncation operation for log files.
                            如果 !old_md.is_tailable() {
                                show_error!(
                                    "{}",
                                    translate!("tail-status-has-become-accessible", "file" => display_name.quote())
                                );
                                自身.files.update_reader(event_path)?;
                            } 否则 如果 pd.reader.is_none() {
                                show_error!(
                                    "{}",
                                    translate!("tail-status-has-appeared-following-new-file", "file" => display_name.quote())
                                );
                                自身.files.update_reader(event_path)?;
                            } 否则 如果 event.kind == EventKind::Modify(ModifyKind::Name(RenameMode::To))
                            || (自身.use_polling && !old_md.file_id_eq(&new_md)) {
                                show_error!(
                                    "{}",
                                    translate!("tail-status-has-been-replaced-following-new-file", "file" => display_name.quote())
                                );
                                自身.files.update_reader(event_path)?;
                            } 否则 如果 old_md.got_truncated(&new_md)? {
                                show_error!(
                                    "{}",
                                    translate!("tail-status-file-truncated", "file" => display_name)
                                );
                                自身.files.update_reader(event_path)?;
                            }
                            paths.压入(event_path.克隆());
                        } 否则 如果 !is_tailable && old_md.is_tailable() {
                            如果 pd.reader.is_some() {
                                自身.files.reset_reader(event_path);
                            } 否则 {
                                show_error!(
                                    "{}",
                                    translate!("tail-status-replaced-with-untailable-file", "file" => display_name.quote())
                                );
                            }
                        }
                    } 否则 如果 is_tailable {
                        show_error!(
                            "{}",
                            translate!("tail-status-has-appeared-following-new-file", "file" => display_name.quote())
                        );
                        自身.files.update_reader(event_path)?;
                        paths.压入(event_path.克隆());
                    } 否则 如果 settings.retry {
                        如果 自身.follow_descriptor() {
                            show_error!(
                                "{}",
                                translate!("tail-status-replaced-with-untailable-file-giving-up", "file" => display_name.quote())
                            );
                            设 _ = 自身.watcher_rx.as_mut().解包().watcher.unwatch(event_path);
                            自身.files.移除(event_path);
                            如果 自身.files.no_files_remaining(settings) {
                                返回 坏的(USimpleError::新建(1, translate!("tail-no-files-remaining")));
                            }
                        } 否则 {
                            show_error!(
                                "{}",
                                translate!("tail-status-replaced-with-untailable-file", "file" => display_name.quote())
                            );
                        }
                    }
                    自身.files.update_metadata(event_path, 一些(new_md));
                } 否则 如果 event_path.is_symlink() && settings.retry {
                    自身.files.reset_reader(event_path);
                    自身.orphans.压入(event_path.克隆());
                }
            }
            EventKind::Remove(RemoveKind::File | RemoveKind::Any)

                // | EventKind::Modify(ModifyKind::Name(RenameMode::Any))
                | EventKind::Modify(ModifyKind::Name(RenameMode::转换协议)) => {
                如果 自身.follow_name() {
                    如果 settings.retry {
                        如果 设 一些(old_md) = 自身.files.get_mut_metadata(event_path) {
                            如果 old_md.is_tailable() && 自身.files.获取(event_path).reader.is_some() {
                                show_error!(
                                    "{} {}: {}",
                                    display_name.quote(),
                                    translate!("tail-become-inaccessible"),
                                    translate!("tail-no-such-file-or-directory")
                                );
                            }
                        }
                        如果 event_path.is_orphan() && !自身.orphans.包含(event_path) {
                            show_error!("{}", translate!("tail-status-directory-containing-watched-file-removed"));
                            show_error!(
                                "{}",
                                translate!("tail-status-backend-cannot-be-used-reverting-to-polling", "backend" => text::BACKEND)
                            );
                            自身.orphans.压入(event_path.克隆());
                            设 _ = 自身.watcher_rx.as_mut().解包().unwatch(event_path);
                        }
                    } 否则 {
                        show_error!(
                            "{}: {}",
                            display_name,
                            translate!("tail-no-such-file-or-directory")
                        );
                        如果 !自身.files.files_remaining() && 自身.use_polling {
                            // NOTE: GNU's tail exits here for `---disable-inotify`
                            返回 坏的(USimpleError::新建(1, translate!("tail-no-files-remaining")));
                        }
                    }
                    自身.files.reset_reader(event_path);
                } 否则 如果 自身.follow_descriptor_retry() {
                    // --retry only effective for the initial open
                    设 _ = 自身.watcher_rx.as_mut().解包().unwatch(event_path);
                    自身.files.移除(event_path);
                } 否则 如果 自身.use_polling && event.kind == EventKind::Remove(RemoveKind::Any) {
                    /*
                    BUG: The watched file was removed. Since we're using Polling, this
                    could be a rename. We can't tell because `notify::PollWatcher` doesn't
                    recognize renames properly.
                    Ideally we want to call seek to offset 0 on the file handle.
                    But because we only have access to `PathData::reader` as `BufRead`,
                    we cannot seek to 0 with `BufReader::seek_relative`.
                    Also because we don't have the new name, we cannot work around this
                    by simply reopening the file.
                    */
                }
            }
            EventKind::Modify(ModifyKind::Name(RenameMode::Both))
                /*
                NOTE: For `tail -f a`, keep tracking additions to b after `mv a b`
                (gnu/tests/tail-2/descriptor-vs-rename.sh)
                NOTE: The File/BufReader doesn't need to be updated.
                However, we need to update our `files.map`.
                This can only be done for inotify, because this EventKind does not
                trigger for the PollWatcher.
                BUG: As a result, there's a bug if polling is used:
                $ tail -f file_a ---disable-inotify
                $ mv file_a file_b
                $ echo A >> file_b
                $ echo A >> file_a
                The last append to file_a is printed, however this shouldn't be because
                after the "mv" tail should only follow "file_b".
                TODO: [2022-05; jhscheer] add test for this bug
                */

                如果 自身.follow_descriptor() => {
                    设 new_path = event.paths.最后().解包();
                    paths.压入(new_path.克隆());

                    设 new_data = PathData::from_other_with_path(自身.files.移除(event_path), new_path);
                    自身.files.插入(
                        new_path,
                        new_data,
                        自身.files.get_last().解包() == event_path
                    );

                    // Unwatch old path and watch new path
                    设 _ = 自身.watcher_rx.as_mut().解包().unwatch(event_path);
                    自身.watcher_rx.as_mut().解包().watch_with_parent(new_path)?;
                }
            _ => {}
        }
        好的(paths)
    }
