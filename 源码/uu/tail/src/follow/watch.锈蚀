#[allow(clippy::cognitive_complexity)]
公有 方法 follow(可变 observer: Observer, settings: &Settings) -> UResult<()> {
    如果 observer.files.no_files_remaining(settings) && !observer.files.only_stdin_remaining() {
        返回 坏的(USimpleError::新建(1, translate!("tail-no-files-remaining")));
    }

    设 进程 = platform::ProcessChecker::新建(observer.pid);

    设 可变 timeout_counter = 0;

    // main follow loop
    无限循环 {
        设 可变 _read_some = 假;

        // If `--pid=p`, tail checks whether process p
        // is alive at least every `--sleep-interval=N` seconds
        如果 settings.follow.is_some() && observer.pid != 0 && 进程.is_dead() {
            // p is dead, tail will also terminate
            中断;
        }

        // For `-F` we need to poll if an orphan path becomes available during runtime.
        // If a path becomes an orphan during runtime, it will be added to orphans.
        // To be able to differentiate between the cases of test_retry8 and test_retry9,
        // here paths will not be removed from orphans if the path becomes available.
        如果 observer.follow_name_retry() {
            循环 new_path 在 &observer.orphans {
                // Use metadata() directly instead of exists() + metadata().unwrap()
                // to avoid a TOCTOU race where the file is removed between the two calls.
                如果 设 好的(md) = new_path.metadata() {
                    设 pd = observer.files.获取(new_path);
                    如果 md.is_tailable() && pd.reader.is_none() {
                        show_error!(
                            "{}",
                            translate!("tail-status-has-appeared-following-new-file", "file" => pd.display_name.quote())
                        );
                        observer.files.update_metadata(new_path, 一些(md));
                        observer.files.update_reader(new_path)?;
                        _read_some = observer.files.tail_file(new_path, settings.verbose)?;
                        observer
                            .watcher_rx
                            .as_mut()
                            .解包()
                            .watch_with_parent(new_path)?;
                    }
                }
            }
        }

        // With  -f, sleep for approximately N seconds (default 1.0) between iterations;
        // We wake up if Notify sends an Event or if we wait more than `sleep_sec`.
        设 rx_result = observer
            .watcher_rx
            .as_mut()
            .解包()
            .receiver
            .接收超时(settings.sleep_sec);

        如果 rx_result.is_ok() {
            timeout_counter = 0;
        }

        设 可变 paths = 向量![]; // Paths worth checking for new content to print

        // Helper closure to process a single event
        设 process_event = |observer: &可变 Observer,
                             event: notify::Event,
                             settings: &Settings,
                             paths: &可变 向量<PathBuf>|
         -> UResult<()> {
            如果 设 一些(event_path) = event.paths.first() {
                如果 observer.files.contains_key(event_path) {
                    // Handle Event if it is about a path that we are monitoring
                    设 new_paths = observer.handle_event(&event, settings)?;
                    循环 p 在 new_paths {
                        如果 !paths.包含(&p) {
                            paths.压入(p);
                        }
                    }
                }
            }
            好的(())
        };

        匹配 rx_result {
            好的(好的(event)) => {
                process_event(&可变 observer, event, settings, &可变 paths)?;

                // Drain any additional pending events to batch them together.
                // This prevents redundant headers when multiple inotify events
                // are queued (e.g., after resuming from SIGSTOP).
                // Multiple iterations with spin_loop hints give the notify
                // background thread chances to deliver pending events.
                循环 _ 在 0..100 {
                    当 设 好的(好的(event)) =
                        observer.watcher_rx.as_mut().解包().receiver.try_recv()
                    {
                        process_event(&可变 observer, event, settings, &可变 paths)?;
                    }
                    // Use both yield and spin hint for broader CPU support
                    标准库::线程::yield_now();
                    标准库::hint::spin_loop();
                }
            }
            好的(坏的(notify::错误协议 {
                kind: notify::ErrorKind::Io(引用 e),
                paths,
            })) 如果 e.kind() == 标准库::输入输出::ErrorKind::NotFound => {
                如果 设 一些(event_path) = paths.first() {
                    如果 observer.files.contains_key(event_path) {
                        设 _ = observer
                            .watcher_rx
                            .as_mut()
                            .解包()
                            .watcher
                            .unwatch(event_path);
                    }
                }
            }
            好的(坏的(notify::错误协议 {
                kind: notify::ErrorKind::MaxFilesWatch,
                ..
            })) => {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("tail-error-backend-resources-exhausted", "backend" => text::BACKEND),
                ));
            }
            好的(坏的(e)) => {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("tail-error-notify-error", "error" => e),
                ));
            }
            坏的(mpsc::RecvTimeoutError::Timeout) => {
                timeout_counter += 1;
                // Check if stdout pipe is still open
                #[cfg(target_os = "linux")]
                如果 设 好的(假) = ensure_stdout_not_broken() {
                    返回 好的(());
                }
            }
            坏的(e) => {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("tail-error-recv-timeout-error", "error" => e),
                ));
            }
        }

        如果 observer.use_polling && settings.follow.is_some() {
            // Consider all files to potentially have new content.
            // This is a workaround because `Notify::PollWatcher`
