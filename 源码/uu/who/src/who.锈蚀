// spell-checker:ignore (ToDO) runlevel mesg

使用 clap::{Arg, ArgAction, Command};
使用 uucore::format_usage;
使用 uucore::translate;

模组 platform;

模组 options {
    公有 常量 ALL: &字符串切片 = "all";
    公有 常量 BOOT: &字符串切片 = "boot";
    公有 常量 DEAD: &字符串切片 = "dead";
    公有 常量 HEADING: &字符串切片 = "heading";
    公有 常量 LOGIN: &字符串切片 = "login";
    公有 常量 LOOKUP: &字符串切片 = "lookup";
    公有 常量 ONLY_HOSTNAME_USER: &字符串切片 = "only_hostname_user";
    公有 常量 PROCESS: &字符串切片 = "process";
    公有 常量 COUNT: &字符串切片 = "count";
    公有 常量 RUNLEVEL: &字符串切片 = "runlevel";
    公有 常量 SHORT: &字符串切片 = "short";
    公有 常量 TIME: &字符串切片 = "time";
    公有 常量 USERS: &字符串切片 = "users";
    公有 常量 MESG: &字符串切片 = "mesg"; // aliases: --message, --writable
    公有 常量 FILE: &字符串切片 = "FILE"; // if length=1: FILE, if length=2: ARG1 ARG2
}

方法 get_runlevel_help() -> 字符串 {
    #[cfg(target_os = "linux")]
    返回 translate!("who-help-runlevel");
    #[cfg(not(target_os = "linux"))]
    返回 translate!("who-help-runlevel-non-linux");
}

#[uucore::主函数(no_signals)]
使用 platform::uumain;

公有 方法 uu_app() -> Command {
    #[cfg(not(target_env = "musl"))]
    设 about = translate!("who-about");
    #[cfg(target_env = "musl")]
    设 about = translate!("who-about") + &translate!("who-about-musl-warning");

    设 cmd = Command::新建("who")
        .version(uucore::crate_version!())
        .about(about)
        .override_usage(format_usage(&translate!("who-usage")))
        .infer_long_args(真);
    uucore::clap_localization::configure_localized_command(cmd)
        .arg(
            Arg::新建(options::ALL)
                .long(options::ALL)
                .short('a')
                .help(translate!("who-help-all"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::BOOT)
                .long(options::BOOT)
                .short('b')
                .help(translate!("who-help-boot"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::DEAD)
                .long(options::DEAD)
                .short('d')
                .help(translate!("who-help-dead"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::HEADING)
                .long(options::HEADING)
                .short('H')
                .help(translate!("who-help-heading"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::LOGIN)
                .long(options::LOGIN)
                .short('l')
                .help(translate!("who-help-login"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::LOOKUP)
                .long(options::LOOKUP)
                .help(translate!("who-help-lookup"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::ONLY_HOSTNAME_USER)
                .short('m')
                .help(translate!("who-help-only-hostname-user"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::PROCESS)
                .long(options::PROCESS)
                .short('p')
                .help(translate!("who-help-process"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::COUNT)
                .long(options::COUNT)
                .short('q')
                .help(translate!("who-help-count"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::RUNLEVEL)
                .long(options::RUNLEVEL)
                .short('r')
                .help(get_runlevel_help())
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::SHORT)
                .long(options::SHORT)
                .short('s')
                .help(translate!("who-help-short"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::TIME)
                .long(options::TIME)
                .short('t')
                .help(translate!("who-help-time"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::USERS)
                .long(options::USERS)
                .short('u')
                .help(translate!("who-help-users"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::MESG)
                .long(options::MESG)
                .short('T')
                .visible_short_alias('w')
                .visible_aliases(["message", "writable"])
                .help(translate!("who-help-mesg"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::FILE)
                .num_args(1..=2)
                .value_hint(clap::ValueHint::FilePath),
        )
}
