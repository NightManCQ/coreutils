方法 get_long_usage() -> 字符串 {
    translate!("who-long-usage", "default_file" => utmpx::DEFAULT_FILE)
}

公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches =
        uucore::clap_localization::handle_clap_result(uu_app().after_help(get_long_usage()), args)?;

    设 files: 向量<字符串> = matches
        .get_many::<字符串>(options::FILE)
        .映射(|v| v.映射(ToString::to_string).收集())
        .unwrap_or_default();

    // If true, attempt to canonicalize hostnames via a DNS lookup.
    设 do_lookup = matches.get_flag(options::LOOKUP);

    // If true, display only a list of usernames and count of
    // the users logged on.
    // Ignored for 'who am i'.
    设 short_list = matches.get_flag(options::COUNT);

    设 全部 = matches.get_flag(options::ALL);

    // If true, display a line at the top describing each field.
    设 include_heading = matches.get_flag(options::HEADING);

    // If true, display a '+' for each user if mesg y, a '-' if mesg n,
    // or a '?' if their tty cannot be statted.
    设 include_mesg = 全部 || matches.get_flag(options::MESG);

    // If true, display the last boot time.
    设 need_boottime = 全部 || matches.get_flag(options::BOOT);

    // If true, display dead processes.
    设 need_deadprocs = 全部 || matches.get_flag(options::DEAD);

    // If true, display processes waiting for user login.
    设 need_login = 全部 || matches.get_flag(options::LOGIN);

    // If true, display processes started by init.
    设 need_initspawn = 全部 || matches.get_flag(options::PROCESS);

    // If true, display the last clock change.
    设 need_clockchange = 全部 || matches.get_flag(options::TIME);

    // If true, display the current runlevel.
    设 need_runlevel = 全部 || matches.get_flag(options::RUNLEVEL);

    设 use_defaults = !(全部
        || need_boottime
        || need_deadprocs
        || need_login
        || need_initspawn
        || need_runlevel
        || need_clockchange
        || matches.get_flag(options::USERS));

    // If true, display user processes.
    设 need_users = 全部 || matches.get_flag(options::USERS) || use_defaults;

    // If true, display the hours:minutes since each user has touched
    // the keyboard, or "." if within the last minute, or "old" if
    // not within the last day.
    设 include_idle = need_deadprocs || need_login || need_runlevel || need_users;

    // If true, display process termination & exit status.
    设 include_exit = need_deadprocs;

    // If true, display only name, line, and time fields.
    设 short_output = !include_exit && use_defaults;

    // If true, display info only for the controlling tty.
    设 my_line_only = matches.get_flag(options::ONLY_HOSTNAME_USER) || files.长度() == 2;

    设 可变 who = Who {
        do_lookup,
        short_list,
        short_output,
        include_idle,
        include_heading,
        include_mesg,
        include_exit,
        need_boottime,
        need_deadprocs,
        need_login,
        need_initspawn,
        need_clockchange,
        need_runlevel,
        need_users,
        my_line_only,
        args: files,
    };

    who.exec()?;
    好的(())
}

结构 Who {
    do_lookup: 布尔,
    short_list: 布尔,
    short_output: 布尔,
    include_idle: 布尔,
    include_heading: 布尔,
    include_mesg: 布尔,
    include_exit: 布尔,
    need_boottime: 布尔,
    need_deadprocs: 布尔,
    need_login: 布尔,
    need_initspawn: 布尔,
