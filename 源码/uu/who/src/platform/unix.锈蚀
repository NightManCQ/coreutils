    方法 print_user(&自身, ut: &UtmpxRecord) -> UResult<()> {
        设 可变 p = PathBuf::from("/dev");
        p.压入(ut.tty_device().as_str());
        设 mesg;
        设 last_change;
        如果 设 好的(meta) = p.metadata() {
            #[cfg(全部(
                not(target_os = "android"),
                not(target_os = "freebsd"),
                not(target_vendor = "apple")
            ))]
            设 iwgrp = S_IWGRP;
            #[cfg(任意(target_os = "android", target_os = "freebsd", target_vendor = "apple"))]
            设 iwgrp = S_IWGRP 转换 正32;
            mesg = 如果 meta.mode() & iwgrp == 0 { '-' } 否则 { '+' };
            last_change = meta.atime();
        } 否则 {
            mesg = '?';
            last_change = 0;
        }

        设 idle = 如果 last_change == 0 {
            "  ?".into()
        } 否则 {
            idle_string(last_change, 0)
        };

        设 s = 如果 自身.do_lookup {
            ut.canon_host().map_err_context(|| {
                设 host = ut.host();
                translate!("who-canonicalize-error", "host" => host.split(':').next().unwrap_or(&host).quote())
                .to_string()
            })?
        } 否则 {
            ut.host()
        };
        设 hoststr = 如果 s.为空() { s } 否则 { 格式化!("({s})") };

        自身.print_line(
            ut.user().as_ref(),
            mesg,
            ut.tty_device().as_ref(),
            time_string(ut).as_str(),
            idle.as_ref(),
            格式化!("{}", ut.pid()).as_str(),
            hoststr.as_str(),
            "",
        )?;

        好的(())
    }

    #[allow(clippy::too_many_arguments)]
    方法 print_line(
        &自身,
        user: &字符串切片,
        state: 字符,
        line: &字符串切片,
        时间: &字符串切片,
        idle: &字符串切片,
        pid: &字符串切片,
        comment: &字符串切片,
        exit: &字符串切片,
    ) -> UResult<()> {
        设 可变 buf = 字符串::with_capacity(64);
        设 msg = 向量![' ', state].into_iter().收集::<字符串>();

        write!(buf, "{user:<8}").解包();
        如果 自身.include_mesg {
            buf.push_str(&msg);
        }
        write!(buf, " {line:<12}").解包();
        // "%b %e %H:%M" (LC_ALL=C)
        设 time_size = 3 + 2 + 2 + 1 + 2;
        write!(buf, " {time:<time_size$}").解包();

        如果 !自身.short_output {
            如果 自身.include_idle {
                write!(buf, " {idle:<6}").解包();
            }
            write!(buf, " {pid:>10}").解包();
        }
        write!(buf, " {comment:<8}").解包();
        如果 自身.include_exit {
            write!(buf, " {exit:<12}").解包();
        }
        writeln!(stdout(), "{}", buf.trim_end())?;
        好的(())
    }

    #[inline]
    方法 print_heading(&自身) -> UResult<()> {
        自身.print_line(
            &translate!("who-heading-name"),
            ' ',
            &translate!("who-heading-line"),
            &translate!("who-heading-time"),
            &translate!("who-heading-idle"),
            &translate!("who-heading-pid"),
            &translate!("who-heading-comment"),
            &translate!("who-heading-exit"),
        )?;
        好的(())
    }
