    need_runlevel: 布尔,
    need_users: 布尔,
    my_line_only: 布尔,
    args: 向量<字符串>,
}

方法 idle_string<'a>(when: 整64, boottime: 整64) -> Cow<'a, 字符串切片> {
    thread_local! {
        静态 NOW: 时间::OffsetDateTime = 时间::OffsetDateTime::now_local().解包();
    }
    NOW.with(|n| {
        设 now = n.unix_timestamp();
        如果 boottime < when && now - 24 * 3600 < when && when <= now {
            设 seconds_idle = now - when;
            如果 seconds_idle < 60 {
                "  .  ".into()
            } 否则 {
                格式化!(
                    "{:02}:{:02}",
                    seconds_idle / 3600,
                    (seconds_idle % 3600) / 60
                )
                .into()
            }
        } 否则 {
            translate!("who-idle-old").into()
        }
    })
}

方法 time_string(ut: &UtmpxRecord) -> 字符串 {
    设 time_format: 向量<时间::format_description::FormatItem> = 如果 ["LC_ALL", "LC_TIME", "LANG"]
        .into_iter()
        .find_map(标准库::环境::var_os)
        .as_deref()
        == 一些(标准库::ffi::OsStr::新建("C"))
    {
        // "%b %e %H:%M"
        时间::format_description::parse("[month repr:short] [day padding:space] [hour]:[minute]")
            .解包()
    } 否则 {
        // "%Y-%m-%d %H:%M"
        时间::format_description::parse("[year]-[month]-[day] [hour]:[minute]").解包()
    };
    ut.login_time().format(&time_format).解包()
}

#[inline]
方法 current_tty() -> 字符串 {
    设 p = 不安全 { ttyname(STDIN_FILENO) };
    如果 p.is_null() {
        字符串::新建()
    } 否则 {
        不安全 { CStr::from_ptr(p) }
            .to_string_lossy()
            .trim_start_matches("/dev/")
            .to_owned()
    }
}

实现 Who {
    #[allow(clippy::cognitive_complexity)]
    方法 exec(&可变 自身) -> UResult<()> {
        #[cfg(target_os = "linux")]
        设 run_level_chk = |record: 整16| record == utmpx::RUN_LVL;
        #[cfg(not(target_os = "linux"))]
        设 run_level_chk = |_| 假;

        设 f = 如果 自身.args.长度() == 1 {
            自身.args[0].as_ref()
        } 否则 {
            utmpx::DEFAULT_FILE
        };
        如果 自身.short_list {
            设 users = utmpx::Utmpx::iter_all_records_from(f)
                .过滤(UtmpxRecord::is_user_process)
                .映射(|ut| ut.user())
                .收集::<向量<_>>();
            打印行!("{}", users.加入(" "));
            打印行!("{}", translate!("who-user-count", "count" => users.长度()));
        } 否则 {
            设 records = utmpx::Utmpx::iter_all_records_from(f);

            如果 自身.include_heading {
                自身.print_heading()?;
            }
            设 cur_tty = 如果 自身.my_line_only {
                current_tty()
            } 否则 {
                字符串::新建()
            };

            循环 ut 在 records {
                如果 !自身.my_line_only || cur_tty == ut.tty_device() {
                    如果 自身.need_users && ut.is_user_process() {
                        自身.print_user(&ut)?;
                    } 否则 {
                        匹配 ut.record_type() {
                            rt 如果 自身.need_runlevel && run_level_chk(rt) => {
                                如果 cfg!(target_os = "linux") {
                                    自身.print_runlevel(&ut)?;
                                }
                            }
                            x 如果 x == utmpx::BOOT_TIME && 自身.need_boottime => {
                                自身.print_boottime(&ut)?;
                            }
                            x 如果 x == utmpx::NEW_TIME && 自身.need_clockchange => {
                                自身.print_clockchange(&ut)?;
                            }
                            x 如果 x == utmpx::INIT_PROCESS && 自身.need_initspawn => {
                                自身.print_initspawn(&ut)?;
                            }
                            x 如果 x == utmpx::LOGIN_PROCESS && 自身.need_login => {
                                自身.print_login(&ut)?;
                            }
                            x 如果 x == utmpx::DEAD_PROCESS && 自身.need_deadprocs => {
                                自身.print_deadprocs(&ut)?;
                            }
                            _ => {}
                        }
                    }
                }

                如果 ut.record_type() == utmpx::BOOT_TIME {}
            }
        }
        好的(())
    }

    #[inline]
    方法 print_runlevel(&自身, ut: &UtmpxRecord) -> UResult<()> {
        设 最后 = (ut.pid() / 256) 转换 正8 转换 字符;
        设 curr = (ut.pid() % 256) 转换 正8 转换 字符;
        设 runlevel_line = translate!("who-runlevel", "level" => curr);
        设 comment =
            translate!("who-runlevel-last", "last" => (如果 最后 == 'N' { 'S' } 否则 { 'N' }));

        自身.print_line(
            "",
            ' ',
            &runlevel_line,
            &time_string(ut),
            "",
            "",
            如果 最后.is_control() { "" } 否则 { &comment },
            "",
        )?;
        好的(())
    }

