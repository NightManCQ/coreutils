                如果 explicit {
                    entry.explicit = 真;
                }
            })
            .or_insert(SignalActionRecord { kind, explicit });
    }
}

#[cfg(unix)]
方法 build_signal_request(
    matches: &clap::ArgMatches,
    option: &字符串切片,
    signal_apply_all: &BTreeSet<&字符串切片>,
) -> UResult<SignalRequest> {
    设 可变 request = SignalRequest::默认();
    设 可变 provided_values = 0正整数大小;

    设 可变 explicit_empty = 假;
    如果 设 一些(迭代) = matches.get_many::<OsString>(option) {
        循环 opt 在 迭代 {
            如果 opt.为空() {
                如果 !signal_apply_all.包含(option) {
                    explicit_empty = 真;
                }
                继续;
            }
            provided_values += 1;
            parse_signal_opt(&可变 request, opt)?;
        }
    }

    设 present = matches.contains_id(option);
    如果 present && provided_values == 0 && !explicit_empty {
        request.apply_all = 真;
    }

    好的(request)
}

