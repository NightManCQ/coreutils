方法 load_config_file(opts: &可变 Options) -> UResult<()> {
    // NOTE: config files are parsed using an INI parser b/c it's available and compatible with ".env"-style files
    //   ... * but support for actual INI files, although working, is not intended, nor claimed
    循环 &file 在 &opts.files {
        设 conf = 如果 file == "-" {
            设 stdin = 输入输出::stdin();
            设 可变 stdin_locked = stdin.锁定();
            Ini::read_from(&可变 stdin_locked)
        } 否则 {
            Ini::load_from_file(file)
        };

        设 conf =
            conf.map_err(|e| USimpleError::新建(1, 格式化!("{}: {e}", file.maybe_quote())))?;

        循环 (_, prop) 在 &conf {
            // ignore all INI section lines (treat them as comments)
            循环 (key, value) 在 prop {
                不安全 {
                    环境::set_var(key, value);
                }
            }
        }
    }

    好的(())
}

