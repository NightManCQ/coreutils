公有 方法 parse_args_from_str(text: &NativeIntStr) -> UResult<向量<NativeIntString>> {
    split_iterator::split(text).map_err(|e| 匹配 e {
        EnvError::EnvBackslashCNotAllowedInDoubleQuotes(_) => USimpleError::新建(125, e.to_string()),
        EnvError::EnvInvalidBackslashAtEndOfStringInMinusS(_, _) => {
            USimpleError::新建(125, e.to_string())
        }
        EnvError::EnvInvalidSequenceBackslashXInMinusS(_, _) => {
            USimpleError::新建(125, e.to_string())
        }
        EnvError::EnvMissingClosingQuote(_, _) => USimpleError::新建(125, e.to_string()),
        EnvError::EnvParsingOfVariableMissingClosingBrace(pos) => USimpleError::新建(
            125,
            translate!("env-error-variable-name-issue", "position" => pos, "error" => e),
        ),
        EnvError::EnvParsingOfMissingVariable(pos) => USimpleError::新建(
            125,
            translate!("env-error-variable-name-issue", "position" => pos, "error" => e),
        ),
        EnvError::EnvParsingOfVariableMissingClosingBraceAfterValue(pos) => USimpleError::新建(
            125,
            translate!("env-error-variable-name-issue", "position" => pos, "error" => e),
        ),
        EnvError::EnvParsingOfVariableUnexpectedNumber(pos, _) => USimpleError::新建(
            125,
            translate!("env-error-variable-name-issue", "position" => pos, "error" => e),
        ),
        EnvError::EnvParsingOfVariableExceptedBraceOrColon(pos, _) => USimpleError::新建(
            125,
            translate!("env-error-variable-name-issue", "position" => pos, "error" => e),
        ),
        _ => USimpleError::新建(
            125,
            translate!("env-error-generic", "error" => 格式化!("{e:?}")),
        ),
    })
}

方法 debug_print_args(args: &[OsString]) {
    设 可变 错误 = stderr().锁定();
    设 _ = writeln!(错误, "input args:");
    循环 (i, arg) 在 args.迭代().enumerate() {
        设 _ = writeln!(错误, "arg[{i}]: {}", arg.quote());
    }
}

方法 check_and_handle_string_args(
    arg: &OsString,
    prefix_to_test: &字符串切片,
    all_args: &可变 向量<OsString>,
    do_debug_print_args: 选项<&向量<OsString>>,
) -> UResult<布尔> {
    设 native_arg = NCvt::convert(arg);
    如果 设 一些(remaining_arg) = native_arg.strip_prefix(&*NCvt::convert(prefix_to_test)) {
        如果 设 一些(input_args) = do_debug_print_args {
            debug_print_args(input_args); // do it here, such that its also printed when we get an error/panic during parsing
        }

        设 arg_strings = parse_args_from_str(remaining_arg)?;
        all_args.extend(
            arg_strings
                .into_iter()
                .映射(from_native_int_representation_owned),
        );

        好的(真)
    } 否则 {
        好的(假)
    }
}

