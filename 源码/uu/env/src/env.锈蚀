方法 parse_name_value_opt<'a>(opts: &可变 Options<'a>, opt: &'a OsStr) -> UResult<布尔> {
    // is it a NAME=VALUE like opt ?
    设 wrap = NativeStr::<'a>::新建(opt);
    设 split_o = wrap.split_once('=');
    如果 设 一些((name, value)) = split_o {
        // yes, so push name, value pair
        opts.sets.压入((name, value));
        好的(假)
    } 否则 {
        // no, it's a program-like opt
        parse_program_opt(opts, opt).映射(|_| 真)
    }
}

方法 parse_program_opt<'a>(opts: &可变 Options<'a>, opt: &'a OsStr) -> UResult<()> {
    如果 opts.line_ending == LineEnding::Nul {
        坏的(UUsageError::新建(
            125,
            translate!("env-error-cannot-specify-null-with-command"),
        ))
    } 否则 {
        opts.program.压入(opt);
        好的(())
    }
}

#[cfg(unix)]
方法 parse_signal_value(signal_name: &字符串切片) -> UResult<正整数大小> {
    设 signal_name_upcase = signal_name.to_uppercase();
    设 optional_signal_value = signal_by_name_or_value(&signal_name_upcase);
    设 错误 = USimpleError::新建(
        125,
        translate!("env-error-invalid-signal", "signal" => signal_name.quote()),
    );
    匹配 optional_signal_value {
        一些(sig_val) => {
            如果 sig_val == 0 {
                坏的(错误)
            } 否则 {
                好的(sig_val)
            }
        }
        无 => 坏的(错误),
    }
}

#[cfg(unix)]
方法 parse_signal_opt(target: &可变 SignalRequest, opt: &OsStr) -> UResult<()> {
    如果 opt.为空() {
        返回 好的(());
    }

    循环 sig 在 opt
        .as_bytes()
        .split(|&b| b == b',')
        .过滤(|chunk| !chunk.为空())
        .映射(OsStr::from_bytes)
    {
        设 一些(sig_str) = sig.to_str() 否则 {
            返回 坏的(USimpleError::新建(
                1,
                translate!("env-error-invalid-signal", "signal" => sig.quote()),
            ));
        };
        设 sig_val = parse_signal_value(sig_str)?;
        target.signals.插入(sig_val);
    }

    好的(())
}

#[cfg(unix)]
#[derive(默认协议, 调试协议)]
结构 SignalRequest {
    apply_all: 布尔,
    signals: BTreeSet<正整数大小>,
}

#[cfg(unix)]
实现 SignalRequest {
    方法 为空(&自身) -> 布尔 {
        !自身.apply_all && 自身.signals.为空()
    }

    方法 for_each_signal<F>(&自身, 可变 f: F) -> UResult<()>
    何处
        F: FnMut(正整数大小, 布尔) -> UResult<()>,
    {
        如果 自身.为空() {
            返回 好的(());
        }
        循环 &sig 在 &自身.signals {
            f(sig, 真)?;
        }
        如果 自身.apply_all {
            循环 sig_value 在 1..=signal_number_upper_bound() {
                如果 自身.signals.包含(&sig_value) {
                    继续;
                }
                // SIGKILL (9) and SIGSTOP (17 on mac, 19 on linux) cannot be caught or ignored
                如果 sig_value == libc::SIGKILL 转换 正整数大小 || sig_value == libc::SIGSTOP 转换 正整数大小 {
                    继续;
                }
                f(sig_value, 假)?;
            }
        }
        好的(())
    }
}

