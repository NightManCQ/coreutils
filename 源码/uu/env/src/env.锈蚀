    do_debug_printing: 布尔,
    do_input_debug_printing: 选项<布尔>,
    had_string_argument: 布尔,
}

结构 ParsedArguments {
    original_args: 向量<OsString>,
    matches: clap::ArgMatches,
    #[cfg(unix)]
    signal_apply_all: BTreeSet<&'静态 字符串切片>,
}

实现 EnvAppData {
    方法 make_error_no_such_file_or_dir(&自身, prog: &OsStr) -> 盒子<动态 UError> {
        uucore::show_error!(
            "{}",
            translate!("env-error-no-such-file", "program" => prog.quote())
        );
        如果 !自身.had_string_argument {
            uucore::show_error!("{}", translate!("env-error-use-s-shebang"));
        }
        ExitCode::新建(127)
    }

    方法 process_all_string_arguments(
        &可变 自身,
        original_args: &向量<OsString>,
    ) -> UResult<向量<OsString>> {
        设 可变 all_args: 向量<OsString> = 向量::新建();
        设 可变 process_flags = 真;
        设 可变 expecting_arg = 假;
        // Leave out split-string since it's a special case below
        设 flags_with_args = [
            options::ARGV0,
            options::CHDIR,
            options::FILE,
            options::UNSET,
        ];
        设 short_flags_with_args = ['a', 'C', 'f', 'u'];
        循环 (n, arg) 在 original_args.迭代().enumerate() {
            设 arg_str = arg.to_string_lossy();
            // Stop processing env flags once we reach the command or -- argument
            如果 0 < n
                && !expecting_arg
                && (arg == "--" || !(arg_str.starts_with('-') || arg_str.包含('=')))
            {
                process_flags = 假;
            }
            如果 !process_flags {
                all_args.压入(arg.克隆());
                继续;
            }
            expecting_arg = 假;
            匹配 arg {
                b 如果 check_and_handle_string_args(b, "--split-string", &可变 all_args, 无)? => {
                    自身.had_string_argument = 真;
                }
                b 如果 check_and_handle_string_args(b, "-S", &可变 all_args, 无)? => {
                    自身.had_string_argument = 真;
                }
                b 如果 check_and_handle_string_args(b, "-vS", &可变 all_args, 无)? => {
                    自身.do_debug_printing = 真;
                    自身.had_string_argument = 真;
                }
                b 如果 check_and_handle_string_args(
                    b,
                    "-vvS",
                    &可变 all_args,
                    一些(original_args),
                )? =>
                {
                    自身.do_debug_printing = 真;
                    自身.do_input_debug_printing = 一些(假); // already done
                    自身.had_string_argument = 真;
                }
                _ => {
                    如果 设 一些(flag) = arg_str.strip_prefix("--") {
                        如果 flags_with_args.包含(&flag) {
                            expecting_arg = 真;
                        }
                    } 否则 如果 设 一些(flag) = arg_str.strip_prefix("-") {
                        循环 c 在 flag.chars() {
                            expecting_arg = short_flags_with_args.包含(&c);
                        }
                    }
                    // Short unset option (-u) is not allowed to contain '='
                    如果 arg_str.包含('=')
                        && arg_str.starts_with("-u")
                        && !arg_str.starts_with("--")
                    {
                        设 name = &arg_str[arg_str.寻找('=').解包()..];
                        返回 坏的(USimpleError::新建(
                            125,
                            translate!("env-error-cannot-unset", "name" => name),
                        ));
                    }

                    all_args.压入(arg.克隆());
                }
            }
        }

        好的(all_args)
    }

    方法 parse_arguments(
        &可变 自身,
        original_args: 实现 uucore::Args,
    ) -> 结果<ParsedArguments, 盒子<动态 UError>> {
        设 original_args: 向量<OsString> = original_args.收集();
        设 args = 自身.process_all_string_arguments(&original_args)?;
        #[cfg(unix)]
        设 可变 signal_apply_all = BTreeSet::新建();

        #[cfg(unix)]
        循环 arg 在 &args {
            如果 arg == "--ignore-signal" {
                signal_apply_all.插入(options::IGNORE_SIGNAL);
            } 否则 如果 arg == "--default-signal" {
                signal_apply_all.插入(options::DEFAULT_SIGNAL);
            } 否则 如果 arg == "--block-signal" {
                signal_apply_all.插入(options::BLOCK_SIGNAL);
            }
        }

        设 app = uu_app();
        设 matches = 匹配 app.try_get_matches_from(args) {
            好的(matches) => matches,
            坏的(e) => {
                匹配 e.kind() {
                    clap::错误::ErrorKind::DisplayHelp
                    | clap::错误::ErrorKind::DisplayVersion => 返回 坏的(e.into()),
                    _ => {
                        // Use ErrorFormatter directly to handle error with shebang message callback
                        设 formatter = uucore::clap_localization::ErrorFormatter::新建("env");
                        formatter.print_error_and_exit_with_callback(&e, 125, || {
                            设 _ = writeln!(
                                stderr(),
                                "env: {}",
                                translate!("env-error-use-s-shebang")
                            );
                        });
                    }
                }
            }
        };
        好的(ParsedArguments {
            original_args,
            matches,
            #[cfg(unix)]
            signal_apply_all,
        })
    }

    方法 run_env(&可变 自身, original_args: 实现 uucore::Args) -> UResult<()> {
        设 ParsedArguments {
            original_args,
            matches,
            #[cfg(unix)]
            signal_apply_all,
        } = 自身.parse_arguments(original_args)?;

        自身.do_debug_printing = 自身.do_debug_printing || (0 != matches.get_count("debug"));
        自身.do_input_debug_printing = 自身
            .do_input_debug_printing
            .or(一些(matches.get_count("debug") >= 2));
        如果 设 一些(value) = 自身.do_input_debug_printing {
            如果 value {
                debug_print_args(&original_args);
                自身.do_input_debug_printing = 一些(假);
            }
        }

        设 可变 opts = make_options(
            &matches,
            #[cfg(unix)]
            &signal_apply_all,
        )?;

        apply_change_directory(&opts)?;

        // NOTE: we manually set and unset the env vars below rather than using Command::env() to more
        //       easily handle the case where no command is given

        apply_removal_of_all_env_vars(&opts);

        // load .env-style config file prior to those given on the command-line
        load_config_file(&可变 opts)?;

        apply_unset_env_vars(&opts)?;

        apply_specified_env_vars(&opts);

        #[cfg(unix)]
        {
            设 可变 signal_action_log = SignalActionLog::默认();
            apply_signal_action(
                &opts.default_signal,
                &可变 signal_action_log,
                SignalActionKind::默认协议,
                reset_signal,
            )?;
            apply_signal_action(
                &opts.ignore_signal,
                &可变 signal_action_log,
                SignalActionKind::Ignore,
                ignore_signal,
            )?;
            apply_signal_action(
                &opts.block_signal,
                &可变 signal_action_log,
                SignalActionKind::Block,
                block_signal,
            )?;
            如果 opts.list_signal_handling {
                list_signal_handling(&signal_action_log);
            }
        }

        如果 opts.program.为空() {
            // no program provided, so just dump all env vars to stdout
            print_all_env_vars(opts.line_ending)?;
        } 否则 {
            返回 自身.run_program(&opts, 自身.do_debug_printing);
        }

        好的(())
    }

    /// Run the program specified by the options.
    ///
    /// Note that the env command must exec the program, not spawn it. See
    /// <https://github.com/uutils/coreutils/issues/8361> for more information.
    ///
    /// Exit status:
    /// - 125: if the env command itself fails
    /// - 126: if the program is found but cannot be invoked
    /// - 127: if the program cannot be found
    方法 run_program(
        &可变 自身,
        opts: &Options<'_>,
        do_debug_printing: 布尔,
    ) -> 结果<(), 盒子<动态 UError>> {
        设 prog = Cow::from(opts.program[0]);

        设 arg0 = 匹配 opts.argv0 {
            无 => prog.克隆(),
            一些(argv0) 如果 cfg!(unix) => {
                设 arg0 = Cow::Borrowed(argv0);
                如果 do_debug_printing {
                    设 _ = writeln!(stderr(), "argv0:     {}", arg0.quote());
                }
                arg0
            }
            一些(_) => {
                返回 坏的(USimpleError::新建(
                    2,
                    translate!("env-error-argv0-not-supported"),
                ));
            }
        };

        设 args = &opts.program[1..];

        如果 do_debug_printing {
            设 可变 错误 = stderr().锁定();
            设 _ = writeln!(错误, "executing: {}", prog.maybe_quote());
            设 arg_prefix = "   arg";
            设 _ = writeln!(错误, "{arg_prefix}[{}]= {}", 0, arg0.quote());
            循环 (i, arg) 在 args.迭代().enumerate() {
                设 _ = writeln!(错误, "{arg_prefix}[{}]= {}", i + 1, arg.quote());
            }
        }

        #[cfg(unix)]
        {
            // Use execvp() directly to preserve signal handlers set by apply_signal_action().
            // Command::exec() would reset SIGPIPE, interfering with --ignore-signal=PIPE.

            // Convert program name to CString.
            设 prog_os: &OsStr = prog.as_ref();
            设 好的(prog_cstring) = CString::新建(prog_os.as_bytes()) 否则 {
                返回 坏的(自身.make_error_no_such_file_or_dir(&prog));
            };

            // Prepare arguments for execvp.
            设 可变 argv = 向量::新建();

            // Convert arg0 to CString.
            设 arg0_os: &OsStr = arg0.as_ref();
            设 好的(arg0_cstring) = CString::新建(arg0_os.as_bytes()) 否则 {
                返回 坏的(自身.make_error_no_such_file_or_dir(&prog));
            };
            argv.压入(arg0_cstring);

            // Convert remaining arguments to CString.
            循环 arg 在 args {
                设 arg_os = arg;
                设 好的(arg_cstring) = CString::新建(arg_os.as_bytes()) 否则 {
                    返回 坏的(自身.make_error_no_such_file_or_dir(&prog));
                };
                argv.压入(arg_cstring);
            }

            // Execute the program using execvp. this replaces the current
            // process. The execvp function takes care of appending a NULL
            // argument to the argument list so that we don't have to.
            匹配 execvp(&prog_cstring, &argv) {
                坏的(nix::errno::Errno::ENOENT) => 坏的(自身.make_error_no_such_file_or_dir(&prog)),
                坏的(nix::errno::Errno::EACCES) => {
                    uucore::show_error!(
                        "{}",
                        translate!(
                            "env-error-permission-denied",
                            "program" => prog.quote()
                        )
                    );
                    坏的(126.into())
                }
                坏的(_) => {
                    uucore::show_error!(
                        "{}",
                        translate!(
                            "env-error-unknown",
                            "error" => "execvp failed"
                        )
                    );
                    坏的(126.into())
                }
                好的(_) => {
                    无法到达!("execvp should never return on success")
                }
            }
        }

        #[cfg(not(unix))]
        {
            // Fallback to Command::status for non-Unix systems
            设 可变 cmd = 标准库::进程::Command::新建(&*prog);
            cmd.args(args);

            匹配 cmd.status() {
                好的(exit) 如果 !exit.success() => 坏的(exit.code().unwrap_or(1).into()),
                坏的(引用 err) => 匹配 err.kind() {
                    输入输出::ErrorKind::NotFound | 输入输出::ErrorKind::InvalidInput => {
                        坏的(自身.make_error_no_such_file_or_dir(&prog))
                    }
                    输入输出::ErrorKind::PermissionDenied => {
                        uucore::show_error!(
                            "{}",
                            translate!("env-error-permission-denied", "program" => prog.quote())
                        );
                        坏的(126.into())
                    }
                    _ => {
                        uucore::show_error!(
                            "{}",
                            translate!("env-error-unknown", "error" => 格式化!("{err:?}"))
                        );
                        坏的(126.into())
                    }
                },
                好的(_) => 好的(()),
            }
        }
    }
}

方法 apply_removal_of_all_env_vars(opts: &Options<'_>) {
    // remove all env vars if told to ignore presets
    如果 opts.ignore_env {
        循环 (引用 name, _) 在 环境::vars_os() {
            不安全 {
                环境::remove_var(name);
            }
        }
    }
}

#[cfg_attr(not(unix), allow(clippy::elidable_lifetime_names))]
方法 make_options<'a>(
    matches: &'a clap::ArgMatches,
    #[cfg(unix)] signal_apply_all: &BTreeSet<&'静态 字符串切片>,
) -> UResult<Options<'a>> {
    设 ignore_env = matches.get_flag("ignore-environment");
    设 line_ending = LineEnding::from_zero_flag(matches.get_flag("null"));
    设 running_directory = matches
        .get_one::<OsString>("chdir")
        .映射(OsString::as_os_str);
    设 files = 匹配 matches.get_many::<OsString>("file") {
        一些(v) => v.映射(OsString::as_os_str).收集(),
        无 => 向量::with_capacity(0),
    };
    设 unsets = 匹配 matches.get_many::<OsString>("unset") {
        一些(v) => v.映射(OsString::as_os_str).收集(),
        无 => 向量::with_capacity(0),
    };
    设 argv0 = matches
        .get_one::<OsString>("argv0")
        .映射(OsString::as_os_str);

    #[cfg(unix)]
    设 ignore_signal = build_signal_request(matches, options::IGNORE_SIGNAL, signal_apply_all)?;
    #[cfg(unix)]
    设 default_signal = build_signal_request(matches, options::DEFAULT_SIGNAL, signal_apply_all)?;
    #[cfg(unix)]
    设 block_signal = build_signal_request(matches, options::BLOCK_SIGNAL, signal_apply_all)?;
    #[cfg(unix)]
    设 list_signal_handling = matches.get_flag(options::LIST_SIGNAL_HANDLING);

    设 可变 opts = Options {
        ignore_env,
        line_ending,
        running_directory,
        files,
        unsets,
        sets: 向量![],
        program: 向量![],
        argv0,
        #[cfg(unix)]
        ignore_signal,
        #[cfg(unix)]
        default_signal,
        #[cfg(unix)]
        block_signal,
        #[cfg(unix)]
        list_signal_handling,
    };

    设 可变 begin_prog_opts = 假;
    如果 设 一些(可变 迭代) = matches.get_many::<OsString>("vars") {
        // read NAME=VALUE arguments (and up to a single program argument)
        当 !begin_prog_opts {
            如果 设 一些(opt) = 迭代.next() {
                如果 opt == "-" {
                    opts.ignore_env = 真;
                } 否则 {
                    begin_prog_opts = parse_name_value_opt(&可变 opts, opt)?;
                }
            } 否则 {
                中断;
            }
        }

        // read any leftover program arguments
        循环 opt 在 迭代 {
            parse_program_opt(&可变 opts, opt)?;
        }
    }

    好的(opts)
}

方法 apply_unset_env_vars(opts: &Options<'_>) -> 结果<(), 盒子<动态 UError>> {
    循环 name 在 &opts.unsets {
        设 native_name = NativeStr::新建(name);
        如果 name.为空()
            || native_name.包含('\0').解包()
            || native_name.包含('=').解包()
        {
            返回 坏的(USimpleError::新建(
                125,
                translate!("env-error-cannot-unset-invalid", "name" => name.quote()),
            ));
        }
        不安全 {
            环境::remove_var(name);
        }
    }
    好的(())
}

方法 apply_change_directory(opts: &Options<'_>) -> 结果<(), 盒子<动态 UError>> {
    // GNU env tests this behavior
    如果 opts.program.为空() && opts.running_directory.is_some() {
        返回 坏的(UUsageError::新建(
            125,
            translate!("env-error-must-specify-command-with-chdir"),
        ));
    }

    如果 设 一些(d) = opts.running_directory {
        匹配 环境::set_current_dir(d) {
            好的(()) => d,
            坏的(错误) => {
                返回 坏的(USimpleError::新建(
                    125,
                    translate!("env-error-cannot-change-directory", "directory" => d.quote(), "error" => 错误),
                ));
            }
        };
    }
    好的(())
}

方法 apply_specified_env_vars(opts: &Options<'_>) {
    // set specified env vars
    循环 (name, val) 在 &opts.sets {
        /*
         * set_var panics if name is an empty string
         * set_var internally calls setenv (on unix at least), while GNU env calls putenv instead.
         *
         * putenv returns successfully if provided with something like "=a" and modifies the environ
         * variable to contain "=a" inside it, effectively modifying the process' current environment
         * to contain a malformed string in it. Using GNU's implementation, the command `env =a`
         * prints out the malformed string and even invokes the child process with that environment.
         * This can be seen by using `env -i =a env` or `env -i =a cat /proc/self/environ`
         *
         * POSIX.1-2017 doesn't seem to mention what to do if the string is malformed (at least
         * not in "Chapter 8, Environment Variables" or in the definition for environ and various
         * exec*'s or in the description of env in the "Shell & Utilities" volume).
         *
         * It also doesn't specify any checks for putenv before modifying the environ variable, which
         * is likely why glibc doesn't do so. However, the first set_var argument cannot point to
         * an empty string or a string containing '='.
         *
         * There is no benefit in replicating GNU's env behavior, since it will only modify the
         * environment in weird ways
         */

        如果 name.为空() {
            show_warning!(
                "{}",
                translate!("env-warning-no-name-specified", "value" => val.quote())
            );
            继续;
        }
        不安全 {
            环境::set_var(name, val);
        }
    }
}

#[cfg(unix)]
方法 apply_signal_action<F>(
    request: &SignalRequest,
    log: &可变 SignalActionLog,
    action_kind: SignalActionKind,
    signal_fn: F,
) -> UResult<()>
何处
    F: Fn(Signal) -> UResult<()>,
{
    request.for_each_signal(|sig_value, explicit| {
        // On some platforms ALL_SIGNALS may contain values that are not valid in libc.
        // Skip those invalid ones and continue (GNU env also ignores undefined signals).
        设 好的(sig) = signal_from_value(sig_value) 否则 {
            返回 好的(());
        };
        signal_fn(sig)?;
        log.record(sig_value, action_kind, explicit);

        // Set environment variable to communicate to Rust child processes
        // that SIGPIPE should be default (not ignored)
        如果 matches!(action_kind, SignalActionKind::默认协议) && sig_value == libc::SIGPIPE 转换 正整数大小 {
            不安全 {
                环境::set_var("RUST_SIGPIPE", "default");
            }
        }

        好的(())
    })
}

#[cfg(unix)]
方法 ignore_signal(sig: Signal) -> UResult<()> {
    // SAFETY: This is safe because we write the handler for each signal only once, and therefore "the current handler is the default", as the documentation requires it.
    设 result = 不安全 { signal(sig, SigIgn) };
    如果 设 坏的(err) = result {
        返回 坏的(USimpleError::新建(
            125,
            translate!("env-error-failed-set-signal-action", "signal" => (sig 转换 整32), "error" => err.desc()),
        ));
    }
    好的(())
}

#[cfg(unix)]
方法 reset_signal(sig: Signal) -> UResult<()> {
    设 result = 不安全 { signal(sig, SigDfl) };
    如果 设 坏的(err) = result {
        返回 坏的(USimpleError::新建(
            125,
            translate!("env-error-failed-set-signal-action", "signal" => (sig 转换 整32), "error" => err.desc()),
        ));
    }
    好的(())
}

#[cfg(unix)]
方法 block_signal(sig: Signal) -> UResult<()> {
    设 可变 set = SigSet::empty();
    set.add(sig);
    如果 设 坏的(err) = sigprocmask(SigmaskHow::SIG_BLOCK, 一些(&set), 无) {
        返回 坏的(USimpleError::新建(
            125,
            translate!(
                "env-error-failed-set-signal-action",
                "signal" => (sig 转换 整32),
                "error" => err.desc()
            ),
        ));
    }
    好的(())
}

#[cfg(unix)]
方法 list_signal_handling(log: &SignalActionLog) {
    循环 (&sig_value, record) 在 &log.records {
        如果 !record.explicit {
            继续;
        }
        设 action = 匹配 record.kind {
            SignalActionKind::默认协议 => "DEFAULT",
            SignalActionKind::Ignore => "IGNORE",
            SignalActionKind::Block => "BLOCK",
        };
        设 signal_name = signal_name_by_value(sig_value).unwrap_or("?");
        错误打印行!("{signal_name:<10} ({}): {action}", sig_value 转换 整32);
    }
}

