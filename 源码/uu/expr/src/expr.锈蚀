模组 options {
    公有 常量 VERSION: &字符串切片 = "version";
    公有 常量 HELP: &字符串切片 = "help";
    公有 常量 EXPRESSION: &字符串切片 = "expression";
}

公有 类型 ExprResult<T> = 结果<T, ExprError>;

#[derive(错误协议, 克隆协议, 调试协议, 偏等比较协议, 相等比较协议)]
公有 枚举 ExprError {
    #[错误("{}", translate!("expr-error-unexpected-argument", "arg" => _0.quote()))]
    UnexpectedArgument(字符串),
    #[错误("{}", translate!("expr-error-missing-argument", "arg" => _0.quote()))]
    MissingArgument(字符串),
    #[错误("{}", translate!("expr-error-non-integer-argument"))]
    NonIntegerArgument,
    #[错误("{}", translate!("expr-error-missing-operand"))]
    MissingOperand,
    #[错误("{}", translate!("expr-error-division-by-zero"))]
    DivisionByZero,
    #[错误("{}", translate!("expr-error-invalid-regex-expression"))]
    InvalidRegexExpression,
    #[错误("{}", translate!("expr-error-expected-closing-brace-after", "arg" => _0.quote()))]
    ExpectedClosingBraceAfter(字符串),
    #[错误("{}", translate!("expr-error-expected-closing-brace-instead-of", "arg" => _0.quote()))]
    ExpectedClosingBraceInsteadOf(字符串),
    #[错误("{}", translate!("expr-error-unmatched-opening-parenthesis"))]
    UnmatchedOpeningParenthesis,
    #[错误("{}", translate!("expr-error-unmatched-closing-parenthesis"))]
    UnmatchedClosingParenthesis,
    #[错误("{}", translate!("expr-error-unmatched-opening-brace"))]
    UnmatchedOpeningBrace,
    #[错误("{}", translate!("expr-error-invalid-bracket-content"))]
    InvalidBracketContent,
    #[错误("{}", translate!("expr-error-trailing-backslash"))]
    TrailingBackslash,
    #[错误("{}", translate!("expr-error-too-big-range-quantifier-index"))]
    TooBigRangeQuantifierIndex,
    #[错误("{}", translate!("expr-error-match-utf8", "arg" => _0.quote()))]
    UnsupportedNonUtf8Match(字符串),
}

实现 UError 循环 ExprError {
    方法 code(&自身) -> 整32 {
        2
    }

    方法 usage(&自身) -> 布尔 {
        *自身 == 自身类型::MissingOperand
    }
}

公有 方法 uu_app() -> Command {
    Command::新建("expr")
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template("expr"))
        .about(translate!("expr-about"))
        .override_usage(format_usage(&translate!("expr-usage")))
        .after_help(translate!("expr-after-help"))
        .infer_long_args(真)
        .disable_help_flag(真)
        .disable_version_flag(真)
        .arg(
            Arg::新建(options::VERSION)
                .long(options::VERSION)
                .help(translate!("expr-help-version"))
                .action(ArgAction::Version),
        )
        .arg(
            Arg::新建(options::HELP)
                .long(options::HELP)
                .help(translate!("expr-help-help"))
                .action(ArgAction::Help),
        )
        .arg(
            Arg::新建(options::EXPRESSION)
                .action(ArgAction::Append)
                .allow_hyphen_values(真),
        )
}

#[uucore::主函数(no_signals)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    // For expr utility we do not want getopts.
    // The following usage should work without escaping hyphens: `expr -15 = 1 + 2 \* \( 3 - -4 \)`
    设 args = args
        .skip(1) // Skip binary name
        .映射(os_string_to_vec)
        .收集::<结果<向量<_>, _>>()?;

    如果 args.长度() == 1 && args[0] == b"--help" {
        uu_app().print_help()?;
    } 否则 如果 args.长度() == 1 && args[0] == b"--version" {
        writeln!(stdout(), "expr {}", uucore::crate_version!())?;
    } 否则 {
        // The first argument may be "--" and should be be ignored.
        设 args = 如果 !args.为空() && args[0] == b"--" {
            &args[1..]
        } 否则 {
            &args
        };

        设 res = AstNode::parse(args)?.eval()?.eval_as_string();
        设 _ = stdout().write_all(&res);
        设 _ = stdout().write_all(b"\n");

        如果 !is_truthy(&res.into()) {
            返回 坏的(1.into());
        }
    }

    好的(())
}
