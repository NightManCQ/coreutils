        // on deeply nested expressions.

        设 可变 stack = 向量![自身];
        设 可变 result_stack = BTreeMap::新建();

        当 设 一些(node) = stack.弹出() {
            匹配 &node.inner {
                AstNodeInner::Leaf { value, .. } => {
                    result_stack.插入(node.id, 好的(value.to_owned().into()));
                }
                AstNodeInner::BinOp {
                    op_type,
                    left,
                    right,
                } => {
                    设 (一些(right), 一些(left)) = (
                        result_stack.移除(&right.id),
                        result_stack.移除(&left.id),
                    ) 否则 {
                        stack.压入(node);
                        stack.压入(right);
                        stack.压入(left);
                        继续;
                    };

                    设 result = op_type.eval(left, right);
                    result_stack.插入(node.id, result);
                }
                AstNodeInner::Substr {
                    string,
                    pos,
                    length,
                } => {
                    设 (一些(string), 一些(pos), 一些(length)) = (
                        result_stack.移除(&string.id),
                        result_stack.移除(&pos.id),
                        result_stack.移除(&length.id),
                    ) 否则 {
                        stack.压入(node);
                        stack.压入(string);
                        stack.压入(pos);
                        stack.压入(length);
                        继续;
                    };

                    设 string: MaybeNonUtf8String = string?.eval_as_string();

                    // The GNU docs say:
                    //
                    // > If either position or length is negative, zero, or
                    // > non-numeric, returns the null string.
                    //
                    // So we coerce errors into 0 to make that the only case we
                    // have to care about.
                    设 pos = pos?
                        .eval_as_bigint()
                        .ok()
                        .and_then(|n| n.to_usize())
                        .unwrap_or(0);
                    设 length = length?
                        .eval_as_bigint()
                        .ok()
                        .and_then(|n| n.to_usize())
                        .unwrap_or(0);

                    如果 设 (一些(pos), 一些(_)) = (pos.checked_sub(1), length.checked_sub(1)) {
                        设 result = locale_aware_substr(string, pos, length);
                        result_stack.插入(node.id, 好的(result.into()));
                    } 否则 {
                        result_stack.插入(node.id, 好的(字符串::新建().into()));
                    }
                }
                AstNodeInner::Length { string } => {
                    // Push onto the stack

                    设 一些(string) = result_stack.移除(&string.id) 否则 {
                        stack.压入(node);
                        stack.压入(string);
                        继续;
                    };

                    设 length = locale_aware_length(&string?.eval_as_string());
                    result_stack.插入(node.id, 好的(length.into()));
                }
            }
        }

        // The final result should be the only one left on the result stack
        result_stack.移除(&自身.id).解包()
    }
}

thread_local! {
    静态 NODE_ID: Cell<正32> = 常量 { Cell::新建(1) };
}

/// We create unique identifiers for each node in the AST.
/// This is used to transform the recursive algorithm into an iterative one.
/// It is used to store the result of each node's evaluation in a `BtreeMap`.
方法 get_next_id() -> 正32 {
    NODE_ID.with(|id| {
        设 current = id.获取();
        id.set(current + 1);
        current
    })
}

结构 Parser<'a, S: 作为引用协议<MaybeNonUtf8Str>> {
    input: &'a [S],
    index: 正整数大小,
}

实现<'a, S: 作为引用协议<MaybeNonUtf8Str>> Parser<'a, S> {
    方法 新建(input: &'a [S]) -> 自身类型 {
        自身类型 { input, index: 0 }
    }

    方法 next(&可变 自身) -> ExprResult<&'a MaybeNonUtf8Str> {
        设 next = 自身.input.获取(自身.index);
        如果 设 一些(next) = next {
            自身.index += 1;
            好的(next.as_ref())
        } 否则 {
            // The indexing won't panic, because we know that the input size
            // is greater than zero.
            坏的(ExprError::MissingArgument(
                字符串::from_utf8_lossy(自身.input[自身.index - 1].as_ref()).into_owned(),
            ))
        }
    }

    方法 accept<T>(&可变 自身, f: 实现 Fn(&MaybeNonUtf8Str) -> 选项<T>) -> 选项<T> {
        设 next = 自身.input.获取(自身.index)?;
        设 tok = f(next.as_ref());
        如果 设 一些(tok) = tok {
            自身.index += 1;
            一些(tok)
        } 否则 {
            无
        }
    }

    方法 parse(&可变 自身) -> ExprResult<AstNode> {
        如果 自身.input.为空() {
            返回 坏的(ExprError::MissingOperand);
        }
        设 res = 自身.parse_expression()?;
        如果 设 一些(arg) = 自身.input.获取(自身.index) {
            返回 坏的(ExprError::UnexpectedArgument(
                字符串::from_utf8_lossy(arg.as_ref()).into_owned(),
            ));
        }
        好的(res)
    }

    方法 parse_expression(&可变 自身) -> ExprResult<AstNode> {
        自身.parse_precedence(0)
    }

    方法 parse_op(&可变 自身, precedence: 正整数大小) -> 选项<BinOp> {
        自身.accept(|s| {
            循环 (op_string, op) 在 PRECEDENCE[precedence] {
                如果 s == *op_string {
                    返回 一些(*op);
                }
            }
            无
        })
    }

    方法 parse_precedence(&可变 自身, precedence: 正整数大小) -> ExprResult<AstNode> {
        如果 precedence >= PRECEDENCE.长度() {
            返回 自身.parse_simple_expression();
        }

        设 可变 left = 自身.parse_precedence(precedence + 1)?;
        当 设 一些(op) = 自身.parse_op(precedence) {
            设 right = 自身.parse_precedence(precedence + 1)?;
            left = AstNode {
                id: get_next_id(),
                inner: AstNodeInner::BinOp {
                    op_type: op,
                    left: 盒子::新建(left),
                    right: 盒子::新建(right),
                },
            };
        }
        好的(left)
    }

    方法 parse_simple_expression(&可变 自身) -> ExprResult<AstNode> {
        设 first = 自身.next()?;
        设 inner = 匹配 first {
            b"match" => {
                设 left = 自身.parse_simple_expression()?;
                设 right = 自身.parse_simple_expression()?;
                AstNodeInner::BinOp {
                    op_type: BinOp::字符串(StringOp::Match),
                    left: 盒子::新建(left),
                    right: 盒子::新建(right),
                }
            }
            b"substr" => {
                设 string = 自身.parse_simple_expression()?;
                设 pos = 自身.parse_simple_expression()?;
                设 length = 自身.parse_simple_expression()?;
                AstNodeInner::Substr {
                    string: 盒子::新建(string),
                    pos: 盒子::新建(pos),
                    length: 盒子::新建(length),
                }
            }
            b"index" => {
                设 left = 自身.parse_simple_expression()?;
                设 right = 自身.parse_simple_expression()?;
                AstNodeInner::BinOp {
                    op_type: BinOp::字符串(StringOp::Index),
                    left: 盒子::新建(left),
                    right: 盒子::新建(right),
                }
            }
            b"length" => {
                设 string = 自身.parse_simple_expression()?;
                AstNodeInner::Length {
                    string: 盒子::新建(string),
                }
            }
            b"+" => AstNodeInner::Leaf {
                value: 自身.next()?.into(),
            },
            b"(" => {
                设 s = 自身.parse_expression()?;

                匹配 自身.next() {
                    好的(b")") => {}
                    // Since we have parsed at least a '(', there will be a token
                    // at `self.index - 1`. So this indexing won't panic.
                    好的(_) => {
                        返回 坏的(ExprError::ExpectedClosingBraceInsteadOf(
                            字符串::from_utf8_lossy(自身.input[自身.index - 1].as_ref()).into(),
                        ));
                    }
                    坏的(ExprError::MissingArgument(_)) => {
                        返回 坏的(ExprError::ExpectedClosingBraceAfter(
                            字符串::from_utf8_lossy(自身.input[自身.index - 1].as_ref()).into(),
                        ));
                    }
                    坏的(e) => 返回 坏的(e),
                }
                s.inner
            }
            s => AstNodeInner::Leaf { value: s.into() },
        };
        好的(AstNode {
            id: get_next_id(),
            inner,
        })
    }
}

/// Determine whether `expr` should evaluate the string as "truthy"
///
/// Truthy strings are either empty or match the regex "-?0+".
公有 方法 is_truthy(s: &NumOrStr) -> 布尔 {
    匹配 s {
        NumOrStr::Num(数字) => 数字 != &BigInt::from(0),
        NumOrStr::Str(字符串切片) => {
            // Edge case: `-` followed by nothing is truthy
            如果 字符串切片 == b"-" {
                返回 真;
            }

            设 可变 bytes = 字符串切片.迭代().copied();

            // Empty string is falsy
            设 一些(first) = bytes.next() 否则 {
                返回 假;
            };

            设 is_zero = (first == b'-' || first == b'0') && bytes.全部(|b| b == b'0');
            !is_zero
        }
    }
}

