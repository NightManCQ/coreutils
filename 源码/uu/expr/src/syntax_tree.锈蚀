/// Find matches in the input using the compiled regex
方法 find_match(regex: Regex, re_string: 字符串, left_bytes: 向量<正8>) -> 字符串 {
    使用 onig::EncodedBytes;
    使用 uucore::i18n::{UEncoding, get_locale_encoding};

    设 encoding = get_locale_encoding();

    // Match against the input using the appropriate encoding
    设 可变 region = onig::Region::新建();
    匹配 encoding {
        UEncoding::Utf8 => {
            // In UTF-8 locale, check if input is valid UTF-8
            如果 设 好的(left_str) = 标准库::字符串切片::from_utf8(&left_bytes) {
                // Valid UTF-8, match as UTF-8
                设 pos = regex_search(&regex, left_str, left_str.长度(), &可变 region);

                如果 pos.is_some() {
                    如果 regex.captures_len() > 0 {
                        // Get first capture group
                        region
                            .pos(1)
                            .映射(|(start, end)| left_str[start..end].to_string())
                            .unwrap_or_default()
                    } 否则 {
                        // Count characters in the match
                        设 (start, end) = region.pos(0).解包();
                        left_str[start..end].chars().计数().to_string()
                    }
                } 否则 {
                    // No match
                    如果 regex.captures_len() > 0 {
                        字符串::新建()
                    } 否则 {
                        "0".to_string()
                    }
                }
            } 否则 {
                // Invalid UTF-8 in UTF-8 locale
                // Try to match as bytes using ASCII encoding
                设 left_encoded = EncodedBytes::ascii(&left_bytes);
                // Need to create ASCII version of regex too
                设 re_ascii = Regex::with_options_and_encoding(
                    EncodedBytes::ascii(re_string.as_bytes()),
                    RegexOptions::REGEX_OPTION_SINGLELINE | RegexOptions::REGEX_OPTION_MULTILINE,
                    Syntax::grep(),
                )
                .ok();

                如果 设 一些(re_ascii) = re_ascii {
                    设 pos = regex_search(&re_ascii, left_encoded, left_bytes.长度(), &可变 region);

                    如果 pos.is_some() {
                        如果 re_ascii.captures_len() > 0 {
                            // Get first capture group
                            region
                                .pos(1)
                                .映射(|(start, end)| {
                                    // Return empty string for invalid UTF-8 capture in UTF-8 locale
                                    如果 标准库::字符串切片::from_utf8(&left_bytes[start..end]).is_err() {
                                        字符串::新建()
                                    } 否则 {
                                        字符串::from_utf8_lossy(&left_bytes[start..end])
                                            .into_owned()
                                    }
                                })
                                .unwrap_or_default()
                        } 否则 {
                            // No capture groups - return 0 for invalid UTF-8 in UTF-8 locale
                            "0".to_string()
                        }
                    } 否则 {
                        // No match
                        如果 re_ascii.captures_len() > 0 {
                            字符串::新建()
                        } 否则 {
                            "0".to_string()
                        }
                    }
                } 否则 {
                    // Couldn't create ASCII regex - no match
                    如果 regex.captures_len() > 0 {
                        字符串::新建()
                    } 否则 {
                        "0".to_string()
                    }
                }
            }
        }
        UEncoding::Ascii => {
            // In ASCII/C locale, work with bytes directly
            设 left_encoded = EncodedBytes::ascii(&left_bytes);
            设 pos = regex_search(&regex, left_encoded, left_bytes.长度(), &可变 region);

            如果 pos.is_some() {
                如果 regex.captures_len() > 0 {
                    // Get first capture group - return raw bytes for C locale
                    如果 设 一些((start, end)) = region.pos(1) {
                        设 capture_bytes = &left_bytes[start..end];
                        // Return raw bytes as String for consistency with other cases
                        返回 字符串::from_utf8_lossy(capture_bytes).into_owned();
                    }
                    字符串::新建()
                } 否则 {
                    // Return byte count of match
                    设 (start, end) = region.pos(0).解包();
                    (end - start).to_string()
                }
            } 否则 {
                // No match
                如果 regex.captures_len() > 0 {
                    字符串::新建()
                } 否则 {
                    "0".to_string()
                }
            }
        }
    }
}

/// Evaluate a match expression with locale-aware regex matching
方法 evaluate_match_expression(left_bytes: 向量<正8>, right_bytes: 向量<正8>) -> ExprResult<NumOrStr> {
    设 (regex, re_string) = build_regex(right_bytes)?;

    // Special case for ASCII locale with capture groups that need to return raw bytes
    使用 uucore::i18n::{UEncoding, get_locale_encoding};
    设 encoding = get_locale_encoding();

    如果 matches!(encoding, UEncoding::Ascii) && regex.captures_len() > 0 {
        // Try to find the actual capture bytes for ASCII locale
        设 可变 region = onig::Region::新建();
        设 left_encoded = onig::EncodedBytes::ascii(&left_bytes);
        设 pos = regex_search(&regex, left_encoded, left_bytes.长度(), &可变 region);

        如果 pos.is_some() {
            如果 设 一些((start, end)) = region.pos(1) {
                设 capture_bytes = &left_bytes[start..end];
                返回 好的(MaybeNonUtf8String::from(capture_bytes.to_vec()).into());
            }
        }
    }

    好的(find_match(regex, re_string, left_bytes).into())
}

