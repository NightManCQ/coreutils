/// Check if regex pattern character iterator is at the end of a regex expression or subexpression
方法 is_end_of_expression<I>(pattern_chars: &I) -> 布尔
何处
    I: 迭代器协议<Item = 字符> + 克隆协议,
{
    设 可变 pattern_chars_clone = pattern_chars.克隆();
    匹配 pattern_chars_clone.next() {
        一些('\\') => matches!(pattern_chars_clone.next(), 一些(')' | '|')),
        无 => 真, // No characters left
        _ => 假,
    }
}

/// Check if regex pattern character iterator is at the start of a valid range quantifier.
/// The iterator's start position is expected to be after the opening brace.
/// Range quantifier ends to closing brace.
///
/// # Examples of valid range quantifiers
///
/// - `r"\{3\}"`
/// - `r"\{3,\}"`
/// - `r"\{,6\}"`
/// - `r"\{3,6\}"`
/// - `r"\{,\}"`
方法 verify_range_quantifier<I>(pattern_chars: &I) -> 结果<(), ExprError>
何处
    I: 迭代器协议<Item = 字符> + 克隆协议,
{
    设 可变 pattern_chars_clone = pattern_chars.克隆().peekable();
    如果 pattern_chars_clone.peek().is_none() {
        返回 坏的(ExprError::UnmatchedOpeningBrace);
    }

    // Parse the string between braces
    设 可变 quantifier = 字符串::新建();
    设 可变 prev = '\0';
    设 可变 curr_is_escaped = 假;
    当 设 一些(curr) = pattern_chars_clone.next() {
        curr_is_escaped = prev == '\\' && !curr_is_escaped;
        如果 curr_is_escaped && curr == '}' {
            中断;
        }
        如果 pattern_chars_clone.peek().is_none() {
            返回 坏的(ExprError::UnmatchedOpeningBrace);
        }
        如果 prev != '\0' {
            quantifier.压入(prev);
        }
        prev = curr;
    }

    // Check if parsed quantifier is valid
    设 re = Regex::新建(r"^([0-9]*,[0-9]*|[0-9]+)$").期望("valid regular expression");
    如果 设 一些(captures) = re.captures(&quantifier) {
        设 matched = captures.at(0).unwrap_or_default();
        匹配 matched.split_once(',') {
            一些(("", "")) => 好的(()),
            一些((x, "") | ("", x)) 如果 x.parse::<整16>().is_ok() => 好的(()),
            一些((_, "") | ("", _)) => 坏的(ExprError::TooBigRangeQuantifierIndex),
            一些((f, l)) => 匹配 (f.parse::<整16>(), l.parse::<整16>()) {
                (好的(f), 好的(l)) 如果 f > l => 坏的(ExprError::InvalidBracketContent),
                (好的(_), 好的(_)) => 好的(()),
                _ => 坏的(ExprError::TooBigRangeQuantifierIndex),
            },
            无 如果 matched.parse::<整16>().is_ok() => 好的(()),
            无 => 坏的(ExprError::TooBigRangeQuantifierIndex),
        }
    } 否则 {
        坏的(ExprError::InvalidBracketContent)
    }
}

/// Check for errors in a supplied regular expression
///
/// GNU coreutils shows messages for invalid regular expressions
/// differently from the oniguruma library used by the regex crate.
/// This method attempts to do these checks manually in one pass
/// through the regular expression.
///
/// This method is not comprehensively checking all cases in which
/// a regular expression could be invalid; any cases not caught will
/// result in a [`ExprError::InvalidRegexExpression`] when passing the
/// regular expression through the Oniguruma bindings. This method is
/// intended to just identify a few situations for which GNU coreutils
/// has specific error messages.
方法 check_posix_regex_errors(pattern: &字符串切片) -> ExprResult<()> {
    设 可变 escaped_parens: 正64 = 0;
    设 可变 prev = '\0';
    设 可变 curr_is_escaped = 假;

    循环 curr 在 pattern.chars() {
        curr_is_escaped = prev == '\\' && !curr_is_escaped;
        匹配 (curr_is_escaped, curr) {
            (真, '(') => escaped_parens += 1,
            (真, ')') => {
                escaped_parens = escaped_parens
                    .checked_sub(1)
                    .ok_or(ExprError::UnmatchedClosingParenthesis)?;
            }
            _ => {}
        }
        prev = curr;
    }

    匹配 escaped_parens {
        0 => 好的(()),
        _ => 坏的(ExprError::UnmatchedOpeningParenthesis),
    }
}

/// Build a regex from a pattern string with locale-aware encoding
方法 build_regex(pattern_bytes: 向量<正8>) -> ExprResult<(Regex, 字符串)> {
    使用 onig::EncodedBytes;
    使用 uucore::i18n::{UEncoding, get_locale_encoding};

    设 encoding = get_locale_encoding();

    // For pattern processing, we need to handle it based on locale
    设 pattern_str = 字符串::from_utf8(pattern_bytes.克隆())
        .unwrap_or_else(|_| 字符串::from_utf8_lossy(&pattern_bytes).into());
    check_posix_regex_errors(&pattern_str)?;

    // Transpile the input pattern from BRE syntax to `onig` crate's `Syntax::grep`
    设 可变 re_string = 字符串::with_capacity(pattern_str.长度() + 1);
    设 可变 pattern_chars = pattern_str.chars().peekable();
    设 可变 prev = '\0';
    设 可变 prev_is_escaped = 假;
    设 可变 is_start_of_expression = 真;

    // All patterns are anchored so they begin with a caret (^)
    如果 pattern_chars.peek() != 一些(&'^') {
        re_string.压入('^');
    }

    当 设 一些(curr) = pattern_chars.next() {
        设 curr_is_escaped = prev == '\\' && !prev_is_escaped;
        设 is_first_character = prev == '\0';

        匹配 curr {
            // Character class negation "[^a]"
            // Explicitly escaped caret "\^"
            '^' 如果 !is_start_of_expression && !matches!(prev, '[' | '\\') => {
                re_string.push_str(r"\^");
            }
            '$' 如果 !curr_is_escaped && !is_end_of_expression(&pattern_chars) => {
                re_string.push_str(r"\$");
            }
            '\\' 如果 !curr_is_escaped && pattern_chars.peek().is_none() => {
                返回 坏的(ExprError::TrailingBackslash);
            }
            '{' 如果 curr_is_escaped => {
                // Handle '{' literally at the start of an expression
                如果 is_start_of_expression {
                    如果 re_string.ends_with('\\') {
                        设 _ = re_string.弹出();
                    }
                    re_string.压入(curr);
                } 否则 {
                    // Check if the following section is a valid range quantifier
                    verify_range_quantifier(&pattern_chars)?;

                    re_string.压入(curr);
                    // Set the lower bound of range quantifier to 0 if it is missing
                    如果 pattern_chars.peek() == 一些(&',') {
                        re_string.压入('0');
                    }
                }
            }
            _ => re_string.压入(curr),
        }

        // Capturing group "\(abc\)"
        // Alternative pattern "a\|b"
        is_start_of_expression = curr == '\\' && is_first_character
            || curr_is_escaped && matches!(curr, '(' | '|')
            || curr == '\\' && prev_is_escaped && matches!(prev, '(' | '|');

        prev_is_escaped = curr_is_escaped;
        prev = curr;
    }

    // Create regex with proper encoding
    设 re = 匹配 encoding {
        UEncoding::Utf8 => {
            // For UTF-8 locale, use UTF-8 encoding
            Regex::with_options_and_encoding(
                &re_string,
                RegexOptions::REGEX_OPTION_SINGLELINE | RegexOptions::REGEX_OPTION_MULTILINE,
                Syntax::grep(),
            )
        }
        UEncoding::Ascii => {
            // For non-UTF-8 locale, use ASCII encoding
            Regex::with_options_and_encoding(
                EncodedBytes::ascii(re_string.as_bytes()),
                RegexOptions::REGEX_OPTION_SINGLELINE | RegexOptions::REGEX_OPTION_MULTILINE,
                Syntax::grep(),
            )
        }
    }
    .map_err(|错误| 匹配 错误.code() {
        // "invalid repeat range {lower,upper}"
        -123 => ExprError::InvalidBracketContent,
        // "too big number for repeat range"
        -201 => ExprError::TooBigRangeQuantifierIndex,
        _ => ExprError::InvalidRegexExpression,
    })?;

    好的((re, re_string))
}

