// spell-checker:ignore (ToDO) algo

使用 clap::Command;

使用 uu_checksum_common::{standalone_checksum_app_with_length, standalone_with_length_main};

使用 uucore::checksum::{AlgoKind, BlakeLength, parse_blake_length};
使用 uucore::错误::UResult;
使用 uucore::translate;

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 calculate_blake2b_length =
        |s: &字符串切片| parse_blake_length(AlgoKind::Blake2b, BlakeLength::字符串(s));
    standalone_with_length_main(AlgoKind::Blake2b, uu_app(), args, calculate_blake2b_length)
}

#[inline]
公有 方法 uu_app() -> Command {
    standalone_checksum_app_with_length(translate!("b2sum-about"), translate!("b2sum-usage"))
        .name("b2sum")
}
