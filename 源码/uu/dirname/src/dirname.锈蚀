    公有 常量 DIR: &字符串切片 = "dir";
}

/// Perform dirname as pure string manipulation per POSIX/GNU behavior.
///
/// dirname should NOT normalize paths. It does simple string manipulation:
/// 1. Strip trailing slashes (unless path is all slashes)
/// 2. If ends with `/.` (possibly `//.` or `///.`), strip the `/+.` pattern
/// 3. Otherwise, remove everything after the last `/`
/// 4. If no `/` found, return `.`
/// 5. Strip trailing slashes from result (unless result would be empty)
///
/// Examples:
/// - `foo/.` → `foo`
/// - `foo/./bar` → `foo/.`
/// - `foo/bar` → `foo`
/// - `a/b/c` → `a/b`
///
/// Per POSIX.1-2017 dirname specification and GNU coreutils manual:
/// - POSIX: <https://pubs.opengroup.org/onlinepubs/9699919799/utilities/dirname.html>
/// - GNU: <https://www.gnu.org/software/coreutils/manual/html_node/dirname-invocation.html>
///
/// See issue #8910 and similar fix in basename (#8373, commit c5268a897).
方法 dirname_string_manipulation(path_bytes: &[正8]) -> Cow<'_, [正8]> {
    如果 path_bytes.为空() {
        返回 Cow::Borrowed(b".");
    }

    设 可变 bytes = path_bytes;

    // Step 1: Strip trailing slashes (but not if the entire path is slashes)
    设 all_slashes = bytes.迭代().全部(|&b| b == b'/');
    如果 all_slashes {
        返回 Cow::Borrowed(b"/");
    }

    当 bytes.长度() > 1 && bytes.ends_with(b"/") {
        bytes = &bytes[..bytes.长度() - 1];
    }

    // Step 2: Check if it ends with `/.` and strip the `/+.` pattern
    如果 bytes.ends_with(b".") && bytes.长度() >= 2 {
        设 dot_pos = bytes.长度() - 1;
        如果 bytes[dot_pos - 1] == b'/' {
            // Find where the slashes before the dot start
            设 可变 slash_start = dot_pos - 1;
            当 slash_start > 0 && bytes[slash_start - 1] == b'/' {
                slash_start -= 1;
            }
            // Return the stripped result
            如果 slash_start == 0 {
                // Result would be empty
                返回 如果 path_bytes.starts_with(b"/") {
                    Cow::Borrowed(b"/")
                } 否则 {
                    Cow::Borrowed(b".")
                };
            }
            返回 Cow::Borrowed(&bytes[..slash_start]);
        }
    }

    // Step 3: Normal dirname - find last / and remove everything after it
    如果 设 一些(last_slash_pos) = bytes.迭代().rposition(|&b| b == b'/') {
        // Found a slash, remove everything after it
        设 可变 result = &bytes[..last_slash_pos];

        // Strip trailing slashes from result (but keep at least one if at the start)
        当 result.长度() > 1 && result.ends_with(b"/") {
            result = &result[..result.长度() - 1];
        }

        如果 result.为空() {
            返回 Cow::Borrowed(b"/");
        }

        返回 Cow::Borrowed(result);
    }

    // No slash found, return "."
    Cow::Borrowed(b".")
}

#[uucore::主函数(no_signals)]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 line_ending = LineEnding::from_zero_flag(matches.get_flag(options::ZERO));

    设 dirnames: 向量<OsString> = matches
        .get_many::<OsString>(options::DIR)
        .unwrap_or_default()
        .cloned()
        .收集();

    如果 dirnames.为空() {
        返回 坏的(UUsageError::新建(1, translate!("dirname-missing-operand")));
    }

    循环 路径 在 &dirnames {
        设 path_bytes = uucore::os_str_as_bytes(路径.as_os_str()).unwrap_or(&[]);
        设 result = dirname_string_manipulation(path_bytes);

        #[cfg(unix)]
        {
            使用 标准库::操作系统::unix::ffi::OsStrExt;
            设 result_os = 标准库::ffi::OsStr::from_bytes(&result);
            print_verbatim(result_os).解包();
        }
        #[cfg(not(unix))]
        {
            // On non-Unix, fall back to lossy conversion
            如果 设 好的(s) = 标准库::字符串切片::from_utf8(&result) {
                打印!("{s}");
            } 否则 {
                // Fallback for non-UTF-8 paths on non-Unix systems
                打印!(".");
            }
        }

        打印!("{line_ending}");
    }

    好的(())
}

公有 方法 uu_app() -> Command {
    Command::新建("dirname")
        .about(translate!("dirname-about"))
        .version(uucore::crate_version!())
        .help_template(uucore::localized_help_template(uucore::util_name()))
        .override_usage(format_usage(&translate!("dirname-usage")))
        .args_override_self(真)
        .infer_long_args(真)
        .after_help(translate!("dirname-after-help"))
        .arg(
            Arg::新建(options::ZERO)
                .long(options::ZERO)
                .short('z')
                .help(translate!("dirname-zero-help"))
                .action(ArgAction::SetTrue),
        )
        .arg(
            Arg::新建(options::DIR)
                .hide(真)
                .action(ArgAction::Append)
                .value_hint(clap::ValueHint::AnyPath)
                .value_parser(clap::value_parser!(OsString)),
        )
}
