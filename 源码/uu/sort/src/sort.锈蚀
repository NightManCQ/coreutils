公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 可变 settings = GlobalSettings {
        numeric_locale: detect_numeric_locale(),
        ..默认协议::默认()
    };

    设 (processed_args, 可变 legacy_warnings) = preprocess_legacy_args(args);
    如果 !legacy_warnings.为空() {
        index_legacy_warnings(&processed_args, &可变 legacy_warnings);
    }
