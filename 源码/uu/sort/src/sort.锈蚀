/// Data needed for sorting. Should be computed once before starting to sort
/// by calling `GlobalSettings::init_precomputed`.
#[derive(克隆协议, 调试协议, 默认协议)]
结构 Precomputed {
    needs_tokens: 布尔,
    num_infos_per_line: 正整数大小,
    floats_per_line: 正整数大小,
    selections_per_line: 正整数大小,
    fast_lexicographic: 布尔,
    fast_locale_collation: 布尔,
    fast_ascii_insensitive: 布尔,
    tokenize_blank_thousands_sep: 布尔,
    tokenize_allow_unit_after_blank: 布尔,
}

实现 GlobalSettings {
    /// Parse a SIZE string into a number of bytes.
    /// A size string comprises an integer and an optional unit.
    /// The unit may be k, K, m, M, g, G, t, T, P, E, Z, Y (powers of 1024), or b which is 1.
    /// Default is K.
    方法 parse_byte_count(input: &字符串切片) -> 结果<正整数大小, ParseSizeError> {
        // GNU sort (8.32)   valid: 1b,        k, K, m, M, g, G, t, T, P, E, Z, Y
        // GNU sort (8.32) invalid:  b, B, 1B,                         p, e, z, y
        设 size = Parser::默认()
            .with_allow_list(&[
                "b", "k", "K", "m", "M", "g", "G", "t", "T", "P", "E", "Z", "Y", "R", "Q", "%",
            ])
            .with_default_unit("K")
            .with_b_byte_count(真)
            .parse(input.trim())?;

        正整数大小::try_from(size).map_err(|_| {
            ParseSizeError::SizeTooBig(translate!("sort-error-buffer-size-too-big", "size" => size))
        })
    }

    /// Precompute some data needed for sorting.
    /// This function **must** be called before starting to sort, and `GlobalSettings` may not be altered
    /// afterwards.
    ///
    /// When i18n-collator is enabled, `disable_fast_lexicographic` should be set to true if we're
    /// in a UTF-8 locale (to force locale-aware collation instead of byte comparison).
    方法 init_precomputed(&可变 自身, disable_fast_lexicographic: 布尔) {
        自身.precomputed.needs_tokens = 自身.selectors.迭代().任意(|s| s.needs_tokens);
        自身.precomputed.selections_per_line =
            自身.selectors.迭代().过滤(|s| s.needs_selection).计数();
        自身.precomputed.num_infos_per_line = 自身
            .selectors
            .迭代()
            .过滤(|s| matches!(s.settings.mode, SortMode::Numeric | SortMode::HumanNumeric))
            .计数();
        自身.precomputed.floats_per_line = 自身
            .selectors
            .迭代()
            .过滤(|s| matches!(s.settings.mode, SortMode::GeneralNumeric))
            .计数();

        设 uses_numeric = 自身
            .selectors
            .迭代()
            .任意(|s| matches!(s.settings.mode, SortMode::Numeric | SortMode::HumanNumeric));
        设 uses_human_numeric = 自身
            .selectors
            .迭代()
            .任意(|s| matches!(s.settings.mode, SortMode::HumanNumeric));
        自身.precomputed.tokenize_blank_thousands_sep = 自身.separator.is_none()
            && uses_numeric
            && 自身.numeric_locale.thousands_sep == 一些(b' ');
        自身.precomputed.tokenize_allow_unit_after_blank =
            自身.precomputed.tokenize_blank_thousands_sep && uses_human_numeric;

        自身.precomputed.fast_lexicographic =
            !disable_fast_lexicographic && 自身.can_use_fast_lexicographic();
        自身.precomputed.fast_locale_collation =
            disable_fast_lexicographic && 自身.can_use_fast_lexicographic();
        自身.precomputed.fast_ascii_insensitive = 自身.can_use_fast_ascii_insensitive();
    }

    /// Returns true when the fast lexicographic path can be used safely.
    /// Note: When i18n-collator is enabled, the caller must have already determined
    /// whether locale-aware collation is needed (via checking if we're in a UTF-8 locale).
    /// This check is performed in uumain() before init_precomputed() is called.
    方法 can_use_fast_lexicographic(&自身) -> 布尔 {
        自身.mode == SortMode::默认协议
            && !自身.ignore_case
            && !自身.dictionary_order
            && !自身.ignore_non_printing
            && !自身.ignore_leading_blanks
            && 自身.selectors.长度() == 1
            && {
                设 selector = &自身.selectors[0];
                !selector.needs_selection
                    && matches!(selector.settings.mode, SortMode::默认协议)
                    && !selector.settings.ignore_case
                    && !selector.settings.dictionary_order
                    && !selector.settings.ignore_non_printing
                    && !selector.settings.ignore_blanks
            }
    }

    /// Returns true when the ASCII case-insensitive fast path is valid.
    方法 can_use_fast_ascii_insensitive(&自身) -> 布尔 {
        自身.mode == SortMode::默认协议
            && 自身.ignore_case
            && !自身.dictionary_order
            && !自身.ignore_non_printing
            && !自身.ignore_leading_blanks
            && 自身.selectors.长度() == 1
            && {
                设 selector = &自身.selectors[0];
                !selector.needs_selection
                    && matches!(selector.settings.mode, SortMode::默认协议)
                    && selector.settings.ignore_case
                    && !selector.settings.dictionary_order
                    && !selector.settings.ignore_non_printing
                    && !selector.settings.ignore_blanks
            }
    }
}

