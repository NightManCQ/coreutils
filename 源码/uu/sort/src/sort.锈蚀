实现 FieldSelector {
    方法 parse(key: &字符串切片, global_settings: &GlobalSettings) -> UResult<自身类型> {
        设 has_options = key.as_bytes().迭代().copied().任意(is_ordering_option_char);
        设 可变 settings = 如果 has_options {
            KeySettings::默认()
        } 否则 {
            KeySettings::from(global_settings)
        };
        设 可变 flags = 如果 has_options {
            ModeFlags::默认()
        } 否则 {
            ModeFlags::from_mode(settings.mode)
        };

        设 可变 from_ignore_blanks = 如果 has_options {
            假
        } 否则 {
            settings.ignore_blanks
        };
        设 可变 to_ignore_blanks = 如果 has_options {
            假
        } 否则 {
            settings.ignore_blanks
        };

        设 (from_field, 可变 rest) = parse_field_count(key, "sort-invalid-number-at-field-start")?;
        如果 from_field == 0 {
            返回 坏的(bad_field_spec(key, "sort-field-number-is-zero"));
        }

        设 可变 from_char = 1;
        如果 设 一些(stripped) = rest.strip_prefix('.') {
            设 (char_idx, rest_after) =
                parse_field_count(stripped, "sort-invalid-number-after-dot")?;
            如果 char_idx == 0 {
                返回 坏的(bad_field_spec(key, "sort-character-offset-is-zero"));
            }
            from_char = char_idx;
            rest = rest_after;
        }

        设 (rest_after_opts, ignore_blanks) =
            parse_ordering_options(rest, &可变 settings, &可变 flags);
        如果 ignore_blanks {
            from_ignore_blanks = 真;
        }

        设 可变 to = 无;
        如果 设 一些(rest_after_comma) = rest_after_opts.strip_prefix(',') {
            设 (to_field, 可变 rest) =
                parse_field_count(rest_after_comma, "sort-invalid-number-after-comma")?;
            如果 to_field == 0 {
                返回 坏的(bad_field_spec(key, "sort-field-number-is-zero"));
            }

            设 可变 to_char = 0;
            如果 设 一些(stripped) = rest.strip_prefix('.') {
                设 (char_idx, rest_after) =
                    parse_field_count(stripped, "sort-invalid-number-after-dot")?;
                to_char = char_idx;
                rest = rest_after;
            }

            设 (rest, ignore_blanks_end) = parse_ordering_options(rest, &可变 settings, &可变 flags);
            如果 ignore_blanks_end {
