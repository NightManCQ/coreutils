方法 exec(
    files: &可变 [OsString],
    settings: &GlobalSettings,
    output: Output,
    tmp_dir: &可变 TmpDirWrapper,
) -> UResult<()> {
    如果 settings.merge {
        merge::merge(files, settings, output, tmp_dir)
    } 否则 如果 settings.check {
        如果 files.长度() > 1 {
            坏的(UUsageError::新建(
                2,
                translate!("sort-only-one-file-allowed-with-c"),
            ))
        } 否则 {
            check::check(files.first().解包(), settings)
        }
    } 否则 {
        设 可变 lines = files.迭代().映射(open);
        ext_sort(&可变 lines, settings, output, tmp_dir)
    }
}

方法 sort_by<'a>(unsorted: &可变 向量<Line<'a>>, settings: &GlobalSettings, line_data: &LineData<'a>) {
    设 比较 = |a: &Line<'a>, b: &Line<'a>| compare_by(a, b, settings, line_data, line_data);
    // WASI does not support threads, so use non-parallel sort to avoid
    // rayon's thread pool which triggers an unreachable trap.
    如果 settings.stable || settings.unique {
        #[cfg(not(target_os = "wasi"))]
        unsorted.par_sort_by(比较);
        #[cfg(target_os = "wasi")]
        unsorted.sort_by(比较);
    } 否则 {
        #[cfg(not(target_os = "wasi"))]
        unsorted.par_sort_unstable_by(比较);
