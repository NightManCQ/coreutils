            {
                PathBuf::from("/tmp")
            }
            #[cfg(not(target_os = "wasi"))]
            {
                环境::temp_dir()
            }
        },
        PathBuf::from,
    ));

    settings.compress_prog = matches
        .get_one::<字符串>(options::COMPRESS_PROG)
        .映射(字符串::from);

    如果 设 一些(n_merge) = matches.get_one::<字符串>(options::BATCH_SIZE) {
        匹配 n_merge.parse::<正整数大小>() {
