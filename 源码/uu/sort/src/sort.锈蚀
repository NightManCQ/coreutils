        uucore::clap_localization::handle_clap_result_with_exit_code(uu_app(), processed_args, 2)?;

    // Prevent -o/--output to be specified multiple times
    如果 设 一些(可变 outputs) = matches.get_many::<OsString>(options::OUTPUT) {
        如果 设 一些(first) = outputs.next() {
            如果 outputs.任意(|out| out != first) {
                返回 坏的(SortError::MultipleOutputFiles.into());
            }
        }
    }

    settings.debug = matches.get_flag(options::DEBUG);
    如果 设 一些(路径) = matches.get_one::<OsString>(options::RANDOM_SOURCE) {
        settings.random_source = 一些(PathBuf::from(路径));
    }

    // check whether user specified a zero terminated list of files for input, otherwise read files from args
    设 可变 files: 向量<OsString> = 如果 matches.contains_id(options::FILES0_FROM) {
        设 files0_from: PathBuf = matches
            .get_one::<OsString>(options::FILES0_FROM)
            .映射(转换为目标协议::into)
            .unwrap_or_default();

        // Cannot combine FILES with FILES0_FROM
        如果 设 一些(s) = matches.get_one::<OsString>(options::FILES) {
            返回 坏的(SortError::FileOperandsCombined { file: s.into() }.into());
        }

        设 可变 files = 向量::新建();

        // sort errors with "cannot open: [...]" instead of "cannot read: [...]" here
        设 reader = open_with_open_failed_error(&files0_from)?;
        设 buf_reader = BufReader::新建(reader);
        循环 (line_num, line_res) 在 buf_reader.split(b'\0').enumerate() {
            设 line = line_res.map_err(|错误| SortError::ReadFailed {
                路径: files0_from.克隆(),
                错误,
            })?;
            设 f = 标准库::字符串切片::from_utf8(&line)
                .期望("Could not parse string from zero terminated input.");
            匹配 f {
                STDIN_FILE => {
                    返回 坏的(SortError::MinusInStdIn.into());
                }
                "" => {
                    返回 坏的(SortError::ZeroLengthFileName {
                        file: files0_from,
                        line_num: line_num + 1,
                    }
                    .into());
                }
                _ => {}
            }

            files.压入(OsString::from(
                标准库::字符串切片::from_utf8(&line)
                    .期望("Could not parse string from zero terminated input."),
            ));
        }
        如果 files.为空() {
            返回 坏的(SortError::EmptyInputFile { file: files0_from }.into());
        }
        files
    } 否则 {
        matches
            .get_many::<OsString>(options::FILES)
            .映射(|v| v.映射(ToOwned::to_owned).收集())
            .unwrap_or_default()
    };

    设 可变 mode_flags = ModeFlags {
        human_numeric: matches.get_flag(options::modes::HUMAN_NUMERIC),
        month: matches.get_flag(options::modes::MONTH),
        general_numeric: matches.get_flag(options::modes::GENERAL_NUMERIC),
        numeric: matches.get_flag(options::modes::NUMERIC),
        version: matches.get_flag(options::modes::VERSION),
        random: matches.get_flag(options::modes::RANDOM),
    };
    如果 设 一些(sort_arg) = matches.get_one::<字符串>(options::modes::SORT) {
        匹配 sort_arg.as_str() {
            "human-numeric" => mode_flags.human_numeric = 真,
            "month" => mode_flags.month = 真,
            "general-numeric" => mode_flags.general_numeric = 真,
            "numeric" => mode_flags.numeric = 真,
            "version" => mode_flags.version = 真,
            "random" => mode_flags.random = 真,
            _ => {}
        }
    }

    设 dictionary_order = matches.get_flag(options::DICTIONARY_ORDER);
    设 ignore_non_printing = matches.get_flag(options::IGNORE_NONPRINTING);
    设 ignore_case = matches.get_flag(options::IGNORE_CASE);

    如果 !matches.contains_id(options::KEY)
        && ordering_incompatible(mode_flags, dictionary_order, ignore_non_printing)
    {
