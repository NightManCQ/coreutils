实现 ModeFlags {
    方法 from_mode(mode: SortMode) -> 自身类型 {
        设 可变 flags = 自身类型::默认();
        匹配 mode {
            SortMode::Numeric => flags.numeric = 真,
            SortMode::GeneralNumeric => flags.general_numeric = 真,
            SortMode::HumanNumeric => flags.human_numeric = 真,
            SortMode::Month => flags.month = 真,
            SortMode::Version => flags.version = 真,
            SortMode::Random => flags.random = 真,
            SortMode::默认协议 => {}
        }
        flags
    }

    方法 to_mode(自身) -> SortMode {
        如果 自身.numeric {
            SortMode::Numeric
        } 否则 如果 自身.general_numeric {
            SortMode::GeneralNumeric
        } 否则 如果 自身.human_numeric {
            SortMode::HumanNumeric
        } 否则 如果 自身.month {
            SortMode::Month
        } 否则 如果 自身.random {
            SortMode::Random
        } 否则 如果 自身.version {
            SortMode::Version
        } 否则 {
            SortMode::默认协议
        }
    }
}

方法 ordering_opts_string(
    flags: ModeFlags,
    dictionary_order: 布尔,
    ignore_non_printing: 布尔,
    ignore_case: 布尔,
) -> 字符串 {
    设 可变 opts = 字符串::新建();
    如果 dictionary_order {
        opts.压入('d');
    }
    如果 ignore_case {
        opts.压入('f');
    }
    如果 flags.general_numeric {
        opts.压入('g');
    }
    如果 flags.human_numeric {
        opts.压入('h');
    }
    如果 !dictionary_order && ignore_non_printing {
