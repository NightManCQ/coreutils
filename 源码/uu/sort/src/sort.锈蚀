            b'd' => {
                settings.dictionary_order = 真;
                settings.ignore_non_printing = 假;
            }
            b'f' => settings.ignore_case = 真,
            b'g' => flags.general_numeric = 真,
            b'h' => flags.human_numeric = 真,
            b'i' => {
