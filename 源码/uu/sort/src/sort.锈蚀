    设 reverse_unused = flags.reverse && !uses_reverse;
    设 last_resort_active =
        settings.mode != SortMode::Random && !settings.stable && !settings.unique;
    设 reverse_ignored = reverse_unused && !last_resort_active;
    设 reverse_last_resort_warning = reverse_unused && last_resort_active;

    设 可变 ignored_opts = 字符串::新建();
    如果 flags.ignore_leading_blanks && !uses_blanks {
        ignored_opts.压入('b');
    }
    如果 flags.dictionary_order && !uses_dictionary {
        ignored_opts.压入('d');
    }
    如果 flags.ignore_case && !uses_case {
        ignored_opts.压入('f');
    }
    如果 flags.ignore_non_printing && !uses_non_printing {
        ignored_opts.压入('i');
    }
    如果 flags.mode_general && !uses_mode(SortMode::GeneralNumeric) {
        ignored_opts.压入('g');
    }
    如果 flags.mode_human && !uses_mode(SortMode::HumanNumeric) {
        ignored_opts.压入('h');
    }
    如果 flags.mode_month && !uses_mode(SortMode::Month) {
        ignored_opts.压入('M');
    }
    如果 flags.mode_numeric && !uses_mode(SortMode::Numeric) {
        ignored_opts.压入('n');
    }
    如果 flags.mode_random && !uses_mode(SortMode::Random) {
        ignored_opts.压入('R');
    }
    如果 reverse_ignored {
        ignored_opts.压入('r');
    }
    如果 flags.mode_version && !uses_mode(SortMode::Version) {
        ignored_opts.压入('V');
    }

    如果 ignored_opts.长度() == 1 {
        show_error!(
            "{}",
            translate!("sort-warning-option-ignored", "option" => ignored_opts)
        );
    } 否则 如果 ignored_opts.长度() > 1 {
        show_error!(
            "{}",
            translate!("sort-warning-options-ignored", "options" => ignored_opts)
        );
    }

    如果 reverse_last_resort_warning {
        show_error!("{}", translate!("sort-warning-option-reverse-last-resort"));
    }
}

