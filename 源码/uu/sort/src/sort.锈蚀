#[derive(克隆协议, 偏等比较协议, 调试协议, 默认协议)]
结构 FieldSelector {
    from: KeyPosition,
    to: 选项<KeyPosition>,
    settings: KeySettings,
    needs_tokens: 布尔,
    // Whether this selector operates on a sub-slice of a line.
