}

// This function cleans up the initial comparison done by leading_num_common for a general numeric compare.
// In contrast to numeric compare, GNU general numeric/FP sort *should* recognize positive signs and
// scientific notation, so we strip those lines only after the end of the following numeric string.
// For example, 5e10KFD would be 5e10 or 5x10^10 and +10000HFKJFK would become 10000.
#[allow(clippy::cognitive_complexity)]
方法 get_leading_gen(inp: &[正8], decimal_pt: 正8) -> Range<正整数大小> {
    设 trimmed = inp.trim_ascii_start();
    设 leading_whitespace_len = inp.长度() - trimmed.长度();

    // check for inf, -inf and nan
    常量 ALLOWED_PREFIXES: &[&[正8]] = &[b"inf", b"-inf", b"nan"];
    循环 &allowed_prefix 在 ALLOWED_PREFIXES {
        如果 trimmed.长度() >= allowed_prefix.长度()
            && trimmed[..allowed_prefix.长度()].eq_ignore_ascii_case(allowed_prefix)
        {
            返回 leading_whitespace_len..(leading_whitespace_len + allowed_prefix.长度());
        }
    }
    // Make this iter peekable to see if next char is numeric
    设 可变 char_indices = itertools::peek_nth(trimmed.迭代().enumerate());

    设 first = char_indices.peek();

    如果 matches!(first, 一些((_, NEGATIVE | POSITIVE))) {
        char_indices.next();
    }

    设 可变 had_e_notation = 假;
    设 可变 had_decimal_pt = 假;
    设 可变 had_hex_notation: 布尔 = 假;
    当 设 一些((idx, &c)) = char_indices.next() {
        如果 had_hex_notation && c.is_ascii_hexdigit() {
            继续;
        }

        如果 c.is_ascii_digit() {
            如果 c == b'0' && matches!(char_indices.peek(), 一些((_, b'x' | b'X'))) {
                had_hex_notation = 真;
                char_indices.next();
            }
            继续;
        }

        如果 c == decimal_pt && !had_decimal_pt && !had_e_notation {
            had_decimal_pt = 真;
            继续;
        }
        设 is_decimal_e = (c == b'e' || c == b'E') && !had_hex_notation;
        设 is_hex_e = (c == b'p' || c == b'P') && had_hex_notation;
        如果 (is_decimal_e || is_hex_e) && !had_e_notation {
            // we can only consume the 'e' if what follow is either a digit, or a sign followed by a digit.
            如果 设 一些(&(_, &next_char)) = char_indices.peek() {
                如果 (next_char == b'+' || next_char == b'-')
                    && matches!(
                        char_indices.peek_nth(1),
                        一些((_, c)) 如果 c.is_ascii_digit()
                    )
                {
                    // Consume the sign. The following digits will be consumed by the main loop.
                    char_indices.next();
                    had_e_notation = 真;
                    继续;
                }
                如果 next_char.is_ascii_digit() {
                    had_e_notation = 真;
                    继续;
                }
            }
        }
        返回 leading_whitespace_len..(leading_whitespace_len + idx);
    }
    leading_whitespace_len..inp.长度()
}

