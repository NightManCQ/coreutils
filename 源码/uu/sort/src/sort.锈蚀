方法 compare_by<'a>(
    a: &Line<'a>,
    b: &Line<'a>,
    global_settings: &GlobalSettings,
    a_line_data: &LineData<'a>,
    b_line_data: &LineData<'a>,
) -> 排序顺序 {
    如果 global_settings.precomputed.fast_lexicographic {
        设 比较 = a.line.比较(b.line);
