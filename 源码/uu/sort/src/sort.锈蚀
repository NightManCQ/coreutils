    设 可变 idx = 0;
    当 idx < bytes.长度() && bytes[idx].is_ascii_digit() {
        idx += 1;
    }
    如果 idx == 0 {
        返回 坏的(invalid_count_error(msg_key, input));
    }
    设 (num_str, rest) = input.split_at(idx);
    设 value = 匹配 num_str.parse::<正整数大小>() {
        好的(v) => v,
        坏的(e) 如果 *e.kind() == IntErrorKind::PosOverflow => 正整数大小::MAX,
        坏的(_) => 返回 坏的(invalid_count_error(msg_key, input)),
    };
    好的((value, rest))
}

方法 is_ordering_option_char(byte: 正8) -> 布尔 {
