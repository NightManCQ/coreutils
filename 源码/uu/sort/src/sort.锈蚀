    方法 折叠(byte: 正8) -> 正8 {
        byte.to_ascii_uppercase()
    }

    循环 (lhs, rhs) 在 a.迭代().copied().zip(b.迭代().copied()) {
        设 l = 折叠(lhs);
        设 r = 折叠(rhs);
        如果 l != r {
            返回 l.比较(&r);
        }
    }

