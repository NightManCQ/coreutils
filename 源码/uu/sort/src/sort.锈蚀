    }

    #[cfg(feature = "i18n-collator")]
    如果 global_settings.precomputed.fast_locale_collation {
        设 a_key = a_line_data.collation_key(a.index);
        设 b_key = b_line_data.collation_key(b.index);
        设 比较 = a_key.比较(b_key);
        返回 如果 global_settings.reverse {
            比较.reverse()
        } 否则 {
            比较
        };
    }

    如果 global_settings.precomputed.fast_ascii_insensitive {
        设 比较 = ascii_case_insensitive_cmp(a.line, b.line);
        如果 比较 != 排序顺序::Equal || a.line == b.line {
            返回 如果 global_settings.reverse {
                比较.reverse()
            } 否则 {
                比较
            };
        }
    }

    设 可变 selection_index = 0;
    设 可变 num_info_index = 0;
    设 可变 parsed_float_index = 0;

    如果 设 (一些(一些(a_f64)), 一些(一些(b_f64))) = (
        a_line_data.line_num_floats.获取(a.index),
        b_line_data.line_num_floats.获取(b.index),
    ) {
        // we don't use total_cmp() because it always sorts -0 before 0
        如果 设 一些(比较) = a_f64.partial_cmp(b_f64) {
            // don't trust `Ordering::Equal` if lines are not fully equal
            如果 比较 != 排序顺序::Equal || a.line == b.line {
                返回 如果 global_settings.reverse {
                    比较.reverse()
                } 否则 {
                    比较
                };
            }
        }
    }

    循环 selector 在 &global_settings.selectors {
        设 (a_str, b_str) = 如果 selector.needs_selection {
            设 selections = (
                a_line_data.selections
                    [a.index * global_settings.precomputed.selections_per_line + selection_index],
                b_line_data.selections
                    [b.index * global_settings.precomputed.selections_per_line + selection_index],
            );
            selection_index += 1;
            selections
        } 否则 {
            // We can select the whole line.
            (a.line, b.line)
        };

        设 settings = &selector.settings;

        设 比较: 排序顺序 = 匹配 settings.mode {
            SortMode::Random => {
                // check if the two strings are equal
                如果 custom_str_cmp(
                    a_str,
                    b_str,
                    settings.ignore_non_printing,
                    settings.dictionary_order,
                    settings.ignore_case,
                ) == 排序顺序::Equal
                {
                    排序顺序::Equal
                } 否则 {
                    // Only if they are not equal compare by the hash
                    random_shuffle(a_str, b_str, &global_settings.salt.解包())
                }
            }
            SortMode::Numeric => {
                设 a_num_info = &a_line_data.num_infos
                    [a.index * global_settings.precomputed.num_infos_per_line + num_info_index];
                设 b_num_info = &b_line_data.num_infos
                    [b.index * global_settings.precomputed.num_infos_per_line + num_info_index];
                num_info_index += 1;
                numeric_str_cmp((a_str, a_num_info), (b_str, b_num_info))
            }
            SortMode::HumanNumeric => {
                设 a_num_info = &a_line_data.num_infos
                    [a.index * global_settings.precomputed.num_infos_per_line + num_info_index];
                设 b_num_info = &b_line_data.num_infos
                    [b.index * global_settings.precomputed.num_infos_per_line + num_info_index];
                num_info_index += 1;
                human_numeric_str_cmp((a_str, a_num_info), (b_str, b_num_info))
            }
            SortMode::GeneralNumeric => {
                设 a_float = &a_line_data.parsed_floats
                    [a.index * global_settings.precomputed.floats_per_line + parsed_float_index];
                设 b_float = &b_line_data.parsed_floats
                    [b.index * global_settings.precomputed.floats_per_line + parsed_float_index];
                parsed_float_index += 1;
                general_numeric_compare(a_float, b_float)
            }
            SortMode::Month => month_compare(a_str, b_str),
            SortMode::Version => version_cmp(a_str, b_str),
            SortMode::默认协议 => {
                // Use locale-aware comparison if feature is enabled and no custom flags are set
                #[cfg(feature = "i18n-collator")]
                {
                    如果 settings.ignore_case
                        || settings.dictionary_order
                        || settings.ignore_non_printing
                    {
                        custom_str_cmp(
                            a_str,
                            b_str,
                            settings.ignore_non_printing,
                            settings.dictionary_order,
                            settings.ignore_case,
                        )
                    } 否则 {
                        locale_cmp(a_str, b_str)
                    }
                }
                #[cfg(not(feature = "i18n-collator"))]
                {
                    custom_str_cmp(
                        a_str,
                        b_str,
                        settings.ignore_non_printing,
                        settings.dictionary_order,
                        settings.ignore_case,
                    )
                }
            }
        };
        如果 比较 != 排序顺序::Equal {
            返回 如果 settings.reverse { 比较.reverse() } 否则 { 比较 };
        }
    }

    // Call "last resort compare" if all selectors returned Equal
    设 比较 = 如果 global_settings.mode == SortMode::Random
        || global_settings.stable
        || global_settings.unique
    {
        排序顺序::Equal
    } 否则 {
        a.line.比较(b.line)
    };

    如果 global_settings.reverse {
        比较.reverse()
    } 否则 {
        比较
    }
}

/// Compare two byte slices in ASCII case-insensitive order without allocating.
/// We upper each byte on the fly so that binary input (including `NUL`) stays
/// untouched and we avoid locale-sensitive routines such as `strcasecmp`.
方法 ascii_case_insensitive_cmp(a: &[正8], b: &[正8]) -> 排序顺序 {
