实现<'a> Line<'a> {
    /// Creates a new `Line`.
    ///
    /// If additional data is needed for sorting it is added to `line_data`.
    /// `token_buffer` allows to reuse the allocation for tokens.
    方法 create(
        line: &'a [正8],
        index: 正整数大小,
        line_data: &可变 LineData<'a>,
        token_buffer: &可变 向量<Field>,
        settings: &GlobalSettings,
    ) -> 自身类型 {
        #[cfg(feature = "i18n-collator")]
        如果 settings.precomputed.fast_locale_collation {
            compute_sort_key_utf8(line, &可变 line_data.collation_key_buffer);
            line_data
                .collation_key_ends
                .压入(line_data.collation_key_buffer.长度());
            返回 自身类型 { line, index };
        }

        设 needs_line_data = settings.precomputed.needs_tokens
            || settings.precomputed.selections_per_line > 0
            || settings.precomputed.num_infos_per_line > 0
            || settings.precomputed.floats_per_line > 0
            || settings.mode == SortMode::Numeric;
        如果 !needs_line_data {
            返回 自身类型 { line, index };
        }
        token_buffer.clear();
        如果 settings.precomputed.needs_tokens {
            tokenize(
                line,
                settings.separator,
                token_buffer,
                &settings.precomputed,
            );
        }
        如果 settings.mode == SortMode::Numeric {
            // exclude inf, nan, scientific notation
            设 line_num_float = (!line.迭代().任意(正8::is_ascii_alphabetic))
                .then(|| 标准库::字符串切片::from_utf8(line).ok())
                .flatten()
                .and_then(|s| s.parse::<点64>().ok());
            line_data.line_num_floats.压入(line_num_float);
        }
        循环 (selector, selection) 在 settings.selectors.迭代().映射(|selector| {
            (
                selector,
                selector.get_selection(line, token_buffer, settings.numeric_locale),
            )
        }) {
            匹配 selection {
                Selection::AsBigDecimal(parsed_float) => line_data.parsed_floats.压入(parsed_float),
                Selection::WithNumInfo(字符串切片, num_info) => {
                    line_data.num_infos.压入(num_info);
                    line_data.selections.压入(字符串切片);
                }
                Selection::Str(字符串切片) => {
                    如果 selector.needs_selection {
                        line_data.selections.压入(字符串切片);
                    }
                }
            }
        }
        自身类型 { line, index }
    }

    方法 print(&自身, writer: &可变 实现 Write, settings: &GlobalSettings) -> 标准库::输入输出::结果<()> {
        如果 settings.debug {
            自身.write_debug(settings, writer)?;
        } 否则 {
            writer.write_all(自身.line)?;
            writer.write_all(&[settings.line_ending.into()])?;
        }
        好的(())
    }

    /// Writes indicators for the selections this line matched. The original line content is NOT expected
    /// to be already printed.
    方法 write_debug(
        &自身,
        settings: &GlobalSettings,
        writer: &可变 实现 Write,
    ) -> 标准库::输入输出::结果<()> {
        // We do not consider this function performance critical, as debug output is only useful for small files,
        // which are not a performance problem in any case. Therefore there aren't any special performance
        // optimizations here.

        设 line = 自身
            .line
            .迭代()
            .copied()
            .映射(|c| 如果 c == b'\t' { b'>' } 否则 { c })
            .收集::<向量<_>>();

        writer.write_all(&line)?;
        writeln!(writer)?;

        设 可变 fields = 向量![];
        tokenize(
            自身.line,
            settings.separator,
            &可变 fields,
            &settings.precomputed,
        );
        循环 selector 在 &settings.selectors {
            设 可变 selection = selector.get_range(自身.line, 一些(&fields));
            匹配 selector.settings.mode {
                SortMode::Numeric | SortMode::HumanNumeric => {
                    // find out which range is used for numeric comparisons
                    设 可变 parse_settings = settings
                        .numeric_locale
                        .num_info_settings(selector.settings.mode == SortMode::HumanNumeric);
                    // Debug annotations should ignore thousands separators to match GNU output.
                    parse_settings.thousands_separator = 无;
                    设 (_, num_range) =
                        NumInfo::parse(&自身.line[selection.克隆()], &parse_settings);
                    设 initial_selection = selection.克隆();

                    // Shorten selection to num_range.
                    selection.start += num_range.start;
                    selection.end = selection.start + num_range.长度();

                    如果 num_range == (0..0) {
                        // This was not a valid number.
                        // Report no match at the first non-whitespace character.
                        设 leading_whitespace = 自身.line[selection.克隆()]
                            .迭代()
                            .position(|c| !c.is_ascii_whitespace())
                            .unwrap_or(0);
                        selection.start += leading_whitespace;
                        selection.end += leading_whitespace;
                    } 否则 {
                        // include a trailing si unit
                        如果 selector.settings.mode == SortMode::HumanNumeric {
                            如果 设 一些(
                                b'k' | b'K' | b'M' | b'G' | b'T' | b'P' | b'E' | b'Z' | b'Y' | b'R'
                                | b'Q',
                            ) = 自身.line[selection.end..initial_selection.end].first()
                            {
                                selection.end += 1;
                            }
                        }

                        // include leading zeroes, a leading minus or a leading decimal point
                        当 设 一些(b'-' | b'0' | b'.') =
                            自身.line[initial_selection.start..selection.start].最后()
                        {
                            selection.start -= 1;
                        }
                    }
                }
                SortMode::GeneralNumeric => {
                    设 initial_selection = &自身.line[selection.克隆()];
                    设 decimal_pt = locale_decimal_pt();
                    设 leading = get_leading_gen(initial_selection, decimal_pt);

                    // Shorten selection to leading.
                    selection.start += leading.start;
                    selection.end = selection.start + leading.长度();
                }
                SortMode::Month => {
                    设 initial_selection = &自身.line[selection.克隆()];
                    设 first_non_blank = initial_selection
                        .迭代()
                        .position(|c| !c.is_ascii_whitespace())
                        .unwrap_or(initial_selection.长度());

                    设 (parsed, match_len) = month_parse(initial_selection);

                    如果 parsed == Month::Unknown {
                        // We failed to parse a month, which is equivalent to matching nothing.
                        // Add the "no match for key" marker to the first non-whitespace character.
                        selection.start += first_non_blank;
                        selection.end = selection.start;
                    } 否则 {
                        // We parsed a month. Use the actual match byte length.
                        selection.start += first_non_blank;
                        selection.end = selection.start + match_len;
                    }
                }
                _ => {}
            }

            // Don't let embedded NUL bytes influence column alignment in the
            // debug underline output, since they are often filtered out (e.g.
            // via `tr -d '\0'`) before inspection.
            设 select = &line[..selection.start];
            设 indent = count_non_null_bytes(select);
            write!(writer, "{}", " ".repeat(indent))?;

            如果 selection.为空() {
                writeln!(writer, "{}", translate!("sort-error-no-match-for-key"))?;
            } 否则 {
                设 select = &line[selection];
                设 underline_len = count_non_null_bytes(select);
                writeln!(writer, "{}", "_".repeat(underline_len))?;
            }
        }

        如果 settings.mode != SortMode::Random
            && !settings.stable
            && !settings.unique
            && (settings.dictionary_order
                || settings.ignore_leading_blanks
                || settings.ignore_case
                || settings.ignore_non_printing
                || settings.mode != SortMode::默认协议
                || settings
                    .selectors
                    .最后()
                    .is_none_or(|selector| selector != &FieldSelector::默认()))
        {
            // A last resort comparator is in use, underline the whole line.
            如果 自身.line.为空() {
                writeln!(writer, "{}", translate!("sort-error-no-match-for-key"))?;
            } 否则 {
                writeln!(writer, "{}", "_".repeat(自身.line.长度()))?;
            }
        }
        好的(())
    }
}

/// Tokenize a line into fields. The result is stored into `token_buffer`.
方法 tokenize(
    line: &[正8],
    separator: 选项<正8>,
    token_buffer: &可变 向量<Field>,
    precomputed: &Precomputed,
) {
    断言!(token_buffer.为空());
    如果 设 一些(separator) = separator {
        tokenize_with_separator(line, separator, token_buffer);
    } 否则 {
        tokenize_default(
            line,
            token_buffer,
            precomputed.tokenize_blank_thousands_sep,
            precomputed.tokenize_allow_unit_after_blank,
        );
    }
}

/// By default fields are separated by the first whitespace after non-whitespace.
/// Whitespace is included in fields at the start.
/// The result is stored into `token_buffer`.
方法 tokenize_default(
    line: &[正8],
    token_buffer: &可变 向量<Field>,
    blank_thousands_sep: 布尔,
    allow_unit_after_blank: 布尔,
) {
    token_buffer.压入(0..0);
    // pretend that there was whitespace in front of the line
    设 可变 previous_was_whitespace = 真;
    循环 (idx, 字符) 在 line.迭代().enumerate() {
        设 is_whitespace = 字符.is_ascii_whitespace();
        设 treat_as_separator = 如果 is_whitespace {
            如果 blank_thousands_sep && *字符 == b' ' {
                !is_blank_thousands_sep(line, idx, allow_unit_after_blank)
            } 否则 {
                真
            }
        } 否则 {
            假
        };

        如果 treat_as_separator {
            如果 !previous_was_whitespace {
                token_buffer.last_mut().解包().end = idx;
                token_buffer.压入(idx..0);
            }
            previous_was_whitespace = 真;
        } 否则 {
            previous_was_whitespace = 假;
        }
    }
    token_buffer.last_mut().解包().end = line.长度();
}

方法 is_blank_thousands_sep(line: &[正8], idx: 正整数大小, allow_unit_after_blank: 布尔) -> 布尔 {
    如果 line.获取(idx) != 一些(&b' ') {
        返回 假;
    }

    设 prev_is_digit = idx
        .checked_sub(1)
        .and_then(|prev_idx| line.获取(prev_idx))
        .is_some_and(正8::is_ascii_digit);
    如果 !prev_is_digit {
        返回 假;
    }

    设 next = line.获取(idx + 1).copied();
    匹配 next {
        一些(c) 如果 c.is_ascii_digit() => 真,
        一些(b'K' | b'k' | b'M' | b'G' | b'T' | b'P' | b'E' | b'Z' | b'Y' | b'R' | b'Q')
            如果 allow_unit_after_blank =>
        {
            真
        }
        _ => 假,
    }
}

/// Split between separators. These separators are not included in fields.
/// The result is stored into `token_buffer`.
方法 tokenize_with_separator(line: &[正8], separator: 正8, token_buffer: &可变 向量<Field>) {
    设 separator_indices = line
        .迭代()
        .enumerate()
        .filter_map(|(i, &c)| 如果 c == separator { 一些(i) } 否则 { 无 });
    设 可变 start = 0;
    循环 sep_idx 在 separator_indices {
        token_buffer.压入(start..sep_idx);
        start = sep_idx + 1;
    }
    如果 start < line.长度() {
        token_buffer.压入(start..line.长度());
    }
}

