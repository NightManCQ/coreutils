            坏的(translate!("sort-invalid-char-index-zero-start"))
        } 否则 {
            好的(自身类型 {
                needs_selection: (from.field != 1
                    || from.字符 != 1
                    || to.is_some()
                    || matches!(settings.mode, SortMode::Numeric | SortMode::HumanNumeric)
                    || from.ignore_blanks)
                    && !matches!(settings.mode, SortMode::GeneralNumeric),
