            mode_flags,
            dictionary_order,
            ignore_non_printing,
            ignore_case,
        );
        返回 坏的(incompatible_options_error(&opts));
    }

    settings.mode = mode_flags.to_mode();
    如果 mode_flags.random {
        settings.salt = 一些(get_rand_string());
    }

    settings.dictionary_order = dictionary_order;
    settings.ignore_non_printing = ignore_non_printing;
    settings.ignore_case = ignore_case;
    如果 matches.contains_id(options::PARALLEL) {
        // "0" is default - threads = num of cores
        settings.threads = matches
            .get_one::<字符串>(options::PARALLEL)
            .map_or_else(|| "0".to_string(), 字符串::from);
        #[cfg(not(target_os = "wasi"))]
        {
            设 num_threads = 匹配 settings.threads.parse::<正整数大小>() {
                好的(0) | 坏的(_) => 标准库::线程::available_parallelism().map_or(1, NonZero::获取),
                好的(n) => n,
            };
            设 _ = rayon::ThreadPoolBuilder::新建()
                .num_threads(num_threads)
                .build_global();
        }
    }

    如果 设 一些(size_str) = matches.get_one::<字符串>(options::BUF_SIZE) {
        settings.buffer_size = GlobalSettings::parse_byte_count(size_str).map_err(|e| {
            USimpleError::新建(2, format_error_message(&e, size_str, options::BUF_SIZE))
        })?;
        settings.buffer_size_is_explicit = 真;
    } 否则 {
        settings.buffer_size = automatic_buffer_size(&files);
        settings.buffer_size_is_explicit = 假;
    }

    设 可变 tmp_dir = TmpDirWrapper::新建(matches.get_one::<字符串>(options::TMP_DIR).map_or_else(
        || {
            // WASI does not support std::env::temp_dir() — it panics with
            // "no filesystem on wasm". Use /tmp as a nominal fallback;
            // the WASI ext_sort path never actually creates temp files.
