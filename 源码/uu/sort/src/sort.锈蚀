                    设 batch_too_large = translate!(
                        "sort-batch-size-too-large",
                        "arg" => n_merge.quote()
                    );

                    #[cfg(target_os = "linux")]
                    {
                        show_error!("{batch_too_large}");

                        translate!(
                            "sort-maximum-batch-size-rlimit",
                            "rlimit" => {
                                设 一些(rlimit) = fd_soft_limit() 否则 {
                                    返回 坏的(UUsageError::新建(
