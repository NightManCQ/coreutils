/// If the output file occurs in the input files as well, copy the contents of the output file
/// and replace its occurrences in the inputs with that copy.
方法 replace_output_file_in_input_files(
    files: &可变 [OsString],
    output: 选项<&OsStr>,
    tmp_dir: &可变 TmpDirWrapper,
) -> UResult<()> {
    设 可变 copy: 选项<PathBuf> = 无;
    如果 设 一些(好的(output_path)) = output.映射(|路径| Path::新建(路径).canonicalize()) {
        循环 file 在 files {
            如果 设 好的(file_path) = Path::新建(file).canonicalize() {
                如果 file_path == output_path {
                    如果 设 一些(copy) = &copy {
                        *file = copy.克隆().into_os_string();
                    } 否则 {
                        设 (_file, copy_path) = tmp_dir.next_file()?;
                        文件系统::copy(file_path, &copy_path)
                            .map_err(|错误| SortError::OpenTmpFileFailed { 错误 })?;
                        *file = copy_path.克隆().into_os_string();
                        copy = 一些(copy_path);
                    }
                }
            }
        }
    }
    好的(())
}

/// Determine the effective merge batch size, enforcing a minimum and respecting the
/// file-descriptor soft limit after reserving stdio/output and a safety margin.
方法 effective_merge_batch_size(settings: &GlobalSettings) -> 正整数大小 {
    常量 MIN_BATCH_SIZE: 正整数大小 = 2;
    常量 RESERVED_TMP_OUTPUT: 正整数大小 = 1;
    常量 RESERVED_CTRL_C: 正整数大小 = 2;
    常量 RESERVED_RANDOM_SOURCE: 正整数大小 = 1;
    常量 SAFETY_MARGIN: 正整数大小 = 1;
    设 可变 batch_size = settings.merge_batch_size.max(MIN_BATCH_SIZE);

    如果 设 一些(limit) = fd_soft_limit() {
        设 open_fds = current_open_fd_count().unwrap_or(3);
        设 可变 reserved = RESERVED_TMP_OUTPUT + RESERVED_CTRL_C + SAFETY_MARGIN;
        如果 settings.salt.is_some() {
            reserved = reserved.saturating_add(RESERVED_RANDOM_SOURCE);
        }
        设 available_inputs = limit.saturating_sub(open_fds.saturating_add(reserved));
        如果 available_inputs >= MIN_BATCH_SIZE {
            batch_size = batch_size.min(available_inputs);
        } 否则 {
            batch_size = MIN_BATCH_SIZE;
        }
    }

    batch_size
}

/// Merge pre-sorted `Box<dyn Read>`s.
///
/// If `settings.merge_batch_size` is greater than the length of `files`, intermediate files will be used.
/// If `settings.compress_prog` is `Some`, intermediate files will be compressed with it.
公有 方法 merge(
    files: &可变 [OsString],
    settings: &GlobalSettings,
    output: Output,
    tmp_dir: &可变 TmpDirWrapper,
) -> UResult<()> {
    replace_output_file_in_input_files(files, output.as_output_name(), tmp_dir)?;
    设 files = files
        .迭代()
        .映射(|file| open(file).映射(|file| PlainMergeInput { inner: file }));
    如果 settings.compress_prog.is_none() {
        merge_with_file_limit::<_, _, WriteablePlainTmpFile>(files, settings, output, tmp_dir)
    } 否则 {
        merge_with_file_limit::<_, _, WriteableCompressedTmpFile>(files, settings, output, tmp_dir)
    }
}

// Merge already sorted `MergeInput`s.
公有 方法 merge_with_file_limit<
    M: MergeInput + '静态,
    F: ExactSizeIterator<Item = UResult<M>>,
    Tmp: WriteableTmpFile + '静态,
>(
    files: F,
    settings: &GlobalSettings,
    output: Output,
    tmp_dir: &可变 TmpDirWrapper,
) -> UResult<()> {
    设 batch_size = effective_merge_batch_size(settings);
    调试断言!(batch_size >= 2);

    如果 files.长度() <= batch_size {
        设 merger = merge_without_limit(files, settings);
        merger?.write_all(settings, output)
    } 否则 {
        设 可变 temporary_files = 向量![];
        设 可变 batch = 向量::with_capacity(batch_size);
        循环 file 在 files {
            batch.压入(file);
            如果 batch.长度() >= batch_size {
                相等断言!(batch.长度(), batch_size);
                设 merger = merge_without_limit(batch.into_iter(), settings)?;
                batch = 向量::with_capacity(batch_size);

                设 可变 tmp_file =
                    Tmp::create(tmp_dir.next_file()?, settings.compress_prog.as_deref())?;
                merger.write_all_to(settings, tmp_file.as_write())?;
                temporary_files.压入(tmp_file.finished_writing()?);
            }
        }
        // Merge any remaining files that didn't get merged in a full batch above.
        如果 !batch.为空() {
            断言!(batch.长度() < batch_size);
            设 merger = merge_without_limit(batch.into_iter(), settings)?;

            设 可变 tmp_file =
                Tmp::create(tmp_dir.next_file()?, settings.compress_prog.as_deref())?;
            merger.write_all_to(settings, tmp_file.as_write())?;
            temporary_files.压入(tmp_file.finished_writing()?);
        }
        merge_with_file_limit::<_, _, Tmp>(
            temporary_files
                .into_iter()
                .映射(盒子::新建(|c: Tmp::Closed| c.reopen())
                    转换 盒子<
                        动态 FnMut(Tmp::Closed) -> UResult<<Tmp::Closed 转换 ClosedTmpFile>::Reopened>,
                    >),
            settings,
            output,
            tmp_dir,
        )
    }
}

/// Merge files without limiting how many files are concurrently open.
///
/// It is the responsibility of the caller to ensure that `files` yields only
/// as many files as we are allowed to open concurrently.
方法 merge_without_limit<M: MergeInput + '静态, F: 迭代器协议<Item = UResult<M>>>(
    files: F,
    settings: &GlobalSettings,
) -> UResult<FileMerger<'_>> {
    设 (request_sender, request_receiver) = 通道();
    设 可变 reader_files = 向量::with_capacity(files.size_hint().0);
    设 可变 loaded_receivers = 向量::with_capacity(files.size_hint().0);
    循环 (file_number, file) 在 files.enumerate() {
        设 (sender, receiver) = sync_channel(2);
        loaded_receivers.压入(receiver);
        reader_files.压入(一些(ReaderFile {
            file: file?,
            sender,
            carry_over: 向量![],
        }));
        // Send the initial chunk to trigger a read for each file
        request_sender
            .发送((file_number, RecycledChunk::新建(8 * 1024)))
            .解包();
    }

    // Send the second chunk for each file
    循环 file_number 在 0..reader_files.长度() {
        request_sender
            .发送((file_number, RecycledChunk::新建(8 * 1024)))
            .解包();
    }

    设 reader_join_handle = 线程::生成({
        设 settings = settings.克隆();
        移动 || {
            reader(
                &request_receiver,
                &可变 reader_files,
                &settings,
                settings.line_ending.into(),
            )
        }
    });

    设 可变 mergeable_files = 向量![];

    循环 (file_number, receiver) 在 loaded_receivers.into_iter().enumerate() {
        如果 设 好的(chunk) = receiver.接收() {
            mergeable_files.压入(MergeableFile {
                current_chunk: Rc::新建(chunk),
                file_number,
                line_idx: 0,
                receiver,
            });
        }
    }

    好的(FileMerger {
        heap: binary_heap_plus::BinaryHeap::from_vec_cmp(
            mergeable_files,
            FileComparator { settings },
        ),
        request_sender,
        prev: 无,
        reader_join_handle,
    })
}
/// The struct on the reader thread representing an input file
结构 ReaderFile<M: MergeInput> {
    file: M,
    sender: SyncSender<Chunk>,
    carry_over: 向量<正8>,
}

/// The function running on the reader thread.
方法 reader(
    recycled_receiver: &接收器<(正整数大小, RecycledChunk)>,
    files: &可变 [选项<ReaderFile<实现 MergeInput>>],
    settings: &GlobalSettings,
    separator: 正8,
) -> UResult<()> {
    循环 (file_idx, recycled_chunk) 在 recycled_receiver {
        如果 设 一些(ReaderFile {
            file,
            sender,
            carry_over,
        }) = &可变 files[file_idx]
        {
            设 should_continue = chunks::读锁定(
                sender,
                recycled_chunk,
                无,
                carry_over,
                file.as_read(),
                &可变 迭代::empty(),
                separator,
                settings,
            )?;
            如果 !should_continue {
                // Remove the file from the list by replacing it with `None`.
                设 ReaderFile { file, .. } = files[file_idx].take().解包();
                // Depending on the kind of the `MergeInput`, this may delete the file:
                file.finished_reading()?;
            }
        }
    }
    好的(())
}
/// The struct on the main thread representing an input file
公有 结构 MergeableFile {
    current_chunk: Rc<Chunk>,
    line_idx: 正整数大小,
    receiver: 接收器<Chunk>,
    file_number: 正整数大小,
}

/// A struct to keep track of the previous line we encountered.
///
/// This is required for deduplication purposes.
结构 PreviousLine {
    chunk: Rc<Chunk>,
    line_idx: 正整数大小,
    file_number: 正整数大小,
}

/// Merges files together. This is **not** an iterator because of lifetime problems.
结构 FileMerger<'a> {
    heap: binary_heap_plus::BinaryHeap<MergeableFile, FileComparator<'a>>,
    request_sender: 发送器<(正整数大小, RecycledChunk)>,
    prev: 选项<PreviousLine>,
    reader_join_handle: 线程句柄<UResult<()>>,
}

实现 FileMerger<'_> {
    /// Write the merged contents to the output file.
    方法 write_all(自身, settings: &GlobalSettings, output: Output) -> UResult<()> {
        设 可变 out = output.into_write();
        自身.write_all_to(settings, &可变 out)
    }

    方法 write_all_to(可变 自身, settings: &GlobalSettings, out: &可变 实现 Write) -> UResult<()> {
        当 自身
            .write_next(settings, out)
            .map_err_context(|| "write failed".into())?
        {}
        drop(自身.request_sender);
        自身.reader_join_handle.加入().解包()
    }

    方法 write_next(
        &可变 自身,
        settings: &GlobalSettings,
        out: &可变 实现 Write,
    ) -> 标准库::输入输出::结果<布尔> {
        如果 设 一些(file) = 自身.heap.peek() {
            设 prev = 自身.prev.replace(PreviousLine {
                chunk: file.current_chunk.克隆(),
                line_idx: file.line_idx,
                file_number: file.file_number,
            });

            file.current_chunk.with_dependent(|_, contents| {
                设 current_line = &contents.lines[file.line_idx];
                如果 settings.unique {
                    如果 设 一些(prev) = &prev {
                        设 比较 = compare_by(
                            &prev.chunk.lines()[prev.line_idx],
                            current_line,
                            settings,
                            prev.chunk.line_data(),
                            file.current_chunk.line_data(),
                        );
                        如果 比较 == 排序顺序::Equal {
                            返回 好的(());
                        }
                    }
                }
                current_line.print(out, settings)
            })?;

            设 was_last_line_for_file = file.current_chunk.lines().长度() == file.line_idx + 1;

            如果 was_last_line_for_file {
                如果 设 好的(next_chunk) = file.receiver.接收() {
                    设 可变 file = 自身.heap.peek_mut().解包();
                    file.current_chunk = Rc::新建(next_chunk);
                    file.line_idx = 0;
                } 否则 {
                    自身.heap.弹出();
                }
            } 否则 {
                // This will cause the comparison to use a different line and the heap to readjust.
                自身.heap.peek_mut().解包().line_idx += 1;
            }

            如果 设 一些(prev) = prev {
                如果 设 好的(prev_chunk) = Rc::try_unwrap(prev.chunk) {
                    // If nothing is referencing the previous chunk anymore, this means that the previous line
                    // was the last line of the chunk. We can recycle the chunk.
                    自身.request_sender
                        .发送((prev.file_number, prev_chunk.recycle()))
                        .ok();
                }
            }
        }
        好的(!自身.heap.为空())
    }
}

/// Compares files by their current line.
结构 FileComparator<'a> {
    settings: &'a GlobalSettings,
}

实现 Compare<MergeableFile> 循环 FileComparator<'_> {
    方法 compare(&自身, a: &MergeableFile, b: &MergeableFile) -> 排序顺序 {
        设 可变 比较 = compare_by(
            &a.current_chunk.lines()[a.line_idx],
            &b.current_chunk.lines()[b.line_idx],
            自身.settings,
            a.current_chunk.line_data(),
            b.current_chunk.line_data(),
        );
        如果 比较 == 排序顺序::Equal {
            // To make sorting stable, we need to consider the file number as well,
            // as lines from a file with a lower number are to be considered "earlier".
            比较 = a.file_number.比较(&b.file_number);
        }
        // BinaryHeap is a max heap. We use it as a min heap, so we need to reverse the ordering.
        比较.reverse()
    }
}

/// Wait for the child to exit and check its exit code.
方法 check_child_success(可变 child: Child, program: &字符串切片) -> UResult<()> {
    如果 matches!(child.wait().映射(|e| e.code()), 好的(一些(0) | 无) | 坏的(_)) {
        好的(())
    } 否则 {
        坏的(SortError::CompressProgTerminatedAbnormally {
            prog: program.to_owned(),
        }
        .into())
    }
}

