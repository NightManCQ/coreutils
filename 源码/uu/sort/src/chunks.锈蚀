#[derive(调试协议)]
公有 结构 ChunkContents<'a> {
    公有 lines: 向量<Line<'a>>,
    公有 line_data: LineData<'a>,
    公有 token_buffer: 向量<Range<正整数大小>>,
    公有 line_count_hint: 正整数大小,
}

#[derive(调试协议, 默认协议)]
公有 结构 LineData<'a> {
    公有 selections: 向量<&'a [正8]>,
    公有 num_infos: 向量<NumInfo>,
    公有 parsed_floats: 向量<GeneralBigDecimalParseResult>,
    公有 line_num_floats: 向量<选项<点64>>,
    /// Arena buffer holding all collation sort keys concatenated.
    公有 collation_key_buffer: 向量<正8>,
    /// End offsets into `collation_key_buffer` for each line's sort key.
    公有 collation_key_ends: 向量<正整数大小>,
}

实现 LineData<'_> {
    /// Get the collation sort key for a line at the given index.
    公有 方法 collation_key(&自身, index: 正整数大小) -> &[正8] {
        设 start = 如果 index == 0 {
            0
        } 否则 {
            自身.collation_key_ends[index - 1]
        };
        设 end = 自身.collation_key_ends[index];
        &自身.collation_key_buffer[start..end]
    }
}

实现 Chunk {
    /// Destroy this chunk and return its components to be reused.
    公有 方法 recycle(可变 自身) -> RecycledChunk {
        设 可变 recycled_contents = 自身.with_dependent_mut(|_, contents| {
            contents.lines.clear();
            contents.line_data.selections.clear();
            contents.line_data.num_infos.clear();
            contents.line_data.parsed_floats.clear();
            contents.line_data.line_num_floats.clear();
            contents.line_data.collation_key_buffer.clear();
            contents.line_data.collation_key_ends.clear();
            contents.token_buffer.clear();
            设 lines = 不安全 {
                // SAFETY: It is safe to (temporarily) transmute to a vector of lines with a longer lifetime,
                // because the vector is empty.
                // Transmuting is necessary to make recycling possible. See https://github.com/rust-lang/rfcs/pull/2802
                // for a rfc to make this unnecessary. Its example is similar to the code here.
                标准库::内存::transmute::<向量<Line<'_>>, 向量<Line<'静态>>>(标准库::内存::take(
                    &可变 contents.lines,
                ))
            };
            设 selections = 不安全 {
                // SAFETY: (same as above) It is safe to (temporarily) transmute to a vector of &str with a longer lifetime,
                // because the vector is empty.
                标准库::内存::transmute::<向量<&'_ [正8]>, 向量<&'静态 [正8]>>(标准库::内存::take(
                    &可变 contents.line_data.selections,
                ))
            };
            RecycledChunk {
                lines,
                selections,
                num_infos: 标准库::内存::take(&可变 contents.line_data.num_infos),
                parsed_floats: 标准库::内存::take(&可变 contents.line_data.parsed_floats),
                line_num_floats: 标准库::内存::take(&可变 contents.line_data.line_num_floats),
                collation_key_buffer: 标准库::内存::take(&可变 contents.line_data.collation_key_buffer),
                collation_key_ends: 标准库::内存::take(&可变 contents.line_data.collation_key_ends),
                token_buffer: 标准库::内存::take(&可变 contents.token_buffer),
                line_count_hint: contents.line_count_hint,
                // buffer is set below after we consume `self`
                buffer: 向量::新建(),
            }
        });
        recycled_contents.buffer = 自身.into_owner();
        recycled_contents
    }

    公有 方法 lines(&自身) -> &向量<Line<'_>> {
        &自身.borrow_dependent().lines
    }

    公有 方法 line_data(&自身) -> &LineData<'_> {
        &自身.borrow_dependent().line_data
    }
}

公有 结构 RecycledChunk {
    lines: 向量<Line<'静态>>,
    selections: 向量<&'静态 [正8]>,
    num_infos: 向量<NumInfo>,
    parsed_floats: 向量<GeneralBigDecimalParseResult>,
    line_num_floats: 向量<选项<点64>>,
    collation_key_buffer: 向量<正8>,
    collation_key_ends: 向量<正整数大小>,
