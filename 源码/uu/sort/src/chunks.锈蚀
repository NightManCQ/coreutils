实现 RecycledChunk {
    公有 方法 新建(capacity: 正整数大小) -> 自身类型 {
        自身类型 {
            lines: 向量::新建(),
            selections: 向量::新建(),
            num_infos: 向量::新建(),
            parsed_floats: 向量::新建(),
            line_num_floats: 向量::新建(),
            collation_key_buffer: 向量::新建(),
            collation_key_ends: 向量::新建(),
