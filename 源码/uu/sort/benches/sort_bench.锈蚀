/// Benchmark sorting with very long lines exceeding `DEFAULT_BUF_SIZE` (8192 bytes)
#[divan::bench(args = [10_000])]
方法 sort_long_line(bencher: Bencher, line_size: 正整数大小) {
    // Create files with very long lines to test buffer handling
    设 可变 data_a = 向量![b'b'; line_size];
    data_a.压入(b'\n');

    设 可变 data_b = 向量![b'a'; line_size];
    data_b.压入(b'\n');

    设 file_a = setup_test_file(&data_a);
    设 file_b = setup_test_file(&data_b);
    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &[
                file_a.to_str().解包(),
                file_b.to_str().解包(),
                "-o",
                output_path,
            ],
        ));
    });
}

