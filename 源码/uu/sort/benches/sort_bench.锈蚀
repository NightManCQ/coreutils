/// Benchmark numeric sorting with mixed data
#[divan::bench(args = [500_000])]
方法 sort_numeric(bencher: Bencher, num_lines: 正整数大小) {
    设 可变 data = 向量::新建();

    // Generate numeric data with some text prefixes
    循环 i 在 0..num_lines {
        设 value = (i * 13) % 10000; // Pseudo-random numeric values
        data.extend_from_slice(格式化!("value_{value}\n").as_bytes());
    }

    设 file_path = setup_test_file(&data);

    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-n", "-o", output_path, file_path.to_str().解包()],
        ));
    });
}

/// Benchmark general numeric sorting (-g) with decimal and exponent notation
#[divan::bench(args = [200_000])]
方法 sort_general_numeric(bencher: Bencher, num_lines: 正整数大小) {
    设 可变 data = 向量::新建();

    // Generate numeric data with decimal points and exponents
    循环 i 在 0..num_lines {
        设 int_part = (i * 13) % 100_000;
        设 frac_part = (i * 7) % 1000;
        设 exp = (i % 5) 转换 整32 - 2; // -2..=2
        设 sign = 如果 i % 2 == 0 { "" } 否则 { "-" };
        data.extend_from_slice(格式化!("{sign}{int_part}.{frac_part:03}e{exp:+}\n").as_bytes());
    }

    设 file_path = setup_test_file(&data);
    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包();

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-g", "-o", output_path, file_path.to_str().解包()],
        ));
    });
}

