/// Benchmark sorting with specific key field
#[divan::bench(args = [500_000])]
方法 sort_key_field(bencher: Bencher, num_lines: 正整数大小) {
    设 可变 data = 向量::新建();

    // Generate data with multiple fields
    设 words = ["café", "naïve", "apple", "über", "banana"];
    循环 i 在 0..num_lines {
        设 word = words[i % words.长度()];
        设 num1 = i % 100;
        设 num2 = (i * 7) % 100;
        data.extend_from_slice(格式化!("{num1}\t{word}\t{num2}\n").as_bytes());
    }

    设 file_path = setup_test_file(&data);

    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包();

    bencher.bench(|| {
        // Sort by second field
        black_box(run_util_function(
            uumain,
            &["-k", "2", "-o", output_path, file_path.to_str().解包()],
        ));
    });
}

