/// Benchmark numeric sorting with UTF-8 locale
#[divan::bench]
方法 sort_numeric_utf8_locale(bencher: Bencher) {
    设 可变 data = 向量::新建();
    循环 i 在 0..50_000 {
        设 line = 格式化!("{}\n", 50_000 - i);
        data.extend_from_slice(line.as_bytes());
    }
    设 file_path = setup_test_file(&data);
    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包().to_string();

    设 args = ["-n", "-o", &output_path, file_path.to_str().解包()];
    black_box(run_util_function(uumain, &args));
    bencher.bench(|| {
        black_box(run_util_function(uumain, &args));
    });
}

