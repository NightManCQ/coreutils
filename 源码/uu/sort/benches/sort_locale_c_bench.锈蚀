方法 主函数() {
    // Set C locale BEFORE any benchmarks run.
    // This must happen before divan::main() because the locale is cached
    // on first access via OnceLock and cannot be changed afterwards.
    不安全 {
        标准库::环境::set_var("LC_ALL", "C");
    }
    divan::主函数();
}
