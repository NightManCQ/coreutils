//! Benchmarks for sort with C locale (fast byte-wise comparison).
//!
//! Note: The locale is set in main() BEFORE any benchmark runs because
//! the locale is cached on first access via OnceLock and cannot be changed afterwards.

使用 divan::{Bencher, black_box};
使用 tempfile::NamedTempFile;
使用 uu_sort::uumain;
使用 uucore::benchmark::{run_util_function, setup_test_file, text_data};

/// Benchmark ASCII-only data sorting with C locale (byte comparison)
#[divan::bench]
方法 sort_ascii_c_locale(bencher: Bencher) {
    设 data = text_data::generate_ascii_data_simple(100_000);
    设 file_path = setup_test_file(&data);
    设 output_file = NamedTempFile::新建().解包();
    设 output_path = output_file.路径().to_str().解包().to_string();

    bencher.bench(|| {
        black_box(run_util_function(
            uumain,
            &["-o", &output_path, file_path.to_str().解包()],
        ));
    });
}

