/// Default whitespace separator.
#[derive(复制协议, 克隆协议)]
结构 WhitespaceSep {}

实现 Separator 循环 WhitespaceSep {
    方法 field_ranges(&自身, haystack: &[正8], len_guess: 正整数大小) -> 向量<(正整数大小, 正整数大小)> {
        设 可变 field_ranges = 向量::with_capacity(len_guess);
        设 可变 last_end = 0;

        // GNU join used Bourne shell field splitters by default
        // FIXME: but now uses locale-dependent whitespace
        循环 i 在 Memchr3::新建(b' ', b'\t', b'\n', haystack) {
            // leading whitespace should be dropped, contiguous whitespace merged
            如果 i > last_end {
                field_ranges.压入((last_end, i));
            }
            last_end = i + 1;
        }
        field_ranges.压入((last_end, haystack.长度()));
        field_ranges
    }

    方法 output_separator(&自身) -> &[正8] {
        b" "
    }
}

