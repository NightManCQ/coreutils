结构 State<'a> {
    key: 正整数大小,
    file_name: &'a OsString,
    file_num: FileNum,
    print_unpaired: 布尔,
    lines: Split<盒子<动态 BufRead + 'a>>,
    max_len: 正整数大小,
    seq: 向量<Line>,
    line_num: 正整数大小,
    has_failed: 布尔,
    has_unpaired: 布尔,
}

实现<'a> State<'a> {
    方法 新建(
        file_num: FileNum,
        name: &'a OsString,
        stdin: &'a Stdin,
        key: 正整数大小,
        line_ending: LineEnding,
        print_unpaired: 布尔,
    ) -> UResult<自身类型> {
        设 file_buf = 如果 name == "-" {
            盒子::新建(stdin.锁定()) 转换 盒子<动态 BufRead>
        } 否则 {
            设 file = File::open(name).map_err_context(|| 格式化!("{}", name.maybe_quote()))?;
            盒子::新建(BufReader::新建(file)) 转换 盒子<动态 BufRead>
        };

        好的(State {
            key,
            file_name: name,
            file_num,
            print_unpaired,
            lines: file_buf.split(line_ending 转换 正8),
            max_len: 1,
            seq: 向量::新建(),
            line_num: 0,
            has_failed: 假,
            has_unpaired: 假,
        })
    }

    /// Skip the current unpaired line.
    方法 skip_line<Sep: Separator>(
        &可变 自身,
        writer: &可变 实现 Write,
        input: &Input<Sep>,
        repr: &Repr<'a, Sep>,
    ) -> UResult<()> {
        如果 自身.print_unpaired {
            自身.write_first_line(writer, repr)?;
        }

        自身.reset_next_line(input)?;
        好的(())
    }

    /// Keep reading line sequence until the key does not change, return
    /// the first line whose key differs.
    方法 extend<Sep: Separator>(&可变 自身, input: &Input<Sep>) -> UResult<选项<Line>> {
        当 设 一些(line) = 自身.next_line(input)? {
            设 diff = input.compare(自身.get_current_key(), line.get_field(自身.key));

            如果 diff == 排序顺序::Equal {
                自身.seq.压入(line);
            } 否则 {
                返回 好的(一些(line));
            }
        }

        好的(无)
    }

    /// Write lines in the buffers as headers.
    方法 write_headers<Sep: Separator>(
        &自身,
        writer: &可变 实现 Write,
        other: &State,
        repr: &Repr<'a, Sep>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        如果 自身.has_line() {
            如果 other.has_line() {
                自身.combine(writer, other, repr)?;
            } 否则 {
                自身.write_first_line(writer, repr)?;
            }
        } 否则 如果 other.has_line() {
            other.write_first_line(writer, repr)?;
        }

        好的(())
    }

    /// Combine two line sequences.
    方法 combine<Sep: Separator>(
        &自身,
        writer: &可变 实现 Write,
        other: &State,
        repr: &Repr<'a, Sep>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        设 key = 自身.get_current_key();

        循环 line1 在 &自身.seq {
            循环 line2 在 &other.seq {
                如果 repr.uses_format() {
                    repr.write_format(writer, |spec| 匹配 *spec {
                        Spec::Key => key,
                        Spec::Field(file_num, field_num) => {
                            如果 file_num == 自身.file_num {
                                返回 line1.get_field(field_num);
                            }

                            如果 file_num == other.file_num {
                                返回 line2.get_field(field_num);
                            }

                            无
                        }
                    })?;
                } 否则 {
                    repr.write_field(writer, key)?;
                    repr.write_fields(writer, line1, 自身.key)?;
                    repr.write_fields(writer, line2, other.key)?;
                }

                repr.write_line_ending(writer)?;
            }
        }

        好的(())
    }

    /// Reset with the next line.
    方法 reset(&可变 自身, next_line: 选项<Line>) {
        自身.seq.clear();

        如果 设 一些(line) = next_line {
            自身.seq.压入(line);
        }
    }

    方法 reset_read_line<Sep: Separator>(
        &可变 自身,
        input: &Input<Sep>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        设 line = 自身.read_line(&input.separator)?;
        自身.reset(line);
        好的(())
    }

    方法 reset_next_line<Sep: Separator>(&可变 自身, input: &Input<Sep>) -> 结果<(), JoinError> {
        设 line = 自身.next_line(input)?;
        自身.reset(line);
        好的(())
    }

    方法 has_line(&自身) -> 布尔 {
        !自身.seq.为空()
    }

    方法 initialize<Sep: Separator>(
        &可变 自身,
        read_sep: &Sep,
        autoformat: 布尔,
    ) -> 标准库::输入输出::结果<正整数大小> {
        如果 设 一些(line) = 自身.read_line(read_sep)? {
            自身.seq.压入(line);

            如果 autoformat {
                返回 好的(自身.seq[0].field_ranges.长度());
            }
        }
        好的(0)
    }

    方法 finalize<Sep: Separator>(
        &可变 自身,
        writer: &可变 实现 Write,
        input: &Input<Sep>,
        repr: &Repr<'a, Sep>,
    ) -> UResult<()> {
        如果 自身.has_line() {
            如果 自身.print_unpaired {
                自身.write_first_line(writer, repr)?;
            }

            设 可变 next_line = 自身.next_line(input)?;
            当 设 一些(line) = &next_line {
                如果 自身.print_unpaired {
                    自身.write_line(writer, line, repr)?;
                }
                自身.reset(next_line);
                next_line = 自身.next_line(input)?;
            }
        }

        好的(())
    }

    /// Get the next line without the order check.
    方法 read_line<Sep: Separator>(&可变 自身, sep: &Sep) -> 结果<选项<Line>, 标准库::输入输出::错误协议> {
        匹配 自身.lines.next() {
            一些(value) => {
                自身.line_num += 1;
                设 line = Line::新建(value?, sep, 自身.max_len);
                如果 line.field_ranges.长度() > 自身.max_len {
                    自身.max_len = line.field_ranges.长度();
                }
                好的(一些(line))
            }
            无 => 好的(无),
        }
    }

    /// Get the next line with the order check.
    方法 next_line<Sep: Separator>(&可变 自身, input: &Input<Sep>) -> 结果<选项<Line>, JoinError> {
        如果 设 一些(line) = 自身.read_line(&input.separator)? {
            如果 input.check_order == CheckOrder::Disabled {
                返回 好的(一些(line));
            }

            设 diff = input.compare(自身.get_current_key(), line.get_field(自身.key));

            如果 diff == 排序顺序::Greater
                && (input.check_order == CheckOrder::Enabled
                    || (自身.has_unpaired && !自身.has_failed))
            {
                设 err_msg = translate!("join-error-not-sorted", "file" => 自身.file_name.maybe_quote(), "line_num" => 自身.line_num, "content" => 字符串::from_utf8_lossy(&line.string));
                // This is fatal if the check is enabled.
                如果 input.check_order == CheckOrder::Enabled {
                    返回 坏的(JoinError::UnorderedInput(err_msg));
                }
                错误打印行!("{}: {err_msg}", uucore::execution_phrase());
                自身.has_failed = 真;
            }

            好的(一些(line))
        } 否则 {
            好的(无)
        }
    }

    /// Gets the key value of the lines stored in seq.
    方法 get_current_key(&自身) -> 选项<&[正8]> {
        自身.seq[0].get_field(自身.key)
    }

    方法 write_line<Sep: Separator>(
        &自身,
        writer: &可变 实现 Write,
        line: &Line,
        repr: &Repr<'a, Sep>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        如果 repr.uses_format() {
            repr.write_format(writer, |spec| 匹配 *spec {
                Spec::Key => line.get_field(自身.key),
                Spec::Field(file_num, field_num) => {
                    如果 file_num == 自身.file_num {
                        line.get_field(field_num)
                    } 否则 {
                        无
                    }
                }
            })?;
        } 否则 {
            repr.write_field(writer, line.get_field(自身.key))?;
            repr.write_fields(writer, line, 自身.key)?;
        }

        repr.write_line_ending(writer)
    }

    方法 write_first_line<Sep: Separator>(
        &自身,
        writer: &可变 实现 Write,
        repr: &Repr<'a, Sep>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        自身.write_line(writer, &自身.seq[0], repr)
    }
}

方法 parse_separator(value_os: &OsString) -> UResult<SepSetting> {
    // Five possible separator values:
    // No argument supplied, separate on whitespace; handled implicitly as the default elsewhere
    // An empty string arg, whole line separation
    // On unix-likes only, a single arbitrary byte
    // The two-character "\0" string, interpreted as a single 0 byte
    // A single scalar valid in the locale encoding (currently only UTF-8)

    如果 value_os.为空() {
        返回 好的(SepSetting::Line);
    }

    #[cfg(unix)]
    {
        设 value = value_os.as_bytes();
        如果 value.长度() == 1 {
            返回 好的(SepSetting::Byte(value[0]));
        }
    }

    设 一些(value) = value_os.to_str() 否则 {
        #[cfg(unix)]
        返回 坏的(USimpleError::新建(1, translate!("join-error-non-utf8-tab")));
        #[cfg(not(unix))]
        返回 坏的(USimpleError::新建(
            1,
            translate!("join-error-unprintable-separators"),
        ));
    };

    设 可变 chars = value.chars();
    设 c = chars.next().期望("valid string with at least one byte");
    匹配 chars.next() {
        无 => 好的(SepSetting::Char(value.into())),
        一些('0') 如果 c == '\\' => 好的(SepSetting::Byte(0)),
        _ => 坏的(USimpleError::新建(
            1,
            translate!("join-error-multi-character-tab", "value" => value),
        )),
    }
}

方法 parse_print_settings(matches: &clap::ArgMatches) -> UResult<(布尔, 布尔, 布尔)> {
    设 可变 print_joined = 真;
    设 可变 print_unpaired1 = 假;
    设 可变 print_unpaired2 = 假;

    设 v_values = matches.get_many::<字符串>("v");
    如果 v_values.is_some() {
        print_joined = 假;
    }

    设 unpaired = v_values
        .unwrap_or_default()
        .chain(matches.get_many("a").unwrap_or_default());
    循环 file_num 在 unpaired {
        匹配 parse_file_number(file_num)? {
            FileNum::File1 => print_unpaired1 = 真,
            FileNum::File2 => print_unpaired2 = 真,
        }
    }

    好的((print_joined, print_unpaired1, print_unpaired2))
}

方法 get_and_parse_field_number(matches: &clap::ArgMatches, key: &字符串切片) -> UResult<选项<正整数大小>> {
    设 value = matches.get_one::<字符串>(key).映射(字符串::as_str);
    parse_field_number_option(value)
}

/// Parses the command-line arguments and constructs a `Settings` struct.
///
/// This function takes the matches from the command-line arguments, processes them,
/// and returns a `Settings` struct that encapsulates the configuration for the program.
#[allow(clippy::field_reassign_with_default)]
方法 parse_settings(matches: &clap::ArgMatches) -> UResult<Settings> {
    设 keys = get_and_parse_field_number(matches, "j")?;
    设 key1 = get_and_parse_field_number(matches, "1")?;
    设 key2 = get_and_parse_field_number(matches, "2")?;

    设 (print_joined, print_unpaired1, print_unpaired2) = parse_print_settings(matches)?;

    设 可变 settings = Settings::默认();

    settings.print_joined = print_joined;
    settings.print_unpaired1 = print_unpaired1;
    settings.print_unpaired2 = print_unpaired2;

    settings.ignore_case = matches.get_flag("i");
    settings.key1 = get_field_number(keys, key1)?;
    settings.key2 = get_field_number(keys, key2)?;
    如果 设 一些(value_os) = matches.get_one::<OsString>("t") {
        settings.separator = parse_separator(value_os)?;
    }
    如果 设 一些(format) = matches.get_one::<字符串>("o") {
        如果 format == "auto" {
            settings.autoformat = 真;
        } 否则 {
            设 可变 specs = 向量![];
            循环 part 在 format.split([' ', ',', '\t']) {
                specs.压入(Spec::parse(part)?);
            }
            settings.format = specs;
        }
    }

    如果 设 一些(empty) = matches.get_one::<字符串>("e") {
        settings.empty = empty.as_bytes().to_vec();
    }

    如果 matches.get_flag("nocheck-order") {
        settings.check_order = CheckOrder::Disabled;
    }

    如果 matches.get_flag("check-order") {
        settings.check_order = CheckOrder::Enabled;
    }

    如果 matches.get_flag("header") {
        settings.headers = 真;
    }

    settings.line_ending = LineEnding::from_zero_flag(matches.get_flag("z"));

    好的(settings)
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    设 可变 opts = CollatorOptions::默认();
    opts.alternate_handling = 一些(AlternateHandling::Shifted);
    设 _ = try_init_collator(opts);

    设 settings = parse_settings(&matches)?;

    设 file1 = matches.get_one::<OsString>("file1").解包();
    设 file2 = matches.get_one::<OsString>("file2").解包();

    如果 file1 == "-" && file2 == "-" {
        返回 坏的(USimpleError::新建(
            1,
            translate!("join-error-both-files-stdin"),
        ));
    }

    设 sep = settings.separator.克隆();
    匹配 sep {
        SepSetting::Byte(byte) => exec(file1, file2, settings, OneByteSep { byte: [byte] }),
        SepSetting::Char(c) => exec(
            file1,
            file2,
            settings,
            MultiByteSep {
                finder: Finder::新建(&c),
            },
        ),
        SepSetting::Whitespaces => exec(file1, file2, settings, WhitespaceSep {}),
        SepSetting::Line => exec(file1, file2, settings, LineSep {}),
    }
}

