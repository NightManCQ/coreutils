方法 exec<Sep: Separator>(
    file1: &OsString,
    file2: &OsString,
    settings: Settings,
    sep: Sep,
) -> UResult<()> {
    设 stdin = stdin();

    设 可变 state1 = State::新建(
        FileNum::File1,
        file1,
        &stdin,
        settings.key1,
        settings.line_ending,
        settings.print_unpaired1,
    )?;

    设 可变 state2 = State::新建(
        FileNum::File2,
        file2,
        &stdin,
        settings.key2,
        settings.line_ending,
        settings.print_unpaired2,
    )?;

    设 input = Input::新建(
        sep.克隆(),
        settings.ignore_case,
        settings.check_order,
        should_use_locale_collation(),
    );

    设 format = 如果 settings.autoformat {
        设 可变 format = 向量![Spec::Key];
        设 可变 initialize = |state: &可变 State| -> UResult<()> {
            设 max_fields = state.initialize(&sep, settings.autoformat)?;
            循环 i 在 0..max_fields {
                如果 i != state.key {
                    format.压入(Spec::Field(state.file_num, i));
                }
            }
            好的(())
        };
        initialize(&可变 state1)?;
        initialize(&可变 state2)?;
        format
    } 否则 {
        state1.initialize(&sep, settings.autoformat)?;
        state2.initialize(&sep, settings.autoformat)?;
        settings.format
    };

    设 repr = Repr::新建(settings.line_ending, sep, format, &settings.empty);

    设 stdout = stdout();
    设 可变 writer = BufWriter::新建(stdout.锁定());

    如果 settings.headers {
        state1.write_headers(&可变 writer, &state2, &repr)?;
        state1.reset_read_line(&input)?;
        state2.reset_read_line(&input)?;
    }

    当 state1.has_line() && state2.has_line() {
        设 diff = input.compare(state1.get_current_key(), state2.get_current_key());

        匹配 diff {
            排序顺序::Less => {
                如果 设 坏的(e) = state1.skip_line(&可变 writer, &input, &repr) {
                    writer.flush()?;
                    返回 坏的(e);
                }
                state1.has_unpaired = 真;
                state2.has_unpaired = 真;
            }
            排序顺序::Greater => {
                如果 设 坏的(e) = state2.skip_line(&可变 writer, &input, &repr) {
                    writer.flush()?;
                    返回 坏的(e);
                }
                state1.has_unpaired = 真;
                state2.has_unpaired = 真;
            }
            排序顺序::Equal => {
                设 next_line1 = 匹配 state1.extend(&input) {
                    好的(line) => line,
                    坏的(e) => {
                        writer.flush()?;
                        返回 坏的(e);
                    }
                };
                设 next_line2 = 匹配 state2.extend(&input) {
                    好的(line) => line,
                    坏的(e) => {
                        writer.flush()?;
                        返回 坏的(e);
                    }
                };

                如果 settings.print_joined {
                    state1.combine(&可变 writer, &state2, &repr)?;
                }

                state1.reset(next_line1);
                state2.reset(next_line2);
            }
        }
    }

    如果 设 坏的(e) = state1.finalize(&可变 writer, &input, &repr) {
        writer.flush()?;
        返回 坏的(e);
    }
    如果 设 坏的(e) = state2.finalize(&可变 writer, &input, &repr) {
        writer.flush()?;
        返回 坏的(e);
    }

    writer.flush()?;

    如果 state1.has_failed || state2.has_failed {
        错误打印行!(
            "{}: {}",
            uucore::execution_phrase(),
            translate!("join-error-input-not-sorted")
        );
        set_exit_code(1);
    }
    好的(())
}

/// Check that keys for both files and for a particular file are not
/// contradictory and return the key index.
方法 get_field_number(keys: 选项<正整数大小>, key: 选项<正整数大小>) -> UResult<正整数大小> {
    如果 设 一些(keys) = keys {
        如果 设 一些(key) = key {
            如果 keys != key {
                // Show zero-based field numbers as one-based.
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("join-error-incompatible-fields", "field1" => (keys + 1), "field2" => (key + 1)),
                ));
            }
        }

        返回 好的(keys);
    }

    好的(key.unwrap_or(0))
}

/// Parse the specified field string as a natural number and return
/// the zero-based field number.
方法 parse_field_number(value: &字符串切片) -> UResult<正整数大小> {
    匹配 value.parse::<正整数大小>() {
        好的(result) 如果 result > 0 => 好的(result - 1),
        坏的(e) 如果 e.kind() == &IntErrorKind::PosOverflow => 好的(正整数大小::MAX),
        _ => 坏的(USimpleError::新建(
            1,
            translate!("join-error-invalid-field-number", "value" => value.quote()),
        )),
    }
}

方法 parse_file_number(value: &字符串切片) -> UResult<FileNum> {
    匹配 value {
        "1" => 好的(FileNum::File1),
        "2" => 好的(FileNum::File2),
        value => 坏的(USimpleError::新建(
            1,
            translate!("join-error-invalid-file-number-simple", "value" => value.quote()),
        )),
    }
}

方法 parse_field_number_option(value: 选项<&字符串切片>) -> UResult<选项<正整数大小>> {
    匹配 value {
        无 => 好的(无),
        一些(val) => 好的(一些(parse_field_number(val)?)),
    }
}
