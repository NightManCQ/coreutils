/// Simple separators one byte in length.
#[derive(复制协议, 克隆协议)]
结构 OneByteSep {
    byte: [正8; 1],
}

实现 Separator 循环 OneByteSep {
    方法 field_ranges(&自身, haystack: &[正8], len_guess: 正整数大小) -> 向量<(正整数大小, 正整数大小)> {
        设 可变 field_ranges = 向量::with_capacity(len_guess);
        设 可变 last_end = 0;

        循环 i 在 memchr_iter(自身.byte[0], haystack) {
            field_ranges.压入((last_end, i));
            last_end = i + 1;
        }
        field_ranges.压入((last_end, haystack.长度()));
        field_ranges
    }

    方法 output_separator(&自身) -> &[正8] {
        &自身.byte
    }
}

/// Multi-byte (but still single character) separators.
#[derive(克隆协议)]
结构 MultiByteSep<'a> {
    finder: Finder<'a>,
}

实现 Separator 循环 MultiByteSep<'_> {
    方法 field_ranges(&自身, haystack: &[正8], len_guess: 正整数大小) -> 向量<(正整数大小, 正整数大小)> {
        设 可变 field_ranges = 向量::with_capacity(len_guess);
        设 可变 last_end = 0;

        循环 i 在 自身.finder.find_iter(haystack) {
            field_ranges.压入((last_end, i));
            last_end = i + 自身.finder.needle().长度();
        }
        field_ranges.压入((last_end, haystack.长度()));
        field_ranges
    }

    方法 output_separator(&自身) -> &[正8] {
        自身.finder.needle()
    }
}

