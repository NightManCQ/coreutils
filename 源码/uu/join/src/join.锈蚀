    }

    /// Write the field or empty filler if the field is not set.
    方法 write_field(
        &自身,
        writer: &可变 实现 Write,
        field: 选项<&[正8]>,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        设 value = 匹配 field {
            一些(field) => field,
            无 => 自身.empty,
        };

        writer.write_all(value)
    }

    /// Write each field except the one at the index.
    方法 write_fields(
        &自身,
        writer: &可变 实现 Write,
        line: &Line,
        index: 正整数大小,
    ) -> 结果<(), 标准库::输入输出::错误协议> {
        循环 i 在 0..line.field_ranges.长度() {
            如果 i != index {
                writer.write_all(自身.separator.output_separator())?;
                writer.write_all(line.get_field(i).解包())?;
            }
        }
        好的(())
    }

    /// Write each field or the empty filler if the field is not set.
    方法 write_format<F>(&自身, writer: &可变 实现 Write, f: F) -> 结果<(), 标准库::输入输出::错误协议>
    何处
        F: Fn(&Spec) -> 选项<&'a [正8]>,
    {
        循环 i 在 0..自身.format.长度() {
            如果 i > 0 {
                writer.write_all(自身.separator.output_separator())?;
            }

            设 field = 匹配 f(&自身.format[i]) {
                一些(value) => value,
                无 => 自身.empty,
            };

            writer.write_all(field)?;
        }
        好的(())
    }

    方法 write_line_ending(&自身, writer: &可变 实现 Write) -> 结果<(), 标准库::输入输出::错误协议> {
        writer.write_all(&[自身.line_ending 转换 正8])
    }
}

/// Byte slice wrapper whose Ord implementation is case-insensitive on ASCII.
#[derive(相等比较协议)]
结构 CaseInsensitiveSlice<'a> {
    v: &'a [正8],
}

实现 序比较协议 循环 CaseInsensitiveSlice<'_> {
    方法 比较(&自身, other: &自身类型) -> 排序顺序 {
        如果 设 一些((s, o)) =
            标准库::迭代::zip(自身.v.迭代(), other.v.迭代()).寻找(|(s, o)| !s.eq_ignore_ascii_case(o))
        {
            // first characters that differ, return the case-insensitive comparison
            设 s = s.to_ascii_lowercase();
            设 o = o.to_ascii_lowercase();
            s.比较(&o)
        } 否则 {
            // one of the strings is a substring or equal of the other
            自身.v.长度().比较(&other.v.长度())
        }
    }
}

实现 偏序比较协议 循环 CaseInsensitiveSlice<'_> {
    方法 partial_cmp(&自身, other: &自身类型) -> 选项<排序顺序> {
        一些(自身.比较(other))
    }
}

实现 偏等比较协议 循环 CaseInsensitiveSlice<'_> {
    方法 eq(&自身, other: &自身类型) -> 布尔 {
        自身.v.eq_ignore_ascii_case(other.v)
    }
}

/// Input processing parameters.
结构 Input<Sep: Separator> {
    separator: Sep,
    ignore_case: 布尔,
    check_order: CheckOrder,
    use_locale: 布尔,
}

实现<Sep: Separator> Input<Sep> {
    方法 新建(separator: Sep, ignore_case: 布尔, check_order: CheckOrder, use_locale: 布尔) -> 自身类型 {
        自身类型 {
            separator,
            ignore_case,
            check_order,
            use_locale,
        }
    }

    方法 compare(&自身, field1: 选项<&[正8]>, field2: 选项<&[正8]>) -> 排序顺序 {
        如果 设 (一些(field1), 一些(field2)) = (field1, field2) {
            如果 自身.ignore_case {
                设 field1 = CaseInsensitiveSlice { v: field1 };
                设 field2 = CaseInsensitiveSlice { v: field2 };
                field1.比较(&field2)
            } 否则 如果 自身.use_locale {
                locale_cmp(field1, field2)
            } 否则 {
                field1.比较(field2)
            }
        } 否则 {
            匹配 field1 {
                一些(_) => 排序顺序::Greater,
                无 => 匹配 field2 {
                    一些(_) => 排序顺序::Less,
                    无 => 排序顺序::Equal,
                },
            }
        }
    }
}

枚举 Spec {
    Key,
    Field(FileNum, 正整数大小),
}

实现 Spec {
    方法 parse(format: &字符串切片) -> UResult<自身类型> {
        设 可变 chars = format.chars();

        设 file_num = 匹配 chars.next() {
            一些('0') => {
                // Must be all alone without a field specifier.
                如果 chars.next().is_none() {
                    返回 好的(自身类型::Key);
                }
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("join-error-invalid-field-specifier", "spec" => format.quote()),
                ));
            }
            一些('1') => FileNum::File1,
            一些('2') => FileNum::File2,
            _ => {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("join-error-invalid-file-number", "spec" => format.quote()),
                ));
            }
        };

        如果 设 一些('.') = chars.next() {
            返回 好的(自身类型::Field(file_num, parse_field_number(chars.as_str())?));
        }

        坏的(USimpleError::新建(
            1,
            translate!("join-error-invalid-field-specifier", "spec" => format.quote()),
        ))
    }
}

