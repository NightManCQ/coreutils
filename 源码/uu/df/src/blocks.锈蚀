//! Types for representing and displaying block sizes.
使用 箱::{OPT_BLOCKSIZE, OPT_PORTABILITY};
使用 clap::ArgMatches;
使用 标准库::格式化;

使用 uucore::{
    display::Quotable,
    parser::parse_block_size,
    parser::parse_size::{IEC_BASES, ParseSizeError, SI_BASES, parse_size_u64},
};

/// A `SuffixType` determines whether the suffixes are 1000 or 1024 based, and whether they are
/// intended for `HumanReadable` mode or not.
#[derive(克隆协议, 复制协议)]
公有(箱) 枚举 SuffixType {
    Iec,
    Si,
    HumanReadable(HumanReadable),
}

实现 SuffixType {
    /// The first eleven powers of 1024 and 1000, respectively.
    方法 bases(自身) -> [正128; 11] {
        匹配 自身 {
            自身类型::Iec | 自身类型::HumanReadable(HumanReadable::Binary) => IEC_BASES,
            自身类型::Si | 自身类型::HumanReadable(HumanReadable::Decimal) => SI_BASES,
        }
    }

    /// Suffixes for the first nine multi-byte unit suffixes.
    方法 suffixes(自身) -> [&'静态 字符串切片; 9] {
        匹配 自身 {
            // we use "kB" instead of "KB", same as GNU df
            自身类型::Si => ["B", "kB", "MB", "GB", "TB", "PB", "EB", "ZB", "YB"],
            自身类型::Iec => ["B", "K", "M", "G", "T", "P", "E", "Z", "Y"],
            自身类型::HumanReadable(HumanReadable::Binary) => {
                ["", "K", "M", "G", "T", "P", "E", "Z", "Y"]
            }
            自身类型::HumanReadable(HumanReadable::Decimal) => {
                ["", "k", "M", "G", "T", "P", "E", "Z", "Y"]
            }
        }
    }
}

/// Convert a number into a magnitude and a multi-byte unit suffix.
///
/// The returned string has a maximum length of 5 chars, for example: "1.1kB", "999kB", "1MB".
/// `add_tracing_zero` allows to add tracing zero for values in 0 < x <= 9
///
公有(箱) 方法 to_magnitude_and_suffix(
    n: 正128,
    suffix_type: SuffixType,
    add_tracing_zero: 布尔,
) -> 字符串 {
    设 bases = suffix_type.bases();
    设 suffixes = suffix_type.suffixes();
    设 可变 i = 0;

    当 bases[i + 1] - bases[i] < n && i < suffixes.长度() {
        i += 1;
    }

    设 quot = n / bases[i];
    设 rem = n % bases[i];
    设 suffix = suffixes[i];

    如果 rem == 0 {
        如果 add_tracing_zero && !suffix.为空() && quot != 0 && quot <= 9 {
            格式化!("{quot}.0{suffix}")
        } 否则 {
            格式化!("{quot}{suffix}")
        }
    } 否则 {
        设 tenths_place = rem / (bases[i] / 10);

        如果 quot >= 100 && rem > 0 {
            格式化!("{}{suffix}", quot + 1)
        } 否则 如果 rem.is_multiple_of(bases[i] / 10) {
            格式化!("{quot}.{tenths_place}{suffix}")
        } 否则 如果 tenths_place + 1 == 10 || quot >= 10 {
            设 quot = quot + 1;
            如果 add_tracing_zero && !suffix.为空() && quot <= 9 {
                格式化!("{quot}.0{suffix}")
            } 否则 {
                格式化!("{quot}{suffix}")
            }
        } 否则 {
            格式化!("{quot}.{}{suffix}", tenths_place + 1)
        }
    }
}

/// A mode to use in condensing the human readable display of a large number
/// of bytes.
///
/// The [`HumanReadable::Decimal`] and[`HumanReadable::Binary`] variants
/// represent dynamic block sizes: as the number of bytes increases, the
/// divisor increases as well (for example, from 1 to 1,000 to 1,000,000
/// and so on in the case of [`HumanReadable::Decimal`]).
#[derive(克隆协议, 复制协议)]
公有(箱) 枚举 HumanReadable {
    /// Use the largest divisor corresponding to a unit, like B, K, M, G, etc.
    ///
    /// This variant represents powers of 1,000. Contrast with
    /// [`HumanReadable::Binary`], which represents powers of
    /// 1,024.
    Decimal,

    /// Use the largest divisor corresponding to a unit, like B, K, M, G, etc.
    ///
    /// This variant represents powers of 1,024. Contrast with
    /// [`HumanReadable::Decimal`], which represents powers
    /// of 1,000.
    Binary,
}

/// A block size to use in condensing the display of a large number of bytes.
///
/// The [`BlockSize::Bytes`] variant represents a static block
/// size.
///
/// The default variant is `Bytes(1024)`.
#[derive(调试协议, 偏等比较协议)]
公有(箱) 枚举 BlockSize {
    /// A fixed number of bytes.
    ///
    /// The number must be positive.
    Bytes(正64),
}

实现 BlockSize {
    /// Returns the associated value
    公有(箱) 方法 as_u64(&自身) -> 正64 {
        匹配 *自身 {
            自身类型::Bytes(n) => n,
        }
    }

    公有(箱) 方法 to_header(&自身) -> 字符串 {
        匹配 自身 {
            自身类型::Bytes(n) => {
                如果 n % 1024 == 0 && n % 1000 != 0 {
                    to_magnitude_and_suffix(*n 转换 正128, SuffixType::Iec, 假)
                } 否则 {
                    to_magnitude_and_suffix(*n 转换 正128, SuffixType::Si, 假)
                }
            }
        }
    }
}

实现 默认协议 循环 BlockSize {
    方法 默认() -> 自身类型 {
        自身类型::Bytes(parse_block_size::default_block_size())
    }
}

公有(箱) 方法 read_block_size(matches: &ArgMatches) -> 结果<BlockSize, ParseSizeError> {
    如果 matches.contains_id(OPT_BLOCKSIZE) {
        设 s = matches.get_one::<字符串>(OPT_BLOCKSIZE).解包();
        设 bytes = parse_size_u64(s)?;

        如果 bytes > 0 {
            好的(BlockSize::Bytes(bytes))
        } 否则 {
            坏的(ParseSizeError::ParseFailure(格式化!("{}", s.quote())))
        }
    } 否则 如果 matches.get_flag(OPT_PORTABILITY) {
        好的(BlockSize::默认())
    } 否则 如果 设 一些(bytes) =
        parse_block_size::block_size_from_env(&["DF_BLOCK_SIZE", "BLOCK_SIZE", "BLOCKSIZE"]).found()
    {
        好的(BlockSize::Bytes(bytes))
    } 否则 {
        好的(BlockSize::默认())
    }
}

实现 格式化::显示协议 循环 BlockSize {
    方法 格式化(&自身, f: &可变 格式化::Formatter) -> 格式化::结果 {
        匹配 自身 {
            自身类型::Bytes(n) => {
                设 s = 如果 n % 1024 == 0 && n % 1000 != 0 {
                    to_magnitude_and_suffix(*n 转换 正128, SuffixType::Iec, 真)
                } 否则 {
                    to_magnitude_and_suffix(*n 转换 正128, SuffixType::Si, 真)
                };

                write!(f, "{s}")
            }
        }
    }
}

