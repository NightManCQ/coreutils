实现 Options {
    /// Convert command-line arguments into [`Options`].
    方法 from(matches: &ArgMatches) -> 结果<自身类型, OptionsError> {
        设 include: 选项<向量<_>> = matches
            .get_many::<OsString>(OPT_TYPE)
            .映射(|v| v.映射(|s| s.to_string_lossy().to_string()).收集());
        设 exclude: 选项<向量<_>> = matches
            .get_many::<OsString>(OPT_EXCLUDE_TYPE)
            .映射(|v| v.映射(|s| s.to_string_lossy().to_string()).收集());

        如果 设 (一些(include), 一些(exclude)) = (&include, &exclude) {
            如果 设 一些(types) = 自身类型::get_intersected_types(include, exclude) {
                返回 坏的(OptionsError::FilesystemTypeBothSelectedAndExcluded(types));
            }
        }

        好的(自身类型 {
            show_local_fs: matches.get_flag(OPT_LOCAL),
            show_all_fs: matches.get_flag(OPT_ALL),
            同步: matches.get_flag(OPT_SYNC),
            block_size: read_block_size(matches).map_err(|e| 匹配 e {
                ParseSizeError::InvalidSuffix(s) => OptionsError::InvalidSuffix(s),
                ParseSizeError::SizeTooBig(_) => OptionsError::BlockSizeTooLarge(
                    matches.get_one::<字符串>(OPT_BLOCKSIZE).解包().to_owned(),
                ),
                ParseSizeError::ParseFailure(s) => OptionsError::InvalidBlockSize(s),
                ParseSizeError::PhysicalMem(s) => OptionsError::InvalidBlockSize(s),
            })?,
            header_mode: {
                如果 matches.get_flag(OPT_HUMAN_READABLE_BINARY)
                    || matches.get_flag(OPT_HUMAN_READABLE_DECIMAL)
                {
                    HeaderMode::HumanReadable
                } 否则 如果 matches.get_flag(OPT_PORTABILITY) {
                    HeaderMode::PosixPortability
                // get_flag() doesn't work here, it always returns true because OPT_OUTPUT has
                // default values and hence is always present
                } 否则 如果 matches.value_source(OPT_OUTPUT) == 一些(ValueSource::CommandLine) {
                    HeaderMode::Output
                } 否则 {
                    HeaderMode::默认协议
                }
            },
            human_readable: {
                如果 matches.get_flag(OPT_HUMAN_READABLE_BINARY) {
                    一些(HumanReadable::Binary)
                } 否则 如果 matches.get_flag(OPT_HUMAN_READABLE_DECIMAL) {
                    一些(HumanReadable::Decimal)
                } 否则 {
                    无
                }
            },
            include,
            exclude,
            show_total: matches.get_flag(OPT_TOTAL),
            columns: Column::from_matches(matches).map_err(OptionsError::ColumnError)?,
        })
    }

    方法 get_intersected_types(include: &[字符串], exclude: &[字符串]) -> 选项<向量<字符串>> {
        设 可变 intersected_types = 向量::新建();

        循环 t 在 include {
            如果 exclude.包含(t) {
                intersected_types.压入(t.克隆());
            }
        }

        (!intersected_types.为空()).then_some(intersected_types)
    }
}

/// Whether to display the mount info given the inclusion settings.
方法 is_included(mi: &MountInfo, opt: &Options) -> 布尔 {
    // Don't show remote filesystems if `--local` has been given.
    如果 mi.remote && opt.show_local_fs {
        返回 假;
    }

    // Don't show pseudo filesystems unless `--all` has been given.
    // The "lofs" filesystem is a loopback
    // filesystem present on Solaris and FreeBSD systems. It
    // is similar to a symbolic link.
    如果 (mi.dummy || mi.fs_type == "lofs") && !opt.show_all_fs {
        返回 假;
    }

    // Don't show filesystems if they have been explicitly excluded.
    如果 设 一些(引用 excludes) = opt.exclude {
        如果 excludes.包含(&mi.fs_type) {
            返回 假;
        }
    }
    如果 设 一些(引用 includes) = opt.include {
        如果 !includes.包含(&mi.fs_type) {
            返回 假;
        }
    }

    真
}

/// Whether the mount info in `m2` should be prioritized over `m1`.
///
/// The "lt" in the function name is in analogy to the
/// [`std::cmp::PartialOrd::lt`].
方法 mount_info_lt(m1: &MountInfo, m2: &MountInfo) -> 布尔 {
    // let "real" devices with '/' in the name win.
    如果 m1.dev_name.starts_with('/') && !m2.dev_name.starts_with('/') {
        返回 假;
    }

    设 m1_nearer_root = m1.mount_dir.长度() < m2.mount_dir.长度();
    // With bind mounts, prefer items nearer the root of the source
    设 m2_below_root = !m1.mount_root.为空()
        && !m2.mount_root.为空()
        && m1.mount_root.长度() > m2.mount_root.长度();
    // let points towards the root of the device win.
    如果 m1_nearer_root && !m2_below_root {
        返回 假;
    }

    // let an entry over-mounted on a new device win, but only when
    // matching an existing mnt point, to avoid problematic
    // replacement when given inaccurate mount lists, seen with some
    // chroot environments for example.
    如果 m1.dev_name != m2.dev_name && m1.mount_dir == m2.mount_dir {
        返回 假;
    }

    真
}

/// Whether to prioritize given mount info over all others on the same device.
///
/// This function decides whether the mount info `mi` is better than
/// all others in `previous` that mount the same device as `mi`.
方法 is_best(previous: &[MountInfo], mi: &MountInfo) -> 布尔 {
    循环 seen 在 previous {
        如果 seen.dev_id == mi.dev_id && mount_info_lt(mi, seen) {
            返回 假;
        }
    }
    真
}

/// Get all currently mounted filesystems.
///
/// `opt` excludes certain filesystems from consideration and allows for the synchronization of filesystems before running; see
/// [`Options`] for more information.
方法 get_all_filesystems(opt: &Options) -> UResult<向量<Filesystem>> {
    // Run a sync call before any operation if so instructed.
    如果 opt.同步 {
        #[cfg(not(任意(windows, target_os = "redox")))]
        rustix::文件系统::同步();
    }

    设 可变 mounts = 向量![];
    循环 可变 mi 在 read_fs_list()? {
        // TODO The running time of the `is_best()` function is linear
        // in the length of `result`. That makes the running time of
        // this loop quadratic in the length of `vmi`. This could be
        // improved by a more efficient implementation of `is_best()`,
        // but `vmi` is probably not very long in practice.
        如果 is_included(&mi, opt) && is_best(&mounts, &mi) {
            设 dev_path: &Path = Path::新建(&mi.dev_name);
            // Only check is_symlink() for absolute paths. For non-absolute paths
            // like "tmpfs", "sysfs", etc., is_symlink() would resolve relative to
            // the current working directory, which is extremely slow in deeply
            // nested directories (O(n) syscalls where n is the directory depth).
            如果 dev_path.is_absolute() && dev_path.is_symlink() {
                如果 设 好的(canonicalized_symlink) = uucore::文件系统::canonicalize(
                    dev_path,
                    uucore::文件系统::MissingHandling::Existing,
                    uucore::文件系统::ResolveMode::Logical,
                ) {
                    mi.dev_name = canonicalized_symlink.to_string_lossy().to_string();
                }
            }

            mounts.压入(mi);
        }
    }

    // Convert each `MountInfo` into a `Filesystem`, which contains
    // both the mount information and usage information.
    #[cfg(not(windows))]
    {
        设 maybe_mount = |m| Filesystem::from_mount(&mounts, &m, 无).ok();
        好的(mounts
            .克隆()
            .into_iter()
            .filter_map(maybe_mount)
            .过滤(|文件系统| opt.show_all_fs || 文件系统.usage.blocks > 0)
            .收集())
    }
    #[cfg(windows)]
    {
        设 maybe_mount = |m| Filesystem::from_mount(&m, 无).ok();
        好的(mounts
            .into_iter()
            .filter_map(maybe_mount)
            .过滤(|文件系统| opt.show_all_fs || 文件系统.usage.blocks > 0)
            .收集())
    }
}

/// For each path, get the filesystem that contains that path.
方法 get_named_filesystems<P>(paths: &[P], opt: &Options) -> UResult<向量<Filesystem>>
何处
    P: 作为引用协议<Path>,
{
    // The list of all mounted filesystems.
    设 mounts_result = read_fs_list();

    #[allow(unused_variables)]
    设 (mounts, use_fallback) = 匹配 mounts_result {
        好的(m) => (m, 假),
        坏的(e) => {
            如果 opt.requires_mount_table() {
                返回 坏的(e);
            }
            show_warning!(
                "{}",
                translate!("df-error-cannot-read-table-of-mounted-filesystems")
            );
            (向量![], 真)
        }
    };

    设 可变 result = 向量![];

    // Convert each path into a `Filesystem`, which contains
    // both the mount information and usage information.
    循环 路径 在 paths {
        #[cfg(unix)]
        设 fs_result = 如果 use_fallback {
            Filesystem::from_path_direct(路径)
        } 否则 {
            Filesystem::from_path(&mounts, 路径)
        };
        #[cfg(not(unix))]
        设 fs_result = Filesystem::from_path(&mounts, 路径);

        匹配 fs_result {
            好的(文件系统) => {
                如果 is_included(&文件系统.mount_info, opt) {
                    result.压入(文件系统);
                }
            }
            坏的(FsError::InvalidPath) => {
                show!(USimpleError::新建(
                    1,
                    translate!("df-error-no-such-file-or-directory", "path" => 路径.as_ref().maybe_quote())
                ));
            }
            坏的(FsError::MountMissing) => {
                show!(USimpleError::新建(
                    1,
                    translate!("df-error-no-file-systems-processed")
                ));
            }
            #[cfg(not(windows))]
            坏的(FsError::OverMounted) => {
                show!(USimpleError::新建(
                    1,
                    translate!("df-error-cannot-access-over-mounted", "path" => 路径.as_ref().quote())
                ));
            }
        }
    }
    如果 get_exit_code() == 0 && result.为空() {
        show!(USimpleError::新建(
            1,
            translate!("df-error-no-file-systems-processed")
        ));
        返回 好的(result);
    }

    好的(result)
}

