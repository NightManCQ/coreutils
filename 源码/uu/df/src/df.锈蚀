#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    #[cfg(windows)]
    {
        如果 matches.get_flag(OPT_INODES) {
            打印行!(
                "{}",
                translate!("df-error-inodes-not-supported-windows", "program" => "df")
            );
            返回 好的(());
        }
    }

    设 opt = Options::from(&matches).map_err(DfError::OptionsError)?;
    // Get the list of filesystems to display in the output table.
    设 filesystems: 向量<Filesystem> = 匹配 matches.get_many::<OsString>(OPT_PATHS) {
        无 => {
            设 filesystems = get_all_filesystems(&opt).map_err(|e| {
                设 context = translate!("df-error-cannot-read-table-of-mounted-filesystems");
                USimpleError::新建(e.code(), 格式化!("{context}: {e}"))
            })?;

            如果 filesystems.为空() {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("df-error-no-file-systems-processed"),
                ));
            }

            filesystems
        }
        一些(paths) => {
            设 paths: 向量<_> = paths.收集();
            设 filesystems = get_named_filesystems(&paths, &opt).map_err(|e| {
                设 context = translate!("df-error-cannot-read-table-of-mounted-filesystems");
                USimpleError::新建(e.code(), 格式化!("{context}: {e}"))
            })?;

            // This can happen if paths are given as command-line arguments
            // but none of the paths exist.
            如果 filesystems.为空() {
                返回 好的(());
            }

            filesystems
        }
    };

    Table::新建(&opt, filesystems).write_to(&可变 stdout())?;

    好的(())
}

