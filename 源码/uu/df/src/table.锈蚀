    #[test]
    方法 test_row_accumulation_u64_overflow() {
        init();
        设 total = 正64::MAX 转换 正128;
        设 used1 = 3000正128;
        设 used2 = 50000正128;

        设 可变 row1 = Row {
            inodes: total,
            inodes_used: used1,
            inodes_free: total - used1,
            ..默认协议::默认()
        };

        设 row2 = Row {
            inodes: total,
            inodes_used: used2,
            inodes_free: total - used2,
            ..默认协议::默认()
        };

        row1 += row2;

        相等断言!(row1.inodes, total * 2);
        相等断言!(row1.inodes_used, used1 + used2);
        相等断言!(row1.inodes_free, total * 2 - used1 - used2);
    }
