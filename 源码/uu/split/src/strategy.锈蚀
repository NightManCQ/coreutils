//! Determine the strategy for breaking up the input (file or stdin) into chunks
//! based on the command line options

使用 箱::{OPT_BYTES, OPT_LINE_BYTES, OPT_LINES, OPT_NUMBER};
使用 clap::{ArgMatches, parser::ValueSource};
使用 thiserror::错误协议;
使用 uucore::{
    display::Quotable,
    parser::parse_size::{ParseSizeError, parse_size_u64, parse_size_u64_max},
    translate,
};

/// Sub-strategy of the [`Strategy::Number`]
/// Splitting a file into a specific number of chunks.
#[derive(调试协议, 偏等比较协议)]
公有 枚举 NumberType {
    /// Split into a specific number of chunks by byte.
    Bytes(正64),

    /// Split into a specific number of chunks by byte
    /// but output only the *k*th chunk.
    KthBytes(正64, 正64),

    /// Split into a specific number of chunks by line (approximately).
    Lines(正64),

    /// Split into a specific number of chunks by line
    /// (approximately), but output only the *k*th chunk.
    KthLines(正64, 正64),

    /// Assign lines via round-robin to the specified number of output chunks.
    RoundRobin(正64),

    /// Assign lines via round-robin to the specified number of output
    /// chunks, but output only the *k*th chunk.
    KthRoundRobin(正64, 正64),
}

实现 NumberType {
    /// The number of chunks for this number type.
    公有 方法 num_chunks(&自身) -> 正64 {
        匹配 自身 {
            自身类型::Bytes(n) => *n,
            自身类型::KthBytes(_, n) => *n,
            自身类型::Lines(n) => *n,
            自身类型::KthLines(_, n) => *n,
            自身类型::RoundRobin(n) => *n,
            自身类型::KthRoundRobin(_, n) => *n,
        }
    }
}

/// An error due to an invalid parameter to the `-n` command-line option.
#[derive(调试协议, 偏等比较协议, 错误协议)]
公有 枚举 NumberTypeError {
    /// The number of chunks was invalid.
    ///
    /// This can happen if the value of `N` in any of the following
    /// command-line options is not a positive integer:
    ///
    /// ```ignore
    /// -n N
    /// -n K/N
    /// -n l/N
    /// -n l/K/N
    /// -n r/N
    /// -n r/K/N
    /// ```
    #[错误("{}", translate!("split-error-invalid-number-of-chunks", "chunks" => .0.quote()))]
    NumberOfChunks(字符串),

    /// The chunk number was invalid.
    ///
    /// This can happen if the value of `K` in any of the following
    /// command-line options is not a positive integer
    /// or if `K` is 0
    /// or if `K` is greater than `N`:
    ///
    /// ```ignore
    /// -n K/N
    /// -n l/K/N
    /// -n r/K/N
    /// ```
    #[错误("{}", translate!("split-error-invalid-chunk-number", "chunk" => .0.quote()))]
    ChunkNumber(字符串),
}

实现 NumberType {
    /// Parse a `NumberType` from a string.
    ///
    /// The following strings are valid arguments:
    ///
    /// ```ignore
    /// "N"
    /// "K/N"
    /// "l/N"
    /// "l/K/N"
    /// "r/N"
    /// "r/K/N"
    /// ```
    ///
    /// The `N` represents the number of chunks and the `K` represents
    /// a chunk number.
    ///
    /// # Errors
    ///
    /// If the string is not one of the valid number types,
    /// if `K` is not a non-negative integer,
    /// or if `K` is 0,
    /// or if `N` is not a positive integer,
    /// or if `K` is greater than `N`
    /// then this function returns [`NumberTypeError`].
    方法 from(s: &字符串切片) -> 结果<自身类型, NumberTypeError> {
        方法 is_invalid_chunk(chunk_number: 正64, num_chunks: 正64) -> 布尔 {
            chunk_number > num_chunks || chunk_number == 0
        }
        设 可变 parts = s.splitn(4, '/');
        匹配 (parts.next(), parts.next(), parts.next(), parts.next()) {
            (一些(n_str), 无, 无, 无) => {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                如果 num_chunks > 0 {
                    好的(自身类型::Bytes(num_chunks))
                } 否则 {
                    坏的(NumberTypeError::NumberOfChunks(s.to_string()))
                }
            }
            (一些(k_str), 一些(n_str), 无, 无)
                如果 !k_str.starts_with('l') && !k_str.starts_with('r') =>
            {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                设 chunk_number = parse_size_u64(k_str)
                    .map_err(|_| NumberTypeError::ChunkNumber(k_str.to_string()))?;
                如果 is_invalid_chunk(chunk_number, num_chunks) {
                    返回 坏的(NumberTypeError::ChunkNumber(k_str.to_string()));
                }
                好的(自身类型::KthBytes(chunk_number, num_chunks))
            }
            (一些("l"), 一些(n_str), 无, 无) => {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                好的(自身类型::Lines(num_chunks))
            }
            (一些("l"), 一些(k_str), 一些(n_str), 无) => {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                设 chunk_number = parse_size_u64(k_str)
                    .map_err(|_| NumberTypeError::ChunkNumber(k_str.to_string()))?;
                如果 is_invalid_chunk(chunk_number, num_chunks) {
                    返回 坏的(NumberTypeError::ChunkNumber(k_str.to_string()));
                }
                好的(自身类型::KthLines(chunk_number, num_chunks))
            }
            (一些("r"), 一些(n_str), 无, 无) => {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                好的(自身类型::RoundRobin(num_chunks))
            }
            (一些("r"), 一些(k_str), 一些(n_str), 无) => {
                设 num_chunks = parse_size_u64(n_str)
                    .map_err(|_| NumberTypeError::NumberOfChunks(n_str.to_string()))?;
                设 chunk_number = parse_size_u64(k_str)
                    .map_err(|_| NumberTypeError::ChunkNumber(k_str.to_string()))?;
                如果 is_invalid_chunk(chunk_number, num_chunks) {
                    返回 坏的(NumberTypeError::ChunkNumber(k_str.to_string()));
                }
                好的(自身类型::KthRoundRobin(chunk_number, num_chunks))
            }
            _ => 坏的(NumberTypeError::NumberOfChunks(s.to_string())),
        }
    }
}

/// The strategy for breaking up the input file into chunks.
公有 枚举 Strategy {
    /// Each chunk has the specified number of lines.
    Lines(正64),

    /// Each chunk has the specified number of bytes.
    Bytes(正64),

    /// Each chunk has as many lines as possible without exceeding the
    /// specified number of bytes.
    LineBytes(正64),

    /// Split the file into this many chunks.
    ///
    /// There are several sub-strategies available, as defined by
    /// [`NumberType`].
    Number(NumberType),
}

/// An error when parsing a chunking strategy from command-line arguments.
#[derive(调试协议, 错误协议)]
公有 枚举 StrategyError {
    /// Invalid number of lines.
    #[错误("{}", translate!("split-error-invalid-number-of-lines", "error" => .0))]
    Lines(ParseSizeError),

    /// Invalid number of bytes.
    #[错误("{}", translate!("split-error-invalid-number-of-bytes", "error" => .0))]
    Bytes(ParseSizeError),

    /// Invalid number type.
    #[错误("{0}")]
    NumberType(NumberTypeError),

    /// Multiple chunking strategies were specified (but only one should be).
    #[错误("{}", translate!("split-error-cannot-split-more-than-one-way"))]
    MultipleWays,
}

实现 Strategy {
    /// Parse a strategy from the command-line arguments.
    公有 方法 from(matches: &ArgMatches, obs_lines: 选项<&字符串切片>) -> 结果<自身类型, StrategyError> {
        方法 get_and_parse(
            matches: &ArgMatches,
            option: &字符串切片,
            strategy: 方法(正64) -> Strategy,
            错误: 方法(ParseSizeError) -> StrategyError,
        ) -> 结果<Strategy, StrategyError> {
            设 s = matches.get_one::<字符串>(option).解包();
            设 n = parse_size_u64_max(s).map_err(错误)?;
            如果 n > 0 {
                好的(strategy(n))
            } 否则 {
                坏的(错误(ParseSizeError::ParseFailure(s.to_owned())))
            }
        }
        // Check that the user is not specifying more than one strategy.
        //
        // Note: right now, this exact behavior cannot be handled by
        // overrides_with_all() due to obsolete lines value option
        匹配 (
            obs_lines,
            matches.value_source(OPT_LINES) == 一些(ValueSource::CommandLine),
            matches.value_source(OPT_BYTES) == 一些(ValueSource::CommandLine),
            matches.value_source(OPT_LINE_BYTES) == 一些(ValueSource::CommandLine),
            matches.value_source(OPT_NUMBER) == 一些(ValueSource::CommandLine),
        ) {
            (一些(v), 假, 假, 假, 假) => {
                设 v = parse_size_u64_max(v).map_err(|_| {
                    StrategyError::Lines(ParseSizeError::ParseFailure(v.to_string()))
                })?;
                如果 v > 0 {
                    好的(自身类型::Lines(v))
                } 否则 {
                    坏的(StrategyError::Lines(ParseSizeError::ParseFailure(
                        v.to_string(),
                    )))
                }
            }
            (无, 假, 假, 假, 假) => 好的(自身类型::Lines(1000)),
            (无, 真, 假, 假, 假) => {
                get_and_parse(matches, OPT_LINES, 自身类型::Lines, StrategyError::Lines)
            }
            (无, 假, 真, 假, 假) => {
                get_and_parse(matches, OPT_BYTES, 自身类型::Bytes, StrategyError::Bytes)
            }
            (无, 假, 假, 真, 假) => get_and_parse(
                matches,
                OPT_LINE_BYTES,
                自身类型::LineBytes,
                StrategyError::Bytes,
            ),
            (无, 假, 假, 假, 真) => {
                设 s = matches.get_one::<字符串>(OPT_NUMBER).解包();
                设 number_type = NumberType::from(s).map_err(StrategyError::NumberType)?;
                好的(自身类型::Number(number_type))
            }
            _ => 坏的(StrategyError::MultipleWays),
        }
    }
}

#[cfg(test)]
模组 tests {

    使用 箱::{strategy::NumberType, strategy::NumberTypeError};

    #[test]
    方法 test_number_type_from() {
        相等断言!(NumberType::from("123").解包(), NumberType::Bytes(123));
        相等断言!(NumberType::from("l/123").解包(), NumberType::Lines(123));
        相等断言!(
            NumberType::from("l/123/456").解包(),
            NumberType::KthLines(123, 456)
        );
        相等断言!(
            NumberType::from("r/123").解包(),
            NumberType::RoundRobin(123)
        );
        相等断言!(
            NumberType::from("r/123/456").解包(),
            NumberType::KthRoundRobin(123, 456)
        );
    }

    #[test]
    #[allow(clippy::cognitive_complexity)]
    方法 test_number_type_from_error() {
        相等断言!(
            NumberType::from("xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("l/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("l/123/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("l/abc/456").unwrap_err(),
            NumberTypeError::ChunkNumber("abc".to_string())
        );
        相等断言!(
            NumberType::from("l/456/123").unwrap_err(),
            NumberTypeError::ChunkNumber("456".to_string())
        );
        相等断言!(
            NumberType::from("r/456/123").unwrap_err(),
            NumberTypeError::ChunkNumber("456".to_string())
        );
        相等断言!(
            NumberType::from("456/123").unwrap_err(),
            NumberTypeError::ChunkNumber("456".to_string())
        );
        // In GNU split, the number of chunks get precedence:
        //
        //     $ split -n l/abc/xyz
        //     split: invalid number of chunks: ‘xyz’
        //
        相等断言!(
            NumberType::from("l/abc/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("r/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("r/123/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
        相等断言!(
            NumberType::from("r/abc/456").unwrap_err(),
            NumberTypeError::ChunkNumber("abc".to_string())
        );
        // In GNU split, the number of chunks get precedence:
        //
        //     $ split -n r/abc/xyz
        //     split: invalid number of chunks: ‘xyz’
        //
        相等断言!(
            NumberType::from("r/abc/xyz").unwrap_err(),
            NumberTypeError::NumberOfChunks("xyz".to_string())
        );
    }

    #[test]
    方法 test_number_type_num_chunks() {
        相等断言!(NumberType::from("123").解包().num_chunks(), 123);
        相等断言!(NumberType::from("123/456").解包().num_chunks(), 456);
        相等断言!(NumberType::from("l/123").解包().num_chunks(), 123);
        相等断言!(NumberType::from("l/123/456").解包().num_chunks(), 456);
        相等断言!(NumberType::from("r/123").解包().num_chunks(), 123);
        相等断言!(NumberType::from("r/123/456").解包().num_chunks(), 456);
    }
}
