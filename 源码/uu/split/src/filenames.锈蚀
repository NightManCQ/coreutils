    #[test]
    方法 test_filename_iterator_alphabetic_fixed_width() {
        设 suffix = Suffix {
            stype: SuffixType::Alphabetic,
            length: 2,
            start: 0,
            auto_widening: 假,
            additional: ".txt".into(),
        };
        设 可变 it = FilenameIterator::新建(标准库::ffi::OsStr::新建("chunk_"), &suffix).解包();
        相等断言!(it.next().解包(), "chunk_aa.txt");
        相等断言!(it.next().解包(), "chunk_ab.txt");
        相等断言!(it.next().解包(), "chunk_ac.txt");

        设 可变 it = FilenameIterator::新建(标准库::ffi::OsStr::新建("chunk_"), &suffix).解包();
        相等断言!(it.nth(26 * 26 - 1).解包(), "chunk_zz.txt");
        相等断言!(it.next(), 无);
    }

