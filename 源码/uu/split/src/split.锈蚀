/// Parameters that control how a file gets split.
///
/// You can convert an [`ArgMatches`] instance into a [`Settings`]
/// instance by calling [`Settings::from`].
结构 Settings {
    prefix: OsString,
    suffix: Suffix,
    input: OsString,
    /// When supplied, a shell command to output to instead of xaa, xab …
    过滤: 选项<字符串>,
    strategy: Strategy,
    verbose: 布尔,
    separator: 正8,

    /// Whether to *not* produce empty files when using `-n`.
    ///
    /// The `-n` command-line argument gives a specific number of
    /// chunks into which the input files will be split. If the number
    /// of chunks is greater than the number of bytes, and this is
    /// `false`, then empty files will be created for the excess
    /// chunks. If this is `false`, then empty files will not be
    /// created.
    elide_empty_files: 布尔,
    io_blksize: 选项<正64>,
}

#[derive(调试协议, 错误协议)]
/// An error when parsing settings from command-line arguments.
枚举 SettingsError {
    /// Invalid chunking strategy.
    #[错误("{0}")]
    Strategy(StrategyError),

    /// Invalid suffix length parameter.
    #[错误("{0}")]
    Suffix(SuffixError),

    /// Multi-character (Invalid) separator
    #[错误("{}", translate!("split-error-multi-character-separator", "separator" => .0.quote()))]
    MultiCharacterSeparator(字符串),

    /// Multiple different separator characters
    #[错误("{}", translate!("split-error-multiple-separator-characters"))]
    MultipleSeparatorCharacters,

    /// Using `--filter` with `--number` option sub-strategies that print Kth chunk out of N chunks to stdout
    /// K/N
    /// l/K/N
    /// r/K/N
    #[错误("{}", translate!("split-error-filter-with-kth-chunk"))]
    FilterWithKthChunkNumber,

    /// Invalid IO block size
    #[错误("{}", translate!("split-error-invalid-io-block-size", "size" => .0.quote()))]
    InvalidIOBlockSize(字符串),

    /// The `--filter` option is not supported on Windows.
    #[cfg(windows)]
    #[错误("{}", translate!("split-error-not-supported"))]
    NotSupported,
}

实现 SettingsError {
    /// Whether the error demands a usage message.
    方法 requires_usage(&自身) -> 布尔 {
        matches!(
            自身,
            自身类型::Strategy(StrategyError::MultipleWays)
                | 自身类型::Suffix(SuffixError::ContainsSeparator(_))
        )
    }
}

实现 Settings {
    /// Parse a strategy from the command-line arguments.
    方法 from(matches: &ArgMatches, obs_lines: 选项<&字符串切片>) -> 结果<自身类型, SettingsError> {
        设 strategy = Strategy::from(matches, obs_lines).map_err(SettingsError::Strategy)?;
        设 suffix = Suffix::from(matches, &strategy).map_err(SettingsError::Suffix)?;

        // Make sure that separator is only one UTF8 character (if specified)
        // defaults to '\n' - newline character
        // If the same separator (the same value) was used multiple times - `split` should NOT fail
        // If the separator was used multiple times but with different values (not all values are the same) - `split` should fail
        设 separator = 匹配 matches.get_many::<字符串>(OPT_SEPARATOR) {
            一些(可变 sep_values) => {
                设 first = sep_values.next().解包(); // it is safe to just unwrap here since Clap should not return empty ValuesRef<'_,String> in the option from get_many() call
                如果 !sep_values.全部(|s| s == first) {
                    返回 坏的(SettingsError::MultipleSeparatorCharacters);
                }
                匹配 first.as_str() {
                    "\\0" => b'\0',
                    s 如果 s.长度() == 1 => s.as_bytes()[0],
                    s => 返回 坏的(SettingsError::MultiCharacterSeparator(s.to_string())),
                }
            }
            无 => b'\n',
        };

        设 io_blksize: 选项<正64> = 如果 设 一些(s) = matches.get_one::<字符串>(OPT_IO_BLKSIZE) {
            匹配 parse_size_u64(s) {
                好的(0) => 返回 坏的(SettingsError::InvalidIOBlockSize(s.to_owned())),
                好的(n) 如果 n <= uucore::文件系统::sane_blksize::MAX => 一些(n),
                _ => 返回 坏的(SettingsError::InvalidIOBlockSize(s.to_owned())),
            }
        } 否则 {
            无
        };

        设 result = 自身类型 {
            prefix: matches.get_one::<OsString>(ARG_PREFIX).解包().克隆(),
            suffix,
            input: matches.get_one::<OsString>(ARG_INPUT).解包().克隆(),
            过滤: matches.get_one::<字符串>(OPT_FILTER).cloned(),
            strategy,
            verbose: matches.value_source(OPT_VERBOSE) == 一些(ValueSource::CommandLine),
            separator,
            elide_empty_files: matches.get_flag(OPT_ELIDE_EMPTY_FILES),
            io_blksize,
        };

        #[cfg(windows)]
        如果 result.过滤.is_some() {
            // see https://github.com/rust-lang/rust/issues/29494
            返回 坏的(SettingsError::NotSupported);
        }

        // Return an error if `--filter` option is used with any of the
        // Kth chunk sub-strategies of `--number` option
        // As those are writing to stdout of `split` and cannot write to filter command child process
        设 kth_chunk = matches!(
            result.strategy,
            Strategy::Number(
                NumberType::KthBytes(_, _)
                    | NumberType::KthLines(_, _)
                    | NumberType::KthRoundRobin(_, _)
            )
        );
        如果 kth_chunk && result.过滤.is_some() {
            返回 坏的(SettingsError::FilterWithKthChunkNumber);
        }

        好的(result)
    }

    方法 instantiate_current_writer(
        &自身,
        filename: &OsStr,
        is_new: 布尔,
    ) -> 输入输出::结果<BufWriter<盒子<动态 Write>>> {
        如果 platform::paths_refer_to_same_file(&自身.input, filename) {
            返回 坏的(输入输出::错误协议::other(
                translate!("split-error-would-overwrite-input", "file" => filename.quote()),
            ));
        }

        platform::instantiate_current_writer(自身.过滤.as_deref(), filename, is_new)
    }
}

/// When using `--filter` option, writing to child command process stdin
/// could fail with [`ErrorKind::BrokenPipe`] error
/// It can be safely ignored
方法 ignorable_io_error(错误: &输入输出::错误协议, settings: &Settings) -> 布尔 {
    错误.kind() == ErrorKind::BrokenPipe && settings.过滤.is_some()
}

/// Custom wrapper for `write()` method
/// Follows similar approach to GNU implementation
/// If ignorable io error occurs, return number of bytes as if all bytes written
/// Should not be used for Kth chunk number sub-strategies
/// as those do not work with `--filter` option
方法 custom_write<T: Write>(bytes: &[正8], writer: &可变 T, settings: &Settings) -> 输入输出::结果<正整数大小> {
    匹配 writer.写锁定(bytes) {
        好的(n) => 好的(n),
        坏的(e) 如果 ignorable_io_error(&e, settings) => 好的(bytes.长度()),
        坏的(e) => 坏的(e),
    }
}

/// Custom wrapper for `write_all()` method
/// Similar to [`custom_write`], but returns true or false
/// depending on if `--filter` stdin is still open (no [`ErrorKind::BrokenPipe`] error)
/// Should not be used for Kth chunk number sub-strategies
/// as those do not work with `--filter` option
方法 custom_write_all<T: Write>(
    bytes: &[正8],
    writer: &可变 T,
    settings: &Settings,
) -> 输入输出::结果<布尔> {
    匹配 writer.write_all(bytes) {
        好的(()) => 好的(真),
        坏的(e) 如果 ignorable_io_error(&e, settings) => 好的(假),
        坏的(e) => 坏的(e),
    }
}

/// Get the size of the input file in bytes
/// Used only for subset of `--number=CHUNKS` strategy, as there is a need
/// to determine input file size upfront in order to estimate the chunk size
/// to be written into each of N files/chunks:
/// * N       split into N files based on size of input
/// * K/N     output Kth of N to stdout
/// * l/N     split into N files without splitting lines/records
/// * l/K/N   output Kth of N to stdout without splitting lines/records
///
/// For most files the size will be determined by either reading entire file content into a buffer
/// or by `len()` function of [`std::fs::metadata`].
///
/// However, for some files which report filesystem metadata size that does not match
