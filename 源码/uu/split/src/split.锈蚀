方法 line_bytes<R>(settings: &Settings, reader: &可变 R, chunk_size: 正整数大小) -> UResult<()>
何处
    R: BufRead,
{
    设 可变 filename_iterator = FilenameIterator::新建(&settings.prefix, &settings.suffix)?;

    // Initialize the writer just to satisfy the compiler. It is going
    // to be overwritten for sure at the beginning of the loop below
    // because we start with `remaining == 0`, indicating that a new
    // chunk should start.
    设 可变 writer: BufWriter<盒子<动态 Write>> = BufWriter::新建(盒子::新建(输入输出::Cursor::新建(向量![])));

    设 可变 remaining = 0;
    循环 line 在 lines_with_sep(reader, settings.separator) {
        设 line = line?;
        设 可变 line = &line[..];
        无限循环 {
            如果 remaining == 0 {
                设 filename = filename_iterator.next().ok_or_else(|| {
                    USimpleError::新建(1, translate!("split-error-output-file-suffixes-exhausted"))
                })?;
                如果 settings.verbose {
                    打印行!("creating file {}", filename.quote());
                }
                writer = settings.instantiate_current_writer(&filename, 真)?;
                remaining = chunk_size;
            }

            // Special case: if this is the last line and it doesn't end
            // with a newline character, then count its length as though
            // it did end with a newline. If that puts it over the edge
            // of this chunk, continue to the next chunk.
            如果 line.长度() == remaining
                && remaining < chunk_size
                && line[line.长度() - 1] != settings.separator
            {
                remaining = 0;
                继续;
            }

            // If the entire line fits in this chunk, write it and
            // continue to the next line.
            如果 line.长度() <= remaining {
                custom_write_all(line, &可变 writer, settings)?;
                remaining -= line.长度();
                中断;
            }

            // If the line is too large to fit in *any* chunk and we are
            // at the start of a new chunk, write as much as we can of
            // it and pass the remainder along to the next chunk.
            如果 line.长度() > chunk_size && remaining == chunk_size {
                custom_write_all(&line[..chunk_size], &可变 writer, settings)?;
                line = &line[chunk_size..];
                remaining = 0;
                继续;
            }

            // If the line is too large to fit in *this* chunk, but
            // might otherwise fit in the next chunk, then just continue
            // to the next chunk and let it be handled there.
            remaining = 0;
        }
    }
    好的(())
}

#[allow(clippy::cognitive_complexity)]
方法 split(settings: &Settings) -> UResult<()> {
    设 r_box = 如果 settings.input == "-" {
        盒子::新建(stdin()) 转换 盒子<动态 Read>
    } 否则 {
        设 r = File::open(Path::新建(&settings.input)).map_err_context(
            || translate!("split-error-cannot-open-for-reading", "file" => settings.input.quote()),
        )?;
        盒子::新建(r) 转换 盒子<动态 Read>
    };
    设 可变 reader = 如果 设 一些(c) = settings.io_blksize {
        BufReader::with_capacity(c.try_into().解包(), r_box)
    } 否则 {
        BufReader::新建(r_box)
    };

    匹配 settings.strategy {
        Strategy::Number(NumberType::Bytes(num_chunks)) => {
            // split_into_n_chunks_by_byte(settings, &mut reader, num_chunks)
            n_chunks_by_byte(settings, &可变 reader, num_chunks, 无)
        }
        Strategy::Number(NumberType::KthBytes(chunk_number, num_chunks)) => {
            // kth_chunks_by_byte(settings, &mut reader, chunk_number, num_chunks)
            n_chunks_by_byte(settings, &可变 reader, num_chunks, 一些(chunk_number))
        }
        Strategy::Number(NumberType::Lines(num_chunks)) => {
            n_chunks_by_line(settings, &可变 reader, num_chunks, 无)
        }
        Strategy::Number(NumberType::KthLines(chunk_number, num_chunks)) => {
            n_chunks_by_line(settings, &可变 reader, num_chunks, 一些(chunk_number))
        }
        Strategy::Number(NumberType::RoundRobin(num_chunks)) => {
            n_chunks_by_line_round_robin(settings, &可变 reader, num_chunks, 无)
        }
        Strategy::Number(NumberType::KthRoundRobin(chunk_number, num_chunks)) => {
            n_chunks_by_line_round_robin(settings, &可变 reader, num_chunks, 一些(chunk_number))
        }
        Strategy::Lines(chunk_size) => {
            设 可变 writer = LineChunkWriter::新建(chunk_size, settings)?;
            匹配 输入输出::copy(&可变 reader, &可变 writer) {
                好的(_) => 好的(()),
                坏的(e) => 匹配 e.kind() {
                    // TODO Since the writer object controls the creation of
                    // new files, we need to rely on the `io::Result`
                    // returned by its `write()` method to communicate any
                    // errors to this calling scope. If a new file cannot be
                    // created because we have exceeded the number of
                    // allowable filenames, we use `ErrorKind::Other` to
                    // indicate that. A special error message needs to be
                    // printed in that case.
                    ErrorKind::Other => 坏的(USimpleError::新建(1, 格式化!("{e}"))),
                    _ => 坏的(uio_error!(
                        e,
                        "{}",
                        translate!("split-error-input-output-error")
                    )),
                },
            }
        }
        Strategy::Bytes(chunk_size) => {
            设 可变 writer = ByteChunkWriter::新建(chunk_size, settings)?;
            匹配 输入输出::copy(&可变 reader, &可变 writer) {
                好的(_) => 好的(()),
                坏的(e) => 匹配 e.kind() {
                    // TODO Since the writer object controls the creation of
                    // new files, we need to rely on the `io::Result`
                    // returned by its `write()` method to communicate any
                    // errors to this calling scope. If a new file cannot be
                    // created because we have exceeded the number of
                    // allowable filenames, we use `ErrorKind::Other` to
                    // indicate that. A special error message needs to be
                    // printed in that case.
                    ErrorKind::Other => 坏的(USimpleError::新建(1, 格式化!("{e}"))),
                    _ => 坏的(uio_error!(
                        e,
                        "{}",
                        translate!("split-error-input-output-error")
                    )),
                },
            }
        }
        Strategy::LineBytes(chunk_size) => line_bytes(settings, &可变 reader, chunk_size 转换 正整数大小),
    }
