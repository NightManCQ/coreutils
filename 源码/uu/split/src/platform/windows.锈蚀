/// Get a file writer
///
/// Unlike the unix version of this function, this _always_ returns
/// a file writer
公有 方法 instantiate_current_writer(
    _filter: 选项<&字符串切片>,
    filename: &OsStr,
    is_new: 布尔,
) -> 结果<BufWriter<盒子<动态 Write>>> {
    设 file = 如果 is_new {
        // create new file
        标准库::文件系统::OpenOptions::新建()
            .写锁定(真)
            .create(真)
            .truncate(真)
            .open(Path::新建(filename))
            .map_err(|e| 匹配 e.kind() {
                ErrorKind::IsADirectory => 错误协议::other(
                    translate!("split-error-is-a-directory", "dir" => filename.quote()),
                ),
                _ => 错误协议::other(
                    translate!("split-error-unable-to-open-file", "file" => filename.quote()),
                ),
            })?
    } 否则 {
        // re-open file that we previously created to append to it
        标准库::文件系统::OpenOptions::新建()
            .append(真)
            .open(Path::新建(filename))
            .map_err(|_| {
                错误协议::other(
                    translate!("split-error-unable-to-reopen-file", "file" => filename.quote()),
                )
            })?
    };
    好的(BufWriter::新建(盒子::新建(file) 转换 盒子<动态 Write>))
}

公有 方法 paths_refer_to_same_file(p1: &OsStr, p2: &OsStr) -> 布尔 {
    // Windows doesn't support many of the unix ways of paths being equals
    文件系统::paths_refer_to_same_file(Path::新建(p1), Path::新建(p2), 真)
}
