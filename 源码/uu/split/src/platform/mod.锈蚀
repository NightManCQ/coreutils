#[cfg(target_os = "wasi")]
公有 方法 instantiate_current_writer(
    _filter: 选项<&字符串切片>,
    filename: &标准库::ffi::OsStr,
    is_new: 布尔,
) -> 标准库::输入输出::结果<标准库::输入输出::BufWriter<盒子<动态 标准库::输入输出::Write>>> {
    设 file = 如果 is_new {
        标准库::文件系统::OpenOptions::新建()
            .写锁定(真)
            .create(真)
            .truncate(真)
            .open(标准库::路径::Path::新建(filename))?
    } 否则 {
        标准库::文件系统::OpenOptions::新建()
            .append(真)
            .open(标准库::路径::Path::新建(filename))?
    };
    好的(标准库::输入输出::BufWriter::新建(
        盒子::新建(file) 转换 盒子<动态 标准库::输入输出::Write>
    ))
}

