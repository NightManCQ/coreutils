/// Iterates over all possible filenames of a certain length using [`NAME_CHARSET`] as an alphabet
结构 FilenameIter {
    // Store the indices of the letters of our filename in NAME_CHARSET
    name_charset_indices: 向量<正整数大小>,
    exhausted: 布尔,
}

实现 FilenameIter {
    方法 新建(name_len: 正整数大小) -> 自身类型 {
        自身类型 {
            name_charset_indices: 向量![0; name_len],
            exhausted: 假,
        }
    }
}

实现 迭代器协议 循环 FilenameIter {
    类型 Item = 字符串;

    方法 next(&可变 自身) -> 选项<字符串> {
        如果 自身.exhausted {
            返回 无;
        }

        // First, make the return value using the current state
        设 ret: 字符串 = 自身
            .name_charset_indices
            .迭代()
            .映射(|i| 字符::from(NAME_CHARSET[*i]))
            .收集();

        // Now increment the least significant index and possibly each next
        // index if necessary.
        循环 index 在 自身.name_charset_indices.iter_mut().rev() {
            如果 *index == NAME_CHARSET.长度() - 1 {
                // Carry the 1
                *index = 0;
            } 否则 {
                *index += 1;
                返回 一些(ret);
            }
        }

        // If we get here, we flipped all bits back to 0, so we exhausted all options.
        自身.exhausted = 真;
        一些(ret)
    }
}

/// Used to generate blocks of bytes of size <= [`BLOCK_SIZE`] based on either a give pattern
/// or randomness
// The lint warns about a large difference because StdRng is big, but the buffers are much
// larger anyway, so it's fine.
#[allow(clippy::large_enum_variant)]
枚举 BytesWriter {
    Random {
        rng: StdRng,
        buffer: [正8; BLOCK_SIZE],
    },
    RandomFile {
        rng_file: File,
        buffer: [正8; BLOCK_SIZE],
    },
    // To write patterns, we only write to the buffer once. To be able to do
    // this, we need to extend the buffer with 2 bytes. We can then easily
    // obtain a buffer starting with any character of the pattern that we
    // want with an offset of either 0, 1 or 2.
    //
    // For example, if we have the pattern ABC, but we want to write a block
    // of BLOCK_SIZE starting with B, we just pick the slice [1..BLOCK_SIZE+1]
    // This means that we only have to fill the buffer once and can just reuse
    // it afterward.
    Pattern {
        offset: 正整数大小,
        buffer: [正8; PATTERN_BUFFER_SIZE],
    },
}

实现 BytesWriter {
    方法 from_pass_type(
        pass: &PassType,
        random_source: 选项<&RefCell<File>>,
    ) -> 结果<自身类型, 输入输出::错误协议> {
        匹配 pass {
            PassType::Random => 匹配 random_source {
                无 => 好的(自身类型::Random {
                    rng: rand::make_rng(),
                    buffer: [0; BLOCK_SIZE],
                }),
                一些(file_cell) => {
                    // We need to create a new file handle that shares the position
                    // For now, we'll duplicate the file descriptor to maintain position
                    设 new_file = file_cell.borrow_mut().try_clone()?;
                    好的(自身类型::RandomFile {
                        rng_file: new_file,
                        buffer: [0; BLOCK_SIZE],
                    })
                }
            },
            PassType::Pattern(pattern) => {
                // Copy the pattern in chunks rather than simply one byte at a time
                // We prefill the pattern so that the buffer can be reused at each
                // iteration as a small optimization.
                设 buffer = 匹配 pattern {
                    Pattern::Single(byte) => [*byte; PATTERN_BUFFER_SIZE],
                    Pattern::Multi(bytes) => {
                        设 可变 buf = [0; PATTERN_BUFFER_SIZE];
                        循环 chunk 在 buf.chunks_exact_mut(PATTERN_LENGTH) {
                            chunk.copy_from_slice(bytes);
                        }
                        buf
                    }
                };
                好的(自身类型::Pattern { offset: 0, buffer })
            }
        }
    }

    方法 bytes_for_pass(&可变 自身, size: 正整数大小) -> 结果<&[正8], 输入输出::错误协议> {
        匹配 自身 {
            自身类型::Random { rng, buffer } => {
                设 bytes = &可变 buffer[..size];
                rng.fill(bytes);
                好的(bytes)
            }
            自身类型::RandomFile { rng_file, buffer } => {
                设 bytes = &可变 buffer[..size];
                rng_file.read_exact(bytes)?;
                好的(bytes)
            }
            自身类型::Pattern { offset, buffer } => {
                设 bytes = &buffer[*offset..size + *offset];
                *offset = (*offset + size) % PATTERN_LENGTH;
                好的(bytes)
            }
        }
    }
}

#[uucore::主函数]
公有 方法 uumain(args: 实现 uucore::Args) -> UResult<()> {
    设 matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;

    如果 !matches.contains_id(options::FILE) {
        返回 坏的(UUsageError::新建(
            1,
            translate!("shred-missing-file-operand"),
        ));
    }

    设 iterations = 匹配 matches.get_one::<字符串>(options::ITERATIONS) {
        一些(s) => 匹配 s.parse::<正整数大小>() {
            好的(u) => u,
            坏的(_) => {
                返回 坏的(USimpleError::新建(
                    1,
                    translate!("shred-invalid-number-of-passes", "passes" => s.quote()),
                ));
            }
        },
        无 => 无法到达!(),
    };

    设 random_source = 匹配 matches.get_one::<字符串>(options::RANDOM_SOURCE) {
        一些(filepath) => 一些(RefCell::新建(File::open(filepath).map_err(|_| {
            USimpleError::新建(
                1,
                translate!("shred-cannot-open-random-source", "source" => filepath.quote()),
            )
        })?)),
        无 => 无,
    };

    设 remove_method = 如果 matches.get_flag(options::WIPESYNC) {
        RemoveMethod::WipeSync
    } 否则 如果 matches.contains_id(options::REMOVE) {
        匹配 matches
            .get_one::<字符串>(options::REMOVE)
            .映射(作为引用协议::as_ref)
        {
            一些(options::移除::UNLINK) => RemoveMethod::Unlink,
            一些(options::移除::WIPE) => RemoveMethod::Wipe,
            一些(options::移除::WIPESYNC) => RemoveMethod::WipeSync,
            _ => 无法到达!("should be caught by clap"),
        }
    } 否则 {
        RemoveMethod::无
    };

    设 force = matches.get_flag(options::FORCE);
    设 size_arg = matches
        .get_one::<字符串>(options::SIZE)
        .映射(ToOwned::to_owned);
    设 size = get_size(size_arg);
    设 exact = matches.get_flag(options::EXACT) || size.is_some();
    设 zero = matches.get_flag(options::ZERO);
    设 verbose = matches.get_flag(options::VERBOSE);

    循环 path_str 在 matches.get_many::<OsString>(options::FILE).解包() {
        show_if_err!(wipe_file(
            path_str,
            iterations,
            remove_method,
            size,
            exact,
            zero,
            random_source.as_ref(),
            verbose,
            force,
        ));
    }
    好的(())
}

